object DataModuleBroker: TDataModuleBroker
  OldCreateOrder = False
  Height = 327
  Width = 360
  object Connection: TFDConnection
    ConnectionName = 'Broker'
    Params.Strings = (
      'Database=BROKER'
      'User_Name=SA'
      'Password=123'
      'Server=indaia10'
      'DriverID=MSSQL')
    LoginPrompt = False
    Left = 32
    Top = 24
  end
  object FDQuery: TFDQuery
    Connection = Connection
    SQL.Strings = (
      'WITH TP AS('
      #9'SELECT'
      #9'  NR_PROCESSO,'
      #9'  CD_CLIENTE,'
      #9'  CD_PAIS_DESTINO,'
      #9'  CD_CANAL,'
      #9'  TX_MERCADORIA,'
      #9'  VL_PESO_BRUTO,'
      #9'  VL_PESO_LIQUIDO'
      #9'FROM TPROCESSO'
      #9'WHERE NR_PROCESSO IN ('#39'0102EA-000001-18'#39','#39'0102EA-000002-18'#39')'
      ')'
      'SELECT'
      'TP.NR_PROCESSO,'
      'EN.NM_EMPRESA'
      
        'DBO.FN_CONCATENA_REFRENCIA_TIPO(TP.NR_PROCESSO, G.TP_PEDIDO_BUSC' +
        'A) AS RefCliente,'
      'PD.DESCRICAO AS PaisDestino,'
      'CA.NM_CANAL AS Canal,'
      'TP.TX_MERCADORIA AS Mercadoria,'
      'TP.VL_PESO_BRUTO AS PesoBruto,'
      'TP.VL_PESO_LIQUIDO AS PesoLiquido,'
      
        '(SELECT COUNT(CNT.NR_CNTR) FROM TPROCESSO_CNTR CNT WHERE CNT.NR_' +
        'PROCESSO=TP.NR_PROCESSO) AS QtdConteiners,'
      'EV113.DT_REALIZACAO AS LiberacaoProcesso,'
      'EV314.DT_REALIZACAO AS CarregamentoFabrica,'
      'EV088.DT_REALIZACAO AS Desembaraco,'
      'ISNULL(EV149.DT_REALIZACAO,EV132.DT_REALIZACAO) AS SaidaVeiculo,'
      'FUP.CD_EVENTO AS CodigoEvento,'
      'EV.NM_EVENTO AS NomeEvento,'
      'FUP.DT_PREVISTA AS Previsto,'
      'FUP.DT_REALIZACAO AS Realizado'
      'FROM TP'
      'INNER JOIN TEMPRESA_NAC EN ON EN.CD_EMPRESA=TP.CD_CLIENTE'
      'INNER JOIN BROKER.DBO.TGRUPO G ON G.CD_GRUPO=EN.CD_GRUPO'
      'INNER JOIN BROKER.DBO.TTP_CANAL CA ON CA.CD_CANAL=TP.CD_CANAL'
      'LEFT JOIN BROKER.DBO.TPAIS PD ON PD.CODIGO=TP.CD_PAIS_DESTINO'
      
        'LEFT JOIN BROKER.DBO.TFOLLOWUP EV113 ON EV113.NR_PROCESSO=TP.NR_' +
        'PROCESSO AND EV113.CD_EVENTO='#39'113'#39' AND EV113.IN_APLICAVEL='#39'1'#39
      
        'LEFT JOIN BROKER.DBO.TFOLLOWUP EV314 ON EV314.NR_PROCESSO=TP.NR_' +
        'PROCESSO AND EV314.CD_EVENTO='#39'311'#39' AND EV113.IN_APLICAVEL='#39'1'#39
      
        'LEFT JOIN BROKER.DBO.TFOLLOWUP EV088 ON EV088.NR_PROCESSO=TP.NR_' +
        'PROCESSO AND EV088.CD_EVENTO='#39'088'#39' AND EV113.IN_APLICAVEL='#39'1'#39
      
        'LEFT JOIN BROKER.DBO.TFOLLOWUP EV149 ON EV149.NR_PROCESSO=TP.NR_' +
        'PROCESSO AND EV149.CD_EVENTO='#39'149'#39' AND EV113.IN_APLICAVEL='#39'1'#39
      
        'LEFT JOIN BROKER.DBO.TFOLLOWUP EV132 ON EV132.NR_PROCESSO=TP.NR_' +
        'PROCESSO AND EV132.CD_EVENTO='#39'132'#39' AND EV113.IN_APLICAVEL='#39'1'#39
      
        'LEFT JOIN BROKER.DBO.TFOLLOWUP FUP ON FUP.NR_PROCESSO=TP.NR_PROC' +
        'ESSO'
      'LEFT JOIN BROKER.DBO.TEVENTO EV ON EV.CD_EVENTO=FUP.CD_EVENTO'
      'ORDER BY TP.NR_PROCESSO')
    Left = 120
    Top = 24
  end

  object qryConsulta: TFDQuery
    Connection = FDConnection1
    FetchOptions.AssignedValues = [evRowsetSize]
    FetchOptions.RowsetSize = 0
    SQL.Strings = (
      'SELECT'
      #39' { "Servico": "'#39' + PR.CD_PRODUTO + '
      #39'", "SBU": "'#39'+ RTRIM(A.NM_AREA) + '
      #39'", "CNPJ_Empresa": "'#39' + RTRIM(EN.CGC_EMPRESA) + '
      #39'", "Pedidos": "'#39' + ISNULL(PED.PEDIDOIMPORTAO,'#39#39') + '
      #39'", "CPNJ_Despachante": "'#39' + RTRIM(UN.CGC_UNID_NEG) + '
      #39'", "Processo": "'#39' + RTRIM(PR.NR_PROCESSO) + '
      
        #39'", "Produtos": "'#39' + REPLACE(RTRIM(CAST(ISNULL(PR.TX_MERCADORIA,' +
        ' '#39#39') AS NVARCHAR(MAX))), '#39'"'#39', '#39#39') + '
      #39'", "NotaFiscal": "'#39' + ISNULL(RIGHT(NF.NRNOTA,20),'#39#39') + '
      
        #39'", "TipoContainer": "'#39' + CASE WHEN PR.TP_ESTUFAGEM <>'#39'1'#39' THEN '#39 +
        '01'#39' ELSE CT.TP_CNTR END + '
      
        #39'", "ContainerCargaSolta":'#9'"'#39' + ISNULL(CASE WHEN CT.TP_CNTR = '#39'0' +
        '1'#39' THEN CONVERT(VARCHAR(15),CS.VL_QTDE)+'#39' '#39'+(CS.NM_ESPECIE) WHEN' +
        ' PR.TP_ESTUFAGEM <>'#39'1'#39' THEN CONVERT(VARCHAR(15),CS.VL_QTDE)+'#39' '#39'+' +
        '(CS.NM_ESPECIE) ELSE CT.NR_CNTR END,'#39'CARGA SOLTA'#39') + '
      
        #39'", "TerminalCarga": "'#39' + ISNULL(RTRIM(AD.CD_RECINTO),'#39'0000000'#39')' +
        ' + '
      
        #39'", "CNPJ_Transportadora":'#9'"'#39' + ISNULL(RTRIM(TR.CNPJ_TRANSP_ROD)' +
        ','#39#39') + '
      
        #39'", "ChegadaSaida": "'#39' + ISNULL(CONVERT(VARCHAR(10),CONVERT(DATE' +
        ',F161.DT_REALIZACAO)),'#39#39') + '
      
        #39'", "PresencaCarga": "'#39' + ISNULL(CONVERT(VARCHAR(10),CONVERT(DAT' +
        'E,F012.DT_REALIZACAO)),'#39#39') + '
      
        #39'", "Desembaraco": "'#39' + ISNULL(CONVERT(VARCHAR(10),CONVERT(DATE,' +
        'F088.DT_REALIZACAO)),'#39#39') + '
      #39'", "LiberacaoDocumentos": "'#39' + '
      'CASE '
      '    WHEN DATEPART(HOUR, F041.DT_REALIZACAO) > 16 THEN '
      
        #9#9'ISNULL(CONVERT(VARCHAR(10), dbo.FN_ProximoDiaUtil(DATEADD(DAY,' +
        ' 1, CONVERT(DATE, F041.DT_REALIZACAO))), 120), '#39#39')'
      '    ELSE '
      
        '        ISNULL(CONVERT(VARCHAR(10), CONVERT(DATE, F041.DT_REALIZ' +
        'ACAO)), '#39#39') '
      'END + '
      #39'", "DiBooking": "'#39' + ISNULL(RTRIM(PR.NR_DI),'#39#39') + '
      
        #39'", "Necessidade": "'#39' + ISNULL(CONVERT(VARCHAR(10),CONVERT(DATE,' +
        'F205.DT_REALIZACAO)),'#39#39') + '
      #39'", "Armador": "'#39' + ISNULL(ARM.DESCRICAO,'#39#39') + '
      #39'", "ArmadorTco": "'#39' + ISNULL(TCO.DESCRICAO,'#39#39') + '
      #39'", "Exportador": "'#39' + ISNULL(EXPORTADOR.NM_EMPRESA,'#39#39') +  '
      #39'", "Glosum": '#39' + ISNULL(PR.IN_FRETE_ACORDADO, '#39'0'#39') + '
      #39' }'#39' AS TAG,'
      'PR.NR_PROCESSO,'
      'PR.TP_ESTUFAGEM,'
      'ISNULL(CT.NR_CNTR, '#39#39') AS NR_CNTR'
      'FROM BROKER.DBO.TPROCESSO             PR   (NOLOCK) '
      
        'JOIN BROKER.DBO.TFOLLOWUP'#9#9#9#9'   F041 (NOLOCK) ON F041.NR_PROCESS' +
        'O = PR.NR_PROCESSO AND F041.CD_SERVICO = PR.CD_SERVICO AND F041.' +
        'CD_EVENTO = '#39'041'#39' AND F041.IN_APLICAVEL = 1 '
      
        'JOIN BROKER.DBO.TFOLLOWUP'#9#9#9#9'   F161 (NOLOCK) ON F161.NR_PROCESS' +
        'O = PR.NR_PROCESSO AND F161.CD_SERVICO = PR.CD_SERVICO AND F161.' +
        'CD_EVENTO = '#39'161'#39' AND F161.IN_APLICAVEL = 1 '
      
        'JOIN BROKER.DBO.TFOLLOWUP'#9#9#9#9'   F082 (NOLOCK) ON F082.NR_PROCESS' +
        'O = PR.NR_PROCESSO AND F082.CD_SERVICO = PR.CD_SERVICO AND F082.' +
        'CD_EVENTO = '#39'082'#39' AND F082.IN_APLICAVEL = 1 '
      
        'LEFT JOIN BROKER.DBO.TFOLLOWUP             F012 (NOLOCK) ON F012' +
        '.NR_PROCESSO = PR.NR_PROCESSO AND F012.CD_SERVICO = PR.CD_SERVIC' +
        'O AND F012.CD_EVENTO = '#39'012'#39' '
      
        'LEFT JOIN BROKER.DBO.TFOLLOWUP             F088 (NOLOCK) ON F088' +
        '.NR_PROCESSO = PR.NR_PROCESSO AND F088.CD_SERVICO = PR.CD_SERVIC' +
        'O AND F088.CD_EVENTO = '#39'088'#39' '
      
        'LEFT JOIN BROKER.DBO.TFOLLOWUP             F205 (NOLOCK) ON F205' +
        '.NR_PROCESSO = PR.NR_PROCESSO AND F205.CD_SERVICO = PR.CD_SERVIC' +
        'O AND F205.CD_EVENTO = '#39'205'#39' '
      
        'LEFT JOIN BROKER.DBO.TAREA                 A    (NOLOCK) ON A.CD' +
        '_AREA        = PR.CD_AREA '
      
        'LEFT JOIN BROKER.DBO.TEMPRESA_NAC          EN   (NOLOCK) ON EN.C' +
        'D_EMPRESA    = PR.CD_CLIENTE '
      
        'LEFT JOIN BROKER.DBO.TUNID_NEG             UN   (NOLOCK) ON UN.C' +
        'D_UNID_NEG   = PR.CD_UNID_NEG '
      
        'LEFT JOIN BROKER.DBO.TPROCESSO_CNTR        CT   (NOLOCK) ON CT.N' +
        'R_PROCESSO   = PR.NR_PROCESSO '
      
        'LEFT JOIN BROKER.DBO.TPROCESSO_CARGA_SOLTA CS   (NOLOCK) ON CS.N' +
        'R_PROCESSO   = PR.NR_PROCESSO '
      
        'LEFT JOIN BROKER.DBO.TARMAZEM              AD   (NOLOCK) ON AD.C' +
        'D_ARMAZEM    = PR.CD_ARMAZEM_DESCARGA '
      
        'LEFT JOIN BROKER.DBO.TTRANSP_ROD           TR   (NOLOCK) ON TR.C' +
        'D_TRANSP_ROD = PR.CD_TRANSP_NAC '
      
        'OUTER APPLY( SELECT STUFF((SELECT DISTINCT '#39', '#39' + RTRIM(RCP.CD_R' +
        'EFERENCIA)+'#39'/'#39'+(RCP.NR_ITEM_PO) FROM TREF_CLIENTE RCP (NOLOCK) W' +
        'HERE RCP.TP_REFERENCIA ='#39'01'#39' AND RCP.NR_PROCESSO = PR.NR_PROCESS' +
        'O FOR XML PATH('#39#39')), 1, 1, '#39#39') AS PEDIDOIMPORTAO ) PED '
      
        'OUTER APPLY( SELECT  STUFF((SELECT DISTINCT '#39','#39' + RTRIM(NF.NR_NO' +
        'TA) FROM TPROCESSO_NF NF (NOLOCK) WHERE NF.NR_PROCESSO = PR.NR_P' +
        'ROCESSO FOR XML PATH('#39#39')), 1, 1, '#39#39') AS [NRNOTA]  ) NF '
      
        'LEFT JOIN BROKER.DBO.TTRANSPORTADOR_ITL     ARM  (NOLOCK) ON ARM' +
        '.CODIGO         = PR.CD_TRANSPORTADOR '
      
        'LEFT JOIN BROKER.DBO.TTRANSPORTADOR_ITL     TCO  (NOLOCK) ON TCO' +
        '.CODIGO         = PR.CD_OPERADOR_TANQUE '
      
        'OUTER APPLY (SELECT TOP 1 EXPORT.NM_EMPRESA FROM TEXPORTADOR_DI ' +
        'EXPDI (NOLOCK), TEMPRESA_EST EXPORT (NOLOCK) WHERE EXPORT.CD_EMP' +
        'RESA = EXPDI.CD_EXPORTADOR AND EXPDI.NR_PROCESSO = PR.NR_PROCESS' +
        'O) AS EXPORTADOR '
      'WHERE '
      'PR.CD_GRUPO IN ('#39'002'#39','#39'013'#39', '#39'559'#39', '#39'D28'#39') '
      'AND PR.CD_PRODUTO = '#39'01'#39' '
      'AND PR.IN_CANCELADO = 0 '
      'AND PR.CD_SERVICO NOT IN ('#39'5'#39','#39'17'#39','#39'22'#39','#39'39'#39') '
      'AND (  '
      '(F041.DT_REALIZACAO IS NULL '
      'AND F161.DT_REALIZACAO IS NOT NULL '
      'AND F082.DT_REALIZACAO IS NOT NULL)  '
      'OR ( '
      'F041.DT_REALIZACAO IS NOT NULL '
      
        'AND (F041.DT_REALIZACAO >= DATEADD(DAY, -10, GETDATE()) ))  /*PR' +
        'OCESSOS QUE TIVERAM O EVENTO 041 PREENCHIDO NOS ULTIMOS 10 DIAS.' +
        '*/ )  '
      '--AND PR.NR_PROCESSO  in ('#39'0101IM-015279-25'#39')')
    Left = 432
    Top = 169
  end

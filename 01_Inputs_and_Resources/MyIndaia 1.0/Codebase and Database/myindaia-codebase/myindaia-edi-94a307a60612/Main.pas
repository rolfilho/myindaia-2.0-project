procedure TFrmMain.ApagaArquivosXLS;
var
  vFileList : TFileListBox;
  i : Integer;
begin
  exit;
  vFileList := TFileListBox.Create(Self);
  vFileList.Parent := frmMain;
  vFileList.Directory := GetPath+'Gerados\';
  vFileList.Mask := '*.xls';
  for i := 0 to vFileList.Items.Count - 1 do
    DeleteFile(pChar(GetPath+'Gerados\' + vFileList.Items[i]));
  vFileList.Free;
end;

function DETERMINA_DATA_VENCIMENTO : string;
begin
  if TAB.FieldByName('QT_PERIOD_PGTO_360').AsString <> '' then
    Result := DateToStr(IncDay(TAB.FieldByName('DATA_EMBARQUE').AsDateTime,TAB.FieldByName('QT_PERIOD_PGTO_360').AsInteger)) // CALCULA DATA VENCIMENTO
  else
    Result := TAB.FieldByName('QT_PERIOD_PGTO_360').AsString
end;

function DETERMINA_DIFERENCA_VENCIMENTO : string;
begin
  if TAB.FieldByName('QT_PERIOD_PGTO_360').AsString <> '' then
    Result := TAB.FieldByName('QT_PERIOD_PGTO_360').AsString
  else
    Result := FloatToStr(DaySpan(TAB.FieldByName('DATA_EMBARQUE').AsDateTime,TAB.FieldByName('DT_PREV_PGTO_360').AsDateTime));
end;


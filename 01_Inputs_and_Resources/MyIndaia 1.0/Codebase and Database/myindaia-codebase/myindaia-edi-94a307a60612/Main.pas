              SQL.Add('   LEFT  JOIN TFOLLOWUP                 F    (NOLOCK) ON F.NR_PROCESSO = PR.NR_PROCESSO                                ');
              sql.add('                                                     AND F.CD_EVENTO = CASE WHEN (SELECT COUNT(*)                      ');
              SQL.Add('                                                                     FROM TFOLLOWUP FL (NOLOCK)                        ');
              SQL.Add('                                                                     WHERE FL.NR_PROCESSO = F.NR_PROCESSO              ');
              SQL.Add('                                                                       AND FL.CD_EVENTO = "082") > 0 THEN "082"        ');

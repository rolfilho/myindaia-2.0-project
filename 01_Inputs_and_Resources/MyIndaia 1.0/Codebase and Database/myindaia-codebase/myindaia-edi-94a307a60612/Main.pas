  with TQuery.Create(frmMain) do begin
    try
     SessionName  := 'SES_EDI';
     DataBaseName := 'BROKER';
     SQL.TEXT     := 'SELECT PC_ALIQ_NORM_ADVAL  ' + sLineBreak +
                     '  FROM TRIBUTO (NOLOCK)    ' + sLineBreak +
                     ' WHERE NR_PROCESSO = ' +  QuotedStr(Aux_Processo)  + sLineBreak +

{*******************************************************************************
Funcao para determinar o peso unitario da mercadoria. Essa funcao e chamada do
script. Atualmente somente utilizada pela Volks - 19/11/02.
*******************************************************************************}
function CALC_PESO_UNITARIO: String;
Var
  Peso, Peso_Unitario, Quantidade : Extended;
  i : integer;
begin
  Quantidade := TAB.Fieldbyname('QT_MERC_UN_COMERC').Asfloat;
  Peso       := TAB.Fieldbyname('PL_MERCADORIA').Asfloat;
  try
    {**Formatar para ficar com cinco casas decimais**}
    Peso_Unitario := arredondar((Peso/Quantidade),5);
    Result := frmMain.FORMATAR_VALOR_VOLKS(Peso_Unitario,5);
  except
    Result := '0'; {**O formato da Volks pede que se nulo retornar tudo 0**}
  end;
  while Length(Result) < cnt do Result := '0' + Result;
end;


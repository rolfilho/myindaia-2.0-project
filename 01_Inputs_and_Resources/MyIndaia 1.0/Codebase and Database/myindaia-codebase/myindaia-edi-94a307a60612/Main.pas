//          oSheet.Cells[ nLinha, nColuna ].value   := str_linha; // pega a OBS inteira
//          if length(trim(str_linha)) > 100 then //somente alongar quando o texto ultrapassar o limite de pelo menos 1 linha ( by carlos - 06/07/2011)
//             oSheet.Cells[ nLinha, nColuna ].Rows.Autofit;

          {  HyperLink - FATURA COMERCIAL}
          inc(nColuna);
           if qry_mail_proc_nao_fat.FieldByName('Fatura_Comercial').AsString<>'' then begin
              Excel.ActiveSheet.Hyperlinks.Add( Anchor:=oSheet.Cells[ nLinha, nColuna ], Address:=qry_mail_proc_nao_fat.FieldByName('Fatura_Comercial').AsString);
              oSheet.Cells[ nLinha, nColuna ].value           := 'a';
           end else
              oSheet.Cells[ nLinha, nColuna].value           := ' ';

           oSheet.Cells[ nLinha, nColuna ].Font.Bold       := False;
           oSheet.Cells[ nLinha, nColuna ].Font.Name       := 'Webdings';
           oSheet.Cells[ nLinha, nColuna ].Font.Size       := 18;
           oSheet.Cells[ nLinha, nColuna ].Font.ColorIndex := 50;
           oSheet.Cells[ nLinha, nColuna ].Font.Underline  := False;

           {  HyperLink - PACKING LIST}
          inc(nColuna);
           if qry_mail_proc_nao_fat.FieldByName('Packing_List').AsString<>'' then begin
              Excel.ActiveSheet.Hyperlinks.Add( Anchor:=oSheet.Cells[ nLinha, nColuna ], Address:=qry_mail_proc_nao_fat.FieldByName('Packing_List').AsString);
              oSheet.Cells[ nLinha, nColuna ].value           := 'a';
           end else
              oSheet.Cells[ nLinha, nColuna].value           := ' ';

           oSheet.Cells[ nLinha, nColuna ].Font.Bold       := False;
           oSheet.Cells[ nLinha, nColuna ].Font.Name       := 'Webdings';
           oSheet.Cells[ nLinha, nColuna ].Font.Size       := 18;
           oSheet.Cells[ nLinha, nColuna ].Font.ColorIndex := 50;
           oSheet.Cells[ nLinha, nColuna ].Font.Underline  := False;

          {  HyperLink - Conhecimento e embarque }

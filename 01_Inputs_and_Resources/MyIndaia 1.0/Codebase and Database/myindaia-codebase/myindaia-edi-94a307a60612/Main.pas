    ' , TTP_CANAL.NM_CANAL ' + sLineBreak +
    ' , CAST(F654.DT_REALIZACAO AS DATE) AS F654_DESEMBARACO ' + sLineBreak +
    ' , CAST(F088.DT_REALIZACAO AS DATE) AS F088_DATA_CONHECIMENTO ' + sLineBreak +
    ' , CAST(F901.DT_REALIZACAO AS DATE) AS F901_PREENCHIMENTO_SLOT ' + sLineBreak +
    ' , CAST(F135.DT_REALIZACAO AS DATE) AS F0135_RETIRADA_BL' + sLineBreak +
    ' , CAST(F125.DT_REALIZACAO AS DATE) AS F125_ENVIO_BL_CLIENTE ' + sLineBreak +
    ' , CAST(F141.DT_REALIZACAO AS DATE) AS F141_AVERBACAO ' + sLineBreak +
    ' , (SELECT TOP 1 E.NM_ETAPA FROM TFOLLOWUP_ETAPA FE ' + sLineBreak +
    '                            LEFT JOIN TETAPA E ON E.CD_ETAPA = FE.CD_ETAPA ' + sLineBreak +

          Range.Borders[xlEdgeLeft].ColorIndex := 15;
          Range.Borders[xlEdgeLeft].Weight := xlThin;
          Range.Borders[xlEdgeTop].LineStyle := xlContinuous;
          Range.Borders[xlEdgeTop].ColorIndex := 15;
          Range.Borders[xlEdgeTop].Weight := xlThin;
          Range.Borders[xlEdgeBottom].LineStyle := xlContinuous;
          Range.Borders[xlEdgeBottom].ColorIndex := 15;
          Range.Borders[xlEdgeBottom].Weight := xlThin;
          Range.Borders[xlEdgeRight].LineStyle := xlContinuous;
          Range.Borders[xlEdgeRight].ColorIndex := 15;
          Range.Borders[xlEdgeRight].Weight := xlThin;
          Range.Borders[xlInsideVertical].LineStyle := xlContinuous;
          Range.Borders[xlInsideVertical].ColorIndex := 15;
          Range.Borders[xlInsideVertical].Weight := xlThin;
          Range.Borders[xlInsideHorizontal].LineStyle := xlContinuous;
          Range.Borders[xlInsideHorizontal].ColorIndex := 15;
          Range.Borders[xlInsideHorizontal].Weight := xlThin;

          qry_mail_proc_nao_fat.Next;
        end;

        oSheet.Sort.SortFields.Clear;
        for I := vTotalEventos -2 downto 0 do
          oSheet.Sort.SortFields.Add(Key:=oSheet.Range[GetCellName(oSheet, 23 + I, 13) + ':' + GetCellName(oSheet, 23 + I, nLinha)], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);

        oSheet.Sort.SetRange(oSheet.Range[GetCellName(oSheet, 2, 13) + ':' + GetCellName(oSheet, vTotalEventos + 23, nLinha)]);
        oSheet.Sort.Header := xlGuess;
        oSheet.Sort.MatchCase := False;
        oSheet.Sort.Orientation := xlTopToBottom;
        oSheet.Sort.SortMethod := xlPinYin;
        oSheet.Sort.Apply;

        //--------------------------------------------------------------------------//
        // finalizando...
        //--------------------------------------------------------------------------//
        //--------------------------------------------------------------------------//
        // deixar a planilha visivel no windows
        //--------------------------------------------------------------------------//
        //Excel.Visible := chkVisualizarExcel.checked;

        if not TemContainer then
          oSheet.Columns['Q:Q'].Delete(Shift:=xlToLeft);
        if not TemBooking then
          oSheet.Columns['O:O'].Delete(Shift:=xlToLeft);

        if FileExists(GetPath+'Gerados\DAILY_FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xls') then
          SysUtils.DeleteFile(GetPath+'Gerados\DAILY_FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xls');
        Excel.ActiveWorkBook.SaveAs(GetPath+'Gerados\DAILY_FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xls');

        if tem_dados then
          Result := GetPath+'Gerados\DAILY_FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xls'
        else
          Result := 'Sem Dados';

      finally
        Excel.ActiveWorkBook.Close(False);
        KillExcel(Excel);
      end;
    finally
      FreeAndNil(vQryEventos);
      FreeAndNil(qry_mail_proc_nao_fat);
      FreeAndNil(qryAuxiliar);
      FreeAndNil(db_broker);
    end;
  except
    on e:Exception do
    begin
      VMsg('Erro - RelEventosDailyFupBasf: ' + e.Message, msError, True);
    end;
  end;
end;

function TfrmMain.RelEventosDailyFupTerminal(pUnidade, pProduto, pGrupo, pCliente, pTerminal: string): String; // DF0 - Terminal
var
  db_broker: TDatabase;
  qryContrainers, qryEventos, qryRelatorio: TQuery;
  Excel, WorkBook, Sheet, Range: OleVariant;
  TimeStamp, NomeProduto: String;
  Linha: Integer;
  strTipoCntrOld, strTipoCntr, strRetiradaCntr, strCntr: String;
  QtdContrainer: Integer;

  procedure PreencheEvento(AColuna: Integer; AEvento: String);
  begin
    //Sheet.Cells[Linha, AColuna].NumberFormat := '[$-409] dd/mm/aaaa;@';
    //Sheet.Cells[Linha, AColuna].HorizontalAlignment := xlCenter;
    with qryEventos do
    begin
      First;
      if Locate('CD_EVENTO', AEvento, []) then
      begin
        if (AnsiIndexText(FieldByName('DT_REALIZACAO').AsString, ['', 'N/A', 'TO BE CONFIRMED']) < 0) then
        begin
          if AnsiIndexText(AEvento, ['270', '271']) >= 0 then
            Sheet.Cells[Linha, AColuna].Value := FieldByName('DT_REALIZACAO').AsDateTime
          else
            Sheet.Cells[Linha, AColuna].Value := DateOf(FieldByName('DT_REALIZACAO').AsDateTime);
        end
        else
          Sheet.Cells[Linha, AColuna].Value := '';//FieldByName('DT_REALIZACAO').AsString;

        if FieldByName('DT_REALIZACAO_EFETIVA').AsString <> '' then
          if ((DayOfWeek(Date) = 2) and (FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -3)) or ((DayOfWeek(Date) <> 2) and (FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -1)) then
            Sheet.Cells[Linha, AColuna].Interior.ColorIndex := 40;
      end
      else
        Sheet.Cells[Linha, AColuna].Value := '';
    end;
  end;
begin
  Result := '';
  try
    db_broker:= TDatabase.Create(Self);
    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;

    try
      db_broker.Connected := True;
      Excel    := CreateOLEObject('Excel.Application');
      try
        WorkBook := Excel.Workbooks.Open(GetPath+'FOLLOWUP_TERMINAL_Nestle.xls');
        Excel.Visible := chkVisualizarExcel.checked;
        TimeStamp := FormatDateTime('ddmmyyyyhhnnsszz', Now);

        try
          Sheet := WorkBook.Worksheets[1];

          qryContrainers := TQuery.Create(Self);
          qryContrainers.DatabaseName := 'DBBROKER';
          qryEventos := TQuery.Create(Self);
          qryEventos.DatabaseName := 'DBBROKER';
          qryRelatorio := TQuery.Create(Self);
          qryRelatorio.DatabaseName := 'DBBROKER';

          with qryEventos do
          begin
            SQL.Add('SELECT *');
            SQL.Add('FROM TFOLLOWUP');
            SQL.Add('WHERE NR_PROCESSO = :NR_PROCESSO');
          end;

          with qryContrainers do
          begin
            SQL.Add('SELECT RTRIM(TC.NM_TP_CNTR) AS TP_CNTR, RTRIM(PC.NR_CNTR) AS NR_CNTR, PC.DT_RET_VAZIO');
            SQL.Add('FROM TPROCESSO_CNTR PC');
            SQL.Add('   INNER JOIN TTP_CNTR TC ON TC.TP_CNTR = PC.TP_CNTR');
            SQL.Add('WHERE NR_PROCESSO = :NR_PROCESSO');
            SQL.Add('ORDER BY TP_CNTR, NR_CNTR, DT_DEVOLUCAO_CNTR');
          end;

          with qryRelatorio do
          begin
            SQL.Clear;
            SQL.Add('SELECT ISNULL((SELECT RTRIM(AP_UNID_NEG)');
            SQL.Add('               FROM TUNID_NEG (NOLOCK)');
            SQL.Add('               WHERE CD_UNID_NEG = :CD_UNID_NEG), "Todas") AS NM_UNID_NEG,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_PRODUTO)');
            SQL.Add('               FROM TPRODUTO (NOLOCK)');
            SQL.Add('               WHERE CD_PRODUTO = :CD_PRODUTO), "Todos") AS NM_PRODUTO,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_GRUPO)');
            SQL.Add('               FROM TGRUPO (NOLOCK)');
            SQL.Add('               WHERE CD_GRUPO = :CD_GRUPO), "Todos") AS NM_GRUPO,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_EMPRESA)');
            SQL.Add('               FROM TEMPRESA_NAC (NOLOCK)');
            SQL.Add('               WHERE CD_EMPRESA = :CD_CLIENTE), "Todos") AS NM_CLIENTE,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_ARMAZEM)');
            SQL.Add('               FROM TARMAZEM (NOLOCK)');
            SQL.Add('               WHERE CD_ARMAZEM = :CD_ARMAZEM), "Todos") AS NM_ARMAZEM');
            ParamByName('CD_UNID_NEG').AsString      := pUnidade;
            ParamByName('CD_PRODUTO').AsString       := pProduto;
            ParamByName('CD_GRUPO').AsString         := pGrupo;
            ParamByName('CD_CLIENTE').AsString       := pCliente;
            ParamByName('CD_ARMAZEM').AsString       := pTerminal;
            Open;

            Sheet.Cells[01, 06].value :=  'Unidade: ' + pUnidade + ' - ' + Fields[0].AsString;
            Sheet.Cells[02, 06].value :=  'Produto: ' + pProduto + ' - ' + Fields[1].AsString;
            Sheet.Cells[03, 06].value :=  'Grupo Cliente: ' + pGrupo + ' - ' + Fields[2].AsString;
            Sheet.Cells[04, 06].value :=  'Cliente: ' + pCliente + ' - ' + Fields[3].AsString;
            Sheet.Cells[05, 06].value :=  'Terminal: ' + pTerminal + ' - ' + Fields[4].AsString;
            Sheet.Cells[06, 06].value :=  'Data: ' + FormatDateTime('dd/mm/yyyy', Now);

            NomeProduto := Copy(Fields[1].AsString, 1, 3);
            Result := GetPath+'Gerados\FOLLOWUP_' + NomeProduto + '_' + TimeStamp + '.xls';
            Close;

            SQL.Clear;
            SQL.Add('SELECT DBO.FN_REFERENCIAS(PR.NR_PROCESSO, ",", "08", "04") AS NR_REFERENCIAS,');
            SQL.Add('       RTRIM(PR.NR_PROCESSO) AS NR_PROCESSO,');
            SQL.Add('       RTRIM(EN.NM_EMPRESA) AS NM_CLIENTE,');
            SQL.Add('       RTRIM(PD.NM_PAIS) AS NM_PAIS_DESTINO,');
            SQL.Add('       RTRIM(LD.DESCRICAO) AS NM_LOCAL_DESEMBARQUE,');
            SQL.Add('       RTRIM(EM.NM_EMBARCACAO) AS NM_NAVIO,');
            SQL.Add('       (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(RC.CD_REFERENCIA) + ", "), ", ")');
            SQL.Add('        FROM TREF_CLIENTE RC');
            SQL.Add('        WHERE RC.NR_PROCESSO = PR.NR_PROCESSO');
            SQL.Add('          AND RC.TP_REFERENCIA = "05") AS NR_BOOKING,');
            SQL.Add('       RTRIM(TR.AP_TRANSP_ROD) AS NM_TRANSPORTADORA,');
            SQL.Add('       RTRIM(AR.NM_ARMAZEM) AS NM_ARMAZEM_ATRACACAO');
            SQL.Add('FROM TPROCESSO                 PR   (NOLOCK)');
            SQL.Add('   INNER JOIN TSERVICO_NOVO    SV   (NOLOCK) ON SV.CD_SERVICO = PR.CD_SERVICO');
            SQL.Add('   INNER JOIN TEMPRESA_NAC     EN   (NOLOCK) ON EN.CD_EMPRESA = PR.CD_CLIENTE');
            SQL.Add('   INNER JOIN TFOLLOWUP        F147 (NOLOCK) ON F147.NR_PROCESSO = PR.NR_PROCESSO AND F147.CD_EVENTO = "147"');
            SQL.Add('   INNER JOIN TFOLLOWUP        F132 (NOLOCK) ON F132.NR_PROCESSO = PR.NR_PROCESSO AND F132.CD_EVENTO = "132"');
            SQL.Add('   LEFT  JOIN TPAIS_BROKER     PD   (NOLOCK) ON PD.CD_PAIS = PR.CD_PAIS_DESTINO');
            SQL.Add('   LEFT  JOIN TLOCAL_EMBARQUE  LD   (NOLOCK) ON LD.CODIGO = PR.CD_LOCAL_DESEMBARQUE');
            SQL.Add('   LEFT  JOIN TEMBARCACAO      EM   (NOLOCK) ON EM.CD_EMBARCACAO = PR.CD_EMBARCACAO');
            SQL.Add('   LEFT  JOIN TTRANSP_ROD      TR   (NOLOCK) ON TR.CD_TRANSP_ROD = PR.CD_TRANSP_NAC');
            SQL.Add('   LEFT  JOIN TARMAZEM         AR   (NOLOCK) ON AR.CD_ARMAZEM = PR.CD_ARMAZEM_ATRACACAO');
            SQL.Add('WHERE :CD_UNID_NEG IN ("", PR.CD_UNID_NEG)');
            SQL.Add('  AND :CD_PRODUTO IN ("", PR.CD_PRODUTO)');
            SQL.Add('  AND :CD_GRUPO IN ("", EN.CD_GRUPO)');
            SQL.Add('  AND :CD_CLIENTE IN ("", PR.CD_CLIENTE)');
            SQL.Add('  AND :CD_ARMAZEM IN ("", PR.CD_ARMAZEM_ATRACACAO)');
            SQL.Add('  AND PR.IN_CANCELADO = "0"');
            SQL.Add('  AND SV.CD_VIA_TRANSPORTE = "01"');
            SQL.Add('  AND F147.DT_REALIZACAO IS NOT NULL');
            SQL.Add('  AND ISNULL(F147.IN_APLICAVEL, "0") = "1"');
            SQL.Add('  AND CONVERT(DATE, ISNULL(F132.DT_REALIZACAO, GETDATE()), 103) >= CONVERT(DATE, GETDATE() -3, 103)');
            SQL.Add('  AND ISNULL(F132.IN_APLICAVEL, "0") = "1"');
            SQL.Add('  --AND PR.NR_PROCESSO IN ("0102EM-4639-13", "0102EM-4637-13")');
            SQL.Add('ORDER BY F147.DT_REALIZACAO DESC');
            ParamByName('CD_UNID_NEG').AsString      := pUnidade;
            ParamByName('CD_PRODUTO').AsString       := pProduto;
            ParamByName('CD_GRUPO').AsString         := pGrupo;
            ParamByName('CD_CLIENTE').AsString       := pCliente;
            ParamByName('CD_ARMAZEM').AsString       := pTerminal;
            Open;

            Linha := 9;

            if Eof then
              Result := 'Sem Dados'
            else
            begin
              while not Eof do
              begin
                Inc(Linha);

                if qryEventos.Active then
                  qryEventos.Close;
                qryEventos.ParamByName('NR_PROCESSO').AsString := FieldByName('NR_PROCESSO').AsString;
                qryEventos.Open;

                if qryContrainers.Active then
                  qryContrainers.Close;
                qryContrainers.ParamByName('NR_PROCESSO').AsString := FieldByName('NR_PROCESSO').AsString;
                qryContrainers.Open;
                qryContrainers.First;

                strTipoCntr     := '';
                strRetiradaCntr := '';
                strCntr         := '';

                while not qryContrainers.Eof do
                begin
                  QtdContrainer := 0;
                  strTipoCntrOld := qryContrainers.FieldByName('TP_CNTR').AsString;
                  strTipoCntr := strTipoCntr + '%I ' + qryContrainers.FieldByName('TP_CNTR').AsString;
                  while (not qryContrainers.Eof) and SameText(strTipoCntrOld, qryContrainers.FieldByName('TP_CNTR').AsString) do
                  begin
                    strTipoCntr     := strTipoCntr + #10;
                    if qryContrainers.FieldByName('DT_RET_VAZIO').IsNull then
                      strRetiradaCntr := strRetiradaCntr + #10
                    else
                      strRetiradaCntr := strRetiradaCntr + FormatDateTime('dd/mm/yyyy hh:nn', qryContrainers.FieldByName('DT_RET_VAZIO').AsDateTime) + #10;
                    strCntr         := strCntr + qryContrainers.FieldByName('NR_CNTR').AsString + #10;
                    Inc(QtdContrainer);
                    qryContrainers.Next;
                  end;
                  strTipoCntr := StringReplace(strTipoCntr, '%I', IntToStr(QtdContrainer), []);
                end;

                strTipoCntr     := Copy(strTipoCntr, 1, Length(strTipoCntr) -1);
                strRetiradaCntr := Copy(strRetiradaCntr, 1, Length(strRetiradaCntr) -1);
                strCntr         := Copy(strCntr, 1, Length(strCntr) -1);

                Sheet.Cells[Linha, 01].value := FieldByName('NR_REFERENCIAS').AsString;                                // A
                Sheet.Cells[Linha, 02].value := FieldByName('NR_PROCESSO').AsString;                                   // B
                Sheet.Cells[Linha, 03].value := FieldByName('NM_CLIENTE').AsString;                                    // C
                Sheet.Cells[Linha, 04].value := FieldByName('NM_PAIS_DESTINO').AsString;                               // D
                Sheet.Cells[Linha, 05].value := FieldByName('NM_LOCAL_DESEMBARQUE').AsString;                          // E
                Sheet.Cells[Linha, 06].value := FieldByName('NM_NAVIO').AsString;                                      // F
                Sheet.Cells[Linha, 07].value := FieldByName('NR_BOOKING').AsString;                                    // G
                Sheet.Cells[Linha, 08].value := strTipoCntr;                                                           // H
                Sheet.Cells[Linha, 09].value := strRetiradaCntr;                                                       // I
                Sheet.Cells[Linha, 10].value := strCntr;                                                               // J
                Sheet.Cells[Linha, 11].value := FieldByName('NM_TRANSPORTADORA').AsString;                             // K
                PreencheEvento(12, '147');                                                                             // L
                PreencheEvento(13, '314');                                                                             // M
                PreencheEvento(14, '497');                                                                             // N
                PreencheEvento(15, '315');                                                                             // O
                Sheet.Cells[Linha, 16].value := FieldByName('NM_ARMAZEM_ATRACACAO').AsString;                          // P
                PreencheEvento(17, '528');                                                                             // Q
                PreencheEvento(18, '088');                                                                             // R
                PreencheEvento(19, '270');                                                                             // S
                PreencheEvento(20, '271');                                                                             // T
                PreencheEvento(21, '131');                                                                             // U
                PreencheEvento(22, '132');                                                                             // V

                Range := Sheet.Range['A' + IntToStr(Linha) + ':' + string(Sheet.Cells[Linha, 22].Address)];

                Range.Borders[xlDiagonalDown].LineStyle := 0;
                Range.Borders[xlDiagonalUp].LineStyle := 0;
                Range.Borders[xlEdgeLeft].LineStyle := xlContinuous;
                Range.Borders[xlEdgeLeft].ColorIndex := 15;
                Range.Borders[xlEdgeLeft].Weight := xlThin;
                Range.Borders[xlEdgeTop].LineStyle := xlContinuous;
                Range.Borders[xlEdgeTop].ColorIndex := 15;
                Range.Borders[xlEdgeTop].Weight := xlThin;
                Range.Borders[xlEdgeBottom].LineStyle := xlContinuous;
                Range.Borders[xlEdgeBottom].ColorIndex := 15;
                Range.Borders[xlEdgeBottom].Weight := xlThin;
                Range.Borders[xlEdgeRight].LineStyle := xlContinuous;
                Range.Borders[xlEdgeRight].ColorIndex := 15;
                Range.Borders[xlEdgeRight].Weight := xlThin;
                Range.Borders[xlInsideVertical].LineStyle := xlContinuous;
                Range.Borders[xlInsideVertical].ColorIndex := 15;
                Range.Borders[xlInsideVertical].Weight := xlThin;
                Range.Borders[xlInsideHorizontal].LineStyle := xlContinuous;
                Range.Borders[xlInsideHorizontal].ColorIndex := 15;
                Range.Borders[xlInsideHorizontal].Weight := xlThin;

                //Sheet.Rows[IntToStr(Linha) + ':' + IntToStr(Linha)].RowHeight := 15;
                Sheet.Rows[IntToStr(Linha) + ':' + IntToStr(Linha)].EntireRow.AutoFit;

                Next;
              end;

              Sheet.Sort.SortFields.Clear;

              Sheet.Sort.SortFields.Add(Key:=Sheet.Range['L10:L' + IntToStr(Linha)], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
              Sheet.Sort.SetRange(Sheet.Range['A10:V' + IntToStr(Linha)]);
              Sheet.Sort.Header := xlGuess;
              Sheet.Sort.MatchCase := False;
              Sheet.Sort.Orientation := xlTopToBottom;
              Sheet.Sort.SortMethod := xlPinYin;
              Sheet.Sort.Apply;
            end;
          end;
        finally
          if Result <> 'Sem Dados' then
          begin
            if FileExists(Result) then
              SysUtils.DeleteFile(Result);
            Excel.ActiveWorkBook.SaveAs(Result);
          end;
          FreeAndNil(qryContrainers);
          FreeAndNil(qryEventos);
          FreeAndNil(qryRelatorio);
        end;

      finally
        WorkBook.Close(False);
        KillExcel(Excel);
      end;
    finally
      FreeAndNil(db_broker);
    end;
  except
    on e:Exception do
    begin
      VMsg('Erro - RelEventosDailyFupTerminal: ' + e.Message, msError, True);
    end;
  end;
end;

end.


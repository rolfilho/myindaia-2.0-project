function TfrmMain.ConsultaLookup(ATabela, ACampo: String): String;
begin
  Result := ConsultaLookupSQL(' SELECT ' + ACampo + ' FROM ' + ATabela + ' (NOLOCK)');
end;

function TfrmMain.ConsultaLookupFiltro(ATabela, ACampo, ACampoComp, AValorComp: String): String;
begin

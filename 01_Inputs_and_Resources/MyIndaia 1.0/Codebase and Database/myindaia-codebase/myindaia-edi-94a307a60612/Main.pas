function TfrmMain.RetornoFuncao(pRetornoDesejado,pProcesso:String) : string;
var
  vStrAux : string;
begin
  if pRetornoDesejado = 'TREF_CLIENTE' then
  begin
    with TQuery.Create(Self) do
    begin
      try
        Databasename := 'DBBROKER';
        SQL.Clear;
        SQL.Add('SELECT CD_REFERENCIA, NR_ITEM_PO FROM TREF_CLIENTE (NOLOCK) WHERE NR_PROCESSO = ''0101' + pProcesso + '''');
        Open;
        while not EOF do
        begin
          vStrAux := vStrAux + ' - ' + Fields[0].AsString + '/' + Fields[1].AsString;
          Next;
        end;
        Close;
      finally
        Free;
      end;
    end;
  end;
  Result := Copy(vStrAux,4,Length(vStrAux)-3);
end;

function TFrmMain.ConfirmacaoEmbarque(pRelatorio : string) : Boolean;
var
  vMails : String;
  vUnidade, vArea, vSubArea, vGrupo, vCliente, vAnalistaCliente, vEvento : string;
  vArrayProcessos : array of string;
  i : Integer;
  vQryAlerta : TQuery;
begin

  try
    vQryAlerta := TQuery.Create(Self);
    with vQryAlerta do
    begin
      try
        vMails := '';
        SessionName := 'SES_EDI';
        DataBaseName := 'BROKER';
        SQL.Clear;
        SQL.Add('SELECT CONVERT(VARCHAR(MAX),USU.NM_EMAIL) NM_EMAIL FROM TUSUARIO USU (NOLOCK), TRELATORIOS_MAIL_AUT_USUARIOS RMAU (NOLOCK) ');
        SQL.Add(' WHERE RMAU.CD_RELATORIO = ''' + ExtractWord(2,pRelatorio,'"') + ''' ');
        SQL.Add('   AND USU.CD_USUARIO = RMAU.CD_USUARIO ');
        Open;
        while not EOF do
        begin
          vMails := vMails + FieldByName('NM_EMAIL').AsString + ';';
          Next;
        end;
//lembrete: qdo pegar o email do atendente e contato colocar um x na frente para năo enviar alerta de teste aos usuario veridicos
        Close;
        SQL.Clear;
        SQL.Add('SELECT TX_CONFIGURACAO ');
        SQL.Add('  FROM TRELATORIOS_MAIL_AUT ( NOLOCK) ');
        SQL.Add(' WHERE CD_RELATORIO = ''' + ExtractWord(2,pRelatorio,'"') + '''');
        Open;
        vUnidade         := ExtractWord(1,Fields[0].AsString,'/');
        vCliente         := ExtractWord(2,Fields[0].AsString,'/');
        vGrupo           := ExtractWord(3,Fields[0].AsString,'/');
        vArea            := ExtractWord(4,Fields[0].AsString,'/');
        vSubArea         := ExtractWord(5,Fields[0].AsString,'/');
        vAnalistaCliente := ExtractWord(7,Fields[0].AsString,'/');
        vEvento          := ExtractWord(8,Fields[0].AsString,'/');

        Close;
        SQL.Clear;
        SQL.Add(' SELECT FUP.NR_PROCESSO ');
        SQL.Add(' FROM TFOLLOWUP FUP ( NOLOCK), TPROCESSO PR ( NOLOCK) ');
        SQL.Add(' WHERE FUP.DT_REALIZACAO IS NOT NULL ');
        SQL.Add('   AND FUP.CD_EVENTO    = ''' + vEvento + ''' ');
        SQL.Add('   AND ISNULL(FUP.IN_ALERTA_ENVIADO,''0'') = ''0'' ');
        SQL.Add('   AND PR.NR_PROCESSO   =  FUP.NR_PROCESSO ');
        if Trim(vUnidade) <> '' then
          SQL.Add('   AND PR.CD_UNID_NEG = ''' + vUnidade + '''');
        if Trim(vArea) <> '' then
          SQL.Add('   AND PR.CD_AREA IN ( SELECT CD_AREA FROM TAREA (NOLOCK) WHERE NM_GRUPO = (SELECT NM_GRUPO FROM TAREA (NOLOCK) WHERE CD_AREA = ''' + vArea + ''' ) )');
        if Trim(vSubArea) <> '' then
          SQL.Add('   AND PR.CD_AREA = ''' + vSubArea + '''');
        if Trim(vGrupo) <> '' then
          SQL.Add('   AND PR.CD_CLIENTE IN ( SELECT CD_EMPRESA FROM TEMPRESA_NAC (NOLOCK) WHERE CD_GRUPO = "' + vGrupo + '")')
        else begin
          SQL.Add('   AND PR.CD_CLIENTE IN ( SELECT E.CD_EMPRESA FROM TEMPRESA_NAC E (NOLOCK), TGRUPO G (NOLOCK) ');
          SQL.Add('                          WHERE  E.CD_GRUPO=G.CD_GRUPO AND G.IN_ALERTA_E01_NAO_GENERICO<>"1" )')
        end;

        if Trim(vCliente) <> '' then
          SQL.Add('   AND PR.CD_CLIENTE = ''' + vCliente + '''');
        if Trim(vAnalistaCliente) <> '' then
          SQL.Add('   AND PR.CD_CONTATO IN (SELECT CD_CONTATO FROM TCLIENTE_CONTATO (NOLOCK) WHERE CD_USUARIO = ''' + vAnalistaCliente + ''' )');
        Open;
      finally
        Free;
      end;
    end;
    if Length(vArrayProcessos) > 0 then
    begin
      with TQuery.Create(Self) do
      begin
        try
          SessionName := 'SES_EDI';
          DataBaseName := 'BROKER';
          SQL.Clear;
          SQL.Add('UPDATE TFOLLOWUP SET IN_ALERTA_ENVIADO = ''1''');
          SQL.Add(' WHERE CD_EVENTO = ''165''');
          if Length(vArrayProcessos) > 1 then
          begin
            SQL.Add('   AND NR_PROCESSO IN (');
            for I:=0 TO Length(vArrayProcessos)-2 do
              SQL.Add('''' + vArrayProcessos[i] + ''',');
            SQL.Add('''' + vArrayProcessos[Length(vArrayProcessos)-1] + ''')');
          end else begin
            SQL.Add('   AND NR_PROCESSO IN (''' + vArrayProcessos[0] + ''')');
          end;
          ExecSQL;
        finally
          Free;
        end;
      end;
    end;
  except
    On e:Exception do
      VMsg(e.message, msError, True);
  end;
end;

function ExtractWord(pPosicao : Integer; pTexto, pBusca : String) : string;
var
  i, vIntAux : Integer;
begin
  vIntAux := 0;
  for i := 0 to pPosicao - 1 do
  begin
    if Pos( pBusca , Copy(pTexto,vIntAux+1,Length(pTexto) ) ) > 0 then
      Result := Copy(pTexto, vIntAux+1 , Pos( pBusca , Copy(pTexto,vIntAux+1,Length(pTexto) ) ) -1 )
    else Result := Trim(Copy(pTexto, vIntAux+1 , Length(pTexto) ) );
    vIntAux := vIntAux + Length(Copy(pTexto, vIntAux+1 , Pos( pBusca , Copy(pTexto,vIntAux+1,Length(pTexto) ) ) -1 )) + 1;
  end;
end;

function TFrmMain.ContaOcorrencias(pTexto,pSubString : string) : Integer;
var
  vIntAux, i : Integer;
begin
  vIntAux := 0;
  Result := 0;
  for i := 0 to Length(pTexto) do
  begin
    if Pos(pSubString, Copy(pTexto,vIntAux+1,Length(pTexto))) > 0 then
    begin
      vIntAux := vIntAux + Pos(pSubString,Copy(pTexto,vIntAux+1,Length(pTexto)));
      Result := Result + 1;
    end;
  end;
end;

function TFrmMain.ConsultaLookUPSQL(pSQL, pRetorno: string): string;
begin
  result := '';
  with TQuery.Create(Self) do begin
    try
      DataBaseName := 'BROKER';
      SessionName := 'SES_EDI';
      SQL.ADD(pSQL);
      Open;
      Result := FieldByName(pRetorno).AsString;
    finally
      Free;
    end;
  end;
end;

function TFrmMain.ConcatenaRegistros(pSQL : String) : string;
begin
  with TQuery.Create(Self) do
  begin
    try
      Result := '';
      SessionName := 'SES_EDI';
      DataBaseName := 'BROKER';
      SQL.Clear;
      SQL.Add(pSQL);
      Open;
      while not EOF do
      begin
        Result := Result + Fields[0].AsString + '/';
        Next;
      end;
      Close;
    finally
      Free;
    end;
    Result := Trim(Copy(Result,1,length(Result)-1));
  end;
end;

Function TFrmMain.IIF(pTest: Boolean; Const pTrue: string; Const pFalse: String): String;
begin
  if pTest then
    Result := pTrue
  else Result := pFalse;
end;


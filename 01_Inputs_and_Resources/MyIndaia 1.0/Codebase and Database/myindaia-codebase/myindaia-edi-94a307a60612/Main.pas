                      SQL.Clear;
                      SQL.Add('SELECT CASE WHEN F.IN_APLICAVEL <> 1 THEN "N/A"');
                      SQL.Add('       ELSE CONVERT(VARCHAR,F.DT_REALIZACAO,103)');
                      SQL.Add('       END AS DT_REALIZACAO,');
                      SQL.Add('       CONVERT(VARCHAR, DT_REALIZACAO_EFETIVA, 103) AS DT_REALIZACAO_EFETIVA,');
                      SQL.Add('       CONVERT(VARCHAR, GETDATE(), 103) AS DT_NOW');
                      SQL.Add(' FROM   TPROCESSO P (NOLOCK)');
                      SQL.Add(' INNER JOIN TFOLLOWUP F (NOLOCK) ON (P.NR_PROCESSO = F.NR_PROCESSO )');
                      SQL.Add(' WHERE  P.NR_PROCESSO = "' + qry_mail_proc_nao_fat.FieldByName('NR_PROCESSO').AsString + '"');

function TfrmMain.RelEventosDailyFupArmador(pUnidade, pProduto, pGrupo, pCliente, pArmador: string): String; // DFA
var
  db_broker: TDatabase;
  qryContrainers, qryEventos, qryRelatorio: TQuery;
  Excel, WorkBook, Sheet, Range: OleVariant;
  TimeStamp, NomeProduto: String;
  Linha: Integer;
  strTipoCntrOld, strTipoCntr, strRetiradaCntr, strCntr: String;
  QtdContrainer: Integer;

  procedure PreencheEvento(AColuna: Integer; AEvento: String);
  begin
    //Sheet.Cells[Linha, AColuna].NumberFormat := '[$-409] dd/mm/aaaa;@';
    //Sheet.Cells[Linha, AColuna].HorizontalAlignment := xlCenter;
    with qryEventos do
    begin
      First;
      if Locate('CD_EVENTO', AEvento, []) then
      begin
        if (AnsiIndexText(FieldByName('DT_REALIZACAO').AsString, ['', 'N/A', 'TO BE CONFIRMED']) < 0) then
        begin
          if AnsiIndexText(AEvento, ['270', '271']) >= 0 then
            Sheet.Cells[Linha, AColuna].Value := FieldByName('DT_REALIZACAO').AsDateTime
          else
            Sheet.Cells[Linha, AColuna].Value := DateOf(FieldByName('DT_REALIZACAO').AsDateTime);
        end
        else
          Sheet.Cells[Linha, AColuna].Value := '';//FieldByName('DT_REALIZACAO').AsString;

        if FieldByName('DT_REALIZACAO_EFETIVA').AsString <> '' then
          if ((DayOfWeek(Date) = 2) and (FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -3)) or ((DayOfWeek(Date) <> 2) and (FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -1)) then
            Sheet.Cells[Linha, AColuna].Interior.ColorIndex := 40;
      end
      else
        Sheet.Cells[Linha, AColuna].Value := '';
    end;
  end;
begin
  Result := '';
  try
    db_broker:= TDatabase.Create(Self);
    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;

    try
      db_broker.Connected := True;
      Excel    := CreateOLEObject('Excel.Application');
      try
        WorkBook := Excel.Workbooks.Open(GetPath+'FOLLOWUP_ARMADOR_Nestle.xls');
        Excel.Visible := chkVisualizarExcel.checked;
        TimeStamp := FormatDateTime('ddmmyyyyhhnnsszz', Now);

        try
          Sheet := WorkBook.Worksheets[1];

          qryContrainers := TQuery.Create(Self);
          qryContrainers.DatabaseName := 'DBBROKER';
          qryEventos := TQuery.Create(Self);
          qryEventos.DatabaseName := 'DBBROKER';
          qryRelatorio := TQuery.Create(Self);
          qryRelatorio.DatabaseName := 'DBBROKER';

          with qryEventos do
          begin
            SQL.Add('SELECT *');
            SQL.Add('FROM TFOLLOWUP');
            SQL.Add('WHERE NR_PROCESSO = :NR_PROCESSO');
          end;

          with qryContrainers do
          begin
            SQL.Add('SELECT RTRIM(TC.NM_TP_CNTR) AS TP_CNTR, RTRIM(PC.NR_CNTR) AS NR_CNTR, PC.DT_RET_VAZIO');
            SQL.Add('FROM TPROCESSO_CNTR PC');
            SQL.Add('   INNER JOIN TTP_CNTR TC ON TC.TP_CNTR = PC.TP_CNTR');
            SQL.Add('WHERE NR_PROCESSO = :NR_PROCESSO');
            SQL.Add('ORDER BY TP_CNTR, NR_CNTR, DT_DEVOLUCAO_CNTR');
          end;

          with qryRelatorio do
          begin
            SQL.Clear;
            SQL.Add('SELECT ISNULL((SELECT RTRIM(AP_UNID_NEG)');
            SQL.Add('               FROM TUNID_NEG (NOLOCK)');
            SQL.Add('               WHERE CD_UNID_NEG = :CD_UNID_NEG), "Todas") AS NM_UNID_NEG,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_PRODUTO)');
            SQL.Add('               FROM TPRODUTO (NOLOCK)');
            SQL.Add('               WHERE CD_PRODUTO = :CD_PRODUTO), "Todos") AS NM_PRODUTO,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_GRUPO)');
            SQL.Add('               FROM TGRUPO (NOLOCK)');
            SQL.Add('               WHERE CD_GRUPO = :CD_GRUPO), "Todos") AS NM_GRUPO,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_EMPRESA)');
            SQL.Add('               FROM TEMPRESA_NAC (NOLOCK)');
            SQL.Add('               WHERE CD_EMPRESA = :CD_CLIENTE), "Todos") AS NM_CLIENTE,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_AGENTE)');
            SQL.Add('               FROM TAGENTE (NOLOCK)');
            SQL.Add('               WHERE CD_AGENTE = :CD_AGENTE), "Todos") AS NM_AGENTE');
            ParamByName('CD_UNID_NEG').AsString      := pUnidade;
            ParamByName('CD_PRODUTO').AsString       := pProduto;
            ParamByName('CD_GRUPO').AsString         := pGrupo;
            ParamByName('CD_CLIENTE').AsString       := pCliente;
            ParamByName('CD_AGENTE').AsString       := pArmador;
            Open;

            Sheet.Cells[01, 06].value :=  'Unidade: ' + pUnidade + ' - ' + Fields[0].AsString;
            Sheet.Cells[02, 06].value :=  'Produto: ' + pProduto + ' - ' + Fields[1].AsString;
            Sheet.Cells[03, 06].value :=  'Grupo Cliente: ' + pGrupo + ' - ' + Fields[2].AsString;
            Sheet.Cells[04, 06].value :=  'Cliente: ' + pCliente + ' - ' + Fields[3].AsString;
            Sheet.Cells[05, 06].value :=  'Armador: ' + pArmador + ' - ' + Fields[4].AsString;
            Sheet.Cells[06, 06].value :=  'Data: ' + FormatDateTime('dd/mm/yyyy', Now);

            NomeProduto := Copy(Fields[1].AsString, 1, 3);
            Result := GetPath+'Gerados\FOLLOWUP_' + NomeProduto + '_' + TimeStamp + '.xls';
            Close;

            SQL.Clear;
            SQL.Add('SELECT DBO.FN_REFERENCIAS(PR.NR_PROCESSO, ",", "08", "04") AS NR_REFERENCIAS,');
            SQL.Add('       RTRIM(PR.NR_PROCESSO) AS NR_PROCESSO,');
            SQL.Add('       RTRIM(EN.NM_EMPRESA) AS NM_CLIENTE,');
            SQL.Add('       RTRIM(PD.NM_PAIS) AS NM_PAIS_DESTINO,');
            SQL.Add('       RTRIM(LD.DESCRICAO) AS NM_LOCAL_DESEMBARQUE,');
            SQL.Add('       RTRIM(LE.DESCRICAO) AS NM_LOCAL_EMBARQUE,');
            SQL.Add('       RTRIM(EM.NM_EMBARCACAO) AS NM_NAVIO,');
            SQL.Add('       (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(RC.CD_REFERENCIA) + ", "), ", ")');
            SQL.Add('        FROM TREF_CLIENTE RC');
            SQL.Add('        WHERE RC.NR_PROCESSO = PR.NR_PROCESSO');
            SQL.Add('          AND RC.TP_REFERENCIA = "05") AS NR_BOOKING,');
            SQL.Add('       (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(RC.CD_REFERENCIA) + ", "), ", ")');
            SQL.Add('        FROM TREF_CLIENTE RC');
            SQL.Add('        WHERE RC.NR_PROCESSO = PR.NR_PROCESSO');
            SQL.Add('          AND RC.TP_REFERENCIA = "04") AS NR_REF_OUTROS,');
            SQL.Add('       RTRIM(TR.AP_TRANSP_ROD) AS NM_TRANSPORTADORA,');
            SQL.Add('       RTRIM(AR.NM_ARMAZEM) AS NM_ARMAZEM_ATRACACAO,');
            SQL.Add('       RTRIM(AG.NM_AGENTE) AS NM_AGENTE');
            SQL.Add('FROM TPROCESSO                 PR   (NOLOCK)');
            SQL.Add('   INNER JOIN TSERVICO_NOVO    SV   (NOLOCK) ON SV.CD_SERVICO = PR.CD_SERVICO');
            SQL.Add('   INNER JOIN TEMPRESA_NAC     EN   (NOLOCK) ON EN.CD_EMPRESA = PR.CD_CLIENTE');
            SQL.Add('   INNER JOIN TFOLLOWUP        F147 (NOLOCK) ON F147.NR_PROCESSO = PR.NR_PROCESSO AND F147.CD_EVENTO = "147"');
            SQL.Add('   INNER JOIN TFOLLOWUP        F132 (NOLOCK) ON F132.NR_PROCESSO = PR.NR_PROCESSO AND F132.CD_EVENTO = "132"');
            SQL.Add('   INNER JOIN TFOLLOWUP        F315 (NOLOCK) ON F315.NR_PROCESSO = PR.NR_PROCESSO AND F315.CD_EVENTO = "315"');
            SQL.Add('   LEFT  JOIN TPAIS_BROKER     PD   (NOLOCK) ON PD.CD_PAIS = PR.CD_PAIS_DESTINO');
            SQL.Add('   LEFT  JOIN TLOCAL_EMBARQUE  LD   (NOLOCK) ON LD.CODIGO = PR.CD_LOCAL_DESEMBARQUE');
            SQL.Add('   LEFT  JOIN TLOCAL_EMBARQUE  LE   (NOLOCK) ON LE.CODIGO = PR.CD_LOCAL_EMBARQUE');
            SQL.Add('   LEFT  JOIN TEMBARCACAO      EM   (NOLOCK) ON EM.CD_EMBARCACAO = PR.CD_EMBARCACAO');
            SQL.Add('   LEFT  JOIN TTRANSP_ROD      TR   (NOLOCK) ON TR.CD_TRANSP_ROD = PR.CD_TRANSP_NAC');
            SQL.Add('   LEFT  JOIN TARMAZEM         AR   (NOLOCK) ON AR.CD_ARMAZEM = PR.CD_ARMAZEM_ATRACACAO');
            SQL.Add('   LEFT  JOIN TAGENTE          AG   (NOLOCK) ON AG.CD_AGENTE = PR.CD_AGENTE');
            SQL.Add('WHERE :CD_UNID_NEG IN ("", PR.CD_UNID_NEG)');
            SQL.Add('  AND :CD_PRODUTO IN ("", PR.CD_PRODUTO)');
            SQL.Add('  AND :CD_GRUPO IN ("", EN.CD_GRUPO)');
            SQL.Add('  AND :CD_CLIENTE IN ("", PR.CD_CLIENTE)');
            SQL.Add('  AND :CD_ARMADOR IN ("", PR.CD_AGENTE)');
            SQL.Add('  AND PR.IN_CANCELADO = "0"');
            SQL.Add('  AND SV.CD_VIA_TRANSPORTE = "01"');
            SQL.Add('  AND F147.DT_REALIZACAO IS NOT NULL');
            SQL.Add('  AND ISNULL(F147.IN_APLICAVEL, "0") = "1"');
            SQL.Add('  AND CONVERT(DATE, ISNULL(F132.DT_REALIZACAO, GETDATE()), 103) >= CONVERT(DATE, GETDATE() -1, 103)');
            SQL.Add('  AND ISNULL(F315.IN_APLICAVEL, "0") = "1"');
            SQL.Add('  AND CONVERT(DATE, ISNULL(F315.DT_REALIZACAO, GETDATE()), 103) >= CONVERT(DATE, GETDATE() -3, 103)');
            SQL.Add('  --AND PR.NR_PROCESSO IN ("0102EM-4639-13", "0102EM-4637-13")');
            SQL.Add('ORDER BY F147.DT_REALIZACAO DESC');
            ParamByName('CD_UNID_NEG').AsString      := pUnidade;
            ParamByName('CD_PRODUTO').AsString       := pProduto;
            ParamByName('CD_GRUPO').AsString         := pGrupo;
            ParamByName('CD_CLIENTE').AsString       := pCliente;
            ParamByName('CD_ARMADOR').AsString       := pArmador;
            Open;

            Linha := 9;

            if Eof then
              Result := 'Sem Dados'
            else
            begin
              while not Eof do
              begin
                Inc(Linha);

                if qryEventos.Active then
                  qryEventos.Close;
                qryEventos.ParamByName('NR_PROCESSO').AsString := FieldByName('NR_PROCESSO').AsString;
                qryEventos.Open;

                if qryContrainers.Active then
                  qryContrainers.Close;
                qryContrainers.ParamByName('NR_PROCESSO').AsString := FieldByName('NR_PROCESSO').AsString;
                qryContrainers.Open;
                qryContrainers.First;

                strTipoCntr     := '';
                strRetiradaCntr := '';
                strCntr         := '';

                while not qryContrainers.Eof do
                begin
                  QtdContrainer := 0;
                  strTipoCntrOld := qryContrainers.FieldByName('TP_CNTR').AsString;
                  strTipoCntr := strTipoCntr + '%I ' + qryContrainers.FieldByName('TP_CNTR').AsString;
                  while (not qryContrainers.Eof) and SameText(strTipoCntrOld, qryContrainers.FieldByName('TP_CNTR').AsString) do
                  begin
                    strTipoCntr     := strTipoCntr + #10;
                    if qryContrainers.FieldByName('DT_RET_VAZIO').IsNull then
                      strRetiradaCntr := strRetiradaCntr + #10
                    else
                      strRetiradaCntr := strRetiradaCntr + FormatDateTime('dd/mm/yyyy hh:nn', qryContrainers.FieldByName('DT_RET_VAZIO').AsDateTime) + #10;
                    strCntr         := strCntr + qryContrainers.FieldByName('NR_CNTR').AsString + #10;
                    Inc(QtdContrainer);
                    qryContrainers.Next;
                  end;
                  strTipoCntr := StringReplace(strTipoCntr, '%I', IntToStr(QtdContrainer), []);
                end;
                strTipoCntr     := Copy(strTipoCntr, 1, Length(strTipoCntr) -1);
                strRetiradaCntr := Copy(strRetiradaCntr, 1, Length(strRetiradaCntr) -1);
                strCntr         := Copy(strCntr, 1, Length(strCntr) -1);

                Sheet.Cells[Linha, 01].value := FieldByName('NR_REFERENCIAS').AsString;                                // A
                Sheet.Cells[Linha, 02].value := FieldByName('NR_PROCESSO').AsString;                                   // B
                Sheet.Cells[Linha, 03].value := FieldByName('NM_CLIENTE').AsString;                                    // C
                Sheet.Cells[Linha, 04].value := FieldByName('NM_PAIS_DESTINO').AsString;                               // D
                Sheet.Cells[Linha, 05].value := FieldByName('NM_LOCAL_EMBARQUE').AsString;                             // E
                Sheet.Cells[Linha, 06].value := FieldByName('NM_LOCAL_DESEMBARQUE').AsString;                          // F
                Sheet.Cells[Linha, 07].value := FieldByName('NM_AGENTE').AsString;                                     // G
                Sheet.Cells[Linha, 08].value := FieldByName('NM_NAVIO').AsString;                                      // H
                Sheet.Cells[Linha, 09].value := FieldByName('NR_BOOKING').AsString;                                    // I
                Sheet.Cells[Linha, 10].value := strTipoCntr;                                                           // J
//                Sheet.Cells[Linha, 11].value := strRetiradaCntr;                                                       // K
//                Sheet.Cells[Linha, 12].value := strCntr;                                                               // L
//                Sheet.Cells[Linha, 13].value := FieldByName('NM_TRANSPORTADORA').AsString;                             // M
                PreencheEvento(11, '147');                                                                             // K
                Sheet.Cells[Linha, 12].value := FieldByName('NR_REF_OUTROS').AsString;                                 // L
                PreencheEvento(13, '314');                                                                             // M
//                PreencheEvento(17, '497');                                                                             // Q
//                PreencheEvento(18, '315');                                                                             // R
                Sheet.Cells[Linha, 14].value := FieldByName('NM_ARMAZEM_ATRACACAO').AsString;                          // N
//                PreencheEvento(20, '528');                                                                             // T
//                PreencheEvento(21, '088');                                                                             // U
//                PreencheEvento(22, '270');                                                                             // V
//                PreencheEvento(23, '271');                                                                             // W
                PreencheEvento(15, '131');                                                                             // O
//                PreencheEvento(25, '132');                                                                             // Y

                Range := Sheet.Range['A' + IntToStr(Linha) + ':' + string(Sheet.Cells[Linha, 15].Address)];

                Range.Borders[xlDiagonalDown].LineStyle := 0;
                Range.Borders[xlDiagonalUp].LineStyle := 0;
                Range.Borders[xlEdgeLeft].LineStyle := xlContinuous;
                Range.Borders[xlEdgeLeft].ColorIndex := 15;
                Range.Borders[xlEdgeLeft].Weight := xlThin;
                Range.Borders[xlEdgeTop].LineStyle := xlContinuous;
                Range.Borders[xlEdgeTop].ColorIndex := 15;
                Range.Borders[xlEdgeTop].Weight := xlThin;
                Range.Borders[xlEdgeBottom].LineStyle := xlContinuous;
                Range.Borders[xlEdgeBottom].ColorIndex := 15;
                Range.Borders[xlEdgeBottom].Weight := xlThin;
                Range.Borders[xlEdgeRight].LineStyle := xlContinuous;
                Range.Borders[xlEdgeRight].ColorIndex := 15;
                Range.Borders[xlEdgeRight].Weight := xlThin;
                Range.Borders[xlInsideVertical].LineStyle := xlContinuous;
                Range.Borders[xlInsideVertical].ColorIndex := 15;
                Range.Borders[xlInsideVertical].Weight := xlThin;
                Range.Borders[xlInsideHorizontal].LineStyle := xlContinuous;
                Range.Borders[xlInsideHorizontal].ColorIndex := 15;
                Range.Borders[xlInsideHorizontal].Weight := xlThin;

                //Sheet.Rows[IntToStr(Linha) + ':' + IntToStr(Linha)].RowHeight := 15;
                Sheet.Rows[IntToStr(Linha) + ':' + IntToStr(Linha)].EntireRow.AutoFit;

                Next;
              end;

              Sheet.Sort.SortFields.Clear;

              Sheet.Sort.SortFields.Add(Key:=Sheet.Range['M10:M' + IntToStr(Linha)], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
              Sheet.Sort.SetRange(Sheet.Range['A10:O' + IntToStr(Linha)]);
              Sheet.Sort.Header := xlGuess;
              Sheet.Sort.MatchCase := False;
              Sheet.Sort.Orientation := xlTopToBottom;
              Sheet.Sort.SortMethod := xlPinYin;
              Sheet.Sort.Apply;
            end;
          end;
        finally
          if Result <> 'Sem Dados' then
          begin
            if FileExists(Result) then
              SysUtils.DeleteFile(Result);
            Excel.ActiveWorkBook.SaveAs(Result);
          end;
          FreeAndNil(qryContrainers);
          FreeAndNil(qryEventos);
          FreeAndNil(qryRelatorio);
        end;

      finally
        WorkBook.Close(False);
        KillExcel(Excel);
      end;
    finally
      FreeAndNil(db_broker);
    end;
  except
    on e:Exception do
    begin
      VMsg('Erro - RelEventosDailyFupArmador: ' + e.Message, msError, True);
    end;
  end;

end;

Function TFrmMain.RelEventosDailyFupBasf(pUnidade, pProduto, pGrupo, pImportador, pEvento, pCliente, pTransportador, pRelatorio, pHorario: string): String;
var
  db_broker                                              : TDatabase;
  vQryEventos, qry_mail_proc_nao_fat, qryAuxiliar        : TQuery;
  Excel, xlWorkB, oSheet, Range                          : OleVariant;
  nLinha, ctLinha, nColuna, vPrimeiraLinha, vCont,
  I, X, vTotalEventos, vUlt_Col_Fixa, vNegrita           : Integer;
  vValorTotalServico                                     : Real;
  vAno, vMes, vDia                                       : Word;
  vTimeStamp, vNomeProduto, vIdioma, str_CD_EVENTO,strTmp,ConfirmaEmbarque: String;
  str_linha                                              : WideString;
  str_OBS                                                : TMemo;
  tem_dados, TemBooking, TemContainer                    : Boolean;
  QtdCourier, tmpQtdCourier                              : Integer;

begin
  try
    db_broker:= TDatabase.Create(Self);
    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;

    vQryEventos              := TQuery.Create(Self);
    vQryEventos.DatabaseName := 'DBBROKER';

    qry_mail_proc_nao_fat              := TQuery.Create(Self);
    qry_mail_proc_nao_fat.DatabaseName := 'DBBROKER';

    qryAuxiliar              := TQuery.Create(Self);
    qryAuxiliar.DatabaseName := 'DBBROKER';
    try
      Excel      := CreateOLEObject('Excel.Application');
      try
        db_broker.Connected := True;

        xlWorkB    := Excel.Workbooks.Open(GetPath+'DAILY_FOLLOWUP_Basf.xlsx');

        vTimeStamp := FormatDateTime('ddmmyyyyhhnnsszz', Now);

        Excel.Visible := chkVisualizarExcel.checked;
        oSheet := Excel.WorkBooks[1].Worksheets[1];

        with TQuery.Create(Self) do
        begin
          try
            DatabaseName := 'DBBROKER';
            // Produto
            SQL.Clear;
            SQL.Add('SELECT NM_PRODUTO FROM TPRODUTO ( NOLOCK ) WHERE CD_PRODUTO = ''' + pProduto + '''');
            Open;
            vNomeProduto := Copy(Fields[0].AsString, 1, 3);
            Close;

            // Importador
            SQL.Clear;
            SQL.Add('SELECT NM_EMPRESA FROM TEMPRESA_EST ( NOLOCK ) WHERE CD_EMPRESA = ''' + pImportador + '''');
            Open;
            oSheet.Cells[ 04, 07 ].value :=  pImportador + ' - ' + Fields[0].AsString;
            Close;

            //busca o idioma do Importador
            SQL.Clear;
            SQL.Add('     SELECT ISNULL(P.CD_IDIOMA_PADRAO, "9")');
            SQL.Add('       FROM TEMPRESA_EST E (NOLOCK)');
            SQL.Add(' INNER JOIN TPAIS        P (NOLOCK) ON E.CD_PAIS = P.CODIGO ');
            SQL.Add('WHERE E.CD_EMPRESA = "' + pImportador + '"');
            Open;
            vIdioma := Fields[0].AsString;
            Close;

          finally
            Free;
          end;
        end;

        oSheet.Cells[ 05, 07 ].value :=  FormatDateTime('mm/dd/yyyy', Now);

        //--------------------------------------------------------------------------//
        // Busca o nome dos Eventos e Monta Cabeçalho
        // colunas fixas
        //--------------------------------------------------------------------------//
        vUlt_Col_Fixa  := 22;
        nLinha         := 11;
        nColuna        := vUlt_Col_Fixa;

        //coloca todas as colunas fixas em negrito
        for vNegrita := 2 to vUlt_Col_Fixa do begin
           oSheet.Cells[ nLinha, vNegrita ].Font.Bold := True;
        end;

        if vIdioma = '2' then
        begin
          oSheet.Cells[ nLinha, 02 ].value := 'Main Leg';
          oSheet.Cells[ nLinha, 03 ].value := 'Ordem';
          oSheet.Cells[ nLinha, 04 ].value := 'Pedido';

          oSheet.Cells[ nLinha, 05 ].value := 'Referencia Indaia';
          oSheet.Cells[ nLinha, 06 ].value := 'BU';
          oSheet.Cells[ nLinha, 07 ].value := 'Exportador';
          oSheet.Cells[ nLinha, 08 ].value := 'Lugar de carga';
          oSheet.Cells[ nLinha, 09 ].value := 'Importador/Consignatario';

          oSheet.Cells[ nLinha, 10 ].value := 'Descripcion de la Mercaderia';
          oSheet.Cells[ nLinha, 11 ].value := 'Pais de la entrega';
          oSheet.Cells[ nLinha, 12 ].value := 'Ciudad de la Entrega';
          oSheet.Cells[ nLinha, 13 ].value := 'Embarcacion';
          oSheet.Cells[ nLinha, 14 ].value := 'Transportista/Agente';
          oSheet.Cells[ nLinha, 15 ].value := 'Booking';
          oSheet.Cells[ nLinha, 16 ].value := 'Bill of lading';
          oSheet.Cells[ nLinha, 17 ].value := 'Cntr Number';
          oSheet.Cells[ nLinha, 18 ].value := 'BML/Packing-List';
          oSheet.Cells[ nLinha, 19 ].value := 'Invoice';
          oSheet.Cells[ nLinha, 20 ].value := 'BL / CRT / AWB';
          oSheet.Cells[ nLinha, 21 ].value := 'Análisis'; //Link
          oSheet.Cells[ nLinha, 22 ].value := 'Certificado de origen'; //Link
          oSheet.Cells[ nLinha, 23 ].value := 'Notes';
        end
        else
        begin
          oSheet.Cells[ nLinha, 02 ].value := 'Main Leg';
          oSheet.Cells[ nLinha, 03 ].value := 'Order Number';
          oSheet.Cells[ nLinha, 04 ].value := 'Customer PO';

          oSheet.Cells[ nLinha, 05 ].value := 'Reference Indaia';
          oSheet.Cells[ nLinha, 06 ].value := 'BU';
          oSheet.Cells[ nLinha, 07 ].value := 'Exporter';
          oSheet.Cells[ nLinha, 08 ].value := 'Place of loading';
          oSheet.Cells[ nLinha, 09 ].value := 'Importer/Consignee';

          oSheet.Cells[ nLinha, 10 ].value := 'Description of Goods';
          oSheet.Cells[ nLinha, 11 ].value := 'Country of Destination';
          oSheet.Cells[ nLinha, 12 ].value := 'Place of Destination';
          oSheet.Cells[ nLinha, 13 ].value := 'Vessel';
          oSheet.Cells[ nLinha, 14 ].value := 'Cargo Agent';
          oSheet.Cells[ nLinha, 15 ].value := 'Booking';
          oSheet.Cells[ nLinha, 16 ].value := 'Bill of lading';
          oSheet.Cells[ nLinha, 17 ].value := 'Cntr Number';
          oSheet.Cells[ nLinha, 18 ].value := 'BML/Packing-List';
          oSheet.Cells[ nLinha, 19 ].value := 'Invoice';
          oSheet.Cells[ nLinha, 20 ].value := 'BL / CRT / AWB';
          oSheet.Cells[ nLinha, 21 ].value := 'Analysis'; //Link
          oSheet.Cells[ nLinha, 22 ].value := 'Certificate of origin'; //Link
          oSheet.Cells[ nLinha, 23 ].value := 'Notes';
        end;

        vTotalEventos := ContaOcorrencias(pEvento, ';') +1;

        for I := 1 to vTotalEventos do
        begin
          str_CD_EVENTO := Trim(ExtractWord(I, pEvento, ';'));
          if str_CD_EVENTO <> '' then
          begin
            vQryEventos.SQL.Clear;
            vQryEventos.SQL.Add('SELECT');
            if vIdioma = '1' then
              vQryEventos.SQL.Add('NM_INGLES')
            else if vIdioma = '2' then
              vQryEventos.SQL.Add('NM_ESPANHOL')
            else
              vQryEventos.SQL.Add('NM_EVENTO');
            vQryEventos.SQL.Add('FROM TEVENTO (NOLOCK)');
            vQryEventos.SQL.Add('WHERE CD_EVENTO = "' + str_CD_EVENTO + '"');
            vQryEventos.Prepare;
            vQryEventos.Open;

            Inc(nColuna);
            oSheet.Cells[ nLinha, nColuna ].EntireColumn.Insert;
            oSheet.Cells[ nLinha, nColuna ].Font.Bold := True;
            oSheet.Cells[ nLinha, nColuna ].value     := vQryEventos.Fields[0].AsString;
          end;
        end;

        { Busca os Processos Năo Faturados }
        with qry_mail_proc_nao_fat do
        begin
          SQL.Clear;
          SQL.Add('SELECT PR.NR_PROCESSO, EE.NM_EMPRESA DOCS_ENVIADO_PARA,');
          SQL.Add('AR.NM_AREA AS AREA,');
          SQL.Add('EN.NM_EMPRESA AS CLIENTE,');
          SQL.Add('LE.DESCRICAO AS LOCAL_EMBARQUE,');
          SQL.Add('ES.NM_EMPRESA AS IMPORTADOR,');
          if vIdioma = '2' then
          begin
            SQL.Add('       (SELECT CASE ISNULL(NM_PAIS_ESP, "")');
            SQL.Add('                   WHEN "" THEN NM_PAIS_ESP');
            SQL.Add('               ELSE NM_PAIS_ING');
            SQL.Add('               END');
            SQL.Add('        FROM TPAIS_BROKER (NOLOCK)');
            SQL.Add('        WHERE CD_PAIS = PR.CD_PAIS_DESTINO) NM_PAIS_DESTINO,');
          end
          else
          begin
            SQL.Add('       (SELECT CASE ISNULL(NM_PAIS_ING, "")');
            SQL.Add('                   WHEN "" THEN NM_PAIS');
            SQL.Add('               ELSE NM_PAIS_ING');
            SQL.Add('               END');
            SQL.Add('        FROM TPAIS_BROKER (NOLOCK)');
            SQL.Add('        WHERE CD_PAIS = PR.CD_PAIS_DESTINO) NM_PAIS_DESTINO,');
          end;
          SQL.Add('       (SELECT DESCRICAO');
          SQL.Add('        FROM TLOCAL_EMBARQUE (NOLOCK)');
          SQL.Add('        WHERE CODIGO=PR.CD_LOCAL_DESEMBARQUE ) NM_PORTO_DESTINO,');
          SQL.Add('       (SELECT MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + " / ")');
          SQL.Add('        FROM TREF_CLIENTE R (NOLOCK)');
          SQL.Add('        WHERE R.NR_PROCESSO=PR.NR_PROCESSO');
          SQL.Add('          AND R.TP_REFERENCIA = CASE WHEN SUBSTRING(R.NR_PROCESSO, 3, 2) <> "02" THEN "01"');
          SQL.Add('                                ELSE (SELECT ISNULL(G.TP_PEDIDO_BUSCA, "01")');
          SQL.Add('                                      FROM TGRUPO G (NOLOCK)');
          SQL.Add('                                      WHERE G.CD_GRUPO = (SELECT E.CD_GRUPO');
          SQL.Add('                                                          FROM TEMPRESA_NAC E (NOLOCK)');
          SQL.Add('                                                          WHERE E.CD_EMPRESA = R.CD_EMPRESA))');
          SQL.Add('                                END) CD_REFERENCIA,');
          SQL.Add('       (SELECT MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + " / ")');
          SQL.Add('        FROM TREF_CLIENTE R (NOLOCK)');
          SQL.Add('        WHERE R.NR_PROCESSO = PR.NR_PROCESSO AND R.TP_REFERENCIA = "01" ) CUSTOMER_PO,');

          SQL.Add('       (SELECT MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + " / ")');
          SQL.Add('        FROM TREF_CLIENTE R (NOLOCK)');
          SQL.Add('        WHERE R.NR_PROCESSO = PR.NR_PROCESSO AND R.TP_REFERENCIA = "02" ) ORDEM,');

          SQL.Add('       ISNULL(F2.TX_OBS, "-") TX_OBS,');
          SQL.Add('       ISNULL(E.NM_EMBARCACAO,"") NM_EMBARCACAO,');
          SQL.Add('       ISNULL(PR.NR_CONHECIMENTO, "") NR_CONHECIMENTO, ');
          SQL.Add('       CASE SUBSTRING(PR.NR_PROCESSO, 5, 2)');
          SQL.Add('           WHEN "ER" THEN ISNULL(TR.AP_TRANSP_ROD, "")');
          SQL.Add('       ELSE ISNULL(A.NM_AGENTE_REDUZIDO,A.NM_AGENTE)');
          SQL.Add('       END NM_AGENTE, PR.TX_MERCADORIA,'); // Incluído o campo "PR.TX_MERCADORIA" em 16/05/2013 - Michel

          {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 07 (BACH MARK) }
          SQL.Add('       (SELECT TOP 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod=" + MASTER.DBO.FN_CRIPROGRAFA("docs_novo/" + D.NR_PROCESSO + "/" + D.NM_ARQUIVO) ');
          SQL.Add('        FROM TPROCESSO_DOCTOS D (NOLOCK)');
          SQL.Add('        WHERE D.CD_TIPO_DOCTO IN (89, 20) AND D.ID_TABELA = 1652005462 AND D.NR_PROCESSO = PR.NR_PROCESSO AND D.IN_ATIVO = "1" AND UPPER(RIGHT(RTRIM(D.NM_ARQUIVO), 3)) = "PDF"');
          SQL.Add('        ORDER BY CASE D.CD_TIPO_DOCTO WHEN 89 THEN 0 ELSE 1 END, D.DT_CRIACAO DESC) doc_digital_BML,');

          {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 08 (INVOICE) }
          SQL.Add('       (SELECT TOP 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod=" + MASTER.DBO.FN_CRIPROGRAFA("docs_novo/" + D.NR_PROCESSO + "/" + D.NM_ARQUIVO)');
          SQL.Add('        FROM TPROCESSO_DOCTOS D (NOLOCK)');
          SQL.Add('        WHERE D.CD_TIPO_DOCTO = 19 AND D.ID_TABELA = 1652005462 AND D.NR_PROCESSO = PR.NR_PROCESSO AND D.IN_ATIVO = "1" AND UPPER(RIGHT(RTRIM(D.NM_ARQUIVO), 3)) = "PDF") doc_digital_invoice,');

          {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 09 (B/L) }
          SQL.Add('       (SELECT TOP 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod=" + MASTER.DBO.FN_CRIPROGRAFA("docs_novo/" + D.NR_PROCESSO + "/" + D.NM_ARQUIVO)');
          SQL.Add('        FROM TPROCESSO_DOCTOS D (NOLOCK)');
          SQL.Add('        WHERE D.CD_TIPO_DOCTO = 70 AND D.ID_TABELA = 1652005462 AND D.NR_PROCESSO = PR.NR_PROCESSO AND D.IN_ATIVO = "1" AND UPPER(RIGHT(RTRIM(D.NM_ARQUIVO), 3)) = "PDF") DOC_DIGITAL_BL,');

          {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha =  (CERTIFICADO ANALISE) }
          SQL.Add('       (SELECT TOP 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod=" + MASTER.DBO.FN_CRIPROGRAFA("docs_novo/" + D.NR_PROCESSO + "/" + D.NM_ARQUIVO)');
          SQL.Add('       FROM TPROCESSO_DOCTOS D (NOLOCK)');
          SQL.Add('       WHERE D.CD_TIPO_DOCTO = 19 AND D.ID_TABELA = 1652005462 AND D.NR_PROCESSO = PR.NR_PROCESSO AND D.IN_ATIVO = "1" AND UPPER(RIGHT(RTRIM(D.NM_ARQUIVO), 3)) = "PDF") DOC_CERTIFICADO_ANALISE,');


          {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha =  (CERTIFICADO ORIGEM) }
          SQL.Add('       (SELECT TOP 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod=" + MASTER.DBO.FN_CRIPROGRAFA("docs_novo/" + D.NR_PROCESSO + "/" + D.NM_ARQUIVO)');
          SQL.Add('       FROM TPROCESSO_DOCTOS D (NOLOCK)');
          SQL.Add('       WHERE D.CD_TIPO_DOCTO = 5 AND D.ID_TABELA = 1652005462 AND D.NR_PROCESSO = PR.NR_PROCESSO AND D.IN_ATIVO = "1" AND UPPER(RIGHT(RTRIM(D.NM_ARQUIVO), 3)) = "PDF") DOC_CERTIFICADO_ORIGEM');


//          {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 10 (DOCs) }
//          SQL.Add('       (SELECT TOP 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod=" + MASTER.DBO.FN_CRIPROGRAFA("docs_novo/" + D.NR_PROCESSO + "/" + D.NM_ARQUIVO)');
//          SQL.Add('        FROM TPROCESSO_DOCTOS D (NOLOCK)');
//          SQL.Add('        WHERE D.CD_TIPO_DOCTO = 22 AND D.ID_TABELA = 1652005462 AND D.NR_PROCESSO = PR.NR_PROCESSO AND D.IN_ATIVO = "1" AND UPPER(RIGHT(RTRIM(D.NM_ARQUIVO), 3)) = "PDF") doc_digital_docs');
          SQL.Add('FROM TPROCESSO             PR (NOLOCK)');
          SQL.Add(' --INNER JOIN TFOLLOWUP    F  (NOLOCK) ON (PR.NR_PROCESSO = F.NR_PROCESSO)');
          SQL.Add('   INNER JOIN TFOLLOWUP    F1 (NOLOCK) ON (PR.NR_PROCESSO = F1.NR_PROCESSO AND F1.CD_EVENTO = "314" AND F1.DT_REALIZACAO IS NOT NULL)');
          SQL.Add('   LEFT  JOIN TFOLLOWUP    F2 (NOLOCK) ON (PR.NR_PROCESSO = F2.NR_PROCESSO AND F2.CD_EVENTO = "653")'); //OBS que passou para NOTE
          SQL.Add('   INNER JOIN TFOLLOWUP    F3 (NOLOCK) ON (PR.NR_PROCESSO = F3.NR_PROCESSO AND F3.CD_EVENTO = "261")');
          SQL.Add('   LEFT JOIN TFOLLOWUP     F4 (NOLOCK) ON (PR.NR_PROCESSO = F4.NR_PROCESSO AND F4.CD_EVENTO = "333")');
          SQL.Add('   LEFT  JOIN TEMBARCACAO  E  (NOLOCK) ON PR.CD_EMBARCACAO = E.CD_EMBARCACAO ');
          SQL.Add('   LEFT  JOIN TAGENTE      A  (NOLOCK) ON A.CD_AGENTE = PR.CD_AGENTE ');
          SQL.Add('   LEFT  JOIN TEMPRESA_EST EE (NOLOCK) ON EE.CD_EMPRESA = PR.DOCS_ENVIADO_PARA ');
          SQL.Add('   LEFT  JOIN TTRANSP_ROD  TR (NOLOCK) ON  PR.CD_TRANSP_NAC = TR.CD_TRANSP_ROD  ');
          SQL.Add('   LEFT  JOIN TAREA        AR (NOLOCK) ON AR.CD_AREA = PR.CD_AREA  ');
          SQL.Add('   LEFT  JOIN TEMPRESA_NAC EN (NOLOCK) ON EN.CD_EMPRESA = PR.CD_CLIENTE  ');
          SQL.Add('   LEFT  JOIN TEMPRESA_EST ES (NOLOCK) ON ES.CD_EMPRESA = PR.CD_IMPORTADOR  ');
          SQL.Add('   LEFT  JOIN TLOCAL_EMBARQUE LE (NOLOCK) ON LE.CODIGO = PR.CD_LOCAL_EMBARQUE  ');
          SQL.Add('WHERE /*(F.CD_EVENTO = "092" AND F.IN_APLICAVEL = 1 AND (F.DT_REALIZACAO IS NULL OR CONVERT(DATE, F.DT_REALIZACAO, 103) >= CONVERT(DATE, GETDATE() -45, 103)))');
          SQL.Add('  AND */(F3.DT_REALIZACAO IS NULL OR CONVERT(DATE, F3.DT_REALIZACAO, 103) >= CONVERT(DATE, GETDATE() -5, 103))');
          SQL.Add('  AND F3.IN_APLICAVEL = "1"');
          SQL.Add('  AND PR.IN_CANCELADO = "0"');
          SQL.Add('  AND PR.IN_LIBERADO = "1"');
          SQL.Add('  AND YEAR(PR.DT_ABERTURA) >= 2013');
          SQL.Add('  AND ISNULL(E.NM_EMBARCACAO, "") NOT IN ("* PROCESSO CANCELADO", "TBN", "AGUARDANDO NAVIO" )');
          if pProduto <> '' then
            SQL.Add('  AND PR.CD_PRODUTO = "' + pProduto + '"');
          if pUnidade <> '' then
            SQL.Add('  AND PR.CD_UNID_NEG = "' + pUnidade + '"');
          if pGrupo <> '' then
            SQL.Add('  AND PR.CD_GRUPO = "' + pGrupo   + '"');
          if pImportador <> '' then
            SQL.Add('  AND PR.CD_IMPORTADOR = "' + pImportador  + '"');
          if pCliente <> '' then
            SQL.Add('  AND PR.CD_CLIENTE = "' + pCliente  + '"');
          if pTransportador <> '' then
            SQL.Add('  AND PR.CD_TRANSP_NAC = "' + pTransportador  + '"');
          SQL.Add('ORDER BY F4.DT_REALIZACAO, 2');

          if not DirectoryExists(GetPath+'SQL') then
           ForceDirectories(GetPath+'SQL');
         try
           SQL.SaveToFile(GetPath+'SQL\' + pRelatorio + '.sql');
         except
         end;

          Open;
        end;


        //--------------------------------------------------------------------------//
        // Preenche as celulas  de acordo com os eventos enviados
        //
        //--------------------------------------------------------------------------//
        tem_dados    := False;
        TemBooking   := False;
        TemContainer := False;
        QtdCourier   := 1;

        qry_mail_proc_nao_fat.First;
        while not qry_mail_proc_nao_fat.Eof do
        begin
          tem_dados := True;
          nColuna   := vUlt_Col_Fixa;
          nLinha    := nLinha+1;

          strTmp := qry_mail_proc_nao_fat.FieldByName('CD_REFERENCIA').AsString;
          strTmp := Copy(strTmp, 1, Length(strTmp) -2);
          oSheet.Cells[ nLinha, 02 ].value := strTmp;

          strTmp := qry_mail_proc_nao_fat.FieldByName('ORDEM').AsString;
          strTmp := Copy(strTmp, 1, Length(strTmp) -2);
          oSheet.Cells[ nLinha, 03 ].value := strTmp;

          strTmp := qry_mail_proc_nao_fat.FieldByName('CUSTOMER_PO').AsString;
          strTmp := Copy(strTmp, 1, Length(strTmp) -2);
          oSheet.Cells[ nLinha, 04 ].value := strTmp;


          oSheet.Cells[ nLinha, 05 ].value := Trim(qry_mail_proc_nao_fat.FieldByName('NR_PROCESSO').AsString);
          oSheet.Cells[ nLinha, 06 ].value := Trim(qry_mail_proc_nao_fat.FieldByName('AREA').AsString);
          oSheet.Cells[ nLinha, 07 ].value := Trim(qry_mail_proc_nao_fat.FieldByName('CLIENTE').AsString);
          oSheet.Cells[ nLinha, 08 ].value := Trim(qry_mail_proc_nao_fat.FieldByName('LOCAL_EMBARQUE').AsString);
          oSheet.Cells[ nLinha, 09 ].value := Trim(qry_mail_proc_nao_fat.FieldByName('IMPORTADOR').AsString);

          oSheet.Cells[ nLinha, 10 ].value := Trim(qry_mail_proc_nao_fat.FieldByName('TX_MERCADORIA').AsString);

          oSheet.Cells[ nLinha, 11 ].value := qry_mail_proc_nao_fat.FieldByName('NM_PAIS_DESTINO').AsString;
          oSheet.Cells[ nLinha, 12 ].value := qry_mail_proc_nao_fat.FieldByName('NM_PORTO_DESTINO').AsString;
          oSheet.Cells[ nLinha, 13 ].value := qry_mail_proc_nao_fat.FieldByName('NM_EMBARCACAO').AsString;
          oSheet.Cells[ nLinha, 14 ].value := qry_mail_proc_nao_fat.FieldByName('NM_AGENTE').AsString;

          if qryAuxiliar.Active then
            qryAuxiliar.Close;
          qryAuxiliar.SQL.Clear;
          qryAuxiliar.SQL.Add('SELECT RC.CD_REFERENCIA');
          qryAuxiliar.SQL.Add('FROM TREF_CLIENTE RC (NOLOCK)');
          qryAuxiliar.SQL.Add('WHERE RC.NR_PROCESSO = :NR_PROCESSO');
          qryAuxiliar.SQL.Add('  AND RC.TP_REFERENCIA = "05"');
          qryAuxiliar.SQL.Add('ORDER BY RC.DT_REFERENCIA');
          qryAuxiliar.ParamByName('NR_PROCESSO').AsString := qry_mail_proc_nao_fat.FieldByName('NR_PROCESSO').AsString;
          qryAuxiliar.Open;
          strTmp := '';
          qryAuxiliar.First;
          while not qryAuxiliar.Eof do
          begin
            strTmp := strTmp + ', ' + Trim(qryAuxiliar.FieldByName('CD_REFERENCIA').AsString);
            qryAuxiliar.Next;
          end;
          Delete(strTmp, 1, 2);
          oSheet.Cells[ nLinha, 15 ].value := strTmp;

          if (strTmp <> '') and (not TemBooking) then
            TemBooking := True;

          oSheet.Cells[ nLinha, 16 ].value := qry_mail_proc_nao_fat.FieldByName('NR_CONHECIMENTO').AsString;

          qryAuxiliar.Close;
          qryAuxiliar.SQL.Clear;
          qryAuxiliar.SQL.Add('SELECT NR_CNTR');
          qryAuxiliar.SQL.Add('FROM TPROCESSO_CNTR PC (NOLOCK)');
          qryAuxiliar.SQL.Add('WHERE PC.NR_PROCESSO = :NR_PROCESSO');
          qryAuxiliar.ParamByName('NR_PROCESSO').AsString := qry_mail_proc_nao_fat.FieldByName('NR_PROCESSO').AsString;
          qryAuxiliar.Open;
          strTmp := '';
          qryAuxiliar.First;
          while not qryAuxiliar.Eof do
          begin
            strTmp := strTmp + #10 + Trim(qryAuxiliar.FieldByName('NR_CNTR').AsString);
            qryAuxiliar.Next;
          end;
          Delete(strTmp, 1, 1);
          oSheet.Cells[ nLinha, 17 ].value := strTmp;

          if (strTmp <> '') and  (not TemContainer) then
            TemContainer := True;


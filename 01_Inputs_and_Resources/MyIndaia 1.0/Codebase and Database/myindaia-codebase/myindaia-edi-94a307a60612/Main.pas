              SQL.Add('   INNER JOIN TFOLLOWUP                 F092 (NOLOCK) ON PR.NR_PROCESSO = F092.NR_PROCESSO AND F092.CD_EVENTO = "092"  ');
              SQL.Add('   INNER JOIN TFOLLOWUP                 F022 (NOLOCK) ON PR.NR_PROCESSO = F022.NR_PROCESSO AND F022.CD_EVENTO = "022"  ');

    //          SQL.Add('   INNER JOIN TFOLLOWUP                 F114 (NOLOCK) ON PR.NR_PROCESSO = F114.NR_PROCESSO AND F114.CD_EVENTO = "11  4"');

              SQL.Add('   LEFT  JOIN TFOLLOWUP                 F653 (NOLOCK) ON F653.NR_PROCESSO = PR.NR_PROCESSO AND F653.CD_EVENTO = "653"  ');
              SQL.Add('WHERE F092.IN_APLICAVEL = 1                                                                                            ');

    //          SQL.Add('  AND F114.IN_APLICAVEL = 1');
    //          SQL.Add('  AND ((F092.DT_REALIZACAO IS NULL OR F114.DT_REALIZACAO IS NULL)');
    //          SQL.Add('    OR CASE WHEN CONVERT(DATETIME, F092.DT_REALIZACAO, 103) > CONVERT(DATETIME, F114.DT_REALIZACAO, 103) THEN CONVERT(DATETIME, F092.DT_REALIZACAO, 103)');
    //          SQL.Add('       ELSE CONVERT(DATETIME, F114.DT_REALIZACAO, 103)');
    //          SQL.Add('       END >= CONVERT(DATETIME, GETDATE() -2, 103))');


              SQL.Add('  AND ((F092.DT_REALIZACAO IS NULL)                                                                                    ');
              SQL.Add('  OR CONVERT(DATETIME, F092.DT_REALIZACAO, 103)                                                                        ');
              SQL.Add('  >= CONVERT(DATETIME, GETDATE() -2, 103))                                                                             ');
              SQL.Add('  AND SV.CD_VIA_TRANSPORTE <> "10"                                                                                     ');

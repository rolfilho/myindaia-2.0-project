           if qry_mail_proc_nao_fat.FieldByName('Conhecimento_Embarque').AsString<>'' then begin
              Excel.ActiveSheet.Hyperlinks.Add( Anchor:=oSheet.Cells[ nLinha, nColuna ], Address:=qry_mail_proc_nao_fat.FieldByName('Conhecimento_Embarque').AsString);

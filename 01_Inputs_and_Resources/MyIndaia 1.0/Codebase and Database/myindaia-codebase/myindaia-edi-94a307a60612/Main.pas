function DETERMINA_ALIQUOTA_II : String;
begin
  frmMain.qry_sel_acordo.Close;
  frmMain.qry_sel_acordo.ParamByName('NR_PROCESSO').AsString := TAB.Fieldbyname('NR_PROCESSO').AsString;
  frmMain.qry_sel_acordo.ParamByName('NR_ADICAO').AsString := TAB.Fieldbyname('NR_ADICAO').AsString;
  frmMain.qry_sel_acordo.Open;

  frmMain.qry_adicao_.close;
  frmMain.qry_adicao_.ParamByName('NR_PROCESSO').AsString := TAB.Fieldbyname('NR_PROCESSO').AsString;
  frmMain.qry_adicao_.ParamByName('NR_ADICAO').AsString := TAB.Fieldbyname('NR_ADICAO').AsString;
  frmMain.qry_adicao_.Open;

  {Tipo Integral e Tarifa Acordo diferente de Zero}
  if (frmMain.qry_adicao_CD_REGIME_TRIBUTAR.AsString = '1') then
  begin
    if (frmMain.qry_adicao_CD_ACORDO_ALADI.AsString <> '') AND (frmMain.qry_adicao_CD_ACORDO_ALADI.AsString <> null ) then
    begin
      Result := frmMain.FORMATAR_VALOR(frmMain.qry_sel_acordoPC_ALIQ_ACOR_TARIF.AsFloat, 2);
      exit;
    end
    else
    begin
      Result := frmMain.FORMATAR_VALOR(frmMain.qry_sel_acordoPC_ALIQ_NORM_ADVAL.AsFloat, 2);
      exit;
    end;
  end
  else
  if frmMain.qry_adicao_CD_REGIME_TRIBUTAR.AsString = '4' then //Reduçăo
  begin
    Result := frmMain.FORMATAR_VALOR(frmMain.qry_sel_acordoPC_ALIQ_REDUZIDA.AsFloat,2);
    Exit;
  end
  else
    Result := '0';
end;


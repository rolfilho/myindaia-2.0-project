                   2:lstTemp.Text:=StringReplace(lstTemp.Text, QuotedStr('123imagem2321')  ,'&nbsp;&nbsp;<img src="http://www.myindaiaweb.com.br/imagens/icones/16x16/open/open2.gif"  style="border-width:0px" alt="Visualizar o documento">',[rfReplaceAll]);
                   3:lstTemp.Text:=StringReplace(lstTemp.Text, QuotedStr('123imagem3321')  ,'&nbsp;&nbsp;<img src="http://www.myindaiaweb.com.br/imagens/icones/16x16/open/open3.gif"  style="border-width:0px" alt="Visualizar o documento">',[rfReplaceAll]);
                   4:lstTemp.Text:=StringReplace(lstTemp.Text, QuotedStr('123imagem4321')  ,'&nbsp;&nbsp;<img src="http://www.myindaiaweb.com.br/imagens/icones/16x16/open/open4.gif"  style="border-width:0px" alt="Visualizar o documento">',[rfReplaceAll]);
                   5:lstTemp.Text:=StringReplace(lstTemp.Text, QuotedStr('123imagem5321')  ,'&nbsp;&nbsp;<img src="http://www.myindaiaweb.com.br/imagens/icones/16x16/open/open5.gif"  style="border-width:0px" alt="Visualizar o documento">',[rfReplaceAll]);
                   6:lstTemp.Text:=StringReplace(lstTemp.Text, QuotedStr('123imagem6321')  ,'&nbsp;&nbsp;<img src="http://www.myindaiaweb.com.br/imagens/icones/16x16/open/open6.gif"  style="border-width:0px" alt="Visualizar o documento">',[rfReplaceAll]);
                   7:lstTemp.Text:=StringReplace(lstTemp.Text, QuotedStr('123imagem7321')  ,'&nbsp;&nbsp;<img src="http://www.myindaiaweb.com.br/imagens/icones/16x16/open/open7.gif"  style="border-width:0px" alt="Visualizar o documento">',[rfReplaceAll]);
                   8:lstTemp.Text:=StringReplace(lstTemp.Text, QuotedStr('123imagem8321')  ,'&nbsp;&nbsp;<img src="http://www.myindaiaweb.com.br/imagens/icones/16x16/open/open8.gif"  style="border-width:0px" alt="Visualizar o documento">',[rfReplaceAll]);

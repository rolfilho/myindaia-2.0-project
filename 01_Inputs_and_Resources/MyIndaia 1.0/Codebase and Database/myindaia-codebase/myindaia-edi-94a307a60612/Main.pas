{*******************************************************************************
Funcao utlitaria que retira os caracteres especiais (tab, enter e outros) de um
texto TXT.
*******************************************************************************}
function TfrmMain.Remove_Carater_Especial(Texto:String):String;
var
   x,Posicao:Integer;
   NovoTexto : String;
begin
  NovoTexto:='';
  if Texto <> '' then
  begin
    for x:=0 to Length(Texto) do begin
       if Texto[x] = Char(13) then
       begin
         NovoTexto:=NovoTexto+' ';
       end
       else
       if Texto[x] > Char(31) then  NovoTexto:=NovoTexto+Texto[x];
    end;
  end;
  Result := NovoTexto;
end;

{*******************************************************************************
Funcao do arquivo 1 de retorno de DI da Volks. Essa funcao controla o tipo de
transacao do registro enviado para a Volks. Os tipos sao: R (registro de DI) -
quando for feito pela primeira vez, T (retificacao antes do desembaraco) -
quando ja e R e nao tiver dt_desembaraco e tiver dt_retificacao, D (desembaraco)
 - quando ja e R ou T e tiver dt_desembaraco e numero de registro e P (retificacao
 depois do desembaraco) - quando ja e R ou D e a dt_retificacao for > dt_desembaraco.
*******************************************************************************}
function CONTROLE_TIPO_TRANSACAO : String;
Var
  Aux_Tipo,
  Aux_Nr_Registro    : String;
  Aux_Dt_Retificacao : TDateTime;
begin
  Aux_Tipo           := TAB.Fieldbyname(campo).AsString;
  Aux_Dt_Retificacao := TAB.Fieldbyname('DT_RETIFICACAO').AsDateTime;
  Aux_Nr_Registro    := TAB.Fieldbyname('NR_DECLARACAO_IMP').AsString;
  Result := Aux_Tipo;
  if ((Aux_Tipo = Null) or (aux_Tipo = '')) then
    Result := 'R'
  else
  if (Aux_Tipo = 'R') then
  begin
    if ((DT_DESEMBARACO = 0) or (DT_DESEMBARACO = 31/12/1899) or (DT_DESEMBARACO = Null)) then
    begin
      if ((Aux_Dt_Retificacao <> Null) or (Aux_Dt_Retificacao <> 31/12/1899) or (Aux_Dt_Retificacao <> 0)) then
        Result := 'T';
    end
    else
    begin
      if (Aux_Nr_Registro <> '') then
      begin
        if (Aux_Dt_Retificacao > DT_DESEMBARACO) then
          Result := 'P'
        else
          Result := 'D';
      end;
    end;
  end
  else
  if (Aux_Tipo = 'T') then
  begin
    if ((DT_DESEMBARACO <> 0) or (DT_DESEMBARACO <> 31/12/1899) or (DT_DESEMBARACO <> Null)) then
    begin
      if (Aux_Nr_Registro <> '') then
          Result := 'D';
    end;
  end
  else
  if (Aux_Tipo = 'D') then
  begin
    if (Aux_Dt_Retificacao > DT_DESEMBARACO) then
      Result := 'P';
  end;
  frmMain.Atualiza_Tipo_Transacao(Result);
end;


function TfrmMain.GetSqlRelEventosDailyFupMinalba(pUnidade, pProduto, pGrupo,
  pCliente: string): String;
begin
  result :=
    ' SELECT RTRIM(EN.NM_EMPRESA)                                                      AS [CLIENTE], ' + sLineBreak +
    '       RTRIM(PR.NR_PROCESSO)                                                      AS [PROCESSO], ' + sLineBreak +
    '       (SELECT TOP 1 LTRIM(RTRIM(R.CD_REFERENCIA)) ' + sLineBreak +
    '          FROM TREF_CLIENTE R WITH (NOLOCK) ' + sLineBreak +
    '         WHERE R.NR_PROCESSO   = PR.NR_PROCESSO ' + sLineBreak +
    '           AND R.TP_REFERENCIA = CASE WHEN SUBSTRING(R.NR_PROCESSO, 3, 2) = ''01'' ' + sLineBreak +
    '                                      THEN GR.TP_PEDIDO_BUSCA_IMP ' + sLineBreak +
    '                                      ELSE GR.TP_PEDIDO_BUSCA ' + sLineBreak +
    '                                 END ' + sLineBreak +
    '       ORDER BY DT_REFERENCIA DESC)                                               AS [PEDIDO], ' + sLineBreak +
    '       RTRIM(VT.NM_VIA_TRANSP)                                                    AS [VIA_TRANSPORTE], ' + sLineBreak +
    ' RTRIM(PB.NM_PAIS)    			                                                       AS [PAIS_ORIGEM], ' + sLineBreak +
    ' RTRIM(EF.NM_EMPRESA) 			                                                       AS [EXPORTADOR], ' + sLineBreak +
    ' RTRIM(CONVERT(VARCHAR(MAX), PR.TX_MERCADORIA))                                   AS [MERCADORIA], ' + sLineBreak +
    ' RTRIM(PR.NR_CONHECIMENTO)                                                        AS [NR_CONHECIMENTO], ' + sLineBreak +
    ' RTRIM(PR.NR_DI)                                                                  AS [NR_DI], ' + sLineBreak +
    ' DM.QT_COMERCIALIZADA                                                             AS [QUANTIDADE], ' + sLineBreak +
    ' DI.PL_CARGA                                                                      AS [PESO_LIQ], ' + sLineBreak +
    ' ISNULL(PR.CD_CANAL, 4)                                                           AS CD_CANAL, ' + sLineBreak +
    ' ISNULL(RTRIM(TC.NM_CANAL), ''AGUARDANDO'')                                         AS [CANAL], ' + sLineBreak +
    ' RTRIM(EB.NM_EMBARCACAO)                                                          AS [NAVIO], ' + sLineBreak +
    ' F022.TX_OBS 							                                          AS [OBSERVACOES], ' + sLineBreak +
    ' (SELECT TOP 1 ''HTTP://WWW.MYINDAIAWEB.COM.BR/REDIRECIONA_DOC.ASP?COD='' ' + sLineBreak +
    '             + MASTER.DBO.FN_CRIPROGRAFA(''DOCS_NOVO/'' + NR_PROCESSO + ''/'' ' + sLineBreak +
    '             + RTRIM(NM_ARQUIVO)) ' + sLineBreak +
    '    FROM TPROCESSO_DOCTOS WITH (NOLOCK) ' + sLineBreak +
    '    WHERE NR_PROCESSO   = PR.NR_PROCESSO ' + sLineBreak +
    '    AND CD_TIPO_DOCTO = 14 ' + sLineBreak +
    '    AND ID_TABELA     = 1652005462 ' + sLineBreak +
    '    AND IN_ATIVO      = 1 ' + sLineBreak +
    '    ORDER BY DT_CRIACAO DESC)                                                       AS [DOCUMENTOS_IMPORTACAO], ' + sLineBreak +
    ' (SELECT TOP 1 ''HTTP://WWW.MYINDAIAWEB.COM.BR/REDIRECIONA_DOC.ASP?COD='' + ' + sLineBreak +
    '                MASTER.DBO.FN_CRIPROGRAFA(''DOCS_NOVO/'' + NR_PROCESSO + ''/'' ' + sLineBreak +
    '                + RTRIM(NM_ARQUIVO)) ' + sLineBreak +
    '    FROM TPROCESSO_DOCTOS WITH (NOLOCK) ' + sLineBreak +
    '    WHERE NR_PROCESSO   = PR.NR_PROCESSO ' + sLineBreak +
    '    AND CD_TIPO_DOCTO = 9 ' + sLineBreak +
    '    AND ID_TABELA     = 1652005462 ' + sLineBreak +
    '    AND IN_ATIVO      = 1 ' + sLineBreak +
    '    ORDER BY DT_CRIACAO DESC)                                                       AS [EXTRATO_DI], ' + sLineBreak +
    ' (SELECT TOP 1 ''HTTP://WWW.MYINDAIAWEB.COM.BR/REDIRECIONA_DOC.ASP?COD='' ' + sLineBreak +
    '              + MASTER.DBO.FN_CRIPROGRAFA(''DOCS_NOVO/'' + NR_PROCESSO + ''/'' ' + sLineBreak +
    '              + RTRIM(NM_ARQUIVO)) ' + sLineBreak +
    '    FROM TPROCESSO_DOCTOS WITH (NOLOCK) ' + sLineBreak +
    '    WHERE NR_PROCESSO   = PR.NR_PROCESSO ' + sLineBreak +
    '    AND CD_TIPO_DOCTO = 10 ' + sLineBreak +
    '    AND ID_TABELA     = 1652005462 ' + sLineBreak +
    '    AND IN_ATIVO      = 1 ' + sLineBreak +
    '    ORDER BY DT_CRIACAO DESC)                                                       AS [EXTRATO_CI], ' + sLineBreak +
    ' (SELECT TOP 1 ''HTTP://WWW.MYINDAIAWEB.COM.BR/REDIRECIONA_DOC.ASP?COD='' ' + sLineBreak +
    '              + MASTER.DBO.FN_CRIPROGRAFA(''DOCS_NOVO/'' + NR_PROCESSO + ''/'' ' + sLineBreak +
    '              + RTRIM(NM_ARQUIVO)) ' + sLineBreak +
    '    FROM TPROCESSO_DOCTOS WITH (NOLOCK) ' + sLineBreak +
    '    WHERE NR_PROCESSO   = PR.NR_PROCESSO ' + sLineBreak +
    '    AND CD_TIPO_DOCTO = 80 ' + sLineBreak +
    '    AND ID_TABELA     = 1652005462 ' + sLineBreak +
    '    AND IN_ATIVO      = 1 ' + sLineBreak +
    '    ORDER BY DT_CRIACAO DESC)                                                       AS [DANFE], ' + sLineBreak +
    ' CAST(F798.DT_REALIZACAO AS DATE) AS F798_NECESSIDADE_FABRICA, ' + sLineBreak +
    ' CAST(F233.DT_REALIZACAO AS DATE) AS F233_DELIVERY_DATE_REVISADA, ' + sLineBreak +
    ' CAST(F486.DT_REALIZACAO AS DATE) AS F486_EMBARQUE_SOLICITADO_P, ' + sLineBreak +
    ' CAST(F506.DT_REALIZACAO AS DATE) AS F506_PREVISAO_PROTIDAO_CARGA, ' + sLineBreak +
    ' CAST(F131.DT_REALIZACAO AS DATE) AS F131_PREVISAO_EMBARQUE, ' + sLineBreak +
    ' CAST(F551.DT_REALIZACAO AS DATE) AS F551_DATA_EMBARQUE, ' + sLineBreak +
    ' CAST(F082.DT_REALIZACAO AS DATE) AS F082_DOCUMENTOS_COMPLETOS_P_ANALISE, ' + sLineBreak +
    ' CAST(F416.DT_REALIZACAO AS DATE) AS F416_ANALISE_DOCUMENTAL, ' + sLineBreak +
    ' CAST(F215.DT_REALIZACAO AS DATE) AS F215_RECEPCAO_BL_ORIGINAL, ' + sLineBreak +
    ' CAST(F045.DT_REALIZACAO AS DATE) AS F045_RECEPCAO_DOC_ORIGINAIS, ' + sLineBreak +
    ' CAST(F161.DT_REALIZACAO AS DATE) AS F161_PREVISAO_CHEGADA_NAC, ' + sLineBreak +
    ' CAST(F162.DT_REALIZACAO AS DATE) AS F162_CHEGADA_NAC, ' + sLineBreak +
    ' CAST(F012.DT_REALIZACAO AS DATE) AS F012_PRESENCAO_CARGA, ' + sLineBreak +
    ' CAST(F195.DT_REALIZACAO AS DATE) AS F195_CHEGADA_EADI, ' + sLineBreak +
    ' CAST(F018.DT_REALIZACAO AS DATE) AS F018_SOLICITACAO_NUMERARIO_DESPESAS, ' + sLineBreak +
    ' CAST(F076.DT_REALIZACAO AS DATE) AS F076_RECEBIMENTO_NUMERARIO_DESPESAS, ' + sLineBreak +
    ' CAST(F379.DT_REALIZACAO AS DATE) AS F379_REGISTRO_LI, ' + sLineBreak +
    ' CAST(F052.DT_REALIZACAO AS DATE) AS F052_PROTOCOLO_LI_ORGAO_ANUENTE, ' + sLineBreak +
    ' CAST(F397.DT_REALIZACAO AS DATE) AS F397_DEFERIMENTO_LI, ' + sLineBreak +
    ' CAST(F021.DT_REALIZACAO AS DATE) AS F021_REGISTRO_DI, ' + sLineBreak +
    ' CAST(F088.DT_REALIZACAO AS DATE) AS F088_DESEMBARACO, ' + sLineBreak +
    ' CAST(F387.DT_REALIZACAO AS DATE) AS F387_SOLICITACAO_DANFE, ' + sLineBreak +
    ' CAST(F616.DT_REALIZACAO AS DATE) AS F616_RECEBIMENTO_DANFE, ' + sLineBreak +
    ' CAST(F041.DT_REALIZACAO AS DATE) AS F041_LIBERACAO_PROC_TRANSPORTADORA, ' + sLineBreak +
    ' CAST(F838.DT_REALIZACAO AS DATE) AS F838_ENTREGA_PROGRAMADA, ' + sLineBreak +
    ' CAST(F164.DT_REALIZACAO AS DATE) AS F164_MERCADORIA_FABRICA, ' + sLineBreak +
    ' CAST(F092.DT_REALIZACAO AS DATE) AS F092_FATURAMENTO_INDAIA ' + sLineBreak +
    ' FROM TPROCESSO                         	  PR   WITH (NOLOCK) ' + sLineBreak +
    ' INNER JOIN TEMPRESA_NAC              	  EN   WITH (NOLOCK) ON EN.CD_EMPRESA    = PR.CD_CLIENTE ' + sLineBreak +
    ' INNER JOIN TGRUPO                    	  GR   WITH (NOLOCK) ON GR.CD_GRUPO      = EN.CD_GRUPO ' + sLineBreak +
    ' INNER JOIN TSERVICO_NOVO             	  SV                 ON SV.CD_SERVICO    = PR.CD_SERVICO ' + sLineBreak +
    ' INNER JOIN TVIA_TRANSP_BROKER        	  VT   WITH (NOLOCK) ON VT.CD_VIA_TRANSP = SV.CD_VIA_TRANSPORTE ' + sLineBreak +
    ' LEFT  JOIN TPAIS_BROKER              	  PB   WITH (NOLOCK) ON PB.CD_PAIS       = PR.CD_PAIS_ORIGEM ' + sLineBreak +
    ' LEFT  JOIN TDECLARACAO_IMPORTACAO    	  DI   WITH (NOLOCK) ON DI.NR_PROCESSO   = PR.NR_PROCESSO ' + sLineBreak +
    ' OUTER APPLY (SELECT DM.NR_PROCESSO, ' + sLineBreak +
    '                       LEFT(MASTER.DBO.ROWCONCAT(DISTINCT ISNULL(DM.CD_UN_MED_COMERC, '''')), 3) AS CD_UNID_MEDIDA, ' + sLineBreak +
    '                       SUM(DM.QT_MERC_UN_COMERC) AS QT_COMERCIALIZADA ' + sLineBreak +
    '                 FROM TDETALHE_MERCADORIA DM WITH (NOLOCK) ' + sLineBreak +
    '                 WHERE DM.NR_PROCESSO = PR.NR_PROCESSO ' + sLineBreak +
    '                 GROUP BY DM.NR_PROCESSO) DM ' + sLineBreak +
    ' LEFT  JOIN TEMPRESA_EST            			  EF   WITH (NOLOCK) ON EF.CD_EMPRESA    = DI.CD_FORNECEDOR ' + sLineBreak +
    ' LEFT  JOIN TTP_CANAL               			  TC   WITH (NOLOCK) ON TC.CD_CANAL      = PR.CD_CANAL ' + sLineBreak +
    ' LEFT  JOIN TEMBARCACAO             			  EB   WITH (NOLOCK) ON EB.CD_EMBARCACAO = PR.CD_EMBARCACAO ' + sLineBreak +
    ' LEFT  JOIN TFOLLOWUP               			  F    WITH (NOLOCK) ON F.NR_PROCESSO    = PR.NR_PROCESSO ' + sLineBreak +
    '                                   			                    AND F.CD_EVENTO      = CASE WHEN (SELECT COUNT(*) ' + sLineBreak +
    '                                   			              		                    	             FROM TFOLLOWUP FL WITH (NOLOCK) ' + sLineBreak +
    '                                   			              		                    	            WHERE FL.NR_PROCESSO = PR.NR_PROCESSO ' + sLineBreak +
    '                                   			              		                    	              AND FL.CD_EVENTO   = ''082'' ' + sLineBreak +
    '                                   			              		                    	              AND FL.CD_SERVICO  = PR.CD_SERVICO) > 0 ' + sLineBreak +
    '                                   			              		                    	     THEN ''082'' ' + sLineBreak +
    '                                   			              		      			    	     ELSE ''215'' ' + sLineBreak +
    '                                   			              		      					 END ' + sLineBreak +
    ' INNER JOIN TFOLLOWUP         			 F022 WITH (NOLOCK) ON PR.NR_PROCESSO = F022.NR_PROCESSO AND F022.CD_EVENTO = ''022'' AND PR.CD_SERVICO = F022.CD_SERVICO ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F798 WITH (NOLOCK) ON PR.NR_PROCESSO = F798.NR_PROCESSO  AND PR.CD_SERVICO = F798.CD_SERVICO  AND F798.CD_EVENTO = ''798'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F233 WITH (NOLOCK) ON PR.NR_PROCESSO = F233.NR_PROCESSO  AND PR.CD_SERVICO = F233.CD_SERVICO  AND F233.CD_EVENTO = ''233'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F486 WITH (NOLOCK) ON PR.NR_PROCESSO = F486.NR_PROCESSO  AND PR.CD_SERVICO = F486.CD_SERVICO  AND F486.CD_EVENTO = ''486'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F506 WITH (NOLOCK) ON PR.NR_PROCESSO = F506.NR_PROCESSO  AND PR.CD_SERVICO = F506.CD_SERVICO  AND F506.CD_EVENTO = ''506'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F131 WITH (NOLOCK) ON PR.NR_PROCESSO = F131.NR_PROCESSO  AND PR.CD_SERVICO = F131.CD_SERVICO  AND F131.CD_EVENTO = ''131'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F551 WITH (NOLOCK) ON PR.NR_PROCESSO = F551.NR_PROCESSO  AND PR.CD_SERVICO = F551.CD_SERVICO  AND F551.CD_EVENTO = ''551'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F082 WITH (NOLOCK) ON PR.NR_PROCESSO = F082.NR_PROCESSO  AND PR.CD_SERVICO = F082.CD_SERVICO  AND F082.CD_EVENTO = ''082'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F416 WITH (NOLOCK) ON PR.NR_PROCESSO = F416.NR_PROCESSO  AND PR.CD_SERVICO = F416.CD_SERVICO  AND F416.CD_EVENTO = ''416'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F215 WITH (NOLOCK) ON PR.NR_PROCESSO = F215.NR_PROCESSO  AND PR.CD_SERVICO = F215.CD_SERVICO  AND F215.CD_EVENTO = ''215'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F045 WITH (NOLOCK) ON PR.NR_PROCESSO = F045.NR_PROCESSO  AND PR.CD_SERVICO = F045.CD_SERVICO  AND F045.CD_EVENTO = ''045'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F161 WITH (NOLOCK) ON PR.NR_PROCESSO = F161.NR_PROCESSO  AND PR.CD_SERVICO = F161.CD_SERVICO  AND F161.CD_EVENTO = ''161'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F162 WITH (NOLOCK) ON PR.NR_PROCESSO = F162.NR_PROCESSO  AND PR.CD_SERVICO = F162.CD_SERVICO  AND F162.CD_EVENTO = ''162'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F012 WITH (NOLOCK) ON PR.NR_PROCESSO = F012.NR_PROCESSO  AND PR.CD_SERVICO = F012.CD_SERVICO  AND F012.CD_EVENTO = ''012'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F195 WITH (NOLOCK) ON PR.NR_PROCESSO = F195.NR_PROCESSO  AND PR.CD_SERVICO = F195.CD_SERVICO  AND F195.CD_EVENTO = ''195'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F018 WITH (NOLOCK) ON PR.NR_PROCESSO = F018.NR_PROCESSO  AND PR.CD_SERVICO = F018.CD_SERVICO  AND F018.CD_EVENTO = ''018'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F076 WITH (NOLOCK) ON PR.NR_PROCESSO = F076.NR_PROCESSO  AND PR.CD_SERVICO = F076.CD_SERVICO  AND F076.CD_EVENTO = ''076'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F379 WITH (NOLOCK) ON PR.NR_PROCESSO = F379.NR_PROCESSO  AND PR.CD_SERVICO = F379.CD_SERVICO  AND F379.CD_EVENTO = ''379'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F052 WITH (NOLOCK) ON PR.NR_PROCESSO = F052.NR_PROCESSO  AND PR.CD_SERVICO = F052.CD_SERVICO  AND F052.CD_EVENTO = ''052'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F397 WITH (NOLOCK) ON PR.NR_PROCESSO = F397.NR_PROCESSO  AND PR.CD_SERVICO = F397.CD_SERVICO  AND F397.CD_EVENTO = ''397'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F021 WITH (NOLOCK) ON PR.NR_PROCESSO = F021.NR_PROCESSO  AND PR.CD_SERVICO = F021.CD_SERVICO  AND F021.CD_EVENTO = ''021'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F088 WITH (NOLOCK) ON PR.NR_PROCESSO = F088.NR_PROCESSO  AND PR.CD_SERVICO = F088.CD_SERVICO  AND F088.CD_EVENTO = ''088'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F387 WITH (NOLOCK) ON PR.NR_PROCESSO = F387.NR_PROCESSO  AND PR.CD_SERVICO = F387.CD_SERVICO  AND F387.CD_EVENTO = ''387'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F616 WITH (NOLOCK) ON PR.NR_PROCESSO = F616.NR_PROCESSO  AND PR.CD_SERVICO = F616.CD_SERVICO  AND F616.CD_EVENTO = ''616'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F041 WITH (NOLOCK) ON PR.NR_PROCESSO = F041.NR_PROCESSO  AND PR.CD_SERVICO = F041.CD_SERVICO  AND F041.CD_EVENTO = ''041'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F838 WITH (NOLOCK) ON PR.NR_PROCESSO = F838.NR_PROCESSO  AND PR.CD_SERVICO = F838.CD_SERVICO  AND F838.CD_EVENTO = ''838'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F164 WITH (NOLOCK) ON PR.NR_PROCESSO = F164.NR_PROCESSO  AND PR.CD_SERVICO = F164.CD_SERVICO  AND F164.CD_EVENTO = ''164'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP                 F092 WITH (NOLOCK) ON PR.NR_PROCESSO = F092.NR_PROCESSO  AND PR.CD_SERVICO = F092.CD_SERVICO  AND F092.CD_EVENTO = ''092'' ' + sLineBreak +
    ' WHERE ((F092.DT_REALIZACAO IS NULL) ' + sLineBreak +
    ' OR CONVERT(DATETIME, F092.DT_REALIZACAO, 103) >= CONVERT(DATETIME, GETDATE() -2, 103)) ' + sLineBreak +
    ' AND SV.CD_VIA_TRANSPORTE <> ''10'' ' + sLineBreak +
    ' AND PR.IN_CANCELADO  = ''0'' ' + sLineBreak +
    ' AND PR.IN_LIBERADO   = ''1'' ';




  if pUnidade <> '' then
    result := result + ('  AND PR.CD_UNID_NEG = ' + QuotedStr(pUnidade));
  if pProduto <> '' then
    result := result + ('  AND PR.CD_PRODUTO  = ' + QuotedStr(pProduto));
  if pGrupo <> '' then
    result := result + ('  AND PR.CD_GRUPO    = ' + QuotedStr(pGrupo));
  if pCliente <> '' then
    result := result + ('  AND PR.CD_CLIENTE  = ' + QuotedStr(pCliente));

  result := result + ('ORDER BY F.DT_REALIZACAO');


end;

function TfrmMain.GetSqlRelEventosDailyFupPirelli(pUnidade, pProduto, pGrupo, pCliente: string) :String;

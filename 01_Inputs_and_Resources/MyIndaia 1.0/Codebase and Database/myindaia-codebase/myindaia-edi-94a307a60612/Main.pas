{**Mensagem na interface local, no texto de log e no log da base de dados (se solicitado por SaveDBLog**}
procedure VMsg(s: String; Tipo: TMsg; SaveDBLog: Boolean);
begin
  with frmMain do
  begin
    LOG.Lines.Add(FormatDateTime('DD/MM/YYYY HH:NN:SS',Now) + ' ' + s);
    if Tipo = msSystem  then
    begin
      Log.SelAttributes.Color := clGray;
      memLog.SelAttributes.Color := clSilver;
    end;
    if Tipo = msErroEmail then
    begin
      Log.SelAttributes.Color := clRed;
      memLog.SelAttributes.Color := clRed;
      LOG.Lines.SaveToFile(GetPath+'ERRO.TXT');
    end;
    if Tipo = msNull then
    begin
      Log.SelAttributes.Color := clRed;
      memLog.SelAttributes.Color := clRed;
      LOG.Lines.SaveToFile(GetPath+'ERRO.TXT');
      EnviaEmail(EmailProgramador,s,GetPath+'ERRO.TXT');
    end;
    if Tipo in [msError,msErrorEnvio] then
    begin
      Log.SelAttributes.Color := clRed;
      memLog.SelAttributes.Color := clRed;
      LOG.Lines.SaveToFile(GetPath+'ERRO.TXT');
      {if Tipo = msError then
      begin
        Inc(TotalErros);
        EnviaEmail(EmailProgramador,'ERRO CRÍTICO nş ' + IntToStr(TotalErros) + ' NO MYROBO - Finalizando daqui ' + IntToStr(MAX_ERROS - TotalErros) + ' erros.',GetPath+'ERRO.TXT');
        if TotalErros = MAX_ERROS then
        begin
          memLog.Lines.Add(FormatDateTime('DD/MM/YYYY HH:NN:SS',Now) + ' Total de erros maior que ' + IntToStr(MAX_ERROS) + '. Prosseguindo no modo silencioso.');
          Halt;
        end;
      end else}
        EnviaEmail(EmailProgramador,'MYROBO ENCONTROU PROBLEMAS PARA ENVIAR UM EMAIL.',GetPath+'ERRO.TXT');
    end;
    if Tipo = msSuccess then
    begin
      Log.SelAttributes.Color := clGreen;
      memLog.SelAttributes.Color := clGreen;
    end;
    if SaveDBLog then
      SaveLogOnDB(s);
    memLog.Lines.Add(FormatDateTime('DD/MM/YYYY HH:NN:SS',Now) + ' ' + s);
  end;
  Application.ProcessMessages;
end;


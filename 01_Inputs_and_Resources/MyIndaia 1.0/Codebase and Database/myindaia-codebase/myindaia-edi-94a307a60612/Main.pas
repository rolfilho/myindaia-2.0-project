            SQL.Add('                   WHEN "" THEN NM_PAIS');
            SQL.Add('               ELSE NM_PAIS_ING');
            SQL.Add('               END');
            SQL.Add('        FROM TPAIS_BROKER (NOLOCK)');
            SQL.Add('        WHERE CD_PAIS = PR.CD_PAIS_DESTINO) NM_PAIS_DESTINO,');
          end;

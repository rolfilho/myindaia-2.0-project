procedure TfrmMain.ReadLine;
var s,c,cnt: Cardinal;
    def,tab_name,tipo,p: String;
    NCD,COD_TAB: Integer;
    X: Byte; PX: PByte;
    Arqcfg : TextFile;
    NRPROC : string;
    NR_ITEM : string;
    header : boolean;
    label IgnoreField;

begin
  // Pular especificaçăo de registro para cada tipo de EDI
  c := 4;
  if EDI.Tipo = 'K' then c := 1;
  if EDI.Tipo = 'L' then c := 1;
  if EDI.Tipo = 'M' then c := 1;
  if EDI.Tipo = 'N' then c := 1;
//  if EDI.Tipo = 'M' then c := 4;
//  if EDI.Tipo = 'S' then c := 1;
//  if EDI.Tipo = 'V' then c := 4;
//  if EDI.Tipo = 'T' then c := 4;

  // Determina a tabela a ser gravada, conforme o tipo do EDI
  EDI.Linha := '';
  if EDI.USE_HUGE_FILE then begin
     EDI.Linha := ''; X := 0;
     while X <> 10 do begin
       PX := Addr(X);
       EDI.HUGE_FILE.Read(PX^,1);
       EDI.Linha := EDI.Linha + Char(X);
       Inc(EDI.NrLn);
     end;
  end else begin
     EDI.Linha := EDI.Texto[EDI.NrLn];
     Inc(EDI.NrLn);
  end;
  s := 0; TAB := nil;


  if EDI.tipo = 'L' then TAB := qryMSG03 else
  if EDI.tipo = 'M' then TAB := qryMSG10N else
  TAB := nil;

  if EDI.Tipo = 'K' then begin
     tipo := trim(Copy(EDI.Linha,4,3));
     for s := 0 to SCRIPT.Count-1 do begin
       if (Copy(SCRIPT[s],1,4) = 'TIPO') and (ExtractWord(2,SCRIPT[s],':') = tipo) then break;
     end;

     if tipo = 'ITE'  then TAB :=  qryFLPPO ;
     If tipo = 'CAP'  then  NM_EMPRESA_BASF:= trim(Copy(EDI.Linha,7,4));
//     if tipo = 'ITEM'  then TAB := ITEM  else TAB := nil;
  end ;

  if EDI.Tipo = 'N' then begin
     tipo := trim(Copy(EDI.Linha,4,3));
     for s := 0 to SCRIPT.Count-1 do begin
       if (Copy(SCRIPT[s],1,4) = 'TIPO') and (ExtractWord(2,SCRIPT[s],':') = tipo) then break;
     end;

     if tipo = 'CAP' then TAB :=  qryMSG11 else
     if tipo = 'ITE' then TAB := insNOTAF else
     if tipo = 'ITI' then TAB := updDETMERC
     else TAB := nil
//     if tipo = 'ITEM'  then TAB := ITEM  else TAB := nil;
  end ;

  if Guia_log.Count > 0 then begin
     GUIA_LOG_NOME_CHAVE := ExtractWord(2,Guia_log[s],':');
     GUIA_LOG_CHAVE      := ExtractWord(3,Guia_log[s],':');
  end;

  // Gera uma linha, guiando-se pelo script
  if TAB <> nil then begin
     Informar_Chave := False;
     Inc(s);
     while SCRIPT[s] <> 'END' do begin
       // Le o campo do EDI
     //  If ((EDI.tipo = 'K') and  (copy(EDI.Linha, 4 , 3 ) = 'CAP')) Then Break;
       If ((EDI.tipo = 'L') and  (copy(EDI.Linha, 4 , 3 ) = 'ITE')) Then Break;

       cnt := StrToInt(ExtractWord(1,SCRIPT[S],':'));
       valor := trim(Copy(EDI.Linha,c,cnt));
       campo := ExtractWord(2,SCRIPT[S],':');


       if campo = 'TP' then begin
          TPMSG10 := VALOR;

          if valor = 'RA_' Then
            TAB := qryMSG10N
          ELSE TAB := qryMSG10F
        END;

       if campo = 'NR_PROCESSO' then begin
          VALOR := TRIM(VALOR);
          NR_PROCESSO_BROKER := VALOR;
          if ((tipo = 'CAP') and (EDI.tipo = 'N')) then break;
       end;


       if campo = 'NR_NOTA'  then begin
          VALOR := TRIM(VALOR);
          NR_NOTAF := VALOR;
       end;

       if campo = '<IGNORE>' then goto IgnoreField;

       // Procurar comando De->Para (código <->)
       try
         if ExtractWord(3,SCRIPT[s],':') = '<->' then
         begin
            with TQuery.Create(Self) do
            begin
              try
                def   := '';
                valor := TrimLeft(TrimRight(valor));
                tab_name := ExtractWord(4,SCRIPT[s],':');
      //          if WordCount(tab_name,'|') = 2 then begin
      //             def := ExtractWord(2,tab_name,'|');
      //             tab_name := ExtractWord(1,tab_name,'|');
      //          end;
                // Caso o valor no edi for branco, procurar uma especificaçăo de default no script
                if valor = '' then valor := def
                else begin
                   // Comando De->Para encontrado


                   SessionName := 'SES_EDI';
                   DataBaseName := 'EDI';
                   SQL.Add('SELECT CD_TABELA FROM TTABELA (NOLOCK) WHERE NM_TABELA = ' + QuotedStr(tab_name));
                   Open;
                   COD_TAB := Fields[0].AsInteger;
                   SQL.Clear;
                   SQL.Add('SELECT CD_DDBROKER FROM TDE_PARA (NOLOCK) WHERE CD_TABELA = ' + IntToStr(COD_TAB) + ' AND CD_EXTERNO = ' + QuotedStr(valor));
                   Open;
                   //if Trim(valor) = '' then             VMSG('<??> DE->PARA ' + Tab.Name + ' no campo ' + campo + ' lookup ' + ExtractWord(4,SCRIPT[s],':') + ', Valor ' + Valor + ' trocado por ' + Fields[0].AsString,False)
                   //else if Fields[0].AsString = '' then VMSG('<!!> DE->PARA ' + Tab.Name + ' no campo ' + campo + ' lookup ' + ExtractWord(4,SCRIPT[s],':') + ', Valor ' + Valor + ' trocado por ' + Fields[0].AsString,False)
                   //else                                 VMSG('<OK> DE->PARA ' + Tab.Name + ' no campo ' + campo + ' lookup ' + ExtractWord(4,SCRIPT[s],':') + ', Valor ' + Valor + ' trocado por ' + Fields[0].AsString,False);
                   valor := Fields[0].AsString;
                end;
              finally
                Free;
              end;
           end;
         end;
       except
          VMSG('Erro no DE->PARA na tabela ' + TAB.Name + ' com a tabela ' + QuotedStr(ExtractWord(4,SCRIPT[s],':')),msError,True);
       end;

       // Procurar por comando de formataçăo de casas decimais (código %)
       if (ExtractWord(3,SCRIPT[s],':') = '%') and (valor <> '') then begin
          valor := Trim(Valor);
          NCD := StrToInt(ExtractWord(4,SCRIPT[s],':'));
          if Length(valor) <= NCD then begin
             valor := '0,' + valor;
          end else Insert(FormatSettings.DecimalSeparator, valor, Length(valor)-NCD+1);
       end;



       // Procurar por comando de Run Time Function
       if ExtractWord(3,SCRIPT[s],':') = '!F!' then begin
          valor := Copy(CallRunTimeFunction(ExtractWord(4,SCRIPT[s],':')),1,cnt);
       end;


       if ExtractWord(2,SCRIPT[s],':') = '*' then begin
          valor := '';
       end;


       // Tratamento para converter data YYYYMMDD para DDMMYYYY
       if (Copy(campo,1,3) = 'DT_') and (Trim(valor) <> '') then begin
          valor := Copy(valor,1,2) + '/' + Copy(valor,3,2) + '/' + Copy(valor,5,4);
          //while Pos('/',valor)>0 do Delete(valor,Pos('/',valor),1);
       end;


       try


         if (Trim(valor) = '') and (Guia_log.Count > 0) then
         begin
            LogFieldMiss(s);
         end
      //   end else if  SCRIPT[s] = 'FTP' THEN  GravaTabelaReadline
         else if (Copy(Campo,1,2) = 'VL') or (Copy(Campo,1,2) = 'PL') or (Copy(Campo,1,2) = 'PC') then
         begin
           if Trim(Valor) = '' then TAB.ParamByName(campo).AsFloat := 0
            else TAB.ParamByName(campo).AsFloat := StrToFloat(Valor);
         end
         else if (campo = 'NR_PROC_PO') and (EDI.tipo <> 'N') then begin
            NRPROC := VALOR;
         end

         else if (Copy(Campo,1,2) = 'DT') and (EDI.tipo = 'K') then
         begin
           with TQuery.Create(Self) do
           begin
             try
               SessionName := 'SES_EDI';
               DataBaseName := 'BROKER';
               SQL.Add('SELECT CD_EVENTO FROM TBASF_MSG01 (NOLOCK) WHERE DESCRICAO = ' + QuotedStr(CAMPO));
               Open;
               if bof <> eof then
               begin
                 TAB.ParamByName('CD_EVENTO').AsString     := fieldbyname('CD_EVENTO').AsString;
                 TAB.ParamByName('NR_PROCESSO').AsString   := NRPROC;
                 TAB.ParamByName('DT_REALIZACAO').AsString := valor;
                 try
                   TAB.ExecSQL;
                   if Assigned(TAB.AfterPost) then
                   TAB.AfterPost(TAB);
                 except end;
               end;
             finally
               close;
               free;
             end;
           end;
         end
         else if Copy(Campo,1,2) = 'DT' then
         begin
           try    TAB.ParamByName(campo).AsString := valor;
           except TAB.ParamByName(campo).AsDateTime := StrToDateTime(Valor);
           end;
         end
         else if  ((valor <> '') and (campo <> 'TP')) then TAB.ParamByName(campo).AsString := TrimLeft(TrimRight(valor));
       except
         on E: Exception do begin
            TAB.Cancel;
            if EDI.USE_HUGE_FILE then VMSG('Erro gravando no caractere ' + IntToStr(EDI.NrLn) + '. "' + E.Message + '"',msError,True)
            else VMSG('Erro gravando linha ' + IntToStr(EDI.NrLn) + '. "' + E.Message + '"',msError,True);
         end;
       END;

       IgnoreField:;

       c := c + cnt;
       s := s + 1;
     end;
     grfBar.Progress := EDI.NrLn;
     Application.ProcessMessages;
   END;
   if (tipo = 'ITE') AND (EDI.tipo = 'N') then
      TAB.ParamByName('NR_PROCESSO').AsString := NR_PROCESSO_BROKER;
   if (tipo = 'ITI') AND (EDI.tipo = 'N') then
   begin
     TAB.ParamByName('NR_PROCESSO').AsString := NR_PROCESSO_BROKER;
     TAB.ParamByName('NR_NOTA').AsString     := NR_NOTAF;
   end;

   if not ((tipo = 'NF_') AND (EDI.tipo = 'N')) then GravaTabelaReadline;

   If (EDI.tipo = 'K') AND (tipo = 'ITE') then
   begin
      qryPO.parambyname ('NR_PROCESSO').AsString := NRPROC;
      qryPO.parambyname ('NM_EMPRESA_BASF').AsString := NM_EMPRESA_BASF;
      qryPO.ExecSql;
   end;
end;


procedure  TfrmMain.GravaTabelaReadline;
begin
   if ((EDI.tipo = 'L') and (copy(EDI.Linha, 4 , 3 ) = 'CAP')) or  (EDI.tipo = 'M') or  ( EDI.tipo = 'N')then
   begin
     try
       if Assigned(TAB.BeforeInsert) then TAB.BeforeInsert(TAB);
       if Assigned(TAB.BeforeEdit)   then TAB.BeforeEdit(TAB);
       if Assigned(TAB.BeforePost)   then TAB.BeforePost(TAB);

       TAB.Prepare;
       try
         TAB.ExecSQL;
         if Assigned(TAB.AfterPost) then
                 TAB.AfterPost(TAB);
       except end;
     except
       on E: Exception do begin
          TAB.Cancel;
          if EDI.USE_HUGE_FILE then VMSG('Erro gravando no caractere ' + IntToStr(EDI.NrLn) + '. "' + E.Message + '"',msError,True)
          else VMSG('Erro gravando linha ' + IntToStr(EDI.NrLn) + '. "' + E.Message + '"',msError,True);
       end;
     end;
   end;
end;

{**Grava uma linha da base de dados para o EDI**}
procedure TfrmMain.WriteLine;

  function Fill(S: String; l: Integer): String;
  begin
    Result := s;
    while Length(Result) < l do Result := ' ' + Result;
  end;

  function FillLeft(S: String; l: Integer): String;
  begin
    Result := s;
    while Length(Result) < l do Result := Result + ' ';
  end;

  function PrepareValue(value: string; LN: Integer): string;
  begin
    if trim(Value) = '' then Value := '0';
    if Pos(FormatSettings.DecimalSeparator,value) = 0 then value := value + ',';
    while Length(ExtractWord(2,value, FormatSettings.DecimalSeparator)) < LN do value := value + '0';
    while Length(ExtractWord(2,value, FormatSettings.DecimalSeparator)) > LN do Delete(value,Length(value),1);
    Delete(value,Pos( FormatSettings.DecimalSeparator,value),1);
    Result := value;
  end;

  function UnPrepareValue(value: String): Double;
  begin
    if Length(value) > 4 then begin
       Insert(FormatSettings.DecimalSeparator,value,Length(value)-4);
    end;
    try
       Result := StrToFloat(value);
    except
      Result := 0;
    end;
  end;

  function PrepareData(value: String): String;
  begin
    while Pos('/',value)>0 do Delete(value,Pos('/',value),1);
    result := Copy(value,5,4) + Copy(value,3,2) + Copy(value,1,2);
  end;

  procedure Put_Desp(Tipo, Desp: String; Valor: Double; DB: Boolean);
  begin
    //
  end;

var c,DSField: Cardinal;
    NR_ITEM, NR_CAIXA,NR_FATURA, MOEDA_TX,DATA_TX,tipo,V: String;
    ID_FAT,NCD,COD_TAB,DF: Integer;
    AllowNull, DisplayField: Boolean;
    CF, VL_TX, TX_TX: Double;
    RATEIO: TQuery;
    SUM_VALOR: Double;
    Valor_Old : String;
    SUM_CD_ITEM, nome_tabela: string;
    label ValorFixo;
begin
  {**Ler o script**}
  EDI.Linha := SCRIPT[EDI.NrLn];
  if ExtractWord(1,EDI.Linha,':') = 'TIPO' then begin
     {**Comando direcionador da tabela**}
     TAB := TQuery(frmMain.FindComponent('qry' + ExtractWord(2,EDI.Linha,':')));
     nome_tabela := TAB.Name;
     if TAB = TAB_MAIN then ProcIni := Edi.Texto.Count;
//     if WordCount(EDI.Linha,':') = 3 then EDI.Linha := ExtractWord(3,EDI.Linha,':') else EDI.Linha := ExtractWord(2,EDI.Linha,':');
     EDI.Linha := Fill(EDI.Linha,4);
     tipo  := EDI.Linha;
     {**Inclui essa linha de código para năo incluir o nome da tabela na linha do arquivo**}
     EDI.Linha := '';
     inc(EDI.NrLn);
  end else if ExtractWord(1,EDI.Linha,'|') = 'LOOP' then begin
     {**Comando de loop**}
     TAB := TQuery(frmMain.FindComponent('qry' + ExtractWord(2,EDI.Linha,'|')));
     TAB.Next;
     TAB.Tag := TAB.Tag + 1;
     for c := 0 to ComponentCount-1 do if (Components[c] is TQuery) and (TQuery(Components[c]).DataSource <> nil) and (TQuery(Components[c]).DataSource.DataSet = TAB) then TQuery(Components[c]).Tag := 0;
     if TAB = TAB_MAIN then grfBar.AddProgress(1);
     if TAB.EOF then begin
        {**Fim do loop nesta tabela, seguir o script**}
        Inc(EDI.NrLn);
        Exit;
     end else begin
        {**Existem mais registros a serem escritos**}
        EDI.NrLn := SCRIPT.IndexOf(ExtractWord(3,EDI.Linha,'|'));
        Exit;
     end;
  end;

  if Guia_log.Count > 0 then begin
     GUIA_LOG_NOME_CHAVE := ExtractWord(2,Guia_log[Edi.NrLn-1],':');
     GUIA_LOG_CHAVE      := ExtractWord(3,Guia_log[Edi.NrLn-1],':');
  end;

  {**Gera a linha com os campos, sob o formato especificado no script, se a tabela nâo estiver vazia ou no fim**}
  if not TAB.IsEmpty then begin
     Informar_Chave := False;
     while SCRIPT[EDI.NrLn] <> 'END' do begin
       try
         cnt := StrToInt(ExtractWord(1,SCRIPT[EDI.NrLn],':'));
         campo := ExtractWord(2,SCRIPT[EDI.NrLn],':');
         AllowNull := True;
         DisplayField := True;
         if campo[1] = '*' then begin
            AllowNull := False;
            campo := Copy(Campo,2,Length(Campo));
         end;
         if campo[1] = '$' then begin
            AllowNull := False;
            DisplayField := False;
            campo := Copy(Campo,2,Length(Campo));
         end;
         if campo = '&' then begin
            Valor := ExtractWord(3,SCRIPT[EDI.NrLn],':');
            Goto ValorFixo;
         end;
         {**Procurar por comando de view (código @)**}
         if ExtractWord(3,SCRIPT[EDI.NrLn],':') = '@' then
         begin
           with TQuery.Create(Self) do begin
             try
                SessionName  := 'SES_EDI';
                DataBaseName := 'BROKER';
                SQL.ADD('SELECT ' + campo + ' FROM TPARAMETROS (NOLOCK)');
                Open;
                if Fields[0].AsString  <> '' then begin
                   V := Fields[0].AsString;
                   SQL.CLEAR;
                   SQL.ADD('SELECT DT_REALIZACAO,NM_HORA FROM TFOLLOWUP (NOLOCK) WHERE CD_EVENTO = ' + QuotedStr(V) + ' AND NR_PROCESSO = ' + QuotedStr(TAB_MAIN.FieldByName('GUIA_VIEW').AsString) + ' AND IN_APLICAVEL = ' + QuotedStr('1'));
                   Open;
                   valor := Fields[0].AsString;
                   while Pos('/',valor)>0 do System.Delete(valor,Pos('/',valor),1);
                   valor := Copy(valor,1,cnt);
                   v := Fields[1].AsString;
                   while Pos(':',v)>0 do System.Delete(v,Pos(':',v),1);
                   if cnt = 12 then v := Copy(v,1,4) else v := Copy(v,1,6);
                   valor := valor + v;
                end else valor := '';
             Finally
                Close;
                Free;
             end;
           end
         end else
         if ExtractWord(3,SCRIPT[EDI.NrLn],':') = '!F!' then
         begin
           if Pos('|', SCRIPT[EDI.NrLn] ) > 0  then
            begin
             parametros := ExtractWord(2,SCRIPT[EDI.NrLn],'|');
             formula    := ExtractWord(4,SCRIPT[EDI.NrLn],':');
             Formula    := ExtractWord(1,formula,'|');
             valor      := Copy(CallRunTimeFunction(Formula),1,cnt);
            end
           else
             valor := Copy(CallRunTimeFunction(ExtractWord(4,SCRIPT[EDI.NrLn],':')),1,cnt);
         end
         else valor := TAB.FieldByName(Campo).AsString;

         if (ExtractWord(3,SCRIPT[EDI.NrLn],':') = '@') or (Copy(campo,1,3) = 'DT_') then begin
            while Pos('/',valor)>0 do Delete(valor,Pos('/',valor),1);
         end;

         {**Procurar por comando de De->Para (código <->)**}
         if ExtractWord(3,SCRIPT[EDI.NrLn],':') = '<->' then
         begin
           Valor_Old := Valor;
           {Só vai fazer a DePara se possuir valor para pegar no correspondente na TDe_Para}
           if Valor_Old <> '' then
           begin
             valor := DePara(ExtractWord(4,SCRIPT[EDI.NrLn],':'),valor);
             if valor = '' then
             begin
               VMsg('Item = ' + Valor_Old + ' - ' + TAB.FieldByname('NM_ITEM').AsString + ' năo possui correspondente na tabela TDE_PARA, arquivo năo será gerado.',msError,True);
               EnvioAbortado := True;
             end;
           end
           else
             Valor := '';
         end
         else
         if campo = 'TX_INFO_COMPL' then
           valor := valor
         else
           valor := Copy(valor,1,cnt);

         {**Procurar por comando de formataçăo de casas decimais (código %)**}
         if (ExtractWord(3,SCRIPT[EDI.NrLn],':') = '%') and (valor <> '') then begin
            NCD := StrToInt(ExtractWord(4,SCRIPT[EDI.NrLn],':'));
            if Pos(FormatSettings.DecimalSeparator,valor) = 0 then valor := valor + ',';
            while Length(ExtractWord(2,valor,FormatSettings.DecimalSeparator)) < NCD do valor := valor + '0';
            while Length(ExtractWord(2,valor,FormatSettings.DecimalSeparator)) > NCD do Delete(valor,Length(valor),1);
            Delete(valor,Pos(FormatSettings.DecimalSeparator,valor),1);
         end;

         ValorFixo:;

         {**Verificar se o campo esta vazio e é obrigatório**}
         if (Trim(valor) = '') and (not AllowNull) then begin
            {**Cancelar a exportaçăo do processo**}
            Edi.NrLn := Script.Count-2;
            while Edi.Texto.Count > ProcIni do Edi.Texto.Delete(Edi.Texto.Count-1);
            EnvioAbortado := True;
            VMsg('[MYROBO] BASF : Campo chave ' + campo + ', registro ' + IntToStr(TAB.TAG+1) + ' está vazio, envio do processo ' + TAB_MAIN.FieldByName('NR_PROCESSO').AsString + ' abortado.',msNull,True);
            Exit;
         end;

         {**Com o valor calculado, completar a linha**}
         if ExtractWord(3,SCRIPT[EDI.NrLn],':') = '<' then EDI.Linha := EDI.Linha + FillLeft(valor,cnt) else
         begin
           {if (TAB_MAIN = qryDIDS) or (TAB_MAIN = qryCSTO)  or (TAB_MAIN = qryNTFS) or
              (TAB_MAIN = qryHDR1) or (TAB_MAIN = qryADD1) or (TAB_MAIN = qryTSP1) or (TAB_MAIN = qryPKG1) or
              (TAB_MAIN = qryPKG2) or (TAB_MAIN = qryLIN) or (TAB_MAIN = qryTRL1) or (TAB_MAIN = qryHEADER) or
              (TAB_MAIN = qryDETAIL) or (TAB_MAIN = qryDAN5) or (TAB_MAIN = qryDAN6) or (TAB_MAIN = qryDAN7) or
              (TAB_MAIN = qryMSG02) or (TAB_MAIN = qryITEM02) or (TAB_MAIN = qryMSG05) or (TAB_MAIN = qryMSG06) then
             EDI.Linha := EDI.Linha + FillLeft(valor,cnt)
           else
             EDI.Linha := EDI.Linha + Fill(valor,cnt);}

            if DisplayField then
              EDI.Linha := EDI.Linha + FillLeft(valor,cnt);
         end;
          if (Trim(valor) = '') and (Guia_log.Count > 0) then begin
            Log.SelAttributes.Color := clRed;
            Informar_Chave := True;
            LogFieldMiss(Edi.NrLn);
         end;
         Inc(EDI.NrLn);
       except
          VMsg('Erro no script, ' + TAB.NAME + ' ' + campo,msError,True);
          EDI.Linha := EDI.Linha + Fill('',cnt);
          Inc(EDI.NrLn);
       end;
     end;

     if not EnvioAbortado then begin

        VMSG('Tabela ' + Copy(TAB.NAME,4,20) + ': Registro ' + IntToStr(TAB.Tag + 1) + ' de ' +  IntToStr(TAB.RECORDCOUNT),msSystem,False);

function TfrmMain.FORMATAR_VALOR(Valor : Extended; Casas_Decimais : Integer) : String;
Var
  Aux_Valor : String;
  Aux_NCD   : Integer;
begin
  Aux_Valor := FloatToStr(Valor);
  if Aux_Valor <> '' then
  begin
    Aux_NCD   := Casas_Decimais;
    if Pos(FormatSettings.DecimalSeparator,Aux_Valor) = 0 then
      Aux_Valor := Aux_Valor + ',';

    while Length(ExtractWord(2,Aux_Valor,FormatSettings.DecimalSeparator)) < Aux_NCD do
      Aux_Valor := Aux_Valor + '0';

    while Length(ExtractWord(2,Aux_Valor,FormatSettings.DecimalSeparator)) > Aux_NCD do
      Delete(Aux_Valor,Length(Aux_Valor),1);

    Delete(Aux_Valor,Pos(FormatSettings.DecimalSeparator,Aux_Valor),1);
    Result := Aux_Valor;
  end
  else
    Result := '';
end;


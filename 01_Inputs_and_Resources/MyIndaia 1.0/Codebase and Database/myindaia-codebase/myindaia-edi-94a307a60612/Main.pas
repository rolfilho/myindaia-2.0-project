procedure TfrmMain.Cadastra_De_Para ;
begin
  with TQuery.Create(Self) do begin
    try
      SessionName := 'SES_EDI';
      DataBaseName := 'BROKER';
      SQL.Add('INSERT INTO TDE_PARA');
      SQL.Add('(CD_UNID_NEG, CD_PRODUTO, CD_TABELA, CD_DDBROKER, CD_EXTERNO, CD_CLIENTE, CD_GRUPO)');
      SQL.Add('VALUES');
      SQL.Add('(:CD_UNID_NEG, :CD_PRODUTO, :CD_TABELA, :CD_DDBROKER, :CD_EXTERNO, :CD_CLIENTE, :CD_GRUPO)');
      {Pegamos como default a unidade de Uruguaina. Fizemos isso para que năo houvesse uma replicaçăo de dados
      referentes a Mercedes na tabela TDe_Para caso pegassemos a unidade do usuário.
      Poderiamos ter criado também uma outra tabela TDe_Para específica para isso mas iriamos ter uma duplicaçăo
      de tabela desnecessária }
      ParamByName('CD_UNID_NEG').AsString := '01';
      ParamByName('CD_PRODUTO').AsString  := '01'; {Importaçăo}
      ParamByName('CD_TABELA').AsString   := '10';
      ParamByName('CD_DDBROKER').AsString := Codigo_De_Para;
      ParamByName('CD_EXTERNO').AsString  := valor;
      ParamByName('CD_CLIENTE').AsString  := Codigo_De_Para;
      ParamByName('CD_GRUPO').AsString    := Grupo_De_Para;
      ExecSQL;
    finally
      Free;
    end;
  end;
end;


  vTextoTodo, vTextoParte, vNmModelo, vNmModelo_Tmp, vNmModelo_Original, vSQL1, vTextoHiperlink, vTexto, vNM_GRUPO, vUSUARIOS_EXTRAS ,in_email_atendente, in_email_contato, in_email_transportador : String;
  vUnidade, vProduto, vArea, vSubArea, vGrupo, vCliente, vAnalistaCliente, vEvento, vProcesso, vTpIdioma, vModal : string;
  i,x,qt_img : Integer;
  lstTemp:TStringList;
  vQryAlerta, vQryAux  : TQuery;

  function InsereImagem(vNumero : Integer):String;
  begin

  end;


  function InsereTexto(vTipoVariavel : String) :String;
  var
    vSQL, vCampo, vStrTexto : String;
    vQryCampo : TQuery;

  begin
    Result := '';
    if vQryAlerta.FieldByName('NM_SQL_MANUAL').Value <> '' then
      vSQL := vQryAlerta.FieldByName('NM_SQL_MANUAL').AsString
    else
    begin
      if vQryAlerta.FieldByName('NM_TABELA').AsString <> '' then
        vSQL := ' SELECT '+ vQryAlerta.FieldByName('NM_CAMPO').AsString +
                ' FROM '  + vQryAlerta.FieldByName('NM_TABELA').AsString + ' (NOLOCK) ' +
                ' WHERE ' + Trim(Copy(vQryAlerta.FieldByName('NM_JOIN').AsString, Pos('>', vQryAlerta.FieldByName('NM_JOIN').AsString) +1, Length(vQryAlerta.FieldByName('NM_JOIN').AsString))) +
                '    = ( SELECT ' + Trim(Copy(vQryAlerta.FieldByName('NM_JOIN').AsString, 1, Pos('>', vQryAlerta.FieldByName('NM_JOIN').AsString) -1)) +
                         ' FROM TPROCESSO (NOLOCK) WHERE NR_PROCESSO = :NR_PROCESSO)'
      else
        vSQL := '  SELECT ' + vQryAlerta.FieldByName('NM_CAMPO').AsString +
                ' FROM TPROCESSO (NOLOCK) WHERE NR_PROCESSO = :NR_PROCESSO';
    end;

    vQryCampo := TQuery.Create(Self);
    with vQryCampo do
    begin
      try
        SessionName := 'SES_EDI';
        DataBaseName := 'BROKER';
        Sql.Clear;
        SQL.Add(vSql);
        // Se há o parâmetro NR_PROCESSO na consulta, atribui o numero do processo
        if Pos(':NR_PROCESSO', vSQL) > 0 then
          ParamByName('NR_PROCESSO').AsString := vProcesso; //'0101im-0001-08';

        Open;
        if vTipoVariavel = '0' then
        begin
          if Fields[0].DataType in [ftFloat, ftCurrency] then
            vCampo := FormatFloat('#0.,00', Fields[0].AsFloat)
          else if (Fields[0].DataType in [ftDate, ftDateTime, ftTime]) and (Fields[0].AsString <> '') and (not Fields[0].IsNull) then
            vCampo := FormatDateTime('dd/mm/yyyy', Fields[0].AsDateTime)
          else
            vCampo := Fields[0].AsString;
          Result := vCampo;
        end
        else
        begin
          while not Eof do
          begin
            // Formata o valor de acordo com o tipo do campo
            if Fields[0].DataType in [ftFloat, ftCurrency] then
              vCampo := FormatFloat('#0.,00', Fields[0].AsFloat)
            else if (Fields[0].DataType in [ftDate, ftDateTime, ftTime]) and (Fields[0].AsString <> '') and (not Fields[0].IsNull) then
              vCampo := FormatDateTime('dd/mm/yyyy', Fields[0].AsDateTime)
            else
              vCampo := Fields[0].AsString;

            // Verifica a direçăo para definir a ordem da lista - Michel - 11/12/2008
            if vQryAlerta.FieldByName('CD_DIRECAO').AsString = 'H' then
              vStrTexto := vStrTexto + ', ' + Trim(vCampo) // H - Lista os itens um do lado do outro separados por virgula
            else
              vStrTexto := vStrTexto + '^l' + Trim(vCampo); // V - Lista os itens um em cada linha
            Next;
          end;
          Result := Copy(vStrTexto, 3, Length(vStrTexto) - 2);
        end;
        // Adicionado porque quando vazio năo substitui a variavel - Michel - 16/12/2008 - Ocorręncia 06950/08
        if Result = '' then
          Result := ' ';
        Close;
      finally
        Free;
      end;
    end;
  end;

begin
  //E01

//exit; //temp carlos

  Result := FALSE;
  vQryAux := TQuery.Create(Self);
  with vQryAux do
  begin
    try
      try
        SessionName := 'SES_EDI';
        DataBaseName := 'BROKER';
        SQL.Clear;
        SQL.Add('SELECT TX_CONFIGURACAO, TP_IDIOMA, TX_MODELO, CD_VIA_TRANSPORTE');
        SQL.Add('  FROM TRELATORIOS_MAIL_AUT ( NOLOCK) ');
        SQL.Add(' WHERE CD_RELATORIO = ''' + vCdrelatorio + ''' ');
        Open;
        vUnidade               := ExtractWord(1, Fields[0].AsString,'/');
        vCliente               := ExtractWord(2, Fields[0].AsString,'/');
        vGrupo                 := ExtractWord(3, Fields[0].AsString,'/');
        vArea                  := ExtractWord(4, Fields[0].AsString,'/');
        vSubArea               := ExtractWord(5, Fields[0].AsString,'/');
        vAnalistaCliente       := ExtractWord(7, Fields[0].AsString,'/');
        vEvento                := ExtractWord(8, Fields[0].AsString,'/');
        vSql1                  := ExtractWord(9, Fields[0].AsString,'/');
        vProduto               := ExtractWord(10,Fields[0].AsString,'/');
        in_email_atendente     := ExtractWord(11,Fields[0].AsString,'/');
        in_email_contato       := ExtractWord(12,Fields[0].AsString,'/');
        in_email_transportador := ExtractWord(13,Fields[0].AsString,'/');
        vTpIdioma              := Fields[1].AsString;
        vNmModelo              := Fields[2].AsString;
        vNmModelo_Original     := vNmModelo;
        vModal                 := Fields[3].AsString;
        Close;
      Finally
        Free;
      end;
    except
    On e:Exception do
      VMsg(e.message, msError, True);
    end;
  end;

  vQryTexto := TQuery.Create(Self);
  with vQryTexto do begin
    try
      SessionName := 'SES_EDI';
      DataBaseName := 'BROKER';
      Close;
      SQL.Clear;
      if  vSQL1 = '' then begin
        SQL.Add(' SELECT FUP.NR_PROCESSO, g.NM_GRUPO ');
        SQL.Add(' FROM TFOLLOWUP FUP (NOLOCK)');
        SQL.Add(' INNER JOIN TPROCESSO PR (NOLOCK) ON PR.NR_PROCESSO = FUP.NR_PROCESSO ');
        SQL.Add(' INNER JOIN TSERVICO_NOVO S (NOLOCK) ON S.CD_SERVICO = PR.CD_SERVICO ');
        SQL.Add(' INNER JOIN TGRUPO g (NOLOCK) ON g.CD_GRUPO = PR.CD_GRUPO ');
        if Trim(vTpIdioma) <> '' then
          SQL.Add(' LEFT JOIN TPAIS p (NOLOCK) ON p.CODIGO = PR.CD_PAIS_DESTINO ');

  //      SQL.Add(' WHERE FUP.DT_REALIZACAO IS NOT NULL  ');
        SQL.Add(' WHERE FUP.DT_REALIZACAO IS NOT NULL  and  isnull(FUP.DT_REALIZACAO_EFETIVA,FUP.dt_realizacao) > GETDATE()-6 ');
        SQL.Add('   AND FUP.CD_EVENTO    = ''' + vEvento + ''' ');
        SQL.Add('   AND ISNULL(FUP.IN_ALERTA_ENVIADO,''0'') = ''0'' ');
        if Trim(vUnidade) <> '' then
          SQL.Add('   AND PR.CD_UNID_NEG = ''' + vUnidade + '''');
        if Trim(vProduto) <> '' then
          SQL.Add('   AND PR.CD_PRODUTO  = ''' + vProduto + '''');
        if Trim(vArea) <> '' then
          SQL.Add('   AND PR.CD_AREA IN ( SELECT CD_AREA FROM TAREA (NOLOCK) WHERE NM_GRUPO = (SELECT NM_GRUPO FROM TAREA (NOLOCK) WHERE CD_AREA = ''' + vArea + ''' ) )');
        if Trim(vSubArea) <> '' then
          SQL.Add('   AND PR.CD_AREA = ''' + vSubArea + ''' ');

        if Trim(vGrupo) <> '' then
          SQL.Add('   AND PR.CD_CLIENTE IN ( SELECT CD_EMPRESA FROM TEMPRESA_NAC (NOLOCK) WHERE CD_GRUPO = "' + vGrupo + '")')
        else begin
          SQL.Add('   AND PR.CD_CLIENTE IN ( SELECT E.CD_EMPRESA FROM TEMPRESA_NAC E (NOLOCK), TGRUPO G (NOLOCK) ');
          SQL.Add('                          WHERE  E.CD_GRUPO=G.CD_GRUPO AND ISNULL(G.IN_ALERTA_E01_NAO_GENERICO,"0")<>"1" )')
        end;

        if Trim(vCliente) <> '' then
          SQL.Add('   AND PR.CD_CLIENTE = ''' + vCliente + '''');
        if Trim(vAnalistaCliente) <> '' then
          SQL.Add('   AND PR.CD_CONTATO IN (SELECT CD_CONTATO FROM TCLIENTE_CONTATO (NOLOCK) WHERE CD_USUARIO = ''' + vAnalistaCliente + ''' )');

        if Trim(vTpIdioma) <> '' then
        //alterado por Andressa 05/05/2011
        //  SQL.Add(' AND ( (ISNULL(PR.CD_LINGUA_PEDIDO,p.CD_IDIOMA_PADRAO) = ''' + vTpIdioma + ''') OR ((PR.CD_LINGUA_PEDIDO <> "0" OR PR.CD_LINGUA_PEDIDO <> "1" OR PR.CD_LINGUA_PEDIDO <> "2") and (ISNULL(PR.CD_LINGUA_PEDIDO,p.CD_IDIOMA_PADRAO) = ''' + vTpIdioma + '''))) ');
        //By carlos 20/07/2011
        SQL.Add(' AND ( CASE when ISNULL(PR.CD_LINGUA_PEDIDO,"") in( "","0")  THEN p.CD_IDIOMA_PADRAO ELSE PR.CD_LINGUA_PEDIDO END )= "'+vTpIdioma+'" ');

  //      if Trim(vModal) <> '10' then

        if Trim(vModal) <> '' then
          SQL.Add(' AND S.CD_VIA_TRANSPORTE = ''' + vModal + ''' ')
        else
          SQL.Add(' AND S.CD_VIA_TRANSPORTE <> "10" ');

      end else begin
        SQL.add(vSQL1);
      end;
      Open;

      vGrupoLogo := '';
      vGrupoLogo := vGrupo;
      while not EOF do  begin
        vNmModelo_tmp  := vNmModelo_Original;
        //copiar para a pasta temporaria
        System.Insert('TMP_EMAIL\' , vNmModelo_tmp , 28);
        CopyFile(PChar(vNmModelo_Original),PChar(vNmModelo_Tmp),true);

        vProcesso := Fields[0].AsString;
  vUltimoProcessoAntesdoErro:=  vProcesso;


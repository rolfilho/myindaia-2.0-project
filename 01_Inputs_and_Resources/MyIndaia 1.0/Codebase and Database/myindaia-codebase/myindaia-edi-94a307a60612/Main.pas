{*******************************************************************************
 Essa rotina é utilizada quando é necessário a formataçăo de dados do tipo DATA
 mas a data năo foi obtida através de uma FUNÇĂO. A VOLKS tem um formatacao
 particular que é DD.MM.YYYY .
*******************************************************************************}
function FORMATACAO_DATA_VOLKS : String;
Var
  Aux_Data,
  A, M, D  : String;
begin
  Aux_Data := TAB.Fieldbyname(campo).AsString;
  if Aux_Data <> '' then
  begin
    if (pos('/',Aux_Data) or pos('-',Aux_Data)) > 0 then
      Result := frmMain.FORMATAR_DATAS_FUNCAO(Aux_Data,'V')
    else
    begin
      D := copy(Aux_Data,1,2);
      M := copy(Aux_Data,3,2);
      A := copy(Aux_Data,5,4);
      Result := D + '.' + M + '.' + A;
    end;
  end
  else
    Result := '';
end;

{*******************************************************************************
 Funçăo utilizada para formatar valores a Esquerda preenchido com zeros a
 esquerda. Funçăo realizado para Volks - Retorno de DI.
*******************************************************************************}
function FILLLEFTVALOR : String;
Var
  Aux_Valor     : String;
  Aux_Casas_Dec,
  Aux_Casas_Int : Integer;
  vColocarPonto : Boolean;
begin
  vColocarPonto := False;
  if (copy(campo,1,2) = 'VL') then
  begin
    Aux_Casas_Dec := 2;
  end
  else
  if (copy(campo,1,2) = 'PC') then
  begin
     Aux_Casas_Dec := 7;
  end
  else
  if (copy(campo,1,2) = 'TX') then
    Aux_Casas_Dec := 8
  else
  if ((copy(campo,1,2) = 'PB') or (copy(campo,1,2) = 'PL') or (copy(campo,1,2) = 'QT')) then
  begin
      Aux_Casas_Dec := 5;
  end
  else
  if ((copy(campo,1,2) = 'NR') OR (copy(campo,1,2) = 'NM') or (copy(campo,1,2) = 'CD')) then
    Aux_Casas_Dec := 0
  else
  if campo = 'QUANTIDADE' then
    Aux_Casas_Dec := 5
  else
  if ((campo = 'PESO_UNITARIO') or (campo = 'VALOR_UNITARIO')) then
    Aux_Casas_Dec := 7;

  if ((TAB.Fieldbyname(campo).AsString <> '') and (TAB.Fieldbyname(campo).AsString <> Null)) then
  begin
    Aux_Valor := frmMain.FORMATAR_VALOR_VOLKS(TAB.Fieldbyname(campo).AsFloat,Aux_Casas_Dec);
    if vColocarPonto then
      Result := copy(Aux_Valor,0,length(Aux_Valor)-5) + '.' + copy(Aux_Valor,length(Aux_Valor)-4,5)
    else
      Result := Aux_Valor;
  end
  else
    Result := '';
  while Length(Result) < cnt do Result := '0' + Result;
end;

function VALOR_TOYOTA : String;
var
  Aux_Casas_Dec,
  vTamanho, Aux_NCD       : integer;
  Aux_Valor     : String;
  vAux : String;
begin
  if ((TAB.Fieldbyname(campo).AsString <> '') and (TAB.Fieldbyname(campo).AsString <> Null)) then
  begin
    Aux_Valor := FloatToStr(TAB.Fieldbyname(campo).AsFloat);
    Aux_NCD   := Aux_Casas_Dec;
    if Pos(FormatSettings.DecimalSeparator,Aux_Valor) = 0 then
      Aux_Valor := Aux_Valor + ',';
    while Length(frmMain.ExtractWord(2,Aux_Valor,FormatSettings.DecimalSeparator)) < Aux_NCD do
      Aux_Valor := Aux_Valor + '0';
    while Length(frmMain.ExtractWord(2,Aux_Valor,FormatSettings.DecimalSeparator)) > Aux_NCD do
      Delete(Aux_Valor,Length(Aux_Valor),1);
    if Pos(',',Aux_Valor) > 0 then
      Aux_valor := copy(aux_valor,0,Pos(',',Aux_valor)-1) + copy(aux_valor,Pos(',',aux_valor) + 1,Aux_casas_dec);
    if vTamanho = 15 then
      Result := copy('000000000000000',0,15-length(Aux_Valor)) + Aux_Valor
    else
      Result := copy('0000000000',0,10-length(Aux_Valor)) + Aux_Valor
  end
  else
    Result := '';
end;


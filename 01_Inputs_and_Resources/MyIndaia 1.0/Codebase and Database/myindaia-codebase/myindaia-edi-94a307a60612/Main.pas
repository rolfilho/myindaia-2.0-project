                  10:lstTemp.Text:=StringReplace(lstTemp.Text, QuotedStr('123imagem10321') ,'&nbsp;&nbsp;<img src="http://www.myindaiaweb.com.br/imagens/icones/16x16/open/open10.gif" style="border-width:0px" alt="Visualizar o documento"> ',[rfReplaceAll]);

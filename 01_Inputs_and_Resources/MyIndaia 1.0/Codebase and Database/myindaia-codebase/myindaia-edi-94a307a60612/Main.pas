procedure KillExcel(var App: OleVariant);
var
  ProcID: DWORD;
  hProc: THandle;
  hW: HWND;
begin
  hW := App.Application.HWND;
  App.DisplayAlerts := False;
  App.Workbooks.Close;
  App.Quit;
  App := Unassigned;
  if not IsWindow(hW) then
   Exit;
  GetWindowThreadProcessId(hW, ProcID);
  hProc := OpenProcess(PROCESS_TERMINATE, False, ProcID);
  TerminateProcess(hProc, 0);
end;

function DePara(Tabela,CD_DDBROKER: String): String;
var
  COD_TAB,
  nr_processo,
  cd_grupo,
  cd_cliente   : String;
begin
  nr_processo := TAB.fieldbyname('NR_PROCESSO').AsString;
  with TQuery.Create(frmMain) do begin
    try
       SessionName  := 'SES_EDI';
       DataBaseName := 'BROKER';
       SQL.Text     := ' SELECT G.CD_GRUPO,                  ' + sLineBreak +
                       '        P.CD_CLIENTE                 ' + sLineBreak +
                       '   FROM TPROCESSO    P (NOLOCK),     ' + sLineBreak +
                       '        TEMPRESA_NAC N (NOLOCK),     ' + sLineBreak +
                       '        TGRUPO       G (NOLOCK)      ' + sLineBreak +
                       '  WHERE P.CD_CLIENTE  = N.CD_EMPRESA ' + sLineBreak +
                       '    AND N.CD_GRUPO    = G.CD_GRUPO   ' + sLineBreak +
                       '    AND P.NR_PROCESSO = :NR_PROCESSO ' + sLineBreak ;

       PARAMBYNAME('NR_PROCESSO').AsString := nr_processo;
       Open;

       if IsEmpty then
       begin
         cd_grupo   := '';
         cd_cliente := '';
       end
       else
       begin
         cd_grupo   := Fields[0].AsString;
         cd_cliente := Fields[1].AsString;
       end;
    Finally
     Free;
    end;
  end;

  with TQuery.Create(frmMain) do begin
    try
     SessionName := 'SES_EDI';
     DataBaseName := 'BROKER';
     SQL.Add('SELECT CD_DE_PARA FROM TTP_DE_PARA (NOLOCK) WHERE NM_DE_PARA = ' + QuotedStr(TABELA));
     Open;
     COD_TAB := Fields[0].AsString;
     SQL.Clear;
     SQL.Add('SELECT CD_EXTERNO FROM TDE_PARA (NOLOCK) WHERE CD_TABELA = ' + QuotedStr(COD_TAB) + ' AND CD_DDBROKER = ' + QuotedStr(CD_DDBROKER));
     if cd_grupo <> '' then
       SQL.Add('AND CD_GRUPO = ' + QuotedStr(cd_grupo))
     else
       SQL.Add('AND CD_CLIENTE = ' + QuotedStr(cd_cliente));
     Open;
     Result := Fields[0].AsString;
    finally
     Free;
    end;
  end;
end;

function StrZero(nNumero : double; i : Integer) : String;
var
  s : string;
begin
  try
    s := FloatToStr( nNumero )
  except
    s := ''
  end;
  While Length( s ) < i do
    s := '0' + s;
  StrZero := s
end;

function nAt( Arg1, Arg2: string ) : Integer;
Var
  nTamanho1 : Integer;
  nTamanho2 : Integer;
  i : Integer;
begin
  Result := 0;
  nTamanho1 := length( Arg1 );
  nTamanho2 := length( Arg2 );
  if nTamanho1 > 0 then
    for i := 1 to nTamanho2 do
      if ( Copy( Arg2, i, nTamanho1 ) = Arg1 ) then
      begin
        Result := i;
        Exit
      end;
end;

function MyInc(var value: integer; valueInc: integer = 1): integer;
begin
  value := value + 1;
  result := value;
end;

function Arredondar( nNumero : Double; nCasas : Integer ) : Double;
Var
  cNumero : String[40];
  cInteiro : String[20];
  cFracao : String[20];
  nPosicaoPonto : Integer;
  nDigito : Integer;
begin
  cNumero := FloatToStr( nNumero );
  nPosicaoPonto := nAt( ',', cNumero );

  if nPosicaoPonto > 0 then
  begin
    cInteiro := Copy( cNumero, 1, nPosicaoPonto - 1 );
    cFracao := Copy( cNumero, nPosicaoPonto + 1, Length( cNumero ) );
    if Length(cFracao) <> nCasas then
    if Length(cFracao) < nCasas then
    begin
       cFracao := cFracao + Copy( '000000000000', 1, nCasas - Length( cFracao ) )
    end else begin
      cFracao := Copy( cFracao, 1, nCasas + 1 );
      nDigito := StrToInt( Copy( cFracao, nCasas + 1, 1 ) );
      if nDigito >= 5 then
        cFracao := StrZero(StrToFloat( Copy( cFracao, 1, nCasas ) ) + 1 , ncasas)
      else
        cFracao := Copy(cFracao, 1, nCasas);
    end;
    if length (cFracao) <> ncasas then
    begin
      cInteiro := FloattoStr(StrtoFloat(cInteiro) + 1 );
      cFracao  := Copy(cFracao,2,Length(cFracao));
    end;
    cNumero := cInteiro + ',' + cFracao;
    nNumero := StrToFloat( cNumero );
  end;
  Result := nNumero;
end;

{**Salva o log no registro atual**}
procedure SaveLogOnDB(S: String);
var STR: TStringList;
    QRY: TQuery;
begin
  STR := TStringList.Create;
  QRY := TQuery.Create(frmMain);
  try
    QRY.DataBaseName := 'BROKER';
    QRY.SessionName  := 'SES_EDI';
    QRY.SQL.ADD('SELECT TX_LOG from TFILA_LOG (NOLOCK) where CD_FILA = ' + IntToStr(EDI.Fila_Reg));
    QRY.Open;
    STR.Text := QRY.Fields[0].AsString;
    STR.Add(FormatDateTime('DD/MM/YYYY HH:NN:SS',Now) + ' - ' + s);
    QRY.SQL.Clear;
    QRY.SQL.ADD('UPDATE TFILA_LOG SET TX_LOG = :LOG WHERE CD_FILA = ' + IntToStr(EDI.Fila_Reg));
    QRY.Params[0].AsMemo := STR.TEXT;
    QRY.ExecSQL;
  finally
    QRY.Free;
    STR.Free;
  end;
end;


                          '     LEFT JOIN TFOLLOWUP                  F233 WITH (NOLOCK) ON PR.NR_PROCESSO = F233.NR_PROCESSO  AND F233.CD_EVENTO = ''233'' ' + sLineBreak +
                          '     LEFT JOIN TFOLLOWUP                  F161 WITH (NOLOCK) ON PR.NR_PROCESSO = F161.NR_PROCESSO  AND F161.CD_EVENTO = ''161'' ' + sLineBreak +
                          '     LEFT JOIN TFOLLOWUP                  F162 WITH (NOLOCK) ON PR.NR_PROCESSO = F162.NR_PROCESSO  AND F162.CD_EVENTO = ''162'' ' + sLineBreak +
                          '     LEFT JOIN TFOLLOWUP                  F021 WITH (NOLOCK) ON PR.NR_PROCESSO = F021.NR_PROCESSO  AND F021.CD_EVENTO = ''021'' ' + sLineBreak +
                          '     LEFT JOIN TFOLLOWUP                  F838 WITH (NOLOCK) ON PR.NR_PROCESSO = F838.NR_PROCESSO  AND F838.CD_EVENTO = ''838'' ' + sLineBreak +
                          '     LEFT JOIN TFOLLOWUP                  F421 WITH (NOLOCK) ON PR.NR_PROCESSO = F421.NR_PROCESSO  AND F421.CD_EVENTO = ''421'' ' + sLineBreak +
                          '     LEFT JOIN TFOLLOWUP                  F391 WITH (NOLOCK) ON PR.NR_PROCESSO = F391.NR_PROCESSO  AND F391.CD_EVENTO = ''391'' ' + sLineBreak +
                          '     OUTER APPLY( SELECT CONVERT(VARCHAR(600), STUFF((SELECT distinct '','' + LTRIM(RTRIM(R.CD_REFERENCIA)) ' + sLineBreak +
                          '                                                         FROM TREF_CLIENTE R WITH (NOLOCK) ' + sLineBreak +
                          '                                                         WHERE R.NR_PROCESSO   = PR.NR_PROCESSO ' + sLineBreak +
                          '                                                         AND ISNULL(TP_REFERENCIA, '''') = ''01'' ' + sLineBreak +
                          '                 FOR XML PATH('''')), 1, 1, ''''))  AS PEDIDOS ' + sLineBreak +
                          '     )     PED ' + sLineBreak +
                          ' WHERE ' + sLineBreak +
                          ' 	PR.IN_CANCELADO   = ''0'' ' + sLineBreak +
                          ' 	AND PR.IN_LIBERADO    = ''1'' ' + sLineBreak +
                          ' 	AND F164.IN_APLICAVEL = ''1'' ' + sLineBreak +
                      //  ' 	AND CONVERT(DATETIME, CONVERT(VARCHAR, ISNULL(F164.DT_REALIZACAO +10, GETDATE()), 103), 103) >= CONVERT(DATETIME, CONVERT(VARCHAR, GETDATE(), 103), 103) ' + sLineBreak +

                          '     AND ( ( PR.CD_SERVICO IN (5,3) AND F164.DT_REALIZACAO IS NULL AND F164.IN_APLICAVEL = ''1'' ) OR								                                                     ' + sLineBreak +
	            		        '			( PR.CD_SERVICO IN (1) AND PR.TP_ESTUFAGEM = ''0'' AND F164.DT_REALIZACAO IS NULL AND F164.IN_APLICAVEL = ''1'' ) OR                                                 ' + sLineBreak +
                          '     ( PR.CD_SERVICO NOT IN (5,3) AND PR.TP_ESTUFAGEM != ''0'' AND (( F164.DT_REALIZACAO IS NULL AND F164.IN_APLICAVEL = ''1'')                                           ' + sLineBreak +
            							'      OR (	(SELECT COUNT(*) FROM TPROCESSO_CNTR C (NOLOCK) WHERE C.NR_PROCESSO = PR.NR_PROCESSO AND C.DT_DEVOLUCAO_CNTR IS NULL) > 0 ) ) ))                               ' + sLineBreak +

                          ' 	AND YEAR(PR.DT_ABERTURA) > 2012 AND PR.CD_SERVICO   <> ''11'' ' + sLineBreak +
                          ' 	AND PR.CD_PRODUTO    = ''01'' ' + sLineBreak +
                          ' 	AND PR.CD_UNID_NEG   = ''01'' ' + sLineBreak +
                          ' 	AND PR.CD_GRUPO      = ''155'' ' + sLineBreak +
                          '   AND PR.IN_URGENTE = 1 ' + sLineBreak +
                       // '   AND PR.CD_SERVICO = 1 ' + sLineBreak +
                          '   AND YEAR(PR.DT_ABERTURA) > 2020 AND PR.CD_SERVICO   <> ''11''                                                                                                        ' + sLineBreak ;
              {$endregion}

              if pProduto <> '' then
                SQL.Add('  AND PR.CD_PRODUTO    = ''' + pProduto + '''  ');
              if pUnidade <> '' then
                SQL.Add('  AND PR.CD_UNID_NEG   = ''' + pUnidade + '''  ');
              if pGrupo <> '' then
                SQL.Add('  AND PR.CD_GRUPO      = ''' + pGrupo   + '''  ');
              if pCliente <> '' then
                SQL.Add('  AND PR.CD_CLIENTE    = ''' + pCliente + '''  ');
              if pArea <> '' then
                SQL.Add('  AND PR.CD_AREA       = ''' + pArea    + '''  ');

            //SQL.Add('AND pr.NR_PROCESSO in (''0101IM-009764-24'' ) ');
            //SQL.Add( ' AND FABRICANTE.NM_FABRICANTE IS NOT NULL ');

              SQL.Add( 'ORDER BY F551.DT_REALIZACAO ');

              if not DirectoryExists(GetPath+'SQL') then
                ForceDirectories(GetPath+'SQL');
              try
                SQL.SaveToFile(GetPath+'SQL\' + pRelatorio + '.sql');
              except
              end;

              Open;
            end;

          except
            on e:Exception do
            begin
              VMsg('Erro - 1 RelEventosFupClientesNestle: ' + e.Message, msError, True);
            end
          end;
          //--------------------------------------------------------------------------//
          // Preenche as celulas  de acordo com os eventos enviados
          //--------------------------------------------------------------------------//

         mdados := TFDMemTable.Create(nil);

         qry_mail_proc_nao_fat.FetchAll;
         mdados.Data :=qry_mail_proc_nao_fat.Data;

         qry_mail_proc_nao_fat.Close;

         try
            tem_dados := False;

            qt_linha_Inicial := nLinha;
            mdados.First;


            while not mdados.Eof do
            begin
              tem_dados := True;
              nLinha    := nLinha +1;

              Coluna := 0;

{*}         {B } oSheet.Cells[ nLinha, MyInc(Coluna)  ].Value := IfThen(mdados.FieldByName('Processo').AsString        <> '', mdados.FieldByName('Processo').AsString, ' ');
{*}         {C } oSheet.Cells[ nLinha, MyInc(Coluna)  ].Value := IfThen(mdados.FieldByName('Pedido').AsString          <> '', mdados.FieldByName('Pedido').AsString, ' ');
{*}         {D } oSheet.Cells[ nLinha, MyInc(Coluna)  ].Value := IfThen(mdados.FieldByName('Cliente').AsString         <> '', mdados.FieldByName('Cliente').AsString, ' ');
{*}         {AE} PreencheData( nLinha, MyInc(Coluna)  , mdados.FieldByName('DELIVERYDATE').asString);
{*}         {AE} PreencheData( nLinha, MyInc(Coluna)  , mdados.FieldByName('VENC_DEMURRAGE').asString);
{*}         {H } oSheet.Cells[ nLinha, MyInc(Coluna)  ].Value := IfThen(mdados.FieldByName('Contato').AsString      <> '', mdados.FieldByName('Contato').AsString, ' ');
{*}         {F } oSheet.Cells[ nLinha, MyInc(Coluna)  ].Value := mdados.FieldByName('Cod_Area').AsString + ' - ' + mdados.FieldByName('Nome_Area').AsString;
{*}         {H } oSheet.Cells[ nLinha, MyInc(Coluna)  ].Value := IfThen(mdados.FieldByName('Mercadoria').AsString      <> '', mdados.FieldByName('Mercadoria').AsString, ' ');
{*}         {I } oSheet.Cells[ nLinha, MyInc(Coluna)  ].Value := IfThen(mdados.FieldByName('Exportador').AsString      <> '', mdados.FieldByName('Exportador').AsString, ' ');
{*}         {AE} PreencheData( nLinha, MyInc(Coluna)  , mdados.FieldByName('PRONT_CARGA').asString);
{*}         {AF} PreencheData( nLinha, MyInc(Coluna)  , mdados.FieldByName('PrevisaoEmbarque').asString);
{*}         {AG} PreencheData( nLinha, MyInc(Coluna)  , mdados.FieldByName('DataEmbarque').asString);
{*}         {AX} PreencheData(  nLinha, MyInc(Coluna) , mdados.FieldByName('PreviChegadaTransporte').AsString);  //Previsăo de Chegada do Navio / Vôo / Caminhăo
{*}         {BA} PreencheData(  nLinha, MyInc(Coluna) , mdados.FieldByName('ChegadaTransporte').AsString);       //Chegada do Navio / Aviăo / Caminhăo
{*}         {BA} PreencheData(  nLinha, MyInc(Coluna) , mdados.FieldByName('PendenciaOK').AsString);       //Pendencia OK
{*}         {BD} PreencheData(  nLinha, MyInc(Coluna) , mdados.FieldByName('RegistroDIDASISCOMEX').AsString);    //Registro DI/DA SISCOMEX
{*}         {BL} preencheData( nLinha, MyInc(Coluna), mdados.FieldByName('EntregaProgramada').AsString);//Entrega Programada
{*}         {E } oSheet.Cells[ nLinha, MyInc(Coluna)  ].Value := IfThen(mdados.FieldByName('CNPJ_CLIENTE').AsString    <> '', mdados.FieldByName('CNPJ_CLIENTE').AsString, ' ');

              mdados.Next;
            end;

           //ATENCAO A ESSA LINHA. SE ADICIONAR UMA COLUNA, PRECISA ALTERAR O "RANGE"
            Range := oSheet.Range['A'+inttostr(qt_linha_Inicial+1)+':' +
                    string(oSheet.Cells[mdados.RecordCount+qt_linha_Inicial+1, 18].Address)];

            Range.Borders[xlDiagonalDown].LineStyle       := 0;
            Range.Borders[xlDiagonalUp].LineStyle         := 0;
            Range.Borders[xlEdgeLeft].LineStyle           := xlContinuous;
            Range.Borders[xlEdgeLeft].ColorIndex          := 15;
            Range.Borders[xlEdgeLeft].Weight              := xlThin;
            Range.Borders[xlEdgeTop].LineStyle            := xlContinuous;
            Range.Borders[xlEdgeTop].ColorIndex           := 15;
            Range.Borders[xlEdgeTop].Weight               := xlThin;
            Range.Borders[xlEdgeBottom].LineStyle         := xlContinuous;
            Range.Borders[xlEdgeBottom].ColorIndex        := 15;
            Range.Borders[xlEdgeBottom].Weight            := xlThin;
            Range.Borders[xlEdgeRight].LineStyle          := xlContinuous;
            Range.Borders[xlEdgeRight].ColorIndex         := 15;
            Range.Borders[xlEdgeRight].Weight             := xlThin;
            Range.Borders[xlInsideVertical].LineStyle     := xlContinuous;
            Range.Borders[xlInsideVertical].ColorIndex    := 15;
            Range.Borders[xlInsideVertical].Weight        := xlThin;
            Range.Borders[xlInsideHorizontal].LineStyle   := xlContinuous;
            Range.Borders[xlInsideHorizontal].ColorIndex  := 15;
            Range.Borders[xlInsideHorizontal].Weight      := xlThin;

            Range.RowHeight := 15;

            //ANTENCAO A ESSA LINHA. SE ADICIONAR UMA COLUNA, PRECISA ALTERAR O "RANGE"
            oSheet.Sort.SetRange(oSheet.Range['A9:R' + IntToStr(nLinha)]);


            oSheet.Sort.Header       := xlGuess;
            oSheet.Sort.MatchCase    := False;
            oSheet.Sort.Orientation  := xlTopToBottom;
            oSheet.Sort.SortMethod   := xlPinYin;
            oSheet.Sort.Apply;

          except
            on e:Exception do
            begin
              VMsg('Erro - RelFollowUpNestleImpoUrgentes: ' + e.Message, msError, True);
            end
          end;
        finally
          Excel.Visible := chkVisualizarExcel.checked;
          if FileExists(GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xlsx') then
            SysUtils.DeleteFile(GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xlsx');

          Excel.ActiveWorkBook.SaveAs(GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xlsx');
        end;

        if tem_dados then
           Result := GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xlsx'
        else
           Result := 'Sem Dados';

      finally
        try
          Excel.ActiveWorkBook.Close(False);
          KillExcel(Excel);
        except
        end;
      end;

    finally
      FreeAndNil(vQryEventos);
      mdados.Free;
      FreeAndNil(qry_mail_proc_nao_fat);
      FreeAndNil(db_broker);
    end;
end;

function TfrmMain.RelFollowupTransp(pUnidade, pProduto, pGrupo, pCliente, pTransportador: String): String;
var
  db_broker: TDatabase;
  qryEventos, qryRelatorio: TQuery;
  Excel, WorkBook, Sheet, Range: OleVariant;
  TimeStamp, NomeProduto: String;
  Linha: Integer;

  procedure PreencheEvento(AColuna: Integer; AEvento: String);
  begin
    //Sheet.Cells[Linha, AColuna].NumberFormat := '[$-409] dd/mm/aaaa;@';
    //Sheet.Cells[Linha, AColuna].HorizontalAlignment := xlCenter;
    with qryEventos do
    begin
      First;
      if Locate('CD_EVENTO', AEvento, []) then
      begin
        if (AnsiIndexText(FieldByName('DT_REALIZACAO').AsString, ['', 'N/A', 'TO BE CONFIRMED']) < 0) then
        begin
          if AnsiIndexText(AEvento, ['270', '271']) >= 0 then
            //Sheet.Cells[Linha, AColuna].Value := StrToDate(FieldByName('DT_REALIZACAO').AsString) + StrToTime(FieldByName('HR_REALIZACAO').AsString)
            Sheet.Cells[Linha, AColuna].Value := FieldByName('DT_REALIZACAO').AsDateTime
          else
            Sheet.Cells[Linha, AColuna].Value := DateOf(FieldByName('DT_REALIZACAO').AsDateTime);
        end
        else
          Sheet.Cells[Linha, AColuna].Value := '';//FieldByName('DT_REALIZACAO').AsString;

        if FieldByName('DT_REALIZACAO_EFETIVA').AsString <> '' then
          if ((DayOfWeek(Date) = 2) and (FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -3)) or ((DayOfWeek(Date) <> 2) and (FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -1)) then
            Sheet.Cells[Linha, AColuna].Interior.ColorIndex := 40;
      end
      else
        Sheet.Cells[Linha, AColuna].Value := '';
    end;
  end;
begin
  Result := '';
  try
    db_broker:= TDatabase.Create(Self);
    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;

    try
      db_broker.Connected := True;
      Excel    := CreateOLEObject('Excel.Application');
      try
        WorkBook := Excel.Workbooks.Open(GetPath+'FOLLOWUP_TRANSP_Nestle.xls');
        Excel.Visible := chkVisualizarExcel.checked;
        TimeStamp := FormatDateTime('ddmmyyyyhhnnsszz', Now);

        try
          Sheet := WorkBook.Worksheets[1];

          qryEventos := TQuery.Create(Self);
          qryEventos.DatabaseName := 'DBBROKER';
          qryRelatorio := TQuery.Create(Self);
          qryRelatorio.DatabaseName := 'DBBROKER';

          with qryEventos do
          begin
            SQL.Add('SELECT *');
            SQL.Add('FROM TFOLLOWUP');
            SQL.Add('WHERE NR_PROCESSO = :NR_PROCESSO');
            SQL.Add('  AND CD_EVENTO IN ("486", "131", "551", "162", "012", "763", "830", "021", "088", "597", "387", "616", "041", "779", "838", "164")');
          end;

          with qryRelatorio do
          begin
            SQL.Clear;
            SQL.Add('SELECT ISNULL((SELECT RTRIM(AP_UNID_NEG)');
            SQL.Add('               FROM TUNID_NEG (NOLOCK)');
            SQL.Add('               WHERE CD_UNID_NEG = :CD_UNID_NEG), "Todas") AS NM_UNID_NEG,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_PRODUTO)');
            SQL.Add('               FROM TPRODUTO (NOLOCK)');
            SQL.Add('               WHERE CD_PRODUTO = :CD_PRODUTO), "Todos") AS NM_PRODUTO,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_GRUPO)');
            SQL.Add('               FROM TGRUPO (NOLOCK)');
            SQL.Add('               WHERE CD_GRUPO = :CD_GRUPO), "Todos") AS NM_GRUPO,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_EMPRESA)');
            SQL.Add('               FROM TEMPRESA_NAC (NOLOCK)');
            SQL.Add('               WHERE CD_EMPRESA = :CD_CLIENTE), "Todos") AS NM_CLIENTE,');
            SQL.Add('       ISNULL((SELECT RTRIM(NM_TRANSP_ROD)');
            SQL.Add('               FROM TTRANSP_ROD (NOLOCK)');
            SQL.Add('               WHERE CD_TRANSP_ROD = :CD_TRANSPORTADOR), "Todos") AS NM_TRANSPORTADOR');
            ParamByName('CD_UNID_NEG').AsString      := pUnidade;
            ParamByName('CD_PRODUTO').AsString       := pProduto;
            ParamByName('CD_GRUPO').AsString         := pGrupo;
            ParamByName('CD_CLIENTE').AsString       := pCliente;
            ParamByName('CD_TRANSPORTADOR').AsString := pTransportador;
            Open;

            Sheet.Cells[02, 06].value :=  'Unidade: ' + pUnidade + ' - ' + Fields[0].AsString;
            Sheet.Cells[03, 06].value :=  'Produto: ' + pProduto + ' - ' + Fields[1].AsString;
            Sheet.Cells[04, 06].value :=  'Grupo Cliente: ' + pGrupo + ' - ' + Fields[2].AsString;
            Sheet.Cells[05, 06].value :=  'Cliente: ' + pCliente + ' - ' + Fields[3].AsString;
            Sheet.Cells[06, 06].value :=  'Transportadora: ' + pTransportador + ' - ' + Fields[4].AsString;
            Sheet.Cells[07, 06].value :=  'Data: ' + FormatDateTime('dd/mm/yyyy', Now);

            NomeProduto := Copy(Fields[1].AsString, 1, 3);
            Result := GetPath+'Gerados\FOLLOWUP_' + NomeProduto + '_' + TimeStamp + '.xls';
            Close;

            SQL.Clear;
            SQL.Add('SELECT RTRIM(PR.NR_PROCESSO) AS Processo,');
            SQL.Add('       (SELECT TOP 1 LTRIM(RTRIM(R.CD_REFERENCIA))');
            SQL.Add('        FROM TREF_CLIENTE R (NOLOCK)');
            SQL.Add('        WHERE R.NR_PROCESSO = PR.NR_PROCESSO');
            SQL.Add('          AND R.TP_REFERENCIA = CASE WHEN SUBSTRING(R.NR_PROCESSO, 3, 2) = "01" THEN GR.TP_PEDIDO_BUSCA_IMP');
            SQL.Add('                                ELSE GR.TP_PEDIDO_BUSCA');
            SQL.Add('                                END');
            SQL.Add('        ORDER BY DT_REFERENCIA DESC) AS Pedido,');
            SQL.Add('       RTRIM(PB.NM_PAIS) AS PaisOrigem,');
            SQL.Add('       RTRIM(EF.NM_EMPRESA) AS Exportador,');
            SQL.Add('       RTRIM(CONVERT(VARCHAR(MAX), PR.TX_MERCADORIA)) AS Mercadoria,');
            SQL.Add('       RTRIM(PB.NM_PAIS) AS PaisProcedencia,');
            SQL.Add('       RTRIM(LF.DESCRICAO) AS Fronteira,');
            SQL.Add('       RTRIM(PR.NR_CONHECIMENTO) AS Conhecimento,');
            SQL.Add('       (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT ISNULL(RTRIM(LI.NR_LI) + ", ", "")), ", ")');
            SQL.Add('        FROM TPROCESSO_LI LI');
            SQL.Add('        WHERE LI.NR_PROCESSO = PR.NR_PROCESSO) AS LI,');
            SQL.Add('       (SELECT TOP 1 CONVERT(VARCHAR, LI.DT_DEFERIMENTO, 103)');
            SQL.Add('        FROM TPROCESSO_LI LI');
            SQL.Add('        WHERE LI.NR_PROCESSO = PR.NR_PROCESSO');
            SQL.Add('        ORDER BY LI.DT_DEFERIMENTO DESC) AS DeferimentoLI,');
            SQL.Add('       ISNULL(PR.CD_CANAL, 4) AS Canal,');
            SQL.Add('       (SELECT TOP 1 RTRIM(E.NM_ETAPA)');
            SQL.Add('        FROM TFOLLOWUP_ETAPA FE');
            SQL.Add('           INNER JOIN TETAPA E ON E.CD_ETAPA = FE.CD_ETAPA');
            SQL.Add('        WHERE FE.NR_PROCESSO = PR.NR_PROCESSO');
            SQL.Add('          AND ISNULL(E.IN_RETRABALHO, "0") = "0"');
            SQL.Add('        ORDER BY FE.DT_ALTERACAO DESC) AS Etapa,');
            SQL.Add('       RTRIM(TR.NM_TRANSP_ROD) AS Transportadora,');
            SQL.Add('       RTRIM(EN.NM_EMPRESA) AS Cliente,');
            SQL.Add('       (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(NR_DCTO_INSTRUCAO) + '', ''), '', '')');
            SQL.Add('        FROM TDOCUMENTO_INSTRUCAO (NOLOCK)');
            SQL.Add('        WHERE NR_PROCESSO = PR.NR_PROCESSO');
            SQL.Add('          AND CD_TIPO_DCTO_INSTR = ''01'') AS Faturas');
            SQL.Add('FROM TPROCESSO                          PR (NOLOCK)');
            SQL.Add('   INNER JOIN TEMPRESA_NAC              EN (NOLOCK) ON EN.CD_EMPRESA = PR.CD_CLIENTE');
            SQL.Add('   INNER JOIN TGRUPO                    GR (NOLOCK) ON GR.CD_GRUPO = EN.CD_GRUPO');
            SQL.Add('   INNER JOIN TFOLLOWUP                 F131 (NOLOCK) ON F131.NR_PROCESSO = PR.NR_PROCESSO AND F131.CD_EVENTO = "131" AND F131.IN_APLICAVEL = "1"');
            SQL.Add('   INNER JOIN TFOLLOWUP                 F164 (NOLOCK) ON F164.NR_PROCESSO = PR.NR_PROCESSO AND F164.CD_EVENTO = "164" AND F164.IN_APLICAVEL = "1"');
            SQL.Add('   LEFT  JOIN TPAIS_BROKER              PB   (NOLOCK) ON PB.CD_PAIS = PR.CD_PAIS_ORIGEM');
            SQL.Add('   LEFT  JOIN TDECLARACAO_IMPORTACAO    DI   (NOLOCK) ON DI.NR_PROCESSO = PR.NR_PROCESSO');
            SQL.Add('   LEFT  JOIN TEMPRESA_EST              EF   (NOLOCK) ON EF.CD_EMPRESA = ISNULL(PR.CD_EXPORTADOR, DI.CD_FORNECEDOR)');
            SQL.Add('   LEFT  JOIN TLOCAL_EMBARQUE           LF   (NOLOCK) ON LF.CODIGO = PR.CD_FRONTEIRA');
            SQL.Add('   LEFT  JOIN TTRANSP_ROD               TR   (NOLOCK) ON TR.CD_TRANSP_ROD = PR.CD_TRANSP_NAC');
            SQL.Add('WHERE :CD_UNID_NEG IN ("", PR.CD_UNID_NEG)');
            SQL.Add('  AND :CD_PRODUTO IN ("", PR.CD_PRODUTO)');
            SQL.Add('  AND :CD_GRUPO IN ("", EN.CD_GRUPO)');
            SQL.Add('  AND :CD_CLIENTE IN ("", PR.CD_CLIENTE)');
            SQL.Add('  AND :CD_TRANSPORTADOR IN ("", PR.CD_TRANSP_NAC)');
            SQL.Add('  AND PR.IN_CANCELADO = "0"');
            SQL.Add('  AND F131.DT_REALIZACAO IS NOT NULL'); // INDELP-359
            SQL.Add('  AND CONVERT(DATE, ISNULL(F164.DT_REALIZACAO, GETDATE()), 103) >= CONVERT(DATE, GETDATE() -1, 103)');
            ParamByName('CD_UNID_NEG').AsString      := pUnidade;
            ParamByName('CD_PRODUTO').AsString       := pProduto;
            ParamByName('CD_GRUPO').AsString         := pGrupo;
            ParamByName('CD_CLIENTE').AsString       := pCliente;
            ParamByName('CD_TRANSPORTADOR').AsString := pTransportador;
            Open;

            Linha := 9;

            if Eof then
              Result := 'Sem Dados'
            else
            begin
              while not Eof do
              begin
                Inc(Linha);

                if qryEventos.Active then
                  qryEventos.Close;
                qryEventos.ParamByName('NR_PROCESSO').AsString := FieldByName('Processo').AsString;
                qryEventos.Open;

                Sheet.Cells[Linha, 01].value := FieldByName('Processo').AsString;                                         // A
                Sheet.Cells[Linha, 02].value := FieldByName('Pedido').AsString;                                           // B
                Sheet.Cells[Linha, 03].value := FieldByName('Cliente').AsString;                                          // C
                Sheet.Cells[Linha, 04].value := FieldByName('Transportadora').AsString;                                   // D
                Sheet.Cells[Linha, 05].value := FieldByName('PaisOrigem').AsString;                                       // E
                Sheet.Cells[Linha, 06].value := FieldByName('Exportador').AsString;                                       // F
                Sheet.Cells[Linha, 07].value := FieldByName('Mercadoria').AsString;                                       // G
                Sheet.Cells[Linha, 08].value := FieldByName('Fronteira').AsString;                                        // H
                Sheet.Cells[Linha, 09].value := FieldByName('Conhecimento').AsString;                                     // I
                Sheet.Cells[Linha, 10].value := FieldByName('Faturas').AsString;                                          // J
                PreencheEvento(11, '486');                                                                                // K
                PreencheEvento(12, '131');                                                                                // L
                PreencheEvento(13, '551');                                                                                // M
                PreencheEvento(14, '162');                                                                                // N
                PreencheEvento(15, '012');                                                                                // O
                PreencheEvento(16, '763');                                                                                // P
                PreencheEvento(17, '830');                                                                                // Q
                Sheet.Cells[Linha, 18].value := FieldByName('LI').AsString;                                               // R
                if FieldByName('DeferimentoLI').AsString <> '' then
                  Sheet.Cells[Linha, 19].value := StrToDate(FieldByName('DeferimentoLI').AsString);                       // S
                PreencheEvento(20, '021');                                                                                // T
                case FieldByName('Canal').AsInteger of

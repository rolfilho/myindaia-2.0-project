              Sheet.Sort.SortFields.Add(Key:=Sheet.Range['O:O'], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
              Sheet.Sort.SortFields.Add(Key:=Sheet.Range['N:N'], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
              Sheet.Sort.SortFields.Add(Key:=Sheet.Range['M:M'], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
              Sheet.Sort.SortFields.Add(Key:=Sheet.Range['L:L'], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
              Sheet.Sort.SortFields.Add(Key:=Sheet.Range['K:K'], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
              Sheet.Sort.SortFields.Add(Key:=Sheet.Range['L:L'], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
              Sheet.Sort.SortFields.Add(Key:=Sheet.Range['K:K'], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
              Sheet.Sort.SortFields.Add(Key:=Sheet.Range['J:J'], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
              Sheet.Sort.SetRange(Sheet.Range['A10:AD' + IntToStr(Linha)]);
              Sheet.Sort.Header := xlGuess;

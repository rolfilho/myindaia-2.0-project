      Excel.ActiveWorkBook.SaveAs(GetPath + 'Gerados\FOLLOWUP_' + DescCab.Produto + '_' + vTimeStamp + '.XLS');
      Result := GetPath + 'Gerados\FOLLOWUP_' + DescCab.Produto + '_' + vTimeStamp + '.XLS';


{**Prepara o inicio da importaçăo do EDI**}
procedure TfrmMain.InitImport;
var
  Rec: TSearchRec;
begin
  stbMain.Panels[0].Text := 'Importando...';
  EDI.Texto.Clear; SCRIPT.Clear;
//  aqui carla - colocar a qry
  {**Mensagem 1 - Faturas de importaçăo**}
  {if EDI.Tipo = 'x' then begin
     SCRIPT.LoadFromFile('MENSAGEM20.TXT');
     {GUIA_LOG.LoadFromFile('GUIALOG1.TXT');
     {**Abrir as tabelas da mensagem 1
     Reseta o buffer de calculo de PO**
     //SetLength(EDI.POS_CALC,0);
  end;}
  if EDI.Tipo = 'K' then
  begin
    SCRIPT.LoadFromFile('mensagem01.TXT');
  end;
  if EDI.Tipo = 'L' then
  begin
    SCRIPT.LoadFromFile('mensagem03.TXT');
  end;
  if EDI.Tipo = 'M' then
  begin
    SCRIPT.LoadFromFile('mensagem10.TXT');
  end;
  if EDI.Tipo = 'N' then
  begin
    SCRIPT.LoadFromFile('mensagem11.TXT');
  end;

  {**Inicia a transaçăo especifica para o EDI**}
  {**Carrega o arquivo do EDI**}
  WatchTimer.Enabled := False;
  EDI.Texto.Clear;
  with TQuery.Create(Self) do begin
    try
      SessionName  := 'SES_EDI';
      DataBaseName := 'BROKER';
      SQL.Add('SELECT NM_PATH_EDI FROM TFILA_LOG (NOLOCK) WHERE CD_FILA = ' + IntToStr(EDI.Fila_Reg));
      Open;
      {**Verifica o tamanhdo e determina o processo de leitura**}
      SysUtils.FindFirst(Fields[0].AsString,faAnyFile,Rec);

      if Rec.Size < 2000000 then begin
         EDI.USE_HUGE_FILE := False;
         EDI.Texto.LoadFromFile(Fields[0].AsString);
      end
      else
      begin
         EDI.USE_HUGE_FILE := True;
         Edi.Path          := Fields[0].AsString;
         Edi.HUGE_FILE     := TFileStream.Create(Fields[0].AsString,fmOpenRead and fmShareDenyNone);
      end;
    finally
      Free;
    end;
  end;
  WatchTimer.Enabled := True;

  {**Limite săo as linhas do texto de dados**}
  if EDI.USE_HUGE_FILE then EDI.LIMITE := EDI.HUGE_FILE.Size-1
  else                      EDI.LIMITE := Edi.Texto.Count-1;

  {**Reseta o gauge**}
  grfBar.Progress := 0;
  grfBar.MaxValue := Edi.Limite;
  grfBar.ShowText := True;

  {**Grava o data do inicio do processo**}
  with TQuery.Create(Self) do begin
    try
      SessionName  := 'SES_EDI';
      DataBaseName := 'BROKER';
      //SQL.Add('UPDATE TFILA_LOG SET DT_INIPROC = ' + QuotedStr(FormatDateTime('YYYY/MM/DD HH:NN:SS',now)) + ' where CD_FILA = ' + IntToStr(EDI.Fila_Reg));
      SQL.Add('UPDATE TFILA_LOG SET DT_INIPROC = ' + QuotedStr(DateTimeToStr(now)) + ' WHERE CD_FILA = ' + IntToStr(EDI.Fila_Reg));
      ExecSQL;
    finally
      Free;
    end;
  end;

  {**Inicializaçâo concluída**}
  VMSG('Importando arquivo ' + EDI.Path,msSystem,True);
  TotalErros := 0;
  Reload := False;
  Start := GetTickCount;
  EDI.Inicio := FormatDateTime('DD/MM/YYYY HH:NN:SS',Now);

  FaturaIgnorada := False;
end;


      '  LEFT  JOIN TEMPRESA_EST           EXPOR   (NOLOCK) ON EXPOR.CD_EMPRESA  = EDI.CD_EXPORTADOR                              ' + sLineBreak +
      '                                                                                                                           ' + sLineBreak +
      '  OUTER APPLY( SELECT STUFF((SELECT DISTINCT '', '' + RTRIM(RCP.CD_REFERENCIA)                                             ' + sLineBreak +
      '                               FROM TREF_CLIENTE RCP   (NOLOCK)                                                            ' + sLineBreak +
      '                              WHERE RCP.TP_REFERENCIA  =''01''                                                             ' + sLineBreak +
      '                                AND RCP.NR_PROCESSO    = P.NR_PROCESSO                                                     ' + sLineBreak +
      '                           FOR XML PATH('''')), 1, 2, '''') AS PEDIDO  ) REF_PED                                           ' + sLineBreak +
      '                                                                                                                           ' + sLineBreak +
      '  OUTER APPLY( SELECT STUFF((SELECT DISTINCT '', '' + RTRIM(RCP.CD_REFERENCIA)                                             ' + sLineBreak +
      '                               FROM TREF_CLIENTE RCP   (NOLOCK)                                                            ' + sLineBreak +
      '                              WHERE RCP.TP_REFERENCIA  =''04''                                                             ' + sLineBreak +
      '                                AND RCP.NR_PROCESSO    = P.NR_PROCESSO                                                     ' + sLineBreak +
      '                                AND RCP.CD_REFERENCIA LIKE ''%SAHY%''                                                      ' + sLineBreak +
      '                           FOR XML PATH('''')), 1, 2, '''') AS CLIENTE  ) REF_CLIENTE                                      ' + sLineBreak +
      '                                                                                                                           ' + sLineBreak +
      '  OUTER APPLY( SELECT STUFF((SELECT DISTINCT '', '' + RTRIM(RCP.CD_REFERENCIA)                                             ' + sLineBreak +
      '                               FROM TREF_CLIENTE RCP   (NOLOCK)                                                            ' + sLineBreak +
      '                              WHERE RCP.TP_REFERENCIA  =''04''                                                             ' + sLineBreak +
      '                                AND RCP.NR_PROCESSO    = P.NR_PROCESSO                                                     ' + sLineBreak +
      '                                AND NOT (RCP.CD_REFERENCIA LIKE ''%SAHY%'')                                                ' + sLineBreak +
      '                           FOR XML PATH('''')), 1, 2, '''') AS OUTROS  ) REF_OUTROS                                        ' + sLineBreak +
      '                                                                                                                           ' + sLineBreak +
      '   LEFT JOIN TFOLLOWUP              F889    (NOLOCK) ON F889.NR_PROCESSO  = P.NR_PROCESSO                                  ' + sLineBreak +
      '                                                    AND F889.CD_SERVICO   = P.CD_SERVICO                                   ' + sLineBreak +
      '                                                    AND F889.CD_EVENTO    = ''889''  --RECEPÇĂO DA CÓPIA DA INVOICE        ' + sLineBreak +
      '   LEFT JOIN TFOLLOWUP              F919    (NOLOCK) ON F919.NR_PROCESSO  = P.NR_PROCESSO                                  ' + sLineBreak +
      '                                                    AND F919.CD_SERVICO   = P.CD_SERVICO                                   ' + sLineBreak +
      '                                                    AND F919.CD_EVENTO    = ''919''  --1Ş APROVAÇĂO DE EMBARQUE            ' + sLineBreak +
      '   LEFT JOIN TFOLLOWUP              F189    (NOLOCK) ON F189.NR_PROCESSO  = P.NR_PROCESSO                                  ' + sLineBreak +
      '                                                    AND F189.CD_SERVICO   = P.CD_SERVICO                                   ' + sLineBreak +
      '                                                    AND F189.CD_EVENTO    = ''189''  --CHEGADA LOCAL EMBARQUE              ' + sLineBreak +
      '   LEFT JOIN TFOLLOWUP              F162    (NOLOCK) ON F162.NR_PROCESSO  = P.NR_PROCESSO                                  ' + sLineBreak +
      '                                                    AND F162.CD_SERVICO   = P.CD_SERVICO                                   ' + sLineBreak +
      '                                                    AND F162.CD_EVENTO    = ''162''  --CHEGADA DO NAVIO / AVIĂO / CAMINHĂO ' + sLineBreak +
      '   LEFT JOIN TFOLLOWUP              F021    (NOLOCK) ON F021.NR_PROCESSO  = P.NR_PROCESSO                                  ' + sLineBreak +
      '                                                    AND F021.CD_SERVICO   = P.CD_SERVICO                                   ' + sLineBreak +
      '                                                    AND F021.CD_EVENTO    = ''021''  --REGISTRO DI/DA SISCOMEX             ' + sLineBreak +
      '   LEFT JOIN TFOLLOWUP              F088    (NOLOCK) ON F088.NR_PROCESSO  = P.NR_PROCESSO                                  ' + sLineBreak +
      '                                                    AND F088.CD_SERVICO   = P.CD_SERVICO                                   ' + sLineBreak +
      '                                                    AND F088.CD_EVENTO    = ''088''  --DESEMBARAÇO                         ' + sLineBreak +
    { '   LEFT JOIN TFOLLOWUP              F022    (NOLOCK) ON F022.NR_PROCESSO  = P.NR_PROCESSO                                  ' + sLineBreak +
      '                                                    AND F022.CD_SERVICO   = P.CD_SERVICO                                   ' + sLineBreak +
      '                                                    AND F022.CD_EVENTO    = ''022''  --OBSERVACAO                          ' + sLineBreak + }
      '   WHERE P.CD_GRUPO      = :CD_GRUPO --''C04''                                                                             ' + sLineBreak +
      '     AND P.IN_CANCELADO  = ''0''                                                                                           ' + sLineBreak +
      '     AND P.CD_PRODUTO    = ''01''	                                                                                        ' + sLineBreak +
      '     AND F222.IN_APLICAVEL = 1                                                                                             ' + sLineBreak +
      '     AND (F222.DT_REALIZACAO IS NULL  OR F222.DT_REALIZACAO >=  DATEADD(DAY, -15, GETDATE()))                              ' + sLineBreak +
      ' ORDER BY  F222.DT_REALIZACAO                                                                                              ' + sLineBreak ;
end;

function FormataData(Field: TField): string;
begin
  Result := '';
  if (not Field.IsNull) then
    if StrToDateDef(Field.AsString, 0) > 0 then
      Result := FormatDateTime('dd/mm/yyyy', Field.AsDateTime);
end;



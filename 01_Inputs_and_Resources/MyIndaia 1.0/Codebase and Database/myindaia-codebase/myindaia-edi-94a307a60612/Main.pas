                      vArquivoGerado := 'IVP'
                      //é enviado pelo robo de parametrizaçăo
                    end
                    else
                    if (Fields[1].AsString = 'IVL') then
                      vArquivoGerado := 'IVL';
                  Finally
                    Close;
                    Free;
                  end;
                end;
              end;
              if   ( vArquivoGerado <> 'IVP' )
               and ( vArquivoGerado <> 'IVL' )
               and ( vArquivoGerado <> 'Sem Dados' ) then
              begin
                // Finalizado, ele retorna o nome da planilha gerada... E salva no TX_FILTRO, para que ele envie por InitSendMail.
                with TQuery.Create(Self) do
                begin
                  try
                    DataBaseName := 'BROKER';
                    SessionName  := 'SES_EDI';
                    if  ( Trim(vArquivoGerado) <> '' )
                    and ( vArquivoGerado <> 'E02' )
                    and ( vArquivoGerado <> 'E03' )
                    and ( vArquivoGerado <> 'E04' )
                    and ( vArquivoGerado <> 'E05' )
                    and ( vArquivoGerado <> 'E06' )
                    and ( vArquivoGerado <> 'E08' )
                    and ( vArquivoGerado <> 'E09' )
                    and ( vArquivoGerado <> 'E10' )
                    and ( vArquivoGerado <> 'E12' )
                    and ( vArquivoGerado <> 'E14' )
                    and ( vArquivoGerado <> 'E15' )
                    and ( vArquivoGerado <> 'E16' )
                    and ( vArquivoGerado <> 'E17' )
                    and ( vArquivoGerado <> 'E18' )
                    and ( vArquivoGerado <> 'DFT' )
                    and ( vArquivoGerado <> 'DFJ' )
                    and ( vArquivoGerado <> 'DFA' )
                    and ( vArquivoGerado <> 'CIS' )
                    and ( vArquivoGerado <> 'DUE' )
                    and ( vArquivoGerado <> 'AVE' )
                    and ( vArquivoGerado <> 'DF0' ) then
                    begin
                      SQL.Add('SELECT MAX(CD_FILA) from TFILA_LOG (NOLOCK) ');
                      Open;
                      try
                        MAX_FILA := Fields[0].AsInteger + 1;
                      except
                        MAX_FILA := 0;
                      end;
                      SQL.Clear;
                      SQL.ADD('INSERT INTO TFILA_LOG ( CD_FILA, ORIGEM, TP_OPERACAO, NM_PATH_EDI, EDI, RESOLVIDA, TX_FILTRO) VALUES ');
                      SQL.ADD('                      (:CD_FILA,:ORIGEM,:TP_OPERACAO,:NM_PATH_EDI,:EDI,:RESOLVIDA,:TX_FILTRO)');
                      Params[0].AsInteger := MAX_FILA;
                      Params[1].AsString  := 'A';
                      Params[2].AsString  := 'M';

                      if SameText(vArquivoGerado, 'Sem Dados') then
                        Params[3].AsString  := ''
                      else
                        Params[3].AsString  := vArquivoGerado;

                      Params[4].AsString  := 'M';
                      Params[5].AsString  := 'N';
                      Params[6].AsString  := 'HORARIO="'+FormatDateTime('HH:mm',AGENDA.FieldByName('PROXIMA_EXEC').AsDateTime)+'"/CD_RELATORIO="' + vUltimaRelatorioEncontrado + '"'; //ExtractWord(2,AGENDA.FieldByName('NM_PATH_EDI').AsString,'/') + '/' + '
                      ExecSQL;
                    end
                    else
                      if  ( vArquivoGerado <> 'E02' )
                      and ( vArquivoGerado <> 'E03' )
                      and ( vArquivoGerado <> 'E04' )
                      and ( vArquivoGerado <> 'E05' )
                      and ( vArquivoGerado <> 'E08' )
                      and ( vArquivoGerado <> 'E09' )
                      and ( vArquivoGerado <> 'E10' )
                      and ( vArquivoGerado <> 'E06' )
                      and ( vArquivoGerado <> 'E12' )
                      and ( vArquivoGerado <> 'E14' )
                      and ( vArquivoGerado <> 'E15' )
                      and ( vArquivoGerado <> 'E16' )
                      and ( vArquivoGerado <> 'E17' )
                      and ( vArquivoGerado <> 'E18' )
                      and ( vArquivoGerado <> 'DFF' )
                      and ( vArquivoGerado <> 'FPE' )
                      and ( vArquivoGerado <> 'DFT' )
                      and ( vArquivoGerado <> 'DFA' )
                      and ( vArquivoGerado <> 'CIS' )
                      and ( vArquivoGerado <> 'DUE' )
                      and ( vArquivoGerado <> 'AVE' )
                      and ( vArquivoGerado <> 'DF0' ) then
                        vMsg(PChar('Năo foram encontrados registros para o relatório : ' + vUltimaRelatorioEncontrado),msSystem,true);
                    // da um update para dizer que já foi executado para todos os usuarios desse alerta nesse horario.
                    SQL.Clear;
                    //if vArquivoGerado <> '' then
                    begin
                      SQL.ADD('UPDATE TFILA_AGENDA SET DT_ULTIMA_EXEC = :DATA, ULTIMA_EXEC = ''00:00'' WHERE NM_PATH_EDI LIKE ''%CD_RELATORIO="'+vUltimaRelatorioEncontrado+'"%'' AND PROXIMA_EXEC = ''' + FormatDateTime('HH:mm',AGENDA.FieldByName('PROXIMA_EXEC').AsDateTime) + '''');
                      ParamByName('DATA').AsDateTime := now;
                      ExecSQL;
                    end;
                  Finally
                    Free;
                    vArquivoGerado := '';
                  end;
                  //AGENDA.Last;
                end;
              end;
            end
            else
            if AGENDA.FieldByName('EDI').AsString = '#' then  // deleta os .XLS antigos, evitando que sobrecarregue o HD do servidor
            begin
              ApagaArquivosXLS;
              with TQuery.Create(Self) do
              begin
                try
                  DataBaseName := 'BROKER';
                  SessionName  := 'SES_EDI';
                  SQL.ADD('UPDATE TFILA_AGENDA SET DT_ULTIMA_EXEC = :DATA, ULTIMA_EXEC = ''00:00'' WHERE CD_AGENDA = ' + QuotedStr(AGENDA.FieldByName('CD_AGENDA').AsString));
                  ParamByName('DATA').AsDateTime := now;
                  ExecSQL;
                Finally
                  Free;
                end;
              end;
              VMSG('**************************************************************',msSuccess,False);
              VMSG('Limpeza de arquivos XLS concluída.                            ',msSuccess,False);
              VMSG('**************************************************************',msSuccess,False);
              vArquivoGerado := 'X';
            end
            else
            // dispara as confirmaçőes de embarque ( exportaçăo )
            if AGENDA.FieldByName('EDI').AsString = 'E' then
            begin
              if ExtractWord(2,AGENDA.FieldByName('NM_PATH_EDI').AsString,'"') <> vUltimaConfirmacao then
              begin
                if Integra_EDI(ExtractWord(2,AGENDA.FieldByName('NM_PATH_EDI').AsString,'"') ) then
                begin
                  VMSG('**************************************************************',msSuccess,False);
                  VMSG('Integraçăo EDI executada com sucesso.                         ',msSuccess,False);
                  VMSG('**************************************************************',msSuccess,False);
                end;

                with TQuery.Create(Self) do
                begin
                  try
                    DataBaseName := 'BROKER';
                    SessionName  := 'SES_EDI';
                    SQL.ADD('UPDATE TFILA_AGENDA SET DT_ULTIMA_EXEC = :DATA, ULTIMA_EXEC = ''00:00'' WHERE NM_PATH_EDI LIKE ''%CD_RELATORIO="'+ExtractWord(2,AGENDA.FieldByName('NM_PATH_EDI').AsString,'"')+'"%'' AND PROXIMA_EXEC = ''' + AGENDA.FieldByName('PROXIMA_EXEC').AsString + '''');
                    ParamByName('DATA').AsDateTime := now;
                    ExecSQL;
                  Finally
                    Free;
                  end;
                end;
              end;
              vArquivoGerado := 'X';
              vUltimaConfirmacao := ExtractWord(2,AGENDA.FieldByName('NM_PATH_EDI').AsString,'"');
            end
            else
            begin
              with TQuery.Create(Self) do
              begin
                try
                  DataBaseName := 'BROKER';
                  SessionName  := 'SES_EDI';
                  SQL.Add('SELECT MAX(CD_FILA) from TFILA_LOG (NOLOCK)');
                  Open;
                  try
                    MAX_FILA := Fields[0].AsInteger + 1;
                  except
                    MAX_FILA := 0;
                  end;
                  SQL.Clear;
                  SQL.ADD('INSERT INTO TFILA_LOG ( CD_FILA, ORIGEM, TP_OPERACAO, NM_PATH_EDI, EDI, RESOLVIDA, TX_FILTRO) VALUES ');
                  SQL.ADD('                      (:CD_FILA,:ORIGEM,:TP_OPERACAO,:NM_PATH_EDI,:EDI,:RESOLVIDA,:TX_FILTRO)');
                  Params[0].AsInteger := MAX_FILA;
                  Params[1].AsString  := 'A';
                  Params[2].AsString  := 'E';
                  Params[3].AsString  := AGENDA.FieldByName('NM_PATH_EDI').AsString;
                  Params[4].AsString  := AGENDA.FieldByName('EDI').AsString;
                  Params[5].AsString  := 'N';
                  Params[6].AsString  := 'DATA_FILTRO = ' + QuotedStr(FormatDateTime('YYYY/MM/DD',Date)) + ' AND FLAG_REENVIO <> ' + QuotedStr('S');
                  ExecSQL;
                  vArquivoGerado := 'X';
                Finally
                  Free;
                end;
              end;
            end;

            if vArquivoGerado <> '' then
            begin
              if AGENDA.FieldByName('METODO_AGEND').AsString = 'M' then
              begin
                T := IncTime(N,0,AGENDA.FieldByName('Minutos').AsInteger,0,0);
                with TQuery.Create(Self) do
                begin
                  try
                    DataBaseName := 'BROKER';
                    SessionName  := 'SES_EDI';
                    SQL.Add('UPDATE TFILA_AGENDA SET PROXIMA_EXEC = ' + QuotedStr(FormatDateTime('HH:NN',T)) + ' WHERE CD_AGENDA = ' + QuotedStr(AGENDA.FieldByName('CD_AGENDA').AsString));
                    ExecSQL;
                  Finally
                    Free;
                  end;
                end;
              end
              else
              begin
                Str.Text := AGENDA.FieldByName('HORAS').AsString;
                if Str.Count > 0 then
                begin
                  for c := 0 to Str.Count-1 do
                  begin
                    if CompareStr(Str[c],FormatDateTime('HH:NN',N)) > 0 then
                      break;
                  end;
                  if c = Str.Count then
                    c := 0;
                  T := IncTime(Now,0,(AGENDA.FieldByName('Horas').AsInteger * 60),0,0);
                  with TQuery.Create(Self) do
                  begin
                    try
                      DataBaseName := 'BROKER';
                      SessionName  := 'SES_EDI';
                      SQL.Add('UPDATE TFILA_AGENDA SET PROXIMA_EXEC = ' + QuotedStr(FormatDateTime('HH:NN',AGENDA.FieldByName('PROXIMA_EXEC').AsDateTime)) + ', DT_ULTIMA_EXEC = :DATA, ULTIMA_EXEC = ''00:00'' WHERE CD_AGENDA = ' + QuotedStr(AGENDA.FieldByName('CD_AGENDA').AsString));
                      ParamByName('DATA').AsDateTime := now;
                      ExecSQL;
                    Finally
                      Free;
                    end;
                  end;
                end;
              end;
            end;

            Str.Free;
          end
          else
            with TQuery.Create(Self) do
            begin
              try
                DataBaseName := 'BROKER';
                SessionName  := 'SES_EDI';
                SQL.ADD('UPDATE TFILA_AGENDA SET DT_ULTIMA_EXEC = :DATA, ULTIMA_EXEC = ''00:00'' WHERE NM_PATH_EDI LIKE ''%CD_RELATORIO="'+vUltimaRelatorioEncontrado+'"%'' AND PROXIMA_EXEC = ''' + FormatDateTime('HH:mm',AGENDA.FieldByName('PROXIMA_EXEC').AsDateTime) + '''');
                ParamByName('DATA').AsDateTime := Now;
                ExecSQL;
              finally
                Free;
              end;
            end;
        end
        //else if (DayOfTheWeek(Now) < 6) then
        else if (DayOfTheWeek(Now) < 6) or // Segunda a Sexta
           ((DayOfTheWeek(Now) = 6) and AGENDA.FieldByName('IN_SABADO').AsBoolean) or // Sábado
           ((DayOfTheWeek(Now) = 7) and AGENDA.FieldByName('IN_DOMINGO').AsBoolean) then // Domingo
        begin
          if (AGENDA.FieldByName('ATIVO').AsString = '1') and
             (FormatDateTime('HH:mm',IncTime(AGENDA.FieldByName('PROXIMA_EXEC').AsDateTime,0,1,0,0)) = FormatDateTime('HH:mm',Now)) and
             (AGENDa.FieldByName('PROXIMA_EXEC').AsDateTime = AGENDa.FieldByName('ULTIMA_EXEC').AsDateTime) then
          begin
            with TQuery.Create(Self) do
            begin
              try
                DataBaseName := 'BROKER';
                SessionName  := 'SES_EDI';
                SQL.ADD('UPDATE TFILA_AGENDA SET ULTIMA_EXEC = ' + QuotedStr('00:00') + ' WHERE CD_AGENDA = ' + QuotedStr(AGENDA.FieldByName('CD_AGENDA').AsString));
                ExecSQL;
              Finally
                Free;
              end;
            end;
          end;
        end;
        if (Sender is TfrmGeraRelatorio) then
          Break;

        {Ocupado := 0;
        ProcessarOrdensNaoResolvidas;
        Done := False;
        ProcessLoop(Application, Done);}

        AGENDA.NEXT;
      end;
    finally
      AGENDA.Free;
      WatchTimer.Enabled := True;
      lblAlerta.Caption := '';
      lbltIPOAlerta.Caption := '';
      Application.ProcessMessages;
//      ShellExecute(Handle,'open',pchar(GetPath+'FechaProcessoExcel'),nil,nil,SW_HIDE);
    end;
    // final do loop dos registros da agenda.
    {**Se ocioso, procurar por ordens năo resolvidas**}
    ProcessarOrdensNaoResolvidas;

  except
    on E: Exception do
    begin
      Lock := False;
      Ocupado := 0;
      Reload := False;

//      VMSG('Erro fatal: ' + e.Message,msError,False);
      VMSG('Erro fatal: Ultimo processo: '+vUltimoProcessoAntesdoErro+'  ' + e.Message,msError,False);
    end;
  end;
  Lock := False;
  memLog.SetFocus;
end;

function TFrmMain.Space( str : string; i : Integer) : String;
var
  s : string;
begin
  s := '';
  While Length( s ) < i do s := s + str;
  Space := s;
end;


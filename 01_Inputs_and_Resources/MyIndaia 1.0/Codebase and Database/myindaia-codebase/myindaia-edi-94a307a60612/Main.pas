          SQL.Add('        AND DATEDIFF(DAY,( FU2.DT_REALIZACAO + SE.PZ_DO_EV_BASICO ),GETDATE()) >  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO2_GP ),1000) ');

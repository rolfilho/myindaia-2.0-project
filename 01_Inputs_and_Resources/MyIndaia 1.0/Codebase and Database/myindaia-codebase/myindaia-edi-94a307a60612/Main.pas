    '                            ORDER BY DT_ALTERACAO DESC) AS STATUS_PROCESSO ' + sLineBreak +
    ' , CAST(F114.DT_REALIZACAO AS DATE) AS F114_PROCESSO_ENVIADO_FATURAMENTO ' + sLineBreak +
    ' , CAST(F092.DT_REALIZACAO AS DATE) AS F092_FATURAMENTO_INDAIA ' + sLineBreak +
    ' , F022.TX_OBS AS F022_OBSERVACOES ' + sLineBreak +
    ' FROM TPROCESSO TP ' + sLineBreak +
    ' INNER JOIN TEMPRESA_NAC ON TP.CD_CLIENTE = TEMPRESA_NAC.CD_EMPRESA ' + sLineBreak +
    ' INNER JOIN TAREA ON TP.CD_AREA = TAREA.CD_AREA ' + sLineBreak +
    ' LEFT JOIN TTRANSP_ROD ON TP.CD_TRANSP_NAC = TTRANSP_ROD.CD_TRANSP_ROD ' + sLineBreak +
    ' LEFT JOIN TLOCAL_EMBARQUE L_EMB ON TP.CD_LOCAL_EMBARQUE = L_EMB.CODIGO ' + sLineBreak +
    ' LEFT JOIN TLOCAL_EMBARQUE L_DESEN ON TP.CD_LOCAL_DESEMBARQUE = L_DESEN.CODIGO ' + sLineBreak +
    ' LEFT JOIN TLOCAL_EMBARQUE L_TRANSB ON TP.CD_LOCAL_TRANSBORDO = L_TRANSB.CODIGO ' + sLineBreak +
    ' LEFT JOIN TEMPRESA_EST ON TP.CD_IMPORTADOR = TEMPRESA_EST.CD_EMPRESA ' + sLineBreak +
    ' LEFT JOIN TPAIS_BROKER PAIS_IMP ON PAIS_IMP.CD_PAIS = TEMPRESA_EST.CD_PAIS ' + sLineBreak +
    ' LEFT JOIN TPAIS_BROKER PAIS_DEST ON PAIS_DEST.CD_PAIS = TP.CD_PAIS_DESTINO ' + sLineBreak +
    ' LEFT JOIN TAGENTE ON TAGENTE.CD_AGENTE = TP.CD_AGENTE ' + sLineBreak +
    ' LEFT JOIN TEMBARCACAO ON TEMBARCACAO.CD_EMBARCACAO = TP.CD_EMBARCACAO ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F131 WITH (NOLOCK) ON TP.NR_PROCESSO = F131.NR_PROCESSO  AND TP.CD_SERVICO = F131.CD_SERVICO  AND F131.CD_EVENTO = ''131'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F124 WITH (NOLOCK) ON TP.NR_PROCESSO = F124.NR_PROCESSO  AND TP.CD_SERVICO = F124.CD_SERVICO  AND F124.CD_EVENTO = ''124'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F210 WITH (NOLOCK) ON TP.NR_PROCESSO = F210.NR_PROCESSO  AND TP.CD_SERVICO = F210.CD_SERVICO  AND F210.CD_EVENTO = ''210'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F348 WITH (NOLOCK) ON TP.NR_PROCESSO = F348.NR_PROCESSO  AND TP.CD_SERVICO = F348.CD_SERVICO  AND F348.CD_EVENTO = ''348'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F167 WITH (NOLOCK) ON TP.NR_PROCESSO = F167.NR_PROCESSO  AND TP.CD_SERVICO = F167.CD_SERVICO  AND F167.CD_EVENTO = ''167'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F731 WITH (NOLOCK) ON TP.NR_PROCESSO = F731.NR_PROCESSO  AND TP.CD_SERVICO = F731.CD_SERVICO  AND F731.CD_EVENTO = ''731'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F431 WITH (NOLOCK) ON TP.NR_PROCESSO = F431.NR_PROCESSO  AND TP.CD_SERVICO = F431.CD_SERVICO  AND F431.CD_EVENTO = ''431'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F089 WITH (NOLOCK) ON TP.NR_PROCESSO = F089.NR_PROCESSO  AND TP.CD_SERVICO = F089.CD_SERVICO  AND F089.CD_EVENTO = ''089'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F165 WITH (NOLOCK) ON TP.NR_PROCESSO = F165.NR_PROCESSO  AND TP.CD_SERVICO = F165.CD_SERVICO  AND F165.CD_EVENTO = ''165'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F271 WITH (NOLOCK) ON TP.NR_PROCESSO = F271.NR_PROCESSO  AND TP.CD_SERVICO = F271.CD_SERVICO  AND F271.CD_EVENTO = ''271'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F315 WITH (NOLOCK) ON TP.NR_PROCESSO = F315.NR_PROCESSO  AND TP.CD_SERVICO = F315.CD_SERVICO  AND F315.CD_EVENTO = ''315'' ' + sLineBreak +
    ' LEFT JOIN TARMAZEM ON TARMAZEM.CD_ARMAZEM = TP.CD_ARMAZEM_ATRACACAO ' + sLineBreak +
    ' LEFT JOIN TTP_CANAL ON TTP_CANAL.CD_CANAL = TP.CD_CANAL ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F088 WITH (NOLOCK) ON TP.NR_PROCESSO = F088.NR_PROCESSO  AND TP.CD_SERVICO = F088.CD_SERVICO  AND F088.CD_EVENTO = ''088'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F654 WITH (NOLOCK) ON TP.NR_PROCESSO = F654.NR_PROCESSO  AND TP.CD_SERVICO = F654.CD_SERVICO  AND F654.CD_EVENTO = ''654'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F901 WITH (NOLOCK) ON TP.NR_PROCESSO = F901.NR_PROCESSO  AND TP.CD_SERVICO = F901.CD_SERVICO  AND F901.CD_EVENTO = ''901'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F135 WITH (NOLOCK) ON TP.NR_PROCESSO = F135.NR_PROCESSO  AND TP.CD_SERVICO = F135.CD_SERVICO  AND F654.CD_EVENTO = ''135'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F125 WITH (NOLOCK) ON TP.NR_PROCESSO = F125.NR_PROCESSO  AND TP.CD_SERVICO = F125.CD_SERVICO  AND F125.CD_EVENTO = ''125'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F141 WITH (NOLOCK) ON TP.NR_PROCESSO = F141.NR_PROCESSO  AND TP.CD_SERVICO = F141.CD_SERVICO  AND F141.CD_EVENTO = ''141'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F114 WITH (NOLOCK) ON TP.NR_PROCESSO = F114.NR_PROCESSO  AND TP.CD_SERVICO = F114.CD_SERVICO  AND F114.CD_EVENTO = ''114'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F092 WITH (NOLOCK) ON TP.NR_PROCESSO = F092.NR_PROCESSO  AND TP.CD_SERVICO = F092.CD_SERVICO  AND F092.CD_EVENTO = ''092'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F022 WITH (NOLOCK) ON TP.NR_PROCESSO = F022.NR_PROCESSO  AND TP.CD_SERVICO = F022.CD_SERVICO  AND F022.CD_EVENTO = ''022'' ' + sLineBreak +
    ' LEFT JOIN TFOLLOWUP F314 WITH (NOLOCK) ON TP.NR_PROCESSO = F314.NR_PROCESSO  AND TP.CD_SERVICO = F314.CD_SERVICO  AND F314.CD_EVENTO = ''314'' ' + sLineBreak +
    ' LEFT  JOIN TEMBARCACAO E (NOLOCK) ON TP.CD_EMBARCACAO = E.CD_EMBARCACAO ' + sLineBreak +
    ' WHERE (F314.DT_REALIZACAO IS NULL OR CONVERT(DATE, F314.DT_REALIZACAO, 103) >= CONVERT(DATE, CONVERT(VARCHAR, GETDATE() -3, 103), 103)) ' + sLineBreak +
    ' AND TP.IN_CANCELADO   = ''0'' ' + sLineBreak +
    ' AND TP.IN_LIBERADO    = ''1'' ' + sLineBreak +
    ' AND F314.IN_APLICAVEL = ''1'' ' + sLineBreak +
    ' AND ISNULL(E.NM_EMBARCACAO, '''') NOT IN (''* PROCESSO CANCELADO'', ''TBN'', ''AGUARDANDO NAVIO'') ';

    if pUnidade <> '' then
      result := result + ('  AND TP.CD_UNID_NEG = ' + QuotedStr(pUnidade));
    if pProduto <> '' then
      result := result + ('  AND TP.CD_PRODUTO  = ' + QuotedStr(pProduto));
    if pGrupo <> '' then
      result := result + ('  AND TP.CD_GRUPO    = ' + QuotedStr(pGrupo));
    if pCliente <> '' then
      result := result + ('  AND TP.CD_CLIENTE  = ' + QuotedStr(pCliente));

    result := result + ('ORDER BY TP.NR_PROCESSO');
end;

function TfrmMain.RelEventosDailyFupTranspRodoviario(pUnidade, pProduto, pGrupo, pTransportador: string): String;
var
  db_broker: TDatabase;
  qryEventos, qryRelatorio, qryAuxiliar: TQuery;
  Excel, WorkBook, Sheet, Range: OleVariant;
  Arquivo: String;
  Linha: Integer;
  TemDados: Boolean;

  procedure PreencheEvento(AColuna: Integer; AEvento: String);
  begin
    with qryEventos do
    begin
      First;
      if Locate('CD_EVENTO', AEvento, []) then
      begin
        if (AnsiIndexText(FieldByName('DT_REALIZACAO').AsString, ['', 'N/A', 'TO BE CONFIRMED']) < 0) then
        begin
          if AnsiIndexText(AEvento, ['270', '271']) >= 0 then
            Sheet.Cells[Linha, AColuna].Value := StrToDate(FieldByName('DT_REALIZACAO').AsString) + StrToTime(FieldByName('HR_REALIZACAO').AsString)
          else
            Sheet.Cells[Linha, AColuna].Value := StrToDate(qryEventos.FieldByName('DT_REALIZACAO').AsString);
        end
        else
          Sheet.Cells[Linha, AColuna].Value := '';

        if FieldByName('DT_REALIZACAO_EFETIVA').AsString <> '' then
          if  ((DayOfWeek(Date)  = 2) and (qryEventos.FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -3))
           or ((DayOfWeek(Date) <> 2) and (qryEventos.FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -1)) then
            Sheet.Cells[Linha, AColuna].Interior.ColorIndex := 40;
      end
      else
        Sheet.Cells[Linha, AColuna].Value := '';
    end;
  end;

begin
  try
    db_broker:= TDatabase.Create(Self);

    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;

    qryEventos              := TQuery.Create(Self);
    qryEventos.DatabaseName := 'DBBROKER';
    qryEventos.SQL.Text :=
	  '  SELECT CD_EVENTO,                                                                                              ' + slinebreak +
    '         CASE WHEN IN_APLICAVEL <> "1" THEN "N/A"                                                                ' + slinebreak +
    '               WHEN DT_REALIZACAO IS NULL THEN "TO BE CONFIRMED"                                                 ' + slinebreak +
    '         ELSE CONVERT(VARCHAR, DT_REALIZACAO, 103)                                                               ' + slinebreak +
    '         END DT_REALIZACAO,                                                                                      ' + slinebreak +
    '         CONVERT(VARCHAR, DT_REALIZACAO, 108) AS HR_REALIZACAO,                                                  ' + slinebreak +
    '         CONVERT(VARCHAR, ISNULL(DT_REALIZACAO_EFETIVA, 0), 103) AS DT_REALIZACAO_EFETIVA                        ' + slinebreak +
    '  FROM TFOLLOWUP (NOLOCK)                                                                                        ' + slinebreak +
    '  WHERE NR_PROCESSO = :NR_PROCESSO                                                                               ' + slinebreak +
    '    AND CD_EVENTO IN ("088", "131", "147", "270", "271", "313", "314", "315", /*"369",*/ "497", "528", "620", "621") ' + slinebreak ;

    qryRelatorio              := TQuery.Create(Self);
    qryRelatorio.DatabaseName := 'DBBROKER';
    qryRelatorio.SQL.text     :=

  '   SELECT (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '' / ''), '' / '') '+ sLineBreak +
  '             FROM TREF_CLIENTE R (NOLOCK)                                                                                 '+ sLineBreak +
  '            WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                        '+ sLineBreak +
  '              AND R.TP_REFERENCIA = CASE SUBSTRING(R.NR_PROCESSO, 3, 2)                                                   '+ sLineBreak +
  '                                        WHEN ''01'' THEN ISNULL(G.TP_PEDIDO_BUSCA_IMP, ''01'')                            '+ sLineBreak +
  '                                        ELSE ISNULL(G.TP_PEDIDO_BUSCA, ''01'')                                            '+ sLineBreak +
  '                                    END)                                  AS CD_REFERENCIA,                               '+ sLineBreak +
  '          PR.NR_PROCESSO                                                  AS NR_PROCESSO,                                 '+ sLineBreak +
  '          RTRIM(EN.NM_EMPRESA)                                            AS NM_CLIENTE,                                  '+ sLineBreak +
  '          RTRIM(CONVERT(VARCHAR(MAX), PR.TX_MERCADORIA))                  AS TX_MERCADORIA,                               '+ sLineBreak +
  '          (SELECT RTRIM(DESCRICAO)                                                                                        '+ sLineBreak +
  '             FROM TPAIS (NOLOCK)                                                                                          '+ sLineBreak +
  '            WHERE CODIGO = PR.CD_PAIS_DESTINO)                            AS NM_PAIS_DESTINO,                             '+ sLineBreak +
  '          RTRIM(CASE SUBSTRING(PR.NR_PROCESSO, 5, 2) WHEN ''ER''                                                          '+ sLineBreak +
  '                     THEN ISNULL(TR.AP_TRANSP_ROD, '''')                                                                  '+ sLineBreak +
  '                     ELSE ISNULL(A.NM_AGENTE_REDUZIDO, A.NM_AGENTE)                                                       '+ sLineBreak +
  '                END)                                                      AS NM_AGENTE,                                   '+ sLineBreak +
  '          ISNULL(RTRIM(E.NM_EMBARCACAO), '''')                            AS NM_EMBARCACAO,                               '+ sLineBreak +
  '          (SELECT RTRIM(DESCRICAO)                                                                                        '+ sLineBreak +
  '             FROM TLOCAL_EMBARQUE (NOLOCK)                                                                                '+ sLineBreak +
  '            WHERE CODIGO=PR.CD_LOCAL_DESEMBARQUE)                         AS NM_PORTO_DESTINO,                            '+ sLineBreak +
  '          (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '', ''), '', '')   '+ sLineBreak +
  '             FROM TREF_CLIENTE R (NOLOCK)                                                                                 '+ sLineBreak +
  '            WHERE R.NR_PROCESSO=PR.NR_PROCESSO                                                                            '+ sLineBreak +
  '              AND R.TP_REFERENCIA = ''05'')                               AS NR_BOOKING,                                  '+ sLineBreak +
  '          (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(                                                     '+ sLineBreak +
  '                  CONVERT(VARCHAR, QT_TIPO) + '' '' + NM_TIPO + CHAR(10)), CHAR(10))                                      '+ sLineBreak +
  '             FROM (SELECT COUNT(*)             AS QT_TIPO,                                                                '+ sLineBreak +
  '                          RTRIM(TC.NM_TP_CNTR) AS NM_TIPO                                                                 '+ sLineBreak +
  '                     FROM TPROCESSO_CNTR  PC (NOLOCK)                                                                     '+ sLineBreak +
  '               INNER JOIN TTP_CNTR        TC (NOLOCK) ON TC.TP_CNTR = PC.TP_CNTR                                          '+ sLineBreak +
  '                 WHERE PC.NR_PROCESSO = PR.NR_PROCESSO                                                                    '+ sLineBreak +
  '                 GROUP BY TC.NM_TP_CNTR) AS VW)                           AS TP_CONTAINERS,                               '+ sLineBreak +
  '          ISNULL(RTRIM(AA.NM_ARMAZEM), '''')                              AS NM_ARMAZEM_ATRACACAO,                        '+ sLineBreak +
  '          (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '', ''), '', '')   '+ sLineBreak +
  '             FROM TREF_CLIENTE R (NOLOCK)                                                                                 '+ sLineBreak +
  '            WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                        '+ sLineBreak +
  '              AND R.TP_REFERENCIA = ''04'')                               AS NR_OUTROS,                                   '+ sLineBreak +
  '          (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '', ''), '', '')   '+ sLineBreak +
  '             FROM TREF_CLIENTE R (NOLOCK)                                                                                 '+ sLineBreak +
  '            WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                        '+ sLineBreak +
  '              AND R.TP_REFERENCIA = ''02'')                               AS NR_ORDEM,                                    '+ sLineBreak +
  '          (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '', ''), '', '')   '+ sLineBreak +
  '             FROM TREF_CLIENTE R (NOLOCK)                                                                                 '+ sLineBreak +
  '            WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                        '+ sLineBreak +
  '              AND R.TP_REFERENCIA = ''26'')                               AS NR_CONJUGADO,                                '+ sLineBreak +
  '           LE.DESCRICAO                                                   AS LOCAL_TRANSBORDO   ,                         '+ sLineBreak +
  '           PR.CD_TRANSP_NAC                                               AS CD_TRANSP_NAC ,                              '+ sLineBreak +
  '           F147_.DT_REALIZACAO                                            AS DT_REALIZACAO_147_ORDENAR,                   '+ sLineBreak +
  '           PR.VL_PESO_BRUTO                                               AS VL_PESO_BRUTO  ,                             '+ sLineBreak +
  '           TRANSP.NM_TRANSP_ROD                                           AS NM_TRANSPORTADORA ,                          '+ sLineBreak +
  '           CONVERT(VARCHAR(1000),                                                                                         '+ sLineBreak +
  '           STUFF(                                                                                                         '+ sLineBreak +
  '           (SELECT '' , '' + CHAVE_NOTA                                                                                   '+ sLineBreak +
  '              FROM TPROCESSO_EXP_NF N                                                                                     '+ sLineBreak +
  '             WHERE N.NR_PROCESSO = PR.NR_PROCESSO                                                                         '+ sLineBreak +
  '             FOR XML PATH('''')), 1, 3, ''''))                            AS CHAVE_NF,                                    '+ sLineBreak +
  '           PR.NR_CONHECIMENTO,                                                                                            '+ sLineBreak +
  '           PR.CD_DUE                                                                                                      '+ sLineBreak +
  '                                                                                                                          '+ sLineBreak +
  '      FROM      TPROCESSO          PR     (NOLOCK)                                                                        '+ sLineBreak +
  '           JOIN TSERVICO_NOVO      S      (NOLOCK) ON S.CD_SERVICO      = PR.CD_SERVICO                                   '+ sLineBreak +
  '           JOIN TEMPRESA_NAC       EN     (NOLOCK) ON EN.CD_EMPRESA     = PR.CD_CLIENTE                                   '+ sLineBreak +
  '           JOIN TGRUPO             G      (NOLOCK) ON G.CD_GRUPO        = EN.CD_GRUPO                                     '+ sLineBreak +
  '      LEFT JOIN TFOLLOWUP          F315   (NOLOCK) ON (F315.NR_PROCESSO  = PR.NR_PROCESSO                                 '+ sLineBreak +
  '                                                  AND F315.CD_EVENTO     = ''315'')                                       '+ sLineBreak +
  '                                                  AND F315.IN_APLICAVEL  = ''1''                                          '+ sLineBreak +
  '                                                  AND F315.CD_SERVICO    = PR.CD_SERVICO                                  '+ sLineBreak +
  '      LEFT JOIN TFOLLOWUP          F874   (NOLOCK) ON (F874.NR_PROCESSO  = PR.NR_PROCESSO                                 '+ sLineBreak +
  '                                                  AND F874.CD_EVENTO     = ''874'')                                       '+ sLineBreak +
  '                                                  AND F874.IN_APLICAVEL  = ''1''                                          '+ sLineBreak +
  '                                                  AND F874.CD_SERVICO    = PR.CD_SERVICO                                  '+ sLineBreak +
  '      LEFT  JOIN TFOLLOWUP          F147_ (NOLOCK) ON (PR.NR_PROCESSO    = F147_.NR_PROCESSO                              '+ sLineBreak +
  '                                                  AND F147_.CD_EVENTO    = ''147'')                                       '+ sLineBreak +
  '                                                  AND F147_.IN_APLICAVEL = ''1''                                          '+ sLineBreak +
  '                                                  AND F147_.CD_SERVICO   = PR.CD_SERVICO                                  '+ sLineBreak +
  '      LEFT  JOIN TEMBARCACAO        E      (NOLOCK) ON E.CD_EMBARCACAO   = PR.CD_EMBARCACAO                               '+ sLineBreak +
  '      LEFT  JOIN TAGENTE            A      (NOLOCK) ON A.CD_AGENTE       = PR.CD_AGENTE                                   '+ sLineBreak +
  '      LEFT  JOIN TTRANSP_ROD        TR     (NOLOCK) ON TR.CD_TRANSP_ROD  = PR.CD_TRANSP_NAC                               '+ sLineBreak +
  '      LEFT  JOIN TEMPRESA_EST       EE     (NOLOCK) ON EE.CD_EMPRESA     = PR.CD_IMPORTADOR                               '+ sLineBreak +
  '      LEFT  JOIN TAREA              AR     (NOLOCK) ON AR.CD_AREA        = PR.CD_AREA                                     '+ sLineBreak +
  '      LEFT  JOIN TARMAZEM           AA     (NOLOCK) ON AA.CD_ARMAZEM     = PR.CD_ARMAZEM_ATRACACAO                        '+ sLineBreak +
  '      LEFT  JOIN TLOCAL_EMBARQUE    LE     (NOLOCK) ON LE.CODIGO         = PR.CD_LOCAL_TRANSBORDO                         '+ sLineBreak +
  '      LEFT  JOIN TVIA_TRANSP_BROKER VT     (NOLOCK) ON VT.CD_VIA_TRANSP  = S.CD_VIA_TRANSPORTE                            '+ sLineBreak +
  '      LEFT  JOIN TTRANSP_ROD        TRANSP (NOLOCK) ON TRANSP.CD_TRANSP_ROD  = PR.CD_TRANSP_NAC                           '+ sLineBreak +
  '                                                                                                                          '+ sLineBreak +
  '  WHERE (((F315.DT_REALIZACAO IS NULL AND F315.IN_APLICAVEL  =''1'')                                                      '+ sLineBreak +
  '        OR CONVERT(DATE, F315.DT_REALIZACAO, 103) >= CONVERT(DATE, CONVERT(VARCHAR, GETDATE() -5, 103), 103))             '+ sLineBreak +
  '     OR                                                                                                                   '+ sLineBreak +
  '        ((F874.DT_REALIZACAO IS NULL AND F874.IN_APLICAVEL  = ''1'')                                                      '+ sLineBreak +
  '         OR CONVERT(DATE, F874.DT_REALIZACAO, 103) >= CONVERT(DATE, CONVERT(VARCHAR, GETDATE() -5, 103), 103))   )        '+ sLineBreak +
  '     AND PR.IN_CANCELADO   = ''0''                                                                                        '+ sLineBreak +
  '     AND PR.IN_LIBERADO    = ''1''                                                                                        '+ sLineBreak +
  '     AND ISNULL(E.NM_EMBARCACAO, '''') NOT IN (''* PROCESSO CANCELADO'', ''TBN'', ''AGUARDANDO NAVIO'' )                  '+ sLineBreak ;

    if pUnidade <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_UNID_NEG   = "' + pUnidade + '"');
    if pProduto <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_PRODUTO    = "' + pProduto + '"');
    if pGrupo <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_GRUPO      = "' + pGrupo + '"');
    if pTransportador <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_TRANSP_NAC = "' + pTransportador + '"');

    qryRelatorio.SQL.Add(' ORDER BY CASE WHEN F147_.DT_REALIZACAO IS NULL      ' + sLineBreak +
                         '               THEN DATEADD(YEAR, 1, GETDATE())      ' + sLineBreak +
                         '               ELSE F147_.DT_REALIZACAO              ' + sLineBreak +
                         '          END                                        ' + sLineBreak +
                         '        , P.NR_PROCESSO                              ' );


    qryAuxiliar              := TQuery.Create(Self);
    qryAuxiliar.DatabaseName := 'DBBROKER';

    try
      db_broker.Connected := True;
      Excel    := CreateOLEObject('Excel.Application');
      try
        WorkBook := Excel.Workbooks.Open(GetPath+'DAILY_FOLLOWUP_Nestle_Transp.xlsx');

        Excel.Visible := chkVisualizarExcel.checked;
        Sheet := Excel.WorkBooks[1].Worksheets[1];

        qryAuxiliar.SQL.Add('SELECT ISNULL((SELECT RTRIM(AP_UNID_NEG) FROM TUNID_NEG   (NOLOCK) WHERE CD_UNID_NEG   = "' + pUnidade + '"), "Todas") AS UNIDADE,');
        qryAuxiliar.SQL.Add('       ISNULL((SELECT RTRIM(NM_PRODUTO)  FROM TPRODUTO    (NOLOCK) WHERE CD_PRODUTO    = "' + pProduto + '"), "Todas") AS PRODUTO,');
        qryAuxiliar.SQL.Add('       ISNULL((SELECT RTRIM(NM_GRUPO)    FROM TGRUPO      (NOLOCK) WHERE CD_GRUPO      = "' + pGrupo + '"), "Todos") AS GRUPO,');
        qryAuxiliar.SQL.Add('       ISNULL((SELECT NM_TRANSP_ROD      FROM TTRANSP_ROD (NOLOCK) WHERE CD_TRANSP_ROD = "' + pTransportador + '"), "Todos") AS TRANSP,');
        qryAuxiliar.SQL.Add('       CONVERT(VARCHAR, GETDATE(), 103) AS DATA');
        qryAuxiliar.Open;

        Sheet.Range['C1'].Value := 'Unidade: ' + pUnidade + ' - ' + qryAuxiliar.FieldByName('UNIDADE').AsString;
        Sheet.Range['D2'].Value := 'Produto: ' + pProduto + ' - ' + qryAuxiliar.FieldByName('PRODUTO').AsString;
        Sheet.Range['D3'].Value := 'Grupo: ' + pGrupo + ' - ' + qryAuxiliar.FieldByName('GRUPO').AsString;
        Sheet.Range['D4'].Value := 'Transportador: ' + pTransportador + ' - ' + qryAuxiliar.FieldByName('TRANSP').AsString;
        Sheet.Range['D5'].Value := 'Data: ' + qryAuxiliar.FieldByName('DATA').AsString;

        Arquivo := GetPath+'Gerados\DAILY_FOLLOWUP_' + AnsiUpperCase(Copy(qryAuxiliar.FieldByName('PRODUTO').AsString, 1, 3)) +
                  FormatDateTime('ddmmyyyyhhnnsszz', Now) + '.xls';
        qryAuxiliar.Close;

        with qryRelatorio do
        begin
          Open;
          First;
          Linha := 7;
          TemDados := not Eof;
          while not Eof do
          begin
            if qryEventos.Active then
              qryEventos.Close;
            qryEventos.ParamByName('NR_PROCESSO').AsString := FieldByName('NR_PROCESSO').AsString;
            qryEventos.Open;

            if Trim(FieldByName('CD_REFERENCIA').AsString) <> '' then
              Sheet.Cells[Linha,  1].Value := FieldByName('CD_REFERENCIA').AsString
            else
              Sheet.Cells[Linha,  1].Value := FieldByName('NR_OUTROS').AsString;

            Sheet.Cells[Linha,  2].Value   := FieldByName('NR_ORDEM').AsString;
            Sheet.Cells[Linha,  3].Value   := FieldByName('NR_CONJUGADO').AsString;
            Sheet.Cells[Linha,  4].Value   := FieldByName('NR_PROCESSO').AsString;
            Sheet.Cells[Linha,  5].Value   := FieldByName('NM_CLIENTE').AsString;
            Sheet.Cells[Linha,  6].Value   := FieldByName('TX_MERCADORIA').AsString;
            Sheet.Cells[Linha,  7].Value   := FieldByName('NM_PAIS_DESTINO').AsString;
            Sheet.Cells[Linha,  8].Value   := FieldByName('NM_TRANSPORTADORA').AsString;/////
            Sheet.Cells[Linha,  9].Value   := FieldByName('NM_PORTO_DESTINO').AsString;
            Sheet.Cells[Linha, 10].Value   := FieldByName('TP_CONTAINERS').AsString;
            Sheet.Cells[Linha, 11].Value   := FieldByName('NR_CONHECIMENTO').AsString;
            PreencheEvento(12, '147');   //previsao de carregamento
            Sheet.Cells[Linha, 13].Value   := GetDataContainer(FieldByName('NR_PROCESSO').AsString, 'DT_PREV_CHEGADA_FABR', 'dd/mm/yyyy hh:nn');  //janela fabrica
            Sheet.Cells[Linha, 14].Columns.Autofit;
            Sheet.Cells[Linha, 14].Value   := GetDataContainer(FieldByName('NR_PROCESSO').AsString, 'DT_CHEGADA_FABR', 'dd/mm/yyyy hh:nn'); //chegada fabrica
            Sheet.Cells[Linha, 14].Columns.Autofit;
            PreencheEvento(15, '314'); //Carregamento na Fábrica
            Sheet.Cells[Linha, 16].Value   := FieldByName('CHAVE_NF').AsString;
            Sheet.Cells[Linha, 17].Value   := FieldByName('CD_DUE').AsString;
            PreencheEvento(18, '398'); //Chegada do caminhăo/mercadoria em fronteira
            PreencheEvento(19, '088'); //Desembaraço
            PreencheEvento(20, '149'); //Data do Cruze
            PreencheEvento(21, '261'); //Chegada no Destino
            PreencheEvento(22, '874'); //Descarga no Importador

            Sheet.Cells[Linha, 1].Rows.Autofit;

            Next;
            Inc(Linha);
          end;
        end;

        Dec(Linha);
        Range := Sheet.Range['A7' + ':V' + IntToStr(Linha)];

        Range.Borders[xlDiagonalDown].LineStyle      := 0;
        Range.Borders[xlDiagonalUp].LineStyle        := 0;
        Range.Borders[xlEdgeLeft].LineStyle          := xlContinuous;
        Range.Borders[xlEdgeLeft].ColorIndex         := 15;
        Range.Borders[xlEdgeLeft].Weight             := xlThin;
        Range.Borders[xlEdgeTop].LineStyle           := xlContinuous;
        Range.Borders[xlEdgeTop].ColorIndex          := 15;
        Range.Borders[xlEdgeTop].Weight              := xlThin;
        Range.Borders[xlEdgeBottom].LineStyle        := xlContinuous;
        Range.Borders[xlEdgeBottom].ColorIndex       := 15;
        Range.Borders[xlEdgeBottom].Weight           := xlThin;
        Range.Borders[xlEdgeRight].LineStyle         := xlContinuous;
        Range.Borders[xlEdgeRight].ColorIndex        := 15;
        Range.Borders[xlEdgeRight].Weight            := xlThin;
        Range.Borders[xlInsideVertical].LineStyle    := xlContinuous;
        Range.Borders[xlInsideVertical].ColorIndex   := 15;
        Range.Borders[xlInsideVertical].Weight       := xlThin;
        Range.Borders[xlInsideHorizontal].LineStyle  := xlContinuous;
        Range.Borders[xlInsideHorizontal].ColorIndex := 15;
        Range.Borders[xlInsideHorizontal].Weight     := xlThin;

        Sheet.Sort.SortFields.Clear;

        Sheet.Sort.SetRange(Sheet.Range['A7:V' + IntToStr(Linha)]);
        Sheet.Sort.Header      := xlGuess;
        Sheet.Sort.MatchCase   := False;
        Sheet.Sort.Orientation := xlTopToBottom;
        Sheet.Sort.SortMethod  := xlPinYin;
        Sheet.Sort.Apply;

        if FileExists(Arquivo) then
          SysUtils.DeleteFile(Arquivo);
        WorkBook.SaveAs(Arquivo);

        if TemDados then
          Result := Arquivo
        else
          Result := 'Sem Dados';

      finally
        WorkBook.Close(False);
        KillExcel(Excel);
      end;
    finally
      FreeAndNil(qryEventos);
      FreeAndNil(qryRelatorio);
      FreeAndNil(qryAuxiliar);
      FreeAndNil(db_broker);
    end;
  except
    on e:Exception do
    begin
      VMsg('Erro - RelEventosDailyFupTranspRodoviario: ' + e.Message, msError, True);
    end;
  end;

end;


function TfrmMain.RelEventosDailyFupTranspMaritimo(pUnidade, pProduto, pGrupo, pTransportador: string): String;
var
  db_broker: TDatabase;
  qryEventos, qryRelatorio, qryAuxiliar: TQuery;
  Excel, WorkBook, Sheet, Range: OleVariant;
  Arquivo: String;
  Linha: Integer;
  TemDados: Boolean;

  procedure PreencheEvento(AColuna: Integer; AEvento: String);
  begin
    with qryEventos do
    begin
      First;
      if Locate('CD_EVENTO', AEvento, []) then
      begin
        if (AnsiIndexText(FieldByName('DT_REALIZACAO').AsString, ['', 'N/A', 'TO BE CONFIRMED']) < 0) then
        begin
          if AnsiIndexText(AEvento, ['270', '271']) >= 0 then
            Sheet.Cells[Linha, AColuna].Value := StrToDate(FieldByName('DT_REALIZACAO').AsString) + StrToTime(FieldByName('HR_REALIZACAO').AsString)
          else
            Sheet.Cells[Linha, AColuna].Value := StrToDate(qryEventos.FieldByName('DT_REALIZACAO').AsString);
        end
        else
          Sheet.Cells[Linha, AColuna].Value := '';

        if FieldByName('DT_REALIZACAO_EFETIVA').AsString <> '' then
          if  ((DayOfWeek(Date)  = 2) and (qryEventos.FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -3))
           or ((DayOfWeek(Date) <> 2) and (qryEventos.FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -1)) then
            Sheet.Cells[Linha, AColuna].Interior.ColorIndex := 40;
      end
      else
        Sheet.Cells[Linha, AColuna].Value := '';
    end;
  end;

begin
  try
    db_broker:= TDatabase.Create(Self);

    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;

    qryEventos              := TQuery.Create(Self);
    qryEventos.DatabaseName := 'DBBROKER';
    qryEventos.SQL.Text :=
	  '  SELECT CD_EVENTO,                                                                                              ' + slinebreak +
    '         CASE WHEN IN_APLICAVEL <> "1" THEN "N/A"                                                                ' + slinebreak +
    '               WHEN DT_REALIZACAO IS NULL THEN "TO BE CONFIRMED"                                                 ' + slinebreak +
    '         ELSE CONVERT(VARCHAR, DT_REALIZACAO, 103)                                                               ' + slinebreak +
    '         END DT_REALIZACAO,                                                                                      ' + slinebreak +
    '         CONVERT(VARCHAR, DT_REALIZACAO, 108) AS HR_REALIZACAO,                                                  ' + slinebreak +
    '         CONVERT(VARCHAR, ISNULL(DT_REALIZACAO_EFETIVA, 0), 103) AS DT_REALIZACAO_EFETIVA                        ' + slinebreak +
    '  FROM TFOLLOWUP (NOLOCK)                                                                                        ' + slinebreak +
    '  WHERE NR_PROCESSO = :NR_PROCESSO                                                                               ' + slinebreak +
    '    AND CD_EVENTO IN ("088", "131", "147", "270", "271", "313", "314", "315", /*"369",*/ "497", "528", "620", "621") ' + slinebreak ;

    qryRelatorio              := TQuery.Create(Self);
    qryRelatorio.DatabaseName := 'DBBROKER';
    qryRelatorio.SQL.text     :=
     '  SELECT (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '' / ''), '' / '')                  ' + sLineBreak +
     '            FROM TREF_CLIENTE R (NOLOCK)                                                                                                  ' + sLineBreak +
     '           WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                                         ' + sLineBreak +
     '             AND R.TP_REFERENCIA = CASE SUBSTRING(R.NR_PROCESSO, 3, 2)                                                                    ' + sLineBreak +
     '                                       WHEN ''01'' THEN ISNULL(G.TP_PEDIDO_BUSCA_IMP, ''01'')                                             ' + sLineBreak +
     '                                       ELSE ISNULL(G.TP_PEDIDO_BUSCA, ''01'')                                                             ' + sLineBreak +
     '                                   END)                                  AS CD_REFERENCIA,                                                ' + sLineBreak +
     '         PR.NR_PROCESSO                                                  AS NR_PROCESSO,                                                  ' + sLineBreak +
     '         RTRIM(EN.NM_EMPRESA)                                            AS NM_CLIENTE,                                                   ' + sLineBreak +
     '         RTRIM(CONVERT(VARCHAR(MAX), PR.TX_MERCADORIA))                  AS TX_MERCADORIA,                                                ' + sLineBreak +
     '         (SELECT RTRIM(DESCRICAO)                                                                                                         ' + sLineBreak +
     '            FROM TPAIS (NOLOCK)                                                                                                           ' + sLineBreak +
     '           WHERE CODIGO = PR.CD_PAIS_DESTINO)                            AS NM_PAIS_DESTINO,                                              ' + sLineBreak +
     '         RTRIM(CASE SUBSTRING(PR.NR_PROCESSO, 5, 2) WHEN ''ER''                                                                           ' + sLineBreak +
     '                    THEN ISNULL(TR.AP_TRANSP_ROD, '''')                                                                                   ' + sLineBreak +
     '                    ELSE ISNULL(A.NM_AGENTE_REDUZIDO, A.NM_AGENTE)                                                                        ' + sLineBreak +
     '               END)                                                      AS NM_AGENTE,                                                    ' + sLineBreak +
     '         ISNULL(RTRIM(E.NM_EMBARCACAO), '''')                            AS NM_EMBARCACAO,                                                ' + sLineBreak +
     '         (SELECT RTRIM(DESCRICAO)                                                                                                         ' + sLineBreak +
     '            FROM TLOCAL_EMBARQUE (NOLOCK)                                                                                                 ' + sLineBreak +
     '           WHERE CODIGO=PR.CD_LOCAL_DESEMBARQUE)                         AS NM_PORTO_DESTINO,                                             ' + sLineBreak +
     '         (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '', ''), '', '')                    ' + sLineBreak +
     '            FROM TREF_CLIENTE R (NOLOCK)                                                                                                  ' + sLineBreak +
     '           WHERE R.NR_PROCESSO=PR.NR_PROCESSO                                                                                             ' + sLineBreak +
     '             AND R.TP_REFERENCIA = ''05'')                               AS NR_BOOKING,                                                   ' + sLineBreak +
          '         (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '', ''), '', '')               ' + sLineBreak +
     '            FROM TREF_CLIENTE R (NOLOCK)                                                                                                  ' + sLineBreak +
     '           WHERE R.NR_PROCESSO=PR.NR_PROCESSO                                                                                             ' + sLineBreak +
     '             AND R.TP_REFERENCIA = ''51'')                               AS NR_LIB_VAZIO,                                                 ' + sLineBreak +
     '         (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(CONVERT(VARCHAR, QT_TIPO) + '' '' + NM_TIPO + CHAR(10)), CHAR(10))    ' + sLineBreak +
     '            FROM (SELECT COUNT(*)             AS QT_TIPO,                                                                                 ' + sLineBreak +
     '                         RTRIM(TC.NM_TP_CNTR) AS NM_TIPO                                                                                  ' + sLineBreak +
     '                    FROM TPROCESSO_CNTR  PC (NOLOCK)                                                                                      ' + sLineBreak +
     '              INNER JOIN TTP_CNTR        TC (NOLOCK) ON TC.TP_CNTR = PC.TP_CNTR                                                           ' + sLineBreak +
     '                WHERE PC.NR_PROCESSO = PR.NR_PROCESSO                                                                                     ' + sLineBreak +
     '                GROUP BY TC.NM_TP_CNTR) AS VW)                           AS TP_CONTAINERS,                                                ' + sLineBreak +
     '         ISNULL(RTRIM(AA.NM_ARMAZEM), '''')                              AS NM_ARMAZEM_ATRACACAO,                                         ' + sLineBreak +
     '         ISNULL(RTRIM(ADE.NM_ARMAZEM), '''')                             AS NM_ARMAZEM_DEPOT,                                             ' + sLineBreak +
     '         (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '', ''), '', '')                    ' + sLineBreak +
     '            FROM TREF_CLIENTE R (NOLOCK)                                                                                                  ' + sLineBreak +
     '           WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                                         ' + sLineBreak +
     '             AND R.TP_REFERENCIA = ''04'')                               AS NR_OUTROS,                                                    ' + sLineBreak +
     '         (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '', ''), '', '')                    ' + sLineBreak +
     '            FROM TREF_CLIENTE R (NOLOCK)                                                                                                  ' + sLineBreak +
     '           WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                                         ' + sLineBreak +
     '             AND R.TP_REFERENCIA = ''46'')                               AS CATEGORIA,                                                    ' + sLineBreak +
     '         (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '', ''), '', '')                    ' + sLineBreak +
     '            FROM TREF_CLIENTE R (NOLOCK)                                                                                                  ' + sLineBreak +
     '           WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                                         ' + sLineBreak +
     '             AND R.TP_REFERENCIA = ''02'')                               AS NR_ORDEM,                                                     ' + sLineBreak +
     '         (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(DISTINCT RTRIM(R.CD_REFERENCIA) + '', ''), '', '')                    ' + sLineBreak +
     '            FROM TREF_CLIENTE R (NOLOCK)                                                                                                  ' + sLineBreak +
     '           WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                                         ' + sLineBreak +
     '             AND R.TP_REFERENCIA = ''26'')                               AS NR_CONJUGADO,                                                 ' + sLineBreak +
     '          LE.DESCRICAO                                                   AS LOCAL_TRANSBORDO   ,                                          ' + sLineBreak +
     '          PR.CD_TRANSP_NAC                                               AS CD_TRANSP_NAC ,                                               ' + sLineBreak +
     '           CASE WHEN PR.IN_MERC_PERIGOSA = ''1'' THEN ''Sim'' ELSE ''Năo'' END  AS  MERC_PERIGOSA,                                        '+ sLineBreak +
     '          F147_.DT_REALIZACAO                                            AS DT_REALIZACAO_147_ORDENAR,                                    ' + sLineBreak +
     '          PR.VL_PESO_BRUTO                                               AS VL_PESO_BRUTO                                                 ' + sLineBreak +
     '  FROM TPROCESSO                   PR     (NOLOCK)                                                                                        ' + sLineBreak +
     '     Left JOIN TFOLLOWUP          F315   (NOLOCK) ON (F315.NR_PROCESSO  = PR.NR_PROCESSO                                                  ' + sLineBreak +
     '                                                 AND F315.CD_EVENTO     = ''315'')                                                        ' + sLineBreak +
     '                                                 AND F315.IN_APLICAVEL  = ''1''                                                           ' + sLineBreak +
     '                                                 AND F315.CD_SERVICO    = PR.CD_SERVICO                                                   ' + sLineBreak +
     '     Left JOIN TFOLLOWUP          F874   (NOLOCK) ON (F874.NR_PROCESSO  = PR.NR_PROCESSO                                                  ' + sLineBreak +
     '                                                 AND F874.CD_EVENTO     = ''874'')                                                        ' + sLineBreak +
     '                                                 AND F874.IN_APLICAVEL  = ''1''                                                           ' + sLineBreak +
     '                                                 AND F874.CD_SERVICO    = PR.CD_SERVICO                                                   ' + sLineBreak +
     '     LEFT  JOIN TEMPRESA_NAC       EN     (NOLOCK) ON EN.CD_EMPRESA     = PR.CD_CLIENTE                                                   ' + sLineBreak +
     '     LEFT  JOIN TGRUPO             G      (NOLOCK) ON G.CD_GRUPO        = EN.CD_GRUPO                                                     ' + sLineBreak +
     '     LEFT  JOIN TEMBARCACAO        E      (NOLOCK) ON PR.CD_EMBARCACAO  = E.CD_EMBARCACAO                                                 ' + sLineBreak +
     '     LEFT  JOIN TAGENTE            A      (NOLOCK) ON A.CD_AGENTE       = PR.CD_AGENTE                                                    ' + sLineBreak +
     '     LEFT  JOIN TTRANSP_ROD        TR     (NOLOCK) ON PR.CD_TRANSP_NAC  = TR.CD_TRANSP_ROD                                                ' + sLineBreak +
     '     LEFT  JOIN TEMPRESA_EST       EE     (NOLOCK) ON EE.CD_EMPRESA     = PR.CD_IMPORTADOR                                                ' + sLineBreak +
     '     INNER JOIN TSERVICO_NOVO      S      (NOLOCK) ON S.CD_SERVICO      = PR.CD_SERVICO                                                   ' + sLineBreak +
     '     LEFT  JOIN TVIA_TRANSP_BROKER VT     (NOLOCK) ON VT.CD_VIA_TRANSP  = S.CD_VIA_TRANSPORTE                                             ' + sLineBreak +
     '     LEFT  JOIN TAREA              AR     (NOLOCK) ON AR.CD_AREA        = PR.CD_AREA                                                      ' + sLineBreak +
     '     LEFT  JOIN TARMAZEM           AA     (NOLOCK) ON AA.CD_ARMAZEM     = PR.CD_ARMAZEM_ATRACACAO                                         ' + sLineBreak +
     '     LEFT  JOIN TARMAZEM           ADE    (NOLOCK) ON ADE.CD_ARMAZEM    = PR.NR_DEPOT                                                     ' + sLineBreak +
     '     LEFT  JOIN TLOCAL_EMBARQUE    LE     (NOLOCK) ON LE.CODIGO         = PR.CD_LOCAL_TRANSBORDO                                          ' + sLineBreak +
     '     LEFT  JOIN TFOLLOWUP          F147_  (NOLOCK) ON (PR.NR_PROCESSO   = F147_.NR_PROCESSO                                               ' + sLineBreak +
     '                                                  AND F147_.CD_EVENTO   = ''147'')                                                        ' + sLineBreak +
//     '  WHERE (F315.DT_REALIZACAO IS NULL OR CONVERT(DATE, F315.DT_REALIZACAO, 103) >= CONVERT(DATE, CONVERT(VARCHAR, GETDATE() -3, 103), 103)) ' + sLineBreak +
     ' WHERE (((F315.DT_REALIZACAO IS NULL AND F315.IN_APLICAVEL  =''1'')                                                                       ' + sLineBreak +
     '       OR CONVERT(DATE, F315.DT_REALIZACAO, 103) >= CONVERT(DATE, CONVERT(VARCHAR, GETDATE() -3, 103), 103))                              ' + sLineBreak +
     '    OR                                                                                                                                    ' + sLineBreak +
     '       ((F874.DT_REALIZACAO IS NULL AND F874.IN_APLICAVEL  = ''1'')                                                                       ' + sLineBreak +
     '        OR CONVERT(DATE, F874.DT_REALIZACAO, 103) >= CONVERT(DATE, CONVERT(VARCHAR, GETDATE() -3, 103), 103))   )                         ' + sLineBreak +
     '    AND PR.IN_CANCELADO   = ''0''                                                                                                         ' + sLineBreak +
     '    AND PR.IN_LIBERADO    = ''1''                                                                                                         ' + sLineBreak +
     '                                                                                                            ' + sLineBreak +
     '    AND ISNULL(E.NM_EMBARCACAO, '''') NOT IN (''* PROCESSO CANCELADO'', ''TBN'', ''AGUARDANDO NAVIO'' )                                   ' + sLineBreak ;

    if pUnidade <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_UNID_NEG   = "' + pUnidade + '"');
    if pProduto <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_PRODUTO    = "' + pProduto + '"');
    if pGrupo <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_GRUPO      = "' + pGrupo + '"');
    if pTransportador <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_TRANSP_NAC = "' + pTransportador + '"');

    qryRelatorio.SQL.Add(' ORDER BY CASE WHEN F147_.DT_REALIZACAO IS NULL      ' + sLineBreak +
                         '               THEN DATEADD(YEAR, 1, GETDATE())      ' + sLineBreak +
                         '               ELSE F147_.DT_REALIZACAO              ' + sLineBreak +
                         '          END                                        ' + sLineBreak +
                         '        , P.NR_PROCESSO                              ' );


    qryAuxiliar              := TQuery.Create(Self);
    qryAuxiliar.DatabaseName := 'DBBROKER';

    try
      db_broker.Connected := True;
      Excel    := CreateOLEObject('Excel.Application');
      try
        WorkBook := Excel.Workbooks.Open(GetPath+'DAILY_FOLLOWUP_Nestle_TranspMaritimo.xlsx');

        Excel.Visible := chkVisualizarExcel.checked;
        Sheet := Excel.WorkBooks[1].Worksheets[1];

        qryAuxiliar.SQL.Add('SELECT ISNULL((SELECT RTRIM(AP_UNID_NEG) FROM TUNID_NEG   (NOLOCK) WHERE CD_UNID_NEG   = "' + pUnidade + '"), "Todas") AS UNIDADE,');
        qryAuxiliar.SQL.Add('       ISNULL((SELECT RTRIM(NM_PRODUTO)  FROM TPRODUTO    (NOLOCK) WHERE CD_PRODUTO    = "' + pProduto + '"), "Todas") AS PRODUTO,');
        qryAuxiliar.SQL.Add('       ISNULL((SELECT RTRIM(NM_GRUPO)    FROM TGRUPO      (NOLOCK) WHERE CD_GRUPO      = "' + pGrupo + '"), "Todos") AS GRUPO,');
        qryAuxiliar.SQL.Add('       ISNULL((SELECT NM_TRANSP_ROD      FROM TTRANSP_ROD (NOLOCK) WHERE CD_TRANSP_ROD = "' + pTransportador + '"), "Todos") AS TRANSP,');
        qryAuxiliar.SQL.Add('       CONVERT(VARCHAR, GETDATE(), 103) AS DATA');
        qryAuxiliar.Open;

        Sheet.Range['C1'].Value := 'Unidade: ' + pUnidade + ' - ' + qryAuxiliar.FieldByName('UNIDADE').AsString;
        Sheet.Range['C2'].Value := 'Produto: ' + pProduto + ' - ' + qryAuxiliar.FieldByName('PRODUTO').AsString;
        Sheet.Range['C3'].Value := 'Grupo: ' + pGrupo + ' - ' + qryAuxiliar.FieldByName('GRUPO').AsString;
        Sheet.Range['C4'].Value := 'Transportador: ' + pTransportador + ' - ' + qryAuxiliar.FieldByName('TRANSP').AsString;
        Sheet.Range['C5'].Value := 'Data: ' + qryAuxiliar.FieldByName('DATA').AsString;

        Arquivo := GetPath+'Gerados\DAILY_FOLLOWUP_' + AnsiUpperCase(Copy(qryAuxiliar.FieldByName('PRODUTO').AsString, 1, 3)) +
                  FormatDateTime('ddmmyyyyhhnnsszz', Now) + '.xls';
        qryAuxiliar.Close;

        with qryRelatorio do
        begin
          Open;
          First;
          Linha := 7;
          TemDados := not Eof;
          while not Eof do
          begin
            if qryEventos.Active then
              qryEventos.Close;
            qryEventos.ParamByName('NR_PROCESSO').AsString := FieldByName('NR_PROCESSO').AsString;
            qryEventos.Open;

            if Trim(FieldByName('CD_REFERENCIA').AsString) <> '' then
              Sheet.Cells[Linha,  1].Value := FieldByName('CD_REFERENCIA').AsString
            else
              Sheet.Cells[Linha,  1].Value := FieldByName('NR_OUTROS').AsString;

            Sheet.Cells[Linha,  2].Value   := FieldByName('NR_PROCESSO').AsString;
            Sheet.Cells[Linha,  3].Value   := FieldByName('NM_CLIENTE').AsString;
            Sheet.Cells[Linha,  4].Value   := FieldByName('TX_MERCADORIA').AsString;
            Sheet.Cells[Linha,  5].Value   := FieldByName('NM_PAIS_DESTINO').AsString;
            Sheet.Cells[Linha,  6].Value   := FieldByName('NM_AGENTE').AsString;
            Sheet.Cells[Linha,  7].Value   := FieldByName('NM_EMBARCACAO').AsString;
            Sheet.Cells[Linha,  8].Value   := FieldByName('NM_PORTO_DESTINO').AsString;
            Sheet.Cells[Linha,  9].Value   := FieldByName('NR_ORDEM').AsString;
            Sheet.Cells[Linha,  10].Value   := FieldByName('NR_CONJUGADO').AsString;
            Sheet.Cells[Linha,  11].Value  := FieldByName('LOCAL_TRANSBORDO').AsString;
            Sheet.Cells[Linha,  12].Value  := FieldByName('NR_BOOKING').AsString;
            Sheet.Cells[Linha,  13].Value  := FieldByName('MERC_PERIGOSA').AsString;
            Sheet.Cells[Linha,  14].Value  := FieldByName('NM_ARMAZEM_DEPOT').AsString;
//            PreencheEvento(12, '369');
            Sheet.Cells[Linha,  15].Value  := FieldByName('NR_LIB_VAZIO').AsString;
            Sheet.Cells[Linha, 16].Value   := FieldByName('TP_CONTAINERS').AsString;
            PreencheEvento(17, '313');
            PreencheEvento(18, '147');
            Sheet.Cells[Linha, 19].Value   := GetDataContainer(FieldByName('NR_PROCESSO').AsString, 'DT_PREV_CHEGADA_FABR', 'dd/mm/yyyy hh:nn');
            Sheet.Cells[Linha, 20].Columns.Autofit;
            Sheet.Cells[Linha, 21].Value   := GetDataContainer(FieldByName('NR_PROCESSO').AsString, 'DT_CHEGADA_FABR', 'dd/mm/yyyy hh:nn');
            Sheet.Cells[Linha, 22].Columns.Autofit;
            PreencheEvento(21, '314');
            PreencheEvento(22, '497');
            PreencheEvento(23, '315');
            Sheet.Cells[Linha, 24].Value   := FieldByName('NM_ARMAZEM_ATRACACAO').AsString;
            PreencheEvento(25, '528');
            PreencheEvento(26, '088');
            PreencheEvento(27, '270');
            PreencheEvento(28, '271');
            PreencheEvento(29, '131');
            Sheet.Cells[Linha, 30].Value   := FormatFloat('#0.,00', FieldByName('VL_PESO_BRUTO').asFloat);
            Sheet.Cells[Linha,  31].Value := FieldByName('CATEGORIA').AsString;

            Sheet.Cells[Linha, 1].Rows.Autofit;

            Next;
            Inc(Linha);
          end;
        end;

        Dec(Linha);
        Range := Sheet.Range['A7' + ':AE' + IntToStr(Linha)];

        Range.Borders[xlDiagonalDown].LineStyle      := 0;
        Range.Borders[xlDiagonalUp].LineStyle        := 0;
        Range.Borders[xlEdgeLeft].LineStyle          := xlContinuous;
        Range.Borders[xlEdgeLeft].ColorIndex         := 15;
        Range.Borders[xlEdgeLeft].Weight             := xlThin;
        Range.Borders[xlEdgeTop].LineStyle           := xlContinuous;
        Range.Borders[xlEdgeTop].ColorIndex          := 15;
        Range.Borders[xlEdgeTop].Weight              := xlThin;
        Range.Borders[xlEdgeBottom].LineStyle        := xlContinuous;
        Range.Borders[xlEdgeBottom].ColorIndex       := 15;
        Range.Borders[xlEdgeBottom].Weight           := xlThin;
        Range.Borders[xlEdgeRight].LineStyle         := xlContinuous;
        Range.Borders[xlEdgeRight].ColorIndex        := 15;
        Range.Borders[xlEdgeRight].Weight            := xlThin;
        Range.Borders[xlInsideVertical].LineStyle    := xlContinuous;
        Range.Borders[xlInsideVertical].ColorIndex   := 15;
        Range.Borders[xlInsideVertical].Weight       := xlThin;
        Range.Borders[xlInsideHorizontal].LineStyle  := xlContinuous;
        Range.Borders[xlInsideHorizontal].ColorIndex := 15;
        Range.Borders[xlInsideHorizontal].Weight     := xlThin;

        Sheet.Sort.SortFields.Clear;


        Sheet.Sort.SetRange(Sheet.Range['A7:AE' + IntToStr(Linha)]);
        Sheet.Sort.Header      := xlGuess;
        Sheet.Sort.MatchCase   := False;
        Sheet.Sort.Orientation := xlTopToBottom;
        Sheet.Sort.SortMethod  := xlPinYin;
        Sheet.Sort.Apply;

        if FileExists(Arquivo) then
          SysUtils.DeleteFile(Arquivo);
        WorkBook.SaveAs(Arquivo);

        if TemDados then
          Result := Arquivo
        else
          Result := 'Sem Dados';

      finally
        WorkBook.Close(False);
        KillExcel(Excel);
      end;
    finally
      FreeAndNil(qryEventos);
      FreeAndNil(qryRelatorio);
      FreeAndNil(qryAuxiliar);
      FreeAndNil(db_broker);
    end;
  except
    on e:Exception do
    begin
      VMsg('Erro - RelEventosDailyFupTranspMaritimo: ' + e.Message, msError, True);
    end;
  end;

end;


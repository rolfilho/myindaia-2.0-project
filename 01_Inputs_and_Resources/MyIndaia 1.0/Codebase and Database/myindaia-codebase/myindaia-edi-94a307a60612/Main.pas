{*******************************************************************************
Funcao que formata os dados do tipo numerico para o formato pedido pela Volks.
O formato Volks é: alinhar a direita a parte inteira do valor e preencher com
zeros o restante do lado esquerdo. A parte decimal é alinhada a esquerda e
preenchida com zero no lado esquerdo. Exemplo: valor 2,54 tamanho dos campos
3,5. Reultado 00254000.
*******************************************************************************}
function TfrmMain.FORMATAR_VALOR_VOLKS(Valor : Extended; Casas_Decimais : Integer) : String;
Var
  Aux_Valor_Int,
  Aux_Valor_Dec,
  Aux_Valor     : String;
  Aux_NCD       : Integer;
begin
  Aux_Valor := FloatToStr(Valor);
  if Aux_Valor <> '' then
  begin
    Aux_NCD   := Casas_Decimais;
    if Pos(FormatSettings.DecimalSeparator,Aux_Valor) = 0 then
    begin
     Aux_Valor_Int := Aux_Valor;
     Aux_Valor_Dec := '';
    end
    else
    begin
      Aux_Valor_Int := ExtractWord(1,Aux_Valor,FormatSettings.DecimalSeparator);
      Aux_Valor_Dec := ExtractWord(2,Aux_Valor,FormatSettings.DecimalSeparator);
    end;
    while Length(Aux_Valor_Dec) < Aux_NCD do Aux_Valor_Dec := Aux_Valor_Dec + '0';
    Aux_Valor := Aux_Valor_Int + Aux_Valor_Dec;
    Delete(Aux_Valor,Pos(FormatSettings.DecimalSeparator,Aux_Valor),1);
    Result := Aux_Valor;
  end
  else
    Result := '';
end;

                     '   AND CD_RECEITA_IMPOSTO = ''0003'''              + sLineBreak ;
     Open;
     if not(IsEmpty) then
     begin
       {**Verifica se e arquivo Volks - se for formato o numero da maneira dela**}
       Result := frmMain.FORMATAR_VALOR(Fields[0].AsFloat,2);
     end
     else
       Result := '00000';
    finally
     Free;
    end;
  end;
end;


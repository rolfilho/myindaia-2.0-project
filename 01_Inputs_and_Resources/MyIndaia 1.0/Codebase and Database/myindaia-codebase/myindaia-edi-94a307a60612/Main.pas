      if Locate('CD_EVENTO', AEvento, []) then
      begin
        if AnsiIndexText(FieldByName('DT_REALIZACAO').AsString, ['', 'N/A', 'TO BE CONFIRMED']) < 0 then
          Sheet.Cells[Linha, AColuna].Value := StrToDate(FieldByName('DT_REALIZACAO').AsString)
        else
          Sheet.Cells[Linha, AColuna].Value := '';//FieldByName('DT_REALIZACAO').AsString;

        if FieldByName('DT_REALIZACAO_EFETIVA').AsString <> '' then
          if ((DayOfWeek(Date) = 2) and (FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -3)) or ((DayOfWeek(Date) <> 2) and (FieldByName('DT_REALIZACAO_EFETIVA').AsDateTime >= Date -1)) then
            Sheet.Cells[Linha, AColuna].Interior.ColorIndex := 40;
      end
      else
        Sheet.Cells[Linha, AColuna].Value := '';
    end;
  end;
begin
  try
    qryEventos            := TFDQuery.Create(Self);
    qryEventos.Connection := FDConnection;
    qryEventos.SQL.text   :=
    '  SELECT CD_EVENTO AS CD_EVENTO,                                                              ' + sLineBreak +
    '         CASE WHEN IN_APLICAVEL <> ''1''   THEN ''N/A''                                       ' + sLineBreak +
    '              WHEN DT_REALIZACAO IS NULL   THEN ''TO BE CONFIRMED''                           ' + sLineBreak +
    '              ELSE CONVERT(VARCHAR, DT_REALIZACAO, 103)                                       ' + sLineBreak +
    '         END AS DT_REALIZACAO,                                                                ' + sLineBreak +
    '         CONVERT(VARCHAR, ISNULL(DT_REALIZACAO_EFETIVA, 0), 103) AS DT_REALIZACAO_EFETIVA     ' + sLineBreak +
    '  FROM TFOLLOWUP (NOLOCK)                                                                     ' + sLineBreak +
    '  WHERE NR_PROCESSO = :NR_PROCESSO                                                            ' + sLineBreak +
    '    AND CD_EVENTO IN (''131'', ''147'', ''313'', ''314'', ''369'', ''506'', ''620'', ''621'') ' + sLineBreak ;

    qryRelatorio            := TFDQuery.Create(Self);
    qryRelatorio.Connection := FDConnection;
    qryRelatorio.SQL.Text :=

     '  SELECT                                                                                                                                    ' + sLineBreak +
     '         ISNULL(STUFF((SELECT DISTINCT '','' + LTRIM(RTRIM(ISNULL(R.CD_REFERENCIA, '''')))                                                  ' + sLineBreak +
     '                         FROM TREF_CLIENTE R WITH (NOLOCK)                                                                                  ' + sLineBreak +
     '                        WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                              ' + sLineBreak +
     '                          AND R.TP_REFERENCIA = CASE SUBSTRING(R.NR_PROCESSO, 3, 2)                                                         ' + sLineBreak +
     '                                                     WHEN ''01'' THEN ISNULL(G.TP_PEDIDO_BUSCA_IMP, ''01'')                                 ' + sLineBreak +
     '                                                     ELSE ISNULL(G.TP_PEDIDO_BUSCA, ''01'')                                                 ' + sLineBreak +
     '                                                END                                                                                         ' + sLineBreak +
     '              FOR XML PATH('''')), 1, 1, ''''), '''')         AS CD_REFERENCIA,                                                             ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '         RTRIM(PR.NR_PROCESSO)                          AS NR_PROCESSO,                                                                     ' + sLineBreak +
     '         RTRIM(EN.NM_EMPRESA)                           AS NM_CLIENTE,                                                                      ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '         ISNULL(STUFF((SELECT DISTINCT '','' + LTRIM(RTRIM(ISNULL(R.CD_REFERENCIA, '''')))                                                  ' + sLineBreak +
     '                         FROM TREF_CLIENTE R WITH (NOLOCK)                                                                                  ' + sLineBreak +
     '                        WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                              ' + sLineBreak +
     '                          AND R.TP_REFERENCIA = ''02''                                                                                      ' + sLineBreak +
     '              FOR XML PATH('''')), 1, 1, ''''), '''')         AS NR_ORDEM,                                                                  ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '         PR.CD_IMPORTADOR                               AS CD_IMPORTADOR,                                                                   ' + sLineBreak +
     '         RTRIM(EE.NM_EMPRESA)                           AS NM_IMPORTADOR,                                                                   ' + sLineBreak +
     '         S.CD_VIA_TRANSPORTE                            AS CD_VIA_TRANSPORTE,                                                               ' + sLineBreak +
     '         RTRIM(VT.NM_VIA_TRANSP)                        AS NM_VIA_TRANSPORTE,                                                               ' + sLineBreak +
     '         RTRIM(CONVERT(VARCHAR(MAX), PR.TX_MERCADORIA)) AS TX_MERCADORIA,                                                                   ' + sLineBreak +
     '         PR.CD_AREA                                     AS CD_AREA,                                                                         ' + sLineBreak +
     '         RTRIM(AR.NM_AREA)                              AS NM_AREA,                                                                         ' + sLineBreak +
     '         RTRIM(PA.DESCRICAO)                            AS NM_PAIS_DESTINO,                                                                 ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '         RTRIM(CASE SUBSTRING(PR.NR_PROCESSO, 5, 2)                                                                                         ' + sLineBreak +
     '                    WHEN ''ER''                                                                                                             ' + sLineBreak +
     '                    THEN ISNULL(TR.AP_TRANSP_ROD, '''')                                                                                     ' + sLineBreak +
     '                    ELSE ISNULL(A.NM_AGENTE_REDUZIDO, A.NM_AGENTE)                                                                          ' + sLineBreak +
     '               END)                                     AS NM_AGENTE,                                                                       ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '         ISNULL(RTRIM(E.NM_EMBARCACAO), '''')           AS NM_EMBARCACAO,                                                                   ' + sLineBreak +
     '         RTRIM(LE.DESCRICAO)                            AS NM_PORTO_DESTINO,                                                                ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '         ISNULL(STUFF((SELECT DISTINCT '','' + LTRIM(RTRIM(ISNULL(R.CD_REFERENCIA, '''')))                                                  ' + sLineBreak +
     '                         FROM TREF_CLIENTE R WITH (NOLOCK)                                                                                  ' + sLineBreak +
     '                        WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                              ' + sLineBreak +
     '                          AND R.TP_REFERENCIA = ''05''                                                                                      ' + sLineBreak +
     '              FOR XML PATH('''')), 1, 1, ''''), '''')  AS NR_BOOKING,                                                                       ' + sLineBreak +

     '         ISNULL(STUFF((SELECT DISTINCT '','' + LTRIM(RTRIM(ISNULL(R.CD_REFERENCIA, '''')))                                                  ' + sLineBreak +
     '                         FROM TREF_CLIENTE R WITH (NOLOCK)                                                                                  ' + sLineBreak +
     '                        WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                              ' + sLineBreak +
     '                          AND R.TP_REFERENCIA = ''25''                                                                                      ' + sLineBreak +
     '              FOR XML PATH('''')), 1, 1, ''''), '''')  AS REF_OIC,                                                                          ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '         (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(CONVERT(VARCHAR, QT_TIPO) + '' '' + NM_TIPO + CHAR(10)), CHAR(10))      ' + sLineBreak +
     '            FROM (SELECT COUNT(*) AS QT_TIPO,                                                                                               ' + sLineBreak +
     '                         RTRIM(TC.NM_TP_CNTR) AS NM_TIPO                                                                                    ' + sLineBreak +
     '                    FROM TPROCESSO_CNTR PC (NOLOCK)                                                                                         ' + sLineBreak +
     '              INNER JOIN TTP_CNTR       TC (NOLOCK) ON TC.TP_CNTR = PC.TP_CNTR                                                              ' + sLineBreak +
     '                   WHERE PC.NR_PROCESSO = PR.NR_PROCESSO                                                                                    ' + sLineBreak +
     '                GROUP BY TC.NM_TP_CNTR                                                                                                      ' + sLineBreak +
     '                ) AS VW ) AS TP_CONTAINERS,                                                                                                 ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '         (SELECT MASTER.DBO.FN_RETIRA_CARACTER(MASTER.DBO.ROWCONCAT(CONVERT(VARCHAR, QT_TIPO) + '' '' + NM_TIPO + CHAR(10)), CHAR(10))      ' + sLineBreak +
     '            FROM (SELECT COUNT(*) AS QT_TIPO, RTRIM(TC.NM_CARRETA) AS NM_TIPO                                                               ' + sLineBreak +
     '                    FROM TPROCESSO_CNTR PC                                                                                                  ' + sLineBreak +
     '              INNER JOIN TTP_CARRETA    TC ON TC.CD_CARRETA = PC.CD_CARRETA                                                                 ' + sLineBreak +
     '                   WHERE PC.NR_PROCESSO = PR.NR_PROCESSO                                                                                    ' + sLineBreak +
     '                GROUP BY TC.NM_CARRETA) AS VW) AS TP_CARRETA,                                                                               ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '         RTRIM(TR.AP_TRANSP_ROD)               AS NM_TRANSP_ROD,                                                                            ' + sLineBreak +
     '         ISNULL(RTRIM(AA.NM_ARMAZEM), '''')      AS NM_ARMAZEM_ATRACACAO,                                                                   ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '         ISNULL(STUFF((SELECT DISTINCT '','' + LTRIM(RTRIM(ISNULL(R.CD_REFERENCIA, '''')))                                                  ' + sLineBreak +
     '                         FROM TREF_CLIENTE R WITH (NOLOCK)                                                                                  ' + sLineBreak +
     '                        WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                              ' + sLineBreak +
     '                          AND R.TP_REFERENCIA = ''04''                                                                                      ' + sLineBreak +
     '             FOR XML PATH('''')), 1, 1, ''''), '''')  AS NR_OUTROS,                                                                         ' + sLineBreak +

     '         CAST(ISNULL(STUFF((SELECT DISTINCT '' ,'' + LTRIM(RTRIM(ISNULL(R.CD_REFERENCIA, '''')))                                            ' + sLineBreak +
     '                         FROM TREF_CLIENTE R WITH (NOLOCK)                                                                                  ' + sLineBreak +
     '                        WHERE R.NR_PROCESSO   = PR.NR_PROCESSO                                                                              ' + sLineBreak +
     '                          AND R.TP_REFERENCIA = ''02''                                                                                      ' + sLineBreak +
     '              FOR XML PATH('''')), 2, 1, ''''), '''') AS VARCHAR(200))   AS NR_ORDEM,                                                       ' + sLineBreak +
     '         ISNULL(LT.DESCRICAO, '''')                    AS LOCAL_TRANSBORDO                                                                  ' + sLineBreak +
     '                                                                                                                                            ' + sLineBreak +
     '  FROM TPROCESSO                   PR   (NOLOCK)                                                                                            ' + sLineBreak +
     '     INNER JOIN TFOLLOWUP          F314 (NOLOCK) ON (PR.NR_PROCESSO   = F314.NR_PROCESSO                                                    ' + sLineBreak +
     '                                                AND F314.CD_EVENTO    = ''314'')                                                            ' + sLineBreak +
     '     INNER JOIN TSERVICO_NOVO      S    (NOLOCK) ON S.CD_SERVICO      = PR.CD_SERVICO                                                       ' + sLineBreak +
     '     INNER JOIN TEMPRESA_NAC       EN   (NOLOCK) ON EN.CD_EMPRESA     = PR.CD_CLIENTE                                                       ' + sLineBreak +
     '     INNER JOIN TGRUPO             G    (NOLOCK) ON G.CD_GRUPO        = EN.CD_GRUPO                                                         ' + sLineBreak +
     '     LEFT  JOIN TEMBARCACAO        E    (NOLOCK) ON PR.CD_EMBARCACAO  = E.CD_EMBARCACAO                                                     ' + sLineBreak +
     '     LEFT  JOIN TAGENTE            A    (NOLOCK) ON A.CD_AGENTE       = PR.CD_AGENTE                                                        ' + sLineBreak +
     '     LEFT  JOIN TTRANSP_ROD        TR   (NOLOCK) ON PR.CD_TRANSP_NAC  = TR.CD_TRANSP_ROD                                                    ' + sLineBreak +
     '     LEFT  JOIN TEMPRESA_EST       EE   (NOLOCK) ON EE.CD_EMPRESA     = PR.CD_IMPORTADOR                                                    ' + sLineBreak +
     '     LEFT  JOIN TVIA_TRANSP_BROKER VT   (NOLOCK) ON VT.CD_VIA_TRANSP  = S.CD_VIA_TRANSPORTE                                                 ' + sLineBreak +
     '     LEFT  JOIN TAREA              AR   (NOLOCK) ON AR.CD_AREA        = PR.CD_AREA                                                          ' + sLineBreak +
     '     LEFT  JOIN TARMAZEM           AA   (NOLOCK) ON AA.CD_ARMAZEM     = PR.CD_ARMAZEM_ATRACACAO                                             ' + sLineBreak +
     '     LEFT  JOIN TPAIS              PA   (NOLOCK) ON PA.CODIGO         = PR.CD_PAIS_DESTINO                                                  ' + sLineBreak +
     '     LEFT  JOIN TLOCAL_EMBARQUE    LE   (NOLOCK) ON LE.CODIGO         = PR.CD_LOCAL_DESEMBARQUE                                             ' + sLineBreak +
     '     LEFT  JOIN TLOCAL_EMBARQUE    LT   (NOLOCK) ON LT.CODIGO         = PR.CD_LOCAL_TRANSBORDO                                              ' + sLineBreak +
     '  WHERE (F314.DT_REALIZACAO IS NULL OR CONVERT(DATE, F314.DT_REALIZACAO, 103) >= CONVERT(DATE, CONVERT(VARCHAR, GETDATE() -3, 103), 103))   ' + sLineBreak +
     '    AND PR.IN_CANCELADO   = ''0''                                                                                                           ' + sLineBreak +
     '    AND PR.IN_LIBERADO    = ''1''                                                                                                           ' + sLineBreak +
     '    AND F314.IN_APLICAVEL = ''1''                                                                                                           ' + sLineBreak +
     '    AND ISNULL(E.NM_EMBARCACAO, '''') NOT IN (''* PROCESSO CANCELADO'', ''TBN'', ''AGUARDANDO NAVIO'' )                                     ' + sLineBreak ;

    if pUnidade <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_UNID_NEG = ' + QuotedStr(pUnidade) + '');
    if pProduto <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_PRODUTO  = ' + QuotedStr(pProduto) + '');
    if pGrupo <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_GRUPO    = ' + QuotedStr(pGrupo)   + '');
    if pCliente <> '' then
      qryRelatorio.SQL.Add('  AND PR.CD_CLIENTE  = ' + QuotedStr(pCliente) + '');

    qryRelatorio.SQL.Add('ORDER BY PR.NR_PROCESSO');

    qryAuxiliar            := TFDQuery.Create(Self);
    qryAuxiliar.Connection := FDConnection;

    try
      Excel    := CreateOLEObject('Excel.Application');
      try
        WorkBook := Excel.Workbooks.Open(GetPath+'DAILY_FOLLOWUP_Nestle_Fab.xlsx');
        Excel.Visible := chkVisualizarExcel.checked;
        Sheet := Excel.WorkBooks[1].Worksheets[1];

        qryAuxiliar.SQL.text :=
        'SELECT ISNULL((SELECT RTRIM(AP_UNID_NEG) AS AP_UNID_NEG FROM TUNID_NEG    (NOLOCK) WHERE CD_UNID_NEG = ' + QuotedStr(pUnidade) + '), ''Todas'') AS UNIDADE, ' + sLineBreak +
        '       ISNULL((SELECT RTRIM(NM_PRODUTO)  AS NM_PRODUTO  FROM TPRODUTO     (NOLOCK) WHERE CD_PRODUTO  = ' + QuotedStr(pProduto) + '), ''Todas'') AS PRODUTO, ' + sLineBreak +
        '       ISNULL((SELECT RTRIM(NM_GRUPO)    AS NM_GRUPO    FROM TGRUPO       (NOLOCK) WHERE CD_GRUPO    = ' + QuotedStr(pGrupo)   + '), ''Todos'') AS GRUPO,   ' + sLineBreak +
        '       ISNULL((SELECT RTRIM(NM_EMPRESA)  AS NM_EMPRESA  FROM TEMPRESA_NAC (NOLOCK) WHERE CD_EMPRESA  = ' + QuotedStr(pCliente) + '), ''Todos'') AS CLIENTE, ' + sLineBreak +
        '       CONVERT(VARCHAR, GETDATE(), 103)  AS DATA ' + sLineBreak ;
        qryAuxiliar.Open;

        Sheet.Range['G1'].Value := 'Unidade: ' + pUnidade + ' - ' + qryAuxiliar.FieldByName('UNIDADE').AsString;
        Sheet.Range['G2'].Value := 'Produto: ' + pProduto + ' - ' + qryAuxiliar.FieldByName('PRODUTO').AsString;
        Sheet.Range['G3'].Value := 'Grupo: '   + pGrupo   + ' - ' + qryAuxiliar.FieldByName('GRUPO').AsString;
        Sheet.Range['G4'].Value := 'Cliente: ' + pCliente + ' - ' + qryAuxiliar.FieldByName('CLIENTE').AsString;
        Sheet.Range['G5'].Value := 'Data: '    + qryAuxiliar.FieldByName('DATA').AsString;

        Arquivo := GetPath+'Gerados\DAILY_FOLLOWUP_' + AnsiUpperCase(Copy(qryAuxiliar.FieldByName('PRODUTO').AsString, 1, 3)) +
                   FormatDateTime('ddmmyyyyhhnnsszz', Now) + '.xls';

        qryAuxiliar.Close;

        with qryRelatorio do
        begin
          Open;
          First;
          Linha := 7;
          TemDados := not Eof;
          while not Eof do
          begin
            if qryEventos.Active then
              qryEventos.Close;

            qryEventos.ParamByName('NR_PROCESSO').AsString := FieldByName('NR_PROCESSO').AsString;
            qryEventos.Open;

            if Trim(FieldByName('CD_REFERENCIA').AsString) <> '' then
              Sheet.Cells[Linha,  1].Value := FieldByName('CD_REFERENCIA').AsString
            else
              Sheet.Cells[Linha,  1].Value := FieldByName('NR_OUTROS').AsString;

            Sheet.Cells[Linha,  2].Value := FieldByName('NR_PROCESSO').AsString;
            Sheet.Cells[Linha,  3].Value := FieldByName('NM_CLIENTE').AsString;
            Sheet.Cells[Linha,  4].Value := FieldByName('NR_ORDEM').AsString;
            Sheet.Cells[Linha,  5].Value := FieldByName('NM_IMPORTADOR').AsString;
            Sheet.Cells[Linha,  6].Value := FieldByName('NM_VIA_TRANSPORTE').AsString;
            Sheet.Cells[Linha,  7].Value := FieldByName('TX_MERCADORIA').AsString;
            Sheet.Cells[Linha,  8].Value := FieldByName('NM_AREA').AsString;
            Sheet.Cells[Linha,  9].Value := FieldByName('REF_OIC').AsString;
            Sheet.Cells[Linha, 10].Value := FieldByName('NR_ORDEM').AsString;
            Sheet.Cells[Linha, 11].Value := FieldByName('LOCAL_TRANSBORDO').AsString;

            Sheet.Cells[Linha, 12].Value := FieldByName('NM_PAIS_DESTINO').AsString;
            Sheet.Cells[Linha, 13].Value := FieldByName('NM_AGENTE').AsString;
            Sheet.Cells[Linha, 14].Value := FieldByName('NM_EMBARCACAO').AsString;
            Sheet.Cells[Linha, 15].Value := FieldByName('NM_PORTO_DESTINO').AsString;
            PreencheEvento(16, '506');
            Sheet.Cells[Linha, 17].Value := FieldByName('NR_BOOKING').AsString;
            PreencheEvento(18, '369');
            Sheet.Cells[Linha, 19].Value := FieldByName('TP_CONTAINERS').AsString;
            Sheet.Cells[Linha, 20].Value := FieldByName('TP_CARRETA').AsString;
            PreencheEvento(21, '313');
            Sheet.Cells[Linha, 22].Value := FieldByName('NM_TRANSP_ROD').AsString;
            PreencheEvento(23, '147');
            Sheet.Cells[Linha, 24].Value := GetDataContainer(FieldByName('NR_PROCESSO').AsString, 'DT_PREV_CHEGADA_FABR', 'dd/mm/yyyy hh:nn');
            Sheet.Cells[Linha, 24].Columns.Autofit;
            Sheet.Cells[Linha, 25].Value := GetDataContainer(FieldByName('NR_PROCESSO').AsString, 'DT_CHEGADA_FABR', 'dd/mm/yyyy hh:nn');
            Sheet.Cells[Linha, 25].Columns.Autofit;
            PreencheEvento(26, '314');
            Sheet.Cells[Linha, 27].Value := FieldByName('NM_ARMAZEM_ATRACACAO').AsString;
            PreencheEvento(28, '131');

            Sheet.Cells[Linha, 1].Rows.Autofit;

            Next;
            Inc(Linha);
          end;
        end;

        Dec(Linha);
        Range := Sheet.Range['A7' + ':AB' + IntToStr(Linha)];

        Range.Borders[xlDiagonalDown].LineStyle       := 0;
        Range.Borders[xlDiagonalUp].LineStyle         := 0;
        Range.Borders[xlEdgeLeft].LineStyle           := xlContinuous;
        Range.Borders[xlEdgeLeft].ColorIndex          := 15;
        Range.Borders[xlEdgeLeft].Weight              := xlThin;
        Range.Borders[xlEdgeTop].LineStyle            := xlContinuous;
        Range.Borders[xlEdgeTop].ColorIndex           := 15;
        Range.Borders[xlEdgeTop].Weight               := xlThin;
        Range.Borders[xlEdgeBottom].LineStyle         := xlContinuous;
        Range.Borders[xlEdgeBottom].ColorIndex        := 15;
        Range.Borders[xlEdgeBottom].Weight            := xlThin;
        Range.Borders[xlEdgeRight].LineStyle          := xlContinuous;
        Range.Borders[xlEdgeRight].ColorIndex         := 15;
        Range.Borders[xlEdgeRight].Weight             := xlThin;
        Range.Borders[xlInsideVertical].LineStyle     := xlContinuous;
        Range.Borders[xlInsideVertical].ColorIndex    := 15;
        Range.Borders[xlInsideVertical].Weight        := xlThin;
        Range.Borders[xlInsideHorizontal].LineStyle   := xlContinuous;
        Range.Borders[xlInsideHorizontal].ColorIndex  := 15;
        Range.Borders[xlInsideHorizontal].Weight      := xlThin;

        Sheet.Sort.SortFields.Clear;
        Sheet.Sort.SortFields.Add(Key:=Sheet.Range['W7:W' + IntToStr(Linha)], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
        Sheet.Sort.SortFields.Add(Key:=Sheet.Range['T7:T' + IntToStr(Linha)], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
        Sheet.Sort.SortFields.Add(Key:=Sheet.Range['U7:U' + IntToStr(Linha)], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
        Sheet.Sort.SortFields.Add(Key:=Sheet.Range['V7:V' + IntToStr(Linha)], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
        Sheet.Sort.SortFields.Add(Key:=Sheet.Range['M7:M' + IntToStr(Linha)], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);

        Sheet.Sort.SetRange(Sheet.Range['A7:AB' + IntToStr(Linha)]);

        Sheet.Sort.Header      := xlGuess;
        Sheet.Sort.MatchCase   := False;
        Sheet.Sort.Orientation := xlTopToBottom;
        Sheet.Sort.SortMethod  := xlPinYin;
        Sheet.Sort.Apply;

        if FileExists(Arquivo) then
          SysUtils.DeleteFile(Arquivo);
        WorkBook.SaveAs(Arquivo);

        if TemDados then
          Result := Arquivo
        else
          Result := 'Sem Dados';

      finally
        WorkBook.Close(False);
        KillExcel(Excel);
      end;
    finally
      FreeAndNil(qryEventos);
      FreeAndNil(qryRelatorio);
      FreeAndNil(qryAuxiliar);
    end;
  except
    on e:Exception do
    begin
      VMsg('Erro - RelEventosDailyFupFabricas: ' + e.Message, msError, True);
    end;
  end;
end;

function TfrmMain.RelEventosDailyFupPirelli(pUnidade, pProduto, pGrupo, pCliente: string): String;
var
  Excel, WorkBook, Sheet, Range: OleVariant;
  Arquivo: String;
  Linha: Integer;
  TemDados: Boolean;
  DescCab: TDescCab;
  vTimeStamp: string;
  Hour, min, sec, MSec: Word;

  procedure PreencheData(ALinha, AColuna: Integer; Data: string);
  begin
    Sheet.Cells[ ALinha, AColuna ].NumberFormat        := 'DD/MM/AAAA';
    Sheet.Cells[ ALinha, AColuna ].HorizontalAlignment := 3;

    if (Data <> 'N/A') and (Data <> '') then
    begin
      Sheet.Cells[ ALinha, AColuna ].Value := StrToDate(FormatDateTime('dd/mm/yyyy', StrToDate(Data)));
    end
    else
      Sheet.Cells[ ALinha, AColuna ].Value := Data;
  end;

begin

  try
    Excel    := CreateOLEObject('Excel.Application');
    try
      WorkBook := Excel.Workbooks.Open(GetPath+'DAILY_FOLLOWUP_Pirelli_Exp.xlsx');
      Excel.Visible := chkVisualizarExcel.checked;
      Sheet := Excel.WorkBooks[1].Worksheets[1];

      DescCab := GetDescCab(pUnidade, pProduto, pGrupo, pCliente, '');
      //Cabeçalho
      Sheet.Range['G1'].Value := 'Unidade: ' + pUnidade + ' - ' + DescCab.Unidade;
      Sheet.Range['G2'].Value := 'Produto: ' + pProduto + ' - ' + DescCab.Produto;
      Sheet.Range['G3'].Value := 'Grupo: '   + pGrupo   + ' - ' + DescCab.Grupo;
      Sheet.Range['G4'].Value := 'Cliente: ' + pCliente + ' - ' + DescCab.Cliente;
      Sheet.Range['G5'].Value := 'Data: '    + FormatDateTime('dd/mm/yyyy', date);

      FDQuery.Close;
      FDQuery.SQL.Text := GetSQLRelEventosDailyFupPirelli(pUnidade, pProduto, pGrupo, pCliente);

      FDQuery.Open;
      Linha := 7;
      FDQuery.First;
      while not FDQuery.Eof do
      begin

        Sheet.Cells[Linha, 01].value := FDQuery.FieldByName('NR_PROCESSO').AsString;
        Sheet.Cells[Linha, 02].value := FDQuery.FieldByName('NM_EMPRESA').AsString;
        Sheet.Cells[Linha, 03].value := FDQuery.FieldByName('CGC_EMPRESA').AsString;
        Sheet.Cells[Linha, 04].value := FDQuery.FieldByName('NR_PEDIDO').AsString;

        Sheet.Cells[Linha, 05].value := FDQuery.FieldByName('NR_FATURA').AsString;
        Sheet.Cells[Linha, 06].value := FDQuery.FieldByName('NM_AREA').AsString;
        Sheet.Cells[Linha, 07].value := FDQuery.FieldByName('NR_BOOKING').AsString;

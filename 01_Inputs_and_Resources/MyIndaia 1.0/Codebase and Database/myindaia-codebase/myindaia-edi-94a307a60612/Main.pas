function TfrmMain.RelDUEsRegistradas(pUnidade, pProduto, pGrupo, pCliente, pArea, pEvento, pRelatorio, pHorario: String): String;
var
  db_broker                                              : TDatabase;
  qryDUEsRegistradas : TFDQuery;
  Excel, xlWorkB, oSheet                                 : OleVariant;
  nLinha, Coluna, ctLinha, nColuna,
  vPrimeiraLinha, vCont,i,x,vTotalEventos                : Integer;
  vTimeStamp                                             : string;
  tem_dados                                              : boolean;
  mDados : TFDMemTable;

  procedure PreencheData(ALinha, AColuna: Integer; Data: string);
  begin
    oSheet.Cells[ ALinha, AColuna ].NumberFormat        := 'dd/mm/aaaa';
    oSheet.Cells[ ALinha, AColuna ].HorizontalAlignment := 3;

    if (Data <> 'N/A') and (trim(Data) <> '') then
    begin
      oSheet.Cells[ ALinha, AColuna ].Value := StrToDate(Data)//FormatDateTime('dd/mm/yyyy', Data)
    end
    else
      oSheet.Cells[ ALinha, AColuna ].Value := Data;
  end;

begin

  if Screen.ActiveForm is TfrmGeraRelatorio then
    ShowMessage('Este relatório está configurado para ser emitido apenas segunda-feira e quinta-feira. Este e-mail de teste será enviado normalmente.')
  else
  if not (dayofweek(now)  in [2, 5]) then {apenas nas segundas e quintas}
    exit;

  db_broker:= TDatabase.Create(Self);
  db_broker.AliasName    := 'BROKER';
  db_broker.DatabaseName := 'DBBROKER';
  db_broker.LoginPrompt  := False;
  db_broker.Params.Add('USER NAME=MYROBO');
  db_broker.Params.Add('PASSWORD=123');

  qryDUEsRegistradas            := TFDQuery.Create(Self);
  qryDUEsRegistradas.Connection := FDConnection;

  try

    Excel   := CreateOLEObject('Excel.Application');
    try
      db_broker.Connected := True;

      xlWorkB       := Excel.Workbooks.Open(GetPath+'DUEsRegistradas.xlsx');
      Excel.Visible := chkVisualizarExcel.checked;
      vTimeStamp    := FormatDateTime('ddmmyyyyhhnnsszz', Now);

      try
        oSheet := Excel.WorkBooks[1].Worksheets[1];

        try
          qryDUEsRegistradas.Close;
          qryDUEsRegistradas.SQL.Clear;

          {$region 'Sql'}
          qryDUEsRegistradas.SQL.Text :=
            ' SELECT ' + sLineBreak +
            ' RC.CD_REFERENCIA AS A,--[Nr. Fatura], ' + sLineBreak +
            ' NF.CHAVE_NOTA AS B,--[Nota Fiscal Exportaçăo - Chave de Acesso], ' + sLineBreak +
            ' TP.CD_DUE AS C,--[DUE], ' + sLineBreak +
            ' CONVERT(VARCHAR(10),EV124.DT_REALIZACAO,103) AS D,--[Emissăo de DUE], ' + sLineBreak +
            ' TE.CD_CHAVE_ACESSO_DUE AS E--[DUE - Chave de Acesso] ' + sLineBreak +
            ' FROM BROKER.DBO.TPROCESSO TP (NOLOCK) ' + sLineBreak +
            ' LEFT JOIN BROKER.DBO.TREF_CLIENTE RC (NOLOCK) ON RC.NR_PROCESSO = TP.NR_PROCESSO AND RC.TP_REFERENCIA=''21'' ' + sLineBreak +
            ' LEFT JOIN BROKER.DBO.TFOLLOWUP EV124 (NOLOCK) ON EV124.NR_PROCESSO = TP.NR_PROCESSO AND EV124.CD_EVENTO=''124'' ' + sLineBreak +
            ' LEFT JOIN BROKER.DBO.TPROCESSO_EXP TE (NOLOCK) ON TE.NR_PROCESSO = TP.NR_PROCESSO ' + sLineBreak +
            ' LEFT JOIN BROKER.DBO.TPROCESSO_EXP_NF NF (NOLOCK) ON NF.NR_PROCESSO = TP.NR_PROCESSO ' + sLineBreak +
            ' WHERE TP.CD_GRUPO = ''C22'' ' + sLineBreak +
            ' AND TP.CD_PRODUTO = ''02'' ' + sLineBreak +
            ' AND EV124.DT_REALIZACAO >= GETDATE()-5 ';
          {$endregion}

          if not DirectoryExists(GetPath+'SQL') then
            ForceDirectories(GetPath+'SQL');

          try
            qryDUEsRegistradas.SQL.SaveToFile(GetPath+'SQL\' + pRelatorio + '.sql');
          except
          end;

          qryDUEsRegistradas.Open;

        except
          on e:Exception do
          begin
            VMsg('Erro - 1 Relatório Cargil: ' + e.Message, msError, True);
          end
        end;

       mdados := TFDMemTable.Create(nil);
       qryDUEsRegistradas.FetchAll;
       mdados.Data := qryDUEsRegistradas.Data;

       qryDUEsRegistradas.Close;

       try
          tem_dados := False;
          nLinha := 1;
          mdados.First;
          while not mdados.Eof do
          begin
            tem_dados := True;
            nLinha    := nLinha +1;
            Coluna := 0;

            oSheet.Cells[ nLinha, MyInc(Coluna)].Value := mdados.FieldByName('A').AsString;
            oSheet.Cells[ nLinha, MyInc(Coluna)].Value := mdados.FieldByName('B').AsString;
            oSheet.Cells[ nLinha, MyInc(Coluna)].Value := mdados.FieldByName('C').AsString;
            oSheet.Cells[ nLinha, MyInc(Coluna)].Value := mdados.FieldByName('D').AsString;
            oSheet.Cells[ nLinha, MyInc(Coluna)].Value := mdados.FieldByName('E').AsString;

            mdados.Next;
          end;

        except
          on e:Exception do
          begin
            VMsg('Erro - 2 Relatório DUEs Registradas: ' + e.Message, msError, True);
          end
        end;
      finally
        Excel.Visible := chkVisualizarExcel.checked;
        if FileExists(GetPath+'Gerados\RelatorioDUEsRegistradas_' + vTimeStamp + '.XLS') then
          SysUtils.DeleteFile(GetPath+'Gerados\RelatorioDUEsRegistradas_' + vTimeStamp + '.XLS');

        Excel.ActiveWorkBook.SaveAs(GetPath+'Gerados\RelatorioDUEsRegistradas_' + vTimeStamp + '.XLS');
      end;

      if tem_dados then
         Result := GetPath+'Gerados\RelatorioDUEsRegistradas_' + vTimeStamp + '.XLS'
      else
         Result := 'Sem Dados';
    finally
      try
        Excel.ActiveWorkBook.Close(False);
        KillExcel(Excel);
      except
      end;
    end;

  finally
    mdados.Free;
    FreeAndNil(qryDUEsRegistradas);
    FreeAndNil(db_broker);
  end;
end;


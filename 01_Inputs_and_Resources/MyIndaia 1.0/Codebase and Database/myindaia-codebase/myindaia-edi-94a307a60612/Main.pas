Function TFrmMain.RelPrevisao(pUnidade, pProduto : string) : string;
var
  db_broker                     : TDatabase;
  qry_mail_proc_nao_fat         : TQuery;
  Excel, xlWorkB, oSheet        : OleVariant;
  nLinha, vPrimeiraLinha, vCont : Integer;
  vValorTotalServico            : Real;
  vAno, vMes, vDia              : Word;
  vTimeStamp, vNomeProduto      : string;
  Hour, min, sec, MSec          : Word;
begin
  try
    Result := '';
    db_broker := TDatabase.Create(Self);
    with db_broker do
    begin
      AliasName    := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt  := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;

    qry_mail_proc_nao_fat := TQuery.Create(Self);
    try
      db_broker.Connected    := True;
      qry_mail_proc_nao_fat.DatabaseName := 'DBBROKER';
      qry_mail_proc_nao_fat.SQL.Clear;
      qry_mail_proc_nao_fat.SQL.text := 'Exec SP_MAIL_PROC_NAO_FAT ''' + pUnidade + ''',''' + pProduto + '''';
      qry_mail_proc_nao_fat.ExecSQL;

      // verifica se o relatório sairá em branco
      with TQuery.Create(Self) do
      begin
        try
          Databasename := 'DBBROKER';
          SQL.Clear;
          SQL.Add('SELECT COUNT(*) FROM TMAIL_PROC_NAO_FAT ( NOLOCK )');
          Open;
          pAlertaEmBranco := ( Fields[0].AsInteger = 0 );
        finally
          Close;

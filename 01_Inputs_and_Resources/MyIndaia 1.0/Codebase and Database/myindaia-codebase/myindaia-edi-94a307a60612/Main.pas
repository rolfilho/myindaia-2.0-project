           oSheet.Cells[ nLinha, nColuna ].Font.Bold       := False;
           oSheet.Cells[ nLinha, nColuna ].Font.Name       := 'Webdings';
           oSheet.Cells[ nLinha, nColuna ].Font.Size       := 18;

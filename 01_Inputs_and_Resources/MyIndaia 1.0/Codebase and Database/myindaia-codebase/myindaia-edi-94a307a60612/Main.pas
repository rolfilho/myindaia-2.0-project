      qry_mail_proc_nao_fat.ParamByName('PRODUTO').AsString := pProduto;
      qry_mail_proc_nao_fat.ParamByName('EVENTO').AsString  := pEvento;
      qry_mail_proc_nao_fat.ParamByName('AREA').AsString    := pArea;
      qry_mail_proc_nao_fat.ParamByName('SUBAREA').AsString := pSubArea;
      qry_mail_proc_nao_fat.ParamByName('CLIENTE').AsString := pCliente;
      qry_mail_proc_nao_fat.ParamByName('GRUPO').AsString   := pGrupo;
      qry_mail_proc_nao_fat.ParamByName('ATENDENTE').AsString := pAtendente;
      qry_mail_proc_nao_fat.ParamByName('CELULA').AsString    := pCelula;
      qry_mail_proc_nao_fat.ParamByName('MODAL').AsString     := pModal;
      qry_mail_proc_nao_fat.ExecSQL;

      // verifica se o relatório sairá em branco
      with TQuery.Create(Self) do
      begin
        try
          Databasename := 'DBBROKER';
          SQL.Clear;
          SQL.Add('SELECT COUNT(*) FROM TMAIL_PENDENTES ( NOLOCK )');
          Open;
          pAlertaEmBranco := ( Fields[0].AsInteger = 0 );
        finally
          Close;
          Free;
        end;
      end;
      // fim da verificaçăo

      if pAlertaEmBranco then
      begin
        Result := '';
        Exit;
      end;

      Excel      := CreateOLEObject('Excel.Application');
      try
        xlWorkB    := Excel.Workbooks.Open( GetPath+'PENDENTES.xlsx' );
        Excel.Visible := chkVisualizarExcel.checked;
        vTimeStamp := FormatDateTime('ddmmyyyyhhnnsszzz', Now);

        with TQuery.Create(Self) do
        begin
          try
            DatabaseName := 'DBBROKER';

            SQL.Clear;
            SQL.Add('SELECT NM_UNID_NEG FROM TUNID_NEG ( NOLOCK ) WHERE CD_UNID_NEG = ''' + pUnidade + '''');
            Open;
            TituloUnidade :=  ' ' + pUnidade + ' - ' + Fields[0].AsString;
            Close;

            SQL.Clear;
            SQL.Add('SELECT NM_PRODUTO FROM TPRODUTO ( NOLOCK ) WHERE CD_PRODUTO = ''' + pProduto + '''');
            Open;
            TituloProduto :=  ' ' + pProduto + ' - ' + Fields[0].AsString;
            vNomeProduto := Copy(Fields[0].AsString,1,3);
            Close;

            if (pArea <> 'X') or (pSubArea <> 'X') then
            begin
              SQL.Clear;
              if pArea <> 'X' then
                SQL.Add('SELECT NM_AREA FROM TAREA ( NOLOCK ) WHERE CD_AREA = ''' + pArea + '''')
              else if pSubArea <> '' then
                SQL.Add('SELECT NM_AREA FROM TAREA ( NOLOCK ) WHERE CD_AREA = ''' + pSubArea + '''');
              Open;

              TituloArea :=  ' ' + pArea + pSubArea + ' - ' + Fields[0].AsString;
              Close;
            end
            else
              TituloArea :=  ' Todas';

            SQL.Clear;
            SQL.Add('SELECT NM_EVENTO FROM TEVENTO ( NOLOCK ) WHERE CD_EVENTO = ''' + pEvento + '''');
            Open;
            TituloEvento :=  ' Evento : ' + pEvento  + ' - ' + Fields[0].AsString;
            Close;
          finally
            Free;
          end;
        end;

        //DATA
        TituloData :=  ' ' + FormatDateTime('dd/mm/yyyy', Now);

        for I := 1 to High(_SQL) do
        begin
          oSheet := Excel.WorkBooks[1].Worksheets[I];

          oSheet.Cells[ 02, 05 ].value := TituloUnidade;
          oSheet.Cells[ 03, 05 ].value := TituloProduto;
          oSheet.Cells[ 04, 05 ].value := TituloArea;
          oSheet.Cells[ 05, 05 ].value := TituloData;
          oSheet.Cells[ 07, 02 ].value := TituloEvento;

          //DecodeDate(Now, vAno, vMes, vDia);
          nLinha := 9;

          // cabeçalho
          vPrimeiraLinha := nLinha;
          if pProduto='01' then
            oSheet.Cells[nLinha +1, 07].value := 'Local de Desembarque'
          else
            oSheet.Cells[nLinha +1, 07].value := 'Local de Embarque';

          nLinha := nLinha +2;

          // preparando a query para o corpo
          qry_mail_proc_nao_fat.SQL.Clear;
          qry_mail_proc_nao_fat.SQL.text := _SQL[I];
          qry_mail_proc_nao_fat.Prepare;
          qry_mail_proc_nao_fat.Open;

          // corpo
          vCont  := 0;
          vValorTotalServico := 0;
          while not qry_mail_proc_nao_fat.EOF do
          begin
            oSheet.Cells[nLinha, 02].value := Trim(qry_mail_proc_nao_fat.FieldByName('NR_PROCESSO').AsString);

            oSheet.Cells[nLinha, 03].value := qry_mail_proc_nao_fat.FieldByName('CD_REFERENCIA').AsString;
            oSheet.Cells[nLinha, 04].value := qry_mail_proc_nao_fat.FieldByName('AREA').AsString;
            oSheet.Cells[nLinha, 05].value := qry_mail_proc_nao_fat.FieldByName('NM_GRUPO').AsString;
            oSheet.Cells[nLinha, 06].value := qry_mail_proc_nao_fat.FieldByName('CLIENTE').AsString;

            { by Carlos - 20/08/2010 }
            if pProduto='01' then
              oSheet.Cells[nLinha, 07].value := qry_mail_proc_nao_fat.FieldByName('LOCAL_DESEMBARQUE').AsString
            else
              oSheet.Cells[nLinha, 07].value := qry_mail_proc_nao_fat.FieldByName('LOCAL_EMBARQUE').AsString;

            if qry_mail_proc_nao_fat.FieldByName('PREVISAO').AsString <> '' then
            begin
              oSheet.Cells[nLinha, 08].value := ' ' + FormatDateTime('dd/mm/yyyy', qry_mail_proc_nao_fat.FieldByName('PREVISAO').AsDateTime);
              oSheet.Cells[nLinha, 09].value := ' ' + FormatDateTime('hh:nn', qry_mail_proc_nao_fat.FieldByName('PREVISAO').AsDateTime);
            end;

            oSheet.Cells[nLinha, 10].value := ' ' + qry_mail_proc_nao_fat.FieldByName('ATRASO').AsString;

            //acrescentada coluna com nome evento base (Andressa)
            oSheet.Cells[nLinha, 11].value := ' ' + qry_mail_proc_nao_fat.FieldByName('NM_EVENTO_BASE').AsString;
            if qry_mail_proc_nao_fat.FieldByName('DT_EVENTO_BASE').AsString <> '' then
            begin
              oSheet.Cells[nLinha, 12].value := ' ' + FormatDateTime('dd/mm/yyyy', qry_mail_proc_nao_fat.FieldByName('DT_EVENTO_BASE').AsDateTime);
              oSheet.Cells[nLinha, 13].value := ' ' + FormatDateTime('hh:nn', qry_mail_proc_nao_fat.FieldByName('DT_EVENTO_BASE').AsDateTime);
            end;

            oSheet.Cells[nLinha, 14].value := ' ' + qry_mail_proc_nao_fat.FieldByName('CD_CELULA').AsString;
            oSheet.Cells[nLinha, 15].value := ' ' + qry_mail_proc_nao_fat.FieldByName('NM_ATENDENTE').AsString;

            nLinha := nLinha + 1;
            vCont  := vCont  + 1;
            qry_mail_proc_nao_fat.Next;
          end;

          // complementando o cabeçalho
          oSheet.Cells[ vPrimeiraLinha, 02 ].value := IntToStr(vCont) + ' processos';
          nLinha := nLinha +1;
        end;

        //--------------------------------------------------------------------------//
        // finalizando...
        //--------------------------------------------------------------------------//
        qry_mail_proc_nao_fat.Close;
        qry_mail_proc_nao_fat.SQL.Clear;
        qry_mail_proc_nao_fat.SQL.text := 'DELETE FROM TMAIL_PENDENTES';
        qry_mail_proc_nao_fat.ExecSQL;
        //--------------------------------------------------------------------------//
        // deixar a planilha visivel no windows
        //--------------------------------------------------------------------------//

        Excel.Visible := chkVisualizarExcel.checked;
        if FileExists(GetPath+'Gerados\PENDENTES_' + vNomeProduto + '_' + vTimeStamp + '.XLS') then
          SysUtils.DeleteFile(GetPath+'Gerados\PENDENTES_' + vNomeProduto + '_' + vTimeStamp + '.XLS');
        Excel.ActiveWorkBook.SaveAs(GetPath+'Gerados\PENDENTES_' + vNomeProduto + '_' + vTimeStamp + '.XLS');
        Result := GetPath+'Gerados\PENDENTES_' + vNomeProduto + '_' + vTimeStamp + '.XLS';

      finally
        Excel.ActiveWorkBook.Close(False);
        KillExcel(Excel);
      end;
    finally
      qry_mail_proc_nao_fat.Free;
      db_broker.Free;
    end;
  except
    on e:Exception do
    begin
      VMsg('Erro - RelPrevisaoGeral: ' + e.Message, msError, True);
    end;
  end;
end;


              sql.Add ( '      THEN CONVERT(DATE,F.DT_REALIZACAO,103)                                                                                                                                                        ');
              sql.add ( '      ELSE CONVERT(DATE,F3.DT_REALIZACAO,103) END   >= CONVERT(DATE,GETDATE()-2,103  )))                                                                                                            ');
              SQL.Add ( ' AND  PR.IN_CANCELADO  = "0"                                                                                                                                                                        ');
              SQL.Add ( ' AND  PR.IN_LIBERADO   = "1"                                                                                                                                                                        ');


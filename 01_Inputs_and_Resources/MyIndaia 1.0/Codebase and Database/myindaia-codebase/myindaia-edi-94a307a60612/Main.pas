{**Chama uma procedure especial**}
function TfrmMain.CallRunTimeFunction(Proc: String): String;
var p: Integer;
begin
   Result := '';
  for p := 0 to high(RTFS) do
    if RTFS[p].Name = Proc then Result := RTFS[p].Func;
end;


function TfrmMain.SendMail(const ARemetente, APara, ACopia, ACopiaOculta: string;
   const AAssunto, ACorpo, AAnexos: string; out Msg: string): Boolean;
var
  NewText1 : TIdText;
  I: Integer;
  Remetente: string;
begin
  IdSMTP1.Host     := strHOST_MAIL;
  IdSMTP1.Port     := strPORT_MAIL;
  IdSMTP1.Username := strUSER_MAIL;
  IdSMTP1.Password := strPWD_MAIL;

  if EMAIL_TLS then
  begin
    IdSMTP1.IOHandler := IdSSLIOHandlerSocketOpenSSL1;
    IdSMTP1.UseTLS := utUseExplicitTLS;
  end
  else
  begin
    IdSMTP1.IOHandler := nil;
    IdSMTP1.UseTLS := utNoTLSSupport;
  end;
  IdMessage1.Clear;

  NewText1 := TIdText.Create(IdMessage1.MessageParts);

  try
    with NewText1 do
    begin
      if AnsiContainsText(ACorpo, '<html>') then
        ContentType:='text/html'
      else
        ContentType:='text/plain';
      if (AAnexos <> '') then
        TIdAttachmentFile.Create(IdMessage1.MessageParts, AAnexos);
      Body.Text := ACorpo;
    end;

    if ARemetente = '' then
      Remetente := 'ti@myindaia.com.br'
    else
      Remetente := ARemetente;

    IdMessage1.From.Text := Remetente;
    IdMessage1.Recipients.EMailAddresses := APara;
    IdMessage1.CCList.EMailAddresses := ACopia;
    IdMessage1.BccList.EMailAddresses := ACopiaOculta;
    IdMessage1.Subject := AAssunto;
    IdSMTP1.Connect;
    try
      IdSMTP1.Send(IdMessage1);
      Result := True;
    except
      on E: Exception do
      begin
        Msg := E.Message;
        Result := False;
      end;
    end;
  finally
    FreeAndNil(NewText1);
    IdSMTP1.Disconnect;
    IdMessage1.Clear;
  end;
end;

function TfrmMain.EnviaEmail(pTo, pAssunto, pAnexo: String): Boolean;
var
  pwAssunto: string;
  pwDestinatarios: string;
  pwRemetente: string;
  pwCopiaOculta: string;
  Body: TStrings;
begin
  Result := True;
  Body := TStringList.Create;
  try
    try
      case StrToInt(FormatDateTime('hh',now)) of
        0..5   : Body.Add('Boa noite,');
        6..11  : Body.Add('Bom dia,');
        12..17 : Body.Add('Boa tarde,');
        18..23 : Body.Add('Boa noite,');
      end;
      if pAnexo = '' then
      begin
        Body.Add('');
        Body.Add('     - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -');
        Body.Add('');
        Body.Add('     [ ' + FormatDateTime('dd "de" mmmm "de" yyyy',now) + ' ]');
        Body.Add('');
        Body.Add('     Năo existem registros pendentes para este evento no dia de hoje.');
        Body.Add('');
        Body.Add('     - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -');
        Body.Add('');
      end;
      Body.Add('');
      Body.Add('     Esta é uma mensagem gerada automaticamente pelo MyIndaiá.');
      Body.Add('');
      Body.Add('     Por favor, năo responda esse email.');
      Body.Add('');
      Body.Add('     Caso tenha dúvidas ou se desejar năo receber mais esta mensagem, favor entrar em contato com myindaia@myindaia.com.br');
      Body.Add('');
      Body.Add('');
      Body.Add('Obrigado,');
      Body.Add('Departamento de TI');
      Body.Add('Indaiá Logística');
      Body.Add('');

      if Screen.ActiveForm is TfrmGeraRelatorio then
        pwDestinatarios := frmGeraRelatorio.GetCheckedMails
      else
      begin
        pTo := Trim(pTo);
        if pTo = '' then
          pwDestinatarios := EmailProgramador
        else
        begin
          pwDestinatarios := pTo;
          pwCopiaOculta := EmailProgramador
        end;
      end;
      pwAssunto := '[myIndaiáMail] ' + pAssunto + ' - ' + FormatDateTime('dd/MM/yyyy hh:mm:ss', Now);
      pwRemetente := 'ti@myindaia.com.br';

      Result := SendMail(pwRemetente, pwDestinatarios, '', pwCopiaOculta, pwAssunto, Body.Text, pAnexo, MensagemErro); // Aqui envia}
      if not Result then
        VMsg('Erro enviando e-mail: ' + MensagemErro, msErroEmail, True);
    except
      on e:exception do begin
        VMsg(e.message + '  -  O email seria para : ' + pTo, msErrorEnvio, True);
        result:=False;
      end;
    end;
  finally
    Body.Free;
  end;
end;


function TfrmMain.EnviaEmailHtmlAnexo(pTo, pAssunto, pAnexo, pGrupo, pImportador, pProduto, pTipo_Rel,  pCodRelatorio, pCorpoEmail: String) : Boolean;
var
  str_nm_matriz: string;
  str_nm_produto: string;
  str_nm_depto: string;
  str_nm_email_contato_daily: string;
  vIdioma : string;
  pwAssunto: string;
  pwDestinatarios: string;
  pwRemetente: string;
  Body: TStrings;
  pwCopiaOculta: string;
begin
  Body := TStringList.Create;
  try
    try
      with TQuery.Create(Self) do
      begin
        try
          DatabaseName := 'BROKER';
          SessionName := 'SES_EDI';
          SQL.Clear;

          if (pTipo_rel = 'E05') or
             (pTipo_rel = 'E08') or
             (pTipo_rel = 'E09') or
             (pTipo_rel = 'E12') or
             (pTipo_rel = 'E18') or
             (pTipo_rel = 'DFF') or
             (pTipo_rel = 'FPE') or
             (pTipo_rel = 'DFT') or
             (pTipo_rel = 'FDT') or
             (pTipo_rel = 'DFA') or
             (pTipo_rel = 'CIS') or
             (pTipo_rel = 'DUE') or
             (pTipo_rel = 'AVE') or
             (pTipo_rel = 'DF0') then
          begin
             SQL.TEXT := '  SELECT NM_EMPRESA                                           ' + sLineBreak +
                         '    FROM TEMPRESA_NAC (NOLOCK)                                ' + sLineBreak +
                         '   WHERE CGC_EMPRESA IN (SELECT CNPJ_GRUPO                    ' + sLineBreak +
                         '                           FROM TGRUPO (NOLOCK)               ' + sLineBreak +
                         '                          WHERE CD_GRUPO = "' + pGrupo + '" ) ' + sLineBreak ;
          end
          else
          begin
             SQL.TEXT := 'SELECT NM_EMPRESA                         '  + sLineBreak +
                         '  FROM TEMPRESA_EST (NOLOCK)              '  + sLineBreak +
                         ' WHERE CD_EMPRESA = "' + pImportador + '" '  + sLineBreak ;
          end;

          Open;
          str_nm_matriz  := Fields[0].AsString;
          close;

          //busca o idioma do Importador
          SQL.Clear;
          SQL.TEXT := ' SELECT ISNULL(P.CD_IDIOMA_PADRAO,"9")                   '  + sLineBreak +

    Body.Add('          <td width="22%" align="left" valign="middle" nowrap="nowrap"><span class="style31">'+IIF(pUnidade='','Todas',ConsultaLookUpSQL('SELECT NM_UNID_NEG FROM TUNID_NEG (NOLOCK) WHERE CD_UNID_NEG = ''' + pUnidade + '''','NM_UNID_NEG'))+'</span> </td>');

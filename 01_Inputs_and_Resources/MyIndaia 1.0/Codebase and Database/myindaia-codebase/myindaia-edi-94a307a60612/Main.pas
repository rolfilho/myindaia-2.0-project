                    SQL.Add(' SELECT isnull( CONVERT(VARCHAR(MAX),U.NM_EMAIL)  ,"") FROM TPROCESSO P (NOLOCK) ');
                    SQL.Add(' LEFT JOIN TCLIENTE_CONTATO CC (NOLOCK) ON (P.CD_CLIENTE=CC.CD_CLIENTE  AND P.CD_UNID_NEG=CC.CD_UNID_NEG AND P.CD_PRODUTO=CC.CD_PRODUTO AND P.CD_CONTATO=CC.CD_CONTATO ) ');

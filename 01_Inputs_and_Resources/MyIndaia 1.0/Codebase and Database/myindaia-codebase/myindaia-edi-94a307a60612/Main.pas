                     oSheet.Cells[ nLinha, nColuna ].Value :='N/A';

                 oSheet.Cells[ nLinha, nColuna ].NumberFormat := '[$-409] dd-mmm-aaaa;@';

              end;
          end;

//          inc(nColuna);
//          str_linha:=qry_mail_proc_nao_fat.FieldByName('TX_OBS').AsString;

          { Pega 5 linhas uteis das ultimas 15 linhas da TX_OBS - by Carlos }

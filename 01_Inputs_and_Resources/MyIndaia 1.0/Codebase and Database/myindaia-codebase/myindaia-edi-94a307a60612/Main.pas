          SQL.Add('         TETAPA_AUTOMATICA_ORDENA EA (NOLOCK), TFLP_PO_ITEM_ETAPA FE (NOLOCK), TSERVICO SE (NOLOCK), TMERCADORIA ME (NOLOCK) ');
          SQL.Add('   WHERE POI.CD_EVENTO = SE.CD_EVENTO_CONCLUSOR ');
          SQL.Add('     AND ( ( POI.DT_REALIZACAO > GETDATE()-2 ) or ( POI.DT_REALIZACAO is null ) ) ');
          SQL.Add('     AND PI.NR_PROCESSO     = POI.NR_PROCESSO ');
          SQL.Add('     AND PI.NR_ITEM         = POI.NR_ITEM ');
          SQL.Add('     AND EP.NR_REFERENCIA   = POI.NR_PROCESSO ');
          SQL.Add('     AND EP.NR_ITEM_CLIENTE = POI.NR_ITEM_CLIENTE ');

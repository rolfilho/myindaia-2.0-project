function TfrmMain.FollowupDiarioNestle(pProduto, pGrupo, pCliente: String): Boolean;
begin
  Result := (pProduto = '01') or (pProduto = '02');
  if Result then
    if pGrupo <> '' then
      Result := (pGrupo = '155')
    else
      Result := (ConsultaLookupFiltro('TEMPRESA_NAC', 'CD_GRUPO', 'CD_EMPRESA', pCliente) = '155');
end;

Function TFrmMain.RelEventosFupClientes(pUnidade, pProduto, pGrupo, pCliente, pArea, pEvento, pRelatorio, pHorario: string): String;
var
  db_broker                                              : TDatabase;
  vQryEventos,  qry_mail_proc_nao_fat                    : TQuery;
  Excel, xlWorkB, oSheet                                 : OleVariant;
  nLinha, ctLinha, nColuna, vPrimeiraLinha, vCont,i,x,vTotalEventos : Integer;
  vValorTotalServico                                     : Real;
  vAno, vMes, vDia                                       : Word;
  vTimeStamp, vNomeProduto, str_CD_EVENTO                : string;
  str_linha                                              : widestring;
  Hour, min, sec, MSec                                   : Word;
  str_OBS                                                : TMemo;
  tem_dados                                              : boolean;
  dtEvento, dtEfetiva, dtNow: TDateTime;
  DiasSub: Integer;
  Range: OleVariant;
begin
  if FollowupDiarioNestle(pProduto, pGrupo, pCliente) then
  begin
    Result := RelEventosFupClientesNestle(pUnidade, pProduto, pGrupo, pCliente, pArea, pEvento, pRelatorio, pHorario);
    Exit;
  end
  else
    Result := '';
  try
    db_broker:= TDatabase.Create(Self);
    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;
    vQryEventos := TQuery.Create(Self);
    vQryEventos.DatabaseName := 'DBBROKER';
    //
    qry_mail_proc_nao_fat              := TQuery.Create(Self);
    qry_mail_proc_nao_fat.DatabaseName := 'DBBROKER';

    try
      Excel      := CreateOLEObject('Excel.Application');
      try
        db_broker.Connected := True;

        Excel.Visible := chkVisualizarExcel.checked;
        if pProduto='02' then
          xlWorkB    := Excel.Workbooks.Open(GetPath+'FOLLOWUP_CLIENTES_EXP.xls')
        else
          xlWorkB    := Excel.Workbooks.Open(GetPath+'FOLLOWUP_CLIENTES_NOVO_IMP.xls');
        DecodeTime(now, Hour, min, sec, MSec);
        vTimeStamp := FormatDateTime('ddmmyyyy',now) + Copy('00',1,2-Length(IntToStr(Hour)))+IntToStr(Hour) + Copy('00',1,2-Length(IntToStr(min)))+IntToStr(min) + Copy('00',1,2-Length(IntToStr(sec)))+IntToStr(sec) + Copy('00',1,2-Length(IntToStr(MSec)))+IntToStr(MSec);

        try
          oSheet := Excel.WorkBooks[1].Worksheets[1];

          with TQuery.Create(Self) do
          begin
            try
              DatabaseName := 'DBBROKER';
              // Unidade
              SQL.Clear;
              SQL.Add('SELECT ISNULL((SELECT RTRIM(AP_UNID_NEG)');
              SQL.Add('               FROM TUNID_NEG (NOLOCK)');
              SQL.Add('               WHERE CD_UNID_NEG = :CD_UNID_NEG), "Todas") AS NM_UNID_NEG,');
              SQL.Add('       ISNULL((SELECT RTRIM(NM_PRODUTO)');
              SQL.Add('               FROM TPRODUTO (NOLOCK)');
              SQL.Add('               WHERE CD_PRODUTO = :CD_PRODUTO), "Todos") AS NM_PRODUTO,');
              SQL.Add('       ISNULL((SELECT RTRIM(NM_GRUPO)');
              SQL.Add('               FROM TGRUPO (NOLOCK)');
              SQL.Add('               WHERE CD_GRUPO = :CD_GRUPO), "Todos") AS NM_GRUPO,');
              SQL.Add('       ISNULL((SELECT RTRIM(NM_EMPRESA)');
              SQL.Add('               FROM TEMPRESA_NAC (NOLOCK)');
              SQL.Add('               WHERE CD_EMPRESA = :CD_CLIENTE), "Todos") AS NM_CLIENTE,');
              SQL.Add('       ISNULL((SELECT RTRIM(NM_AREA)');
              SQL.Add('               FROM TAREA (NOLOCK)');
              SQL.Add('               WHERE CD_AREA = :CD_AREA), "Todas") AS NM_AREA');
              ParamByName('CD_UNID_NEG').AsString := pUnidade;
              ParamByName('CD_PRODUTO').AsString  := pProduto;
              ParamByName('CD_GRUPO').AsString    := pGrupo;
              ParamByName('CD_CLIENTE').AsString  := pCliente;
              ParamByName('CD_AREA').AsString     := pArea;
              Open;

              if pProduto = '02' then // Forma Antiga
              begin
                oSheet.Cells[ 02, 05 ].value :=  ' ' + pUnidade + ' - ' + Fields[0].AsString;
                oSheet.Cells[ 03, 05 ].value :=  ' ' + pProduto + ' - ' + Fields[1].AsString;
                oSheet.Cells[ 04, 05 ].value :=  ' ' + pGrupo + ' - ' + Fields[2].AsString;
                oSheet.Cells[ 05, 05 ].value :=  ' ' + FormatDateTime('dd/mm/yyyy', Now);
              end
              else // Forma nova - Michel - 25/03/2013
              begin
                oSheet.Cells[ 01, 03 ].value :=  'Unidade: ' + pUnidade + ' - ' + Fields[0].AsString;
                oSheet.Cells[ 02, 03 ].value :=  'Produto: ' + pProduto + ' - ' + Fields[2].AsString;
                oSheet.Cells[ 03, 03 ].value :=  'Grupo: ' + pGrupo + ' - ' + Fields[2].AsString;
                oSheet.Cells[ 04, 03 ].value :=  'Cliente: ' + pCliente + ' - ' + Fields[3].AsString;
                oSheet.Cells[ 05, 03 ].value :=  'Área: ' + pArea + ' - ' + Fields[4].AsString;
                oSheet.Cells[ 06, 03 ].value :=  'Data: ' + FormatDateTime('dd/mm/yyyy', Now);
              end;

              vNomeProduto := Copy(Fields[1].AsString, 1, 3);
              Close;
            finally
              Free;
            end;
          end;

          //--------------------------------------------------------------------------//
          // Busca o nome dos Eventos e Monta Cabeçalho
          // colunas fixas
          //--------------------------------------------------------------------------//
          if pProduto = '02' then
            nLinha := 9
          else
            nLinha := 8;

          nColuna:= 15;

          if pProduto = '02' then // Forma Antiga - Michel
          begin
            oSheet.Cells[ nLinha, 01 ].Font.Bold := True;
            oSheet.Cells[ nLinha, 02 ].Font.Bold := True;
            oSheet.Cells[ nLinha, 03 ].Font.Bold := True;
            oSheet.Cells[ nLinha, 04 ].Font.Bold := True;
            oSheet.Cells[ nLinha, 05 ].Font.Bold := True;
            oSheet.Cells[ nLinha, 06 ].Font.Bold := True;
            oSheet.Cells[ nLinha, 07 ].Font.Bold := True;
            oSheet.Cells[ nLinha, 08 ].Font.Bold := True;
            oSheet.Cells[ nLinha, 09 ].Font.Bold := True;
            oSheet.Cells[ nLinha, 10 ].Font.Bold := True;
            //
            oSheet.Cells[ nLinha, 02 ].value := 'Ref. Cliente';
            oSheet.Cells[ nLinha, 03 ].value := 'Ref. Indaiá';
            oSheet.Cells[ nLinha, 04 ].value := 'Navio / Voo / Caminhăo ';
            oSheet.Cells[ nLinha, 05 ].value := 'Canal';
            if pProduto='02' then
               oSheet.Cells[ nLinha, 06 ].value := 'Destino'
            else
               oSheet.Cells[ nLinha, 06 ].value := 'Procedencia';

            oSheet.Cells[ nLinha, 07 ].value := 'Local de Desembarque';
            oSheet.Cells[ nLinha, 08 ].value := 'Transporte';
            if pProduto='02' then
               oSheet.Cells[ nLinha, 09 ].value := 'Data Conhecimento'
            else
               oSheet.Cells[ nLinha, 09 ].value := 'Nr. da DI';

            oSheet.Cells[ nLinha, 10 ].value := 'Nr. Conhecimento';

            if pProduto='02' then
            begin
              oSheet.Cells[ nLinha, 11 ].value := 'Nr.Courrier';
              oSheet.Cells[ nLinha, 12 ].value := 'Nr. RE';
              oSheet.Cells[ nLinha, 13 ].value := 'Nr. DDE';
            end else
            begin
              oSheet.Cells[ nLinha, 11 ].value := '';
              oSheet.Cells[ nLinha, 12 ].value := '';
              oSheet.Cells[ nLinha, 13 ].value := '';
            end;
          end;

          vTotalEventos := ContaOcorrencias(pEvento,';')+1;
          for i:=1 to vTotalEventos do
          begin
             str_CD_EVENTO:=Trim(ExtractWord(i,pEvento,';'));
             if str_CD_EVENTO<>'' then
             begin
                vQryEventos.SQL.Clear;
                vQryEventos.SQL.Add('Select NM_EVENTO from TEVENTO (NOLOCK) where CD_EVENTO="'+str_CD_EVENTO+'"');
                vQryEventos.Prepare;
                vQryEventos.Open;

                oSheet.Cells[ nLinha, nColuna ].EntireColumn.Insert;
                oSheet.Cells[ nLinha, nColuna ].Font.Bold := True;
                oSheet.Cells[ nLinha, nColuna ].value     := vQryEventos.Fields[0].AsString;;
                oSheet.Columns[nColuna].ColumnWidth       := 20;
                Inc(nColuna);
             end;
          end;


          { Busca os Processos Năo Faturados }
          with qry_mail_proc_nao_fat do
          begin
            SQL.Clear;
            // Relatório diferente para Importaçăo - Michel - 22/03/2013
            if pProduto = '01' then
            begin
               {$REGION 'Codigo comentado'}
              {
              SQL.Add('SELECT RTRIM(EN.NM_EMPRESA)  AS [Cliente],                                                                             ');
              SQL.Add('       RTRIM(PR.NR_PROCESSO) AS [Processo],                                                                            ');
              SQL.Add('       RTRIM(PR.NR_PROCESSO) AS [NR_PROCESSO],                                                                         ');
              SQL.Add('       (SELECT TOP 1 LTRIM(RTRIM(R.CD_REFERENCIA))                                                                     ');
              SQL.Add('        FROM TREF_CLIENTE R (NOLOCK)                                                                                   ');
              SQL.Add('        WHERE R.NR_PROCESSO = PR.NR_PROCESSO                                                                           ');
              SQL.Add('          AND R.TP_REFERENCIA = CASE WHEN SUBSTRING(R.NR_PROCESSO, 3, 2) = "01" THEN GR.TP_PEDIDO_BUSCA_IMP            ');
              SQL.Add('                                ELSE GR.TP_PEDIDO_BUSCA                                                                ');
              SQL.Add('                                END                                                                                    ');
              SQL.Add('        ORDER BY DT_REFERENCIA DESC) AS [Pedido],                                                                      ');
              SQL.Add('       RTRIM(VT.NM_VIA_TRANSP) AS [Via_Transporte],                                                                    ');
              SQL.Add('       RTRIM(AR.NM_AREA) AS [Area],                                                                                    ');

              //SQL.Add('       (SELECT RTRIM(U.NM_USUARIO)');
              //SQL.Add('        FROM TCLIENTE_HABILITACAO CH (NOLOCK)');
              //SQL.Add('           LEFT JOIN TUSUARIO U (NOLOCK) ON U.CD_USUARIO = CH.CD_ATENDENTE');
              //SQL.Add('        WHERE CH.CD_CLIENTE  =  PR.CD_CLIENTE');
              //SQL.Add('          AND CH.CD_UNID_NEG = PR.CD_UNID_NEG');
              //SQL.Add('          AND CH.CD_PRODUTO  = PR.CD_PRODUTO');
              //SQL.Add('          AND CH.IN_ATIVO    = "1") AS [Atendente],');

              SQL.Add('       RTRIM(PB.NM_PAIS) AS [Pais_Origem],                                                                             ');
              SQL.Add('       RTRIM(EF.NM_EMPRESA) AS [Exportador],                                                                           ');
              SQL.Add('       RTRIM(CONVERT(VARCHAR(MAX), PR.TX_MERCADORIA)) AS [Mercadoria],                                                 ');
              SQL.Add('       DM.QT_COMERCIALIZADA AS [Quantidade],                                                                           ');

              //SQL.Add('       RTRIM(UM.NM_SIGLA) AS [Unidade_Medida],');

              SQL.Add('       DI.PL_CARGA AS [Peso_Liq],                                                                                      ');

              //SQL.Add('       RTRIM(ISNULL(MI.CD_SIGLA, MB.AP_MOEDA)) AS [Moeda_Merc_Cond_Venda],');
              //SQL.Add('       DI.VL_TOT_MLE_MNEG -  CASE ISNULL(DI.IN_EMBUT_FRT_ITENS, "0")');
              //SQL.Add('                                WHEN "1" THEN ISNULL(VL_TOTAL_FRETE_MNEG, 0)');
              //SQL.Add('                             ELSE 0');
              //SQL.Add('                             END - CASE ISNULL(DI.IN_EMBUT_SEG_ITENS, "0")');
              //SQL.Add('                                       WHEN "1" THEN ISNULL(VL_TOT_SEGURO_MNEG, 0)');
              //SQL.Add('                                   ELSE 0');
              //SQL.Add('                                   END AS [Total_FOB],');

              SQL.Add('       ISNULL(PR.CD_CANAL, 4) AS CD_CANAL,                                                                             ');
              SQL.Add('       ISNULL(RTRIM(TC.NM_CANAL), "Aguardando") AS [Canal],                                                            ');
              SQL.Add('       RTRIM(EB.NM_EMBARCACAO) AS [Navio],                                                                             ');
              SQL.Add('       RTRIM(AG.NM_AGENTE) AS [Armador_Agente],                                                                        ');
              SQL.Add('       RTRIM(TR.NM_TRANSP_ROD) AS [Transportador],                                                                     ');

              //SQL.Add('       RTRIM(LE.DESCRICAO) AS [Local_Entrega],');

              SQL.Add('       F653.TX_OBS AS [Status],                                                                                        ');
              SQL.Add('       F022.TX_OBS AS [Observacoes],                                                                                   ');
              SQL.Add('       F022.TX_OBS AS [TX_OBS],                                                                                        ');
              SQL.Add('       (SELECT TOP 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="                                          ');
              SQL.Add('                   + MASTER.DBO.FN_CRIPROGRAFA("docs_novo/" + NR_PROCESSO + "/" + RTRIM(NM_ARQUIVO))                   ');
              SQL.Add('        FROM TPROCESSO_DOCTOS (NOLOCK)                                                                                 ');
              SQL.Add('        WHERE NR_PROCESSO = PR.NR_PROCESSO                                                                             ');
              SQL.Add('          AND CD_TIPO_DOCTO = 14                                                                                       ');
              SQL.Add('          AND ID_TABELA = 1652005462                                                                                   ');
              SQL.Add('          AND IN_ATIVO = 1                                                                                             ');
              SQL.Add('        ORDER BY DT_CRIACAO DESC) AS [Documentos_Importacao],                                                          ');
              SQL.Add('       (SELECT TOP 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod=" +                                        ');
              sql.add('                      MASTER.DBO.FN_CRIPROGRAFA("docs_novo/" + NR_PROCESSO + "/" + RTRIM(NM_ARQUIVO))                  ');
              SQL.Add('        FROM TPROCESSO_DOCTOS (NOLOCK)                                                                                 ');
              SQL.Add('        WHERE NR_PROCESSO = PR.NR_PROCESSO                                                                             ');
              SQL.Add('          AND CD_TIPO_DOCTO = 9                                                                                        ');
              SQL.Add('          AND ID_TABELA = 1652005462                                                                                   ');
              SQL.Add('          AND IN_ATIVO = 1                                                                                             ');
              SQL.Add('        ORDER BY DT_CRIACAO DESC) AS [Extrato_DI],                                                                     ');
              SQL.Add('       (SELECT TOP 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="                                          ');
              sql.Add('                    + MASTER.DBO.FN_CRIPROGRAFA("docs_novo/" + NR_PROCESSO + "/" + RTRIM(NM_ARQUIVO))                  ');
              SQL.Add('        FROM TPROCESSO_DOCTOS (NOLOCK)                                                                                 ');
              SQL.Add('        WHERE NR_PROCESSO = PR.NR_PROCESSO                                                                             ');
              SQL.Add('          AND CD_TIPO_DOCTO = 10                                                                                       ');
              SQL.Add('          AND ID_TABELA = 1652005462                                                                                   ');
              SQL.Add('          AND IN_ATIVO = 1                                                                                             ');
              SQL.Add('        ORDER BY DT_CRIACAO DESC) AS [Extrato_CI],                                                                     ');
              SQL.Add('       (SELECT TOP 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="                                          ');
              sql.Add('                    + MASTER.DBO.FN_CRIPROGRAFA("docs_novo/" + NR_PROCESSO + "/" + RTRIM(NM_ARQUIVO))                  ');
              SQL.Add('        FROM TPROCESSO_DOCTOS (NOLOCK)                                                                                 ');
              SQL.Add('        WHERE NR_PROCESSO = PR.NR_PROCESSO                                                                             ');
              SQL.Add('          AND CD_TIPO_DOCTO = 80                                                                                       ');
              SQL.Add('          AND ID_TABELA = 1652005462                                                                                   ');
              SQL.Add('          AND IN_ATIVO = 1                                                                                             ');
              SQL.Add('        ORDER BY DT_CRIACAO DESC) AS [DANFE],                                                                          ');
              SQL.Add('       PR.NR_CONHECIMENTO,                                                                                             ');
              SQL.Add('       DI.NR_DECLARACAO_IMP                                                                                            ');
              SQL.Add(' FROM TPROCESSO                          PR   (NOLOCK)                                                                 ');
              SQL.Add('   INNER JOIN TEMPRESA_NAC              EN   (NOLOCK) ON EN.CD_EMPRESA = PR.CD_CLIENTE                                 ');
              SQL.Add('   INNER JOIN TGRUPO                    GR   (NOLOCK) ON GR.CD_GRUPO = EN.CD_GRUPO                                     ');
              SQL.Add('   INNER JOIN VW_SERVICO_GERAL          SV            ON SV.CD_SERVICO = PR.CD_SERVICO                                 ');
              SQL.Add('   INNER JOIN TVIA_TRANSP_BROKER        VT   (NOLOCK) ON VT.CD_VIA_TRANSP = SV.CD_VIA_TRANSPORTE                       ');
              SQL.Add('   LEFT  JOIN TAREA                     AR   (NOLOCK) ON AR.CD_AREA = PR.CD_AREA                                       ');
              SQL.Add('   LEFT  JOIN TPAIS_BROKER              PB   (NOLOCK) ON PB.CD_PAIS = PR.CD_PAIS_ORIGEM                                ');
              SQL.Add('   LEFT  JOIN TDECLARACAO_IMPORTACAO    DI   (NOLOCK) ON DI.NR_PROCESSO = PR.NR_PROCESSO                               ');
              SQL.Add('   LEFT  JOIN (SELECT DM.NR_PROCESSO,                                                                                  ');
              SQL.Add('                      LEFT(MASTER.DBO.ROWCONCAT(DISTINCT ISNULL(DM.CD_UN_MED_COMERC, "")), 3) AS CD_UNID_MEDIDA,       ');
              SQL.Add('                      SUM(DM.QT_MERC_UN_COMERC) AS QT_COMERCIALIZADA                                                   ');
              SQL.Add('               FROM TDETALHE_MERCADORIA DM (NOLOCK)                                                                    ');
              SQL.Add('               GROUP BY DM.NR_PROCESSO) DM            ON DM.NR_PROCESSO = DI.NR_PROCESSO                               ');

              //SQL.Add('   LEFT  JOIN TUNID_MEDIDA_BROKER       UM   (NOLOCK) ON UM.CD_UNID_MEDIDA = DM.CD_UNID_MEDIDA');

              SQL.Add('   LEFT  JOIN TEMPRESA_EST              EF   (NOLOCK) ON EF.CD_EMPRESA = DI.CD_FORNECEDOR                              ');


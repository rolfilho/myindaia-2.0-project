function TfrmMain.GetDataContainer(AProcesso, ACampoData, AFormatoData: String): String;
begin
  with TQuery.Create(frmMain) do
  begin
    try
      SessionName := 'SES_EDI';
      DataBaseName := 'BROKER';
      SQL.Add('SELECT CONVERT(VARCHAR, COUNT(*)) + '' CNTR '' + REPLACE(TC.NM_TP_CNTR, ''CNTR '', ''''), ' + ACampoData);
      SQL.Add('FROM TPROCESSO_CNTR PC (NOLOCK)');
      SQL.Add('   INNER JOIN TTP_CNTR TC (NOLOCK) ON TC.TP_CNTR = PC.TP_CNTR');
      SQL.Add('WHERE PC.NR_PROCESSO = :NR_PROCESSO');
      SQL.Add('  AND PC.' + ACampoData + ' IS NOT NULL');
      SQL.Add('GROUP BY TC.NM_TP_CNTR, PC.' + ACampoData);
      SQL.Add('ORDER BY PC.' + ACampoData);
      ParamByName('NR_PROCESSO').AsString := AProcesso;
      Open;

      First;
      Result := '';
      while not Eof do
      begin
        if AFormatoData = '' then
          Result := Result + #10 + Fields[0].AsString + ' - ' + Fields[1].AsString
        else
          Result := Result + #10 + Fields[0].AsString + ' - ' + FormatDateTime(AFormatoData, Fields[1].AsDateTime);
        Next;
      end;
    finally
      Free;
    end;
  end;
  Delete(Result, 1, 1);
end;


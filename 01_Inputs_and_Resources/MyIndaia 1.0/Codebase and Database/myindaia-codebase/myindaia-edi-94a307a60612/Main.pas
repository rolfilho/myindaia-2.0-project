function TfrmMain.DisparaEmail( vCdrelatorio, vNmModelo, vProcesso, vTpIdioma, vNM_GRUPO, vUSUARIOS_EXTRAS : String): Boolean;   // manda arquivo .html por email para usuários do alerta André
var
  vMailUsuario: string;
  vNmRelatorio: string;
  vImagemSite: string;
  vRefCliente: string;
  Body: TStrings;
  Assunto: string;
  vReplyTo: string;
begin
  Result := False;
  Body := TStringList.Create;
  try
    try
      vMailUsuario := '';
      with TQuery.Create(Self) do
      begin
        try
          SessionName := 'SES_EDI';
          DataBaseName := 'BROKER';
          SQL.Clear;
          SQL.Add(' SELECT CONVERT(VARCHAR(MAX),U.NM_EMAIL) NM_EMAIL, MAIL.NM_RELATORIO');
          SQL.Add(' FROM TRELATORIOS_MAIL_AUT MAIL (NOLOCK) ');
          SQL.Add('   INNER JOIN TRELATORIOS_MAIL_AUT_USUARIOS UMAIL (NOLOCK) ON MAIL.CD_RELATORIO = UMAIL.CD_RELATORIO');
          SQL.Add('   INNER JOIN TUSUARIO U (NOLOCK) ON U.CD_USUARIO = UMAIL.CD_USUARIO');
          SQL.Add(' WHERE UMAIL.CD_RELATORIO = ''' + vCdrelatorio + ''' ');
          SQL.Add(' AND IsNull(U.NM_EMAIL,"")<>"" ');   //apesar de năo ser necessario, inclui essa validaçăo - by carlos 25/08/2011
          Open;
          while not EOF do
          begin
            vMailUsuario := vMailUsuario + FieldByName('NM_EMAIL').AsString + ';';
            Next;
          end;
          vMailUsuario:=vMailUsuario+vUSUARIOS_EXTRAS;
          vNmRelatorio := FieldByName('NM_RELATORIO').AsString;
          Close;

          { busca a referencia do cliente - respeitando o produto - 05/05/2011 }
          SQL.Clear;
          SQL.Add(' select TOP 1 RTRIM(LTRIM(rc.CD_REFERENCIA)) NR_PEDIDO from TREF_CLIENTE rc (NOLOCK) ');
          SQL.Add(' JOIN TPROCESSO pr (NOLOCK) ON rc.NR_PROCESSO=pr.NR_PROCESSO ');
          SQL.Add(' WHERE rc.NR_PROCESSO= "'+vPROCESSO+'" ');
          SQL.Add(' AND rc.TP_REFERENCIA = ');
          SQL.Add(' ( SELECT ISNULL( CASE WHEN SUBSTRING(rc.NR_PROCESSO,3,2)="01" THEN g.TP_PEDIDO_BUSCA_IMP ELSE g.TP_PEDIDO_BUSCA END  ,"01" ) ');
          SQL.Add(' FROM TGRUPO g (NOLOCK) ');
          SQL.Add(' WHERE g.CD_GRUPO = ( SELECT e.CD_GRUPO ');
          SQL.Add(' FROM TEMPRESA_NAC e (NOLOCK) ');
          SQL.Add(' WHERE e.CD_EMPRESA = rc.CD_EMPRESA ) ) ');

          Open;
          vRefCliente:=Fields[0].AsString;
          Close;

          SQL.Clear;
          SQL.Add(' select isnull( CONVERT(VARCHAR(MAX),u.NM_EMAIL) ,"") ');
          SQL.Add(' from TPROCESSO pr (NOLOCK) ');
          SQL.Add(' join TCLIENTE_HABILITACAO ch (NOLOCK) on ch.CD_CLIENTE=pr.CD_CLIENTE and ch.CD_UNID_NEG=pr.CD_UNID_NEG and ch.CD_PRODUTO=pr.CD_PRODUTO ');
          SQL.Add(' left join TUSUARIO U (NOLOCK) on u.CD_USUARIO=ch.CD_ATENDENTE ');
          SQL.Add(' where ch.IN_ATIVO=1 ');
          SQL.Add(' and pr.NR_PROCESSO="'+vPROCESSO+'" ');
          Open;
          vReplyTo := Fields[0].AsString;
          if vReplyTo = '' then
             vReplyTo := 'no_reply@myindaia.com.br';
          Close;
        finally
          Free;
        end;
      end;
      //
      repeat
        try
          Body.LoadFromFile(vNmModelo);
          Break;
        except
        end;
      until False;
      Body.Insert(0,'<HTML>');
      Body.Insert(1,'<BODY>');

      if vTpIdioma <> '' then
        Case StrtoInt(vTpIdioma) of
          0: vImagemSite := 'http://www.myindaia.com.br/img/cabecalho_3.gif';    // Portuguęs
          1: vImagemSite := 'http://www.myindaia.com.br/img/cabecalho_3ing.gif'; // Inglęs
          2: vImagemSite := 'http://www.myindaia.com.br/img/cabecalho_3esp.gif'; // Espanhol
        end
      else
        vImagemSite := 'http://www.myindaia.com.br/img/cabecalho_3.gif';    // Portuguęs

      if fileExists('\\Indaia100\Sites\myindaia\imagens\logos\' + vGrupoLogo + '.gif') then
      begin
        Body.Insert(2,'<table width="100%"><tr><td colspan="2"><IMG SRC='+vImagemSite+'></td></tr><tr>' +
        '<td width="85%" align="right"></td><td width="15%" align="left"><IMG SRC=http://www.myindaiaweb.com.br/imagens/logos/' + vGrupoLogo + '.gif></td></tr></table>');
      end
      else
        Body.Insert(2,'<IMG SRC='+vImagemSite+'><br><br>');

      Body.Insert(Body.Count -1,'<IMG SRC=http://www.myindaiaweb.com.br/imagens/recicle.jpg><br>');

      Assunto := vNmRelatorio + vNM_GRUPO+ ' ( ' +vProcesso+'/'+vRefCliente +' )';  //by Carlos 05/05/2011

      SendMail(vReplyTo, vMailUsuario, '', '', Assunto, Body.Text, '', MensagemErro);
      Result := True;
    except
      on e:exception do
        VMsg('Erro no ALERTA DE EVENTO',msError,false);
    end;
  finally
    Body.Free;
  end;
end;



  vAno, vMes, vDia              : Word;
  vTimeStamp, vNomeProduto, vDataAux,a : string;
  Hour, min, sec, MSec          : Word;
  vCampoChave, vCamposHidden : Integer;
begin
  try
    vImprimindoPrevistosHoje := False;
    db_broker:= TDatabase.Create(Self);
    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;

    try
      db_broker.Connected := True;
      with TQuery.Create(Self) do
      begin
        try
          DatabaseName := 'DBBROKER';
          SQL.Clear;
          if pTipo = '0' then

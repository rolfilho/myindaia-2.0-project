          try
            SessionName := 'SES_EDI';
            DataBaseName := 'BROKER';
            Sql.Clear;
            Sql.Add(' SELECT * FROM TCARTAS_CONFIG (NOLOCK)');
            Open;
            While not Eof do begin
              Word.Selection.Find.ClearFormatting;
              Word.Selection.Find.Text := LowerCase(StringReplace(StringReplace(FieldByName('TX_CARTAS_CONFIG').AsString,'\','123', [rfReplaceAll]), '/', '321', [rfReplaceAll]));
              Word.Selection.Find.Forward           := True;
              Word.Selection.Find.Wrap              := 1;
              Word.Selection.Find.Format            := False;
              Word.Selection.Find.MatchCase         := False;
              Word.Selection.Find.MatchWholeWord    := False;
              Word.Selection.Find.MatchWildcards    := True;
              Word.Selection.Find.MatchSoundsLike   := False;
              Word.Selection.Find.MatchAllWordForms := False;
              if Word.Selection.Find.Execute then begin

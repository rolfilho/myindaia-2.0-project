procedure TQuery.Open;
var
  Count: Byte;
begin
  Count := 1;
  try
    frmMain.lblMensagem.Caption := 'Abrindo Consulta';
    inherited;
  finally
    frmMain.lblMensagem.Caption := '';
  end;
  {while True do
  begin
    if not VerifyConnection then
    begin
      VMsg('Erro de conexăo com o banco. Tentando nova conexăo em 60 segundos.', msNull, True);
      Application.ProcessMessages;
      Sleep(60000);
    end
    else
      try
        inherited;
        Break;
      except
        on E: Exception do
        begin
          Inc(Count);
          if Count > 10 then
          begin
            raise Exception.Create('Ecutadas 10 tentativas de consulta na query "' + name + '".Cancelada para continuar os outros relatórios. Mensagem original: ' + E.Message);
            Application.ProcessMessages;
            Break;
          end
          else
          begin
            VMsg('Erro executando consulta na query "' + Name + '". Tentando nova conexăo em 1 segundo. Mensagem original: ' + E.Message, msNull, True);
            Application.ProcessMessages;
            Sleep(1000);
          end;
        end;
      end;
  end;}
end;

function TQuery.VerifyConnection: Boolean;
begin
  Result := True;
  if GetDatabase.Connected then
    try
      GetDatabase.GetFieldNames('TVIA_TRANSPORTE', FListFields);
      Result := True;
    except
      try
        GetDatabase.Close;
      except
      end;
      Result := False;
    end;
  if not GetDatabase.Connected then
    try
      GetDatabase.Open;
      Result := True;
    except
      Result := False;
    end;
end;


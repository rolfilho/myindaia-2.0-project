              '     ISNULL(RTRIM(TC.NM_CANAL), ''AGUARDANDO'')                                       AS [CANAL],                                                                              ' +sLineBreak +
              '     RTRIM(EB.NM_EMBARCACAO)                                                          AS [NAVIO],                                                                              ' +sLineBreak +
              '     RTRIM(AG.NM_AGENTE)                                                              AS [ARMADOR_AGENTE],                                                                     ' +sLineBreak +
              '     RTRIM(TR.NM_TRANSP_ROD)                                                          AS [TRANSPORTADOR],                                                                      ' +sLineBreak +
              '     F653.TX_OBS 							                                                       AS [STATUS],                                                                             ' +sLineBreak +
              '     F022.TX_OBS 							                                                       AS [OBSERVACOES],                                                                        ' +sLineBreak +
              '     F022.TX_OBS 							                                                       AS [TX_OBS],                                                                             ' +sLineBreak +
              '     (SELECT TOP 1 ''HTTP://WWW.MYINDAIAWEB.COM.BR/REDIRECIONA_DOC.ASP?COD=''                                                                                                  ' +sLineBreak +
              '                 + MASTER.DBO.FN_CRIPROGRAFA(''DOCS_NOVO/'' + NR_PROCESSO + ''/'' + RTRIM(NM_ARQUIVO))                                                                         ' +sLineBreak +
              '      FROM TPROCESSO_DOCTOS WITH (NOLOCK)                                                                                                                                      ' +sLineBreak +
              '      WHERE NR_PROCESSO   = PR.NR_PROCESSO                                                                                                                                     ' +sLineBreak +

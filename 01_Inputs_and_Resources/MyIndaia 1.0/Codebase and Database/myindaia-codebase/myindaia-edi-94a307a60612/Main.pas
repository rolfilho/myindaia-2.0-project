function TfrmMain.Sequencial_basf ( mensagem:string ): String;
var nr_sequencia:String;
begin
with TQuery.Create(Self) do
 begin
  try
    SessionName  := 'SES_EDI';
    DataBaseName := 'BROKER';
    Sql.Add('SELECT DT_SEQ_EDI_BASF, ISNULL(NR_SEQ_EDI_BASF,0) FROM TSEQ_BASF (NOLOCK) WHERE MENSAGEM =:msg ');
    Params[0].AsString   :=  mensagem;  Open;
    if formatdatetime('DD/MM/YYYY',Fields[0].AsDAtetime) = formatdatetime('DD/MM/YYYY',NOW) then
      nr_sequencia := formatfloat('0000',strtofloat(inttostr(Fields[1].AsInteger + 1)))
    else
      nr_sequencia := '0001';
    Sql.Clear;
    Sql.Add('UPDATE TSEQ_BASF SET NR_SEQ_EDI_BASF = :NR_SEQ_EDI_BASF, DT_SEQ_EDI_BASF = :DT_SEQ_EDI_BASF WHERE MENSAGEM =:msg ');
    Params[0].AsInteger  :=  strtoint(nr_sequencia);
    Params[1].AsString   :=  formatdatetime('DD/MM/YYYY',NOW);
    Params[2].AsString   :=  mensagem;
    ExecSql;
  finally
    Free;
  end;
  result := nr_sequencia;
 end;

end;


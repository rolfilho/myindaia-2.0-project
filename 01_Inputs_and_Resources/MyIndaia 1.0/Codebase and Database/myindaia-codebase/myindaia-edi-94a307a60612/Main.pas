        if tem_dados then
           Result := GetPath+'Gerados\DAILY_FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.XLS'
        else
           Result := 'Sem Dados';

      finally
        Excel.ActiveWorkBook.Close(False);
        KillExcel(Excel);
      end;
    finally
      FreeAndNil(vQryEventos);
      FreeAndNil(qry_mail_proc_nao_fat);
      FreeAndNil(db_broker);
    end;
  except
    on e:Exception do
    begin
      VMsg('Erro - RelEventosDailyFupMod2: ' + e.Message, msError, True);
    end;
  end;
end;

{ Alerta Criado em 06/12/2010 By Carlos - E06 }
Function TFrmMain.RelEventosDailyFup(pUnidade, pProduto, pGrupo, pImportador, pEvento, pCliente, pTransportador, pRelatorio, pHorario: string): String;
var
  db_broker                                              : TDatabase;
  vQryEventos,  qry_mail_proc_nao_fat                    : TQuery;
  Excel, xlWorkB, oSheet                                 : OleVariant;
  nLinha, ctLinha, nColuna, vPrimeiraLinha, vCont,i,x,vTotalEventos,vUlt_Col_Fixa, vNegrita : Integer;
  vValorTotalServico                                     : Real;
  vAno, vMes, vDia                                       : Word;
  vTimeStamp, vNomeProduto, vIdioma, str_CD_EVENTO,strTmp: string;
  str_linha                                              : widestring;
  Hour, min, sec, MSec                                   : Word;
  str_OBS                                                : TMemo;
  tem_dados                                              : boolean;
begin
  if FollowupDiarioNestle(pProduto, pGrupo, pImportador) then
  begin
    Result := RelEventosDailyFupNestle(pUnidade, pProduto, pGrupo, pImportador, pEvento, pCliente, pTransportador, pRelatorio, pHorario);
    Exit;
  end
  else
    Result := '';
  try
    db_broker:= TDatabase.Create(Self);
    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;
    vQryEventos := TQuery.Create(Self);
    vQryEventos.DatabaseName := 'DBBROKER';
    //
    qry_mail_proc_nao_fat              := TQuery.Create(Self);
    qry_mail_proc_nao_fat.DatabaseName := 'DBBROKER';

    try
      db_broker.Connected := True;
      Excel      := CreateOLEObject('Excel.Application');
      try
        xlWorkB    := Excel.Workbooks.Open( GetPath+'DAILY_FOLLOWUP.xls' );
        Excel.Visible := chkVisualizarExcel.checked;
        DecodeTime(now, Hour, min, sec, MSec);
        vTimeStamp := FormatDateTime('ddmmyyyy',now) + Copy('00',1,2-Length(IntToStr(Hour)))+IntToStr(Hour) + Copy('00',1,2-Length(IntToStr(min)))+IntToStr(min) + Copy('00',1,2-Length(IntToStr(sec)))+IntToStr(sec) + Copy('00',1,2-Length(IntToStr(MSec)))+IntToStr(MSec);

        oSheet := Excel.WorkBooks[1].Worksheets[1];

        with TQuery.Create(Self) do
        begin
          try
            DatabaseName := 'DBBROKER';
            // Produto
            SQL.Clear;
            SQL.Add('SELECT NM_PRODUTO FROM TPRODUTO ( NOLOCK ) WHERE CD_PRODUTO = ''' + pProduto + '''');
            Open;
            vNomeProduto := Copy(Fields[0].AsString,1,3);
            Close;

            // Importador
            SQL.Clear;
            SQL.Add('SELECT NM_EMPRESA FROM TEMPRESA_EST ( NOLOCK ) WHERE CD_EMPRESA = ''' + pImportador + '''');
            Open;
            oSheet.Cells[ 03, 05 ].value :=  ' ' + pImportador + ' - ' + Fields[0].AsString;
            Close;

            //busca o idioma do Importador
            SQL.Clear;
            SQL.Add(' select Isnull(P.CD_IDIOMA_PADRAO,"9") ');
            SQL.Add(' from TEMPRESA_EST E (NOLOCK) ');
            SQL.Add(' JOIN TPAIS P (NOLOCK) ON E.CD_PAIS=P.CODIGO ');
            SQL.Add(' where e.CD_EMPRESA="'+pImportador+'"');
            Open;
            vIdioma:=Fields[0].AsString;
            Close;

          finally
            Free;
          end;
        end;

        oSheet.Cells[ 04, 05 ].value :=  ' ' + FormatDateTime('mm/dd/yyyy',now);

        //--------------------------------------------------------------------------//
        // Busca o nome dos Eventos e Monta Cabeçalho
        // colunas fixas
        //--------------------------------------------------------------------------//
        vUlt_Col_Fixa  := 13;
        nLinha         := 9;
        nColuna        := vUlt_Col_Fixa;

        //coloca todas as colunas fixas em negrito
        for vNegrita:=2 to vUlt_Col_Fixa do begin
           oSheet.Cells[ nLinha, vNegrita ].Font.Bold := True;
        end;
        //
        if vIdioma='2' then begin
           oSheet.Cells[ nLinha, 02 ].value := 'Pedido';
           oSheet.Cells[ nLinha, 03 ].value := 'Pedido';
           oSheet.Cells[ nLinha, 04 ].value := 'Pais de la entrega';
           oSheet.Cells[ nLinha, 05 ].value := 'Ciudad de la Entrega';
           oSheet.Cells[ nLinha, 06 ].value := 'Embarcacion';
           oSheet.Cells[ nLinha, 07 ].value := 'Transportista/Agente';
           oSheet.Cells[ nLinha, 08 ].value := 'Courrier';
           oSheet.Cells[ nLinha, 09 ].value := 'Documentos enviados al';
           oSheet.Cells[ nLinha, 10 ].value := 'BML/Packing-List';
           oSheet.Cells[ nLinha, 11 ].value := 'Invoice';
           oSheet.Cells[ nLinha, 12 ].value := 'BL / CRT / AWB';
           oSheet.Cells[ nLinha, 13 ].value := 'Docs';
        end else begin
           oSheet.Cells[ nLinha, 02 ].value := 'Customer Order';
           oSheet.Cells[ nLinha, 03 ].value := 'Customer PO';
           oSheet.Cells[ nLinha, 04 ].value := 'Country of Destination';
           oSheet.Cells[ nLinha, 05 ].value := 'Place of Destination';
           oSheet.Cells[ nLinha, 06 ].value := 'Vessel';
           oSheet.Cells[ nLinha, 07 ].value := 'Cargo Agent';
           oSheet.Cells[ nLinha, 08 ].value := 'Courrier';
           oSheet.Cells[ nLinha, 09 ].value := 'Docs Sent To';
           oSheet.Cells[ nLinha, 10 ].value := 'BML/Packing-List';
           oSheet.Cells[ nLinha, 11 ].value := 'Invoice';
           oSheet.Cells[ nLinha, 12 ].value := 'BL / CRT / AWB';
           oSheet.Cells[ nLinha, 13 ].value := 'Docs';
        end;
        vTotalEventos := ContaOcorrencias(pEvento,';')+1;
        for i:=1 to vTotalEventos do begin
           str_CD_EVENTO:=Trim(ExtractWord(i,pEvento,';'));
           if str_CD_EVENTO<>'' then begin
              vQryEventos.SQL.Clear;
              vQryEventos.SQL.Add('Select ');
              if vIdioma='1' then
                 vQryEventos.SQL.Add('NM_INGLES')
              else if vIdioma='2' then
                 vQryEventos.SQL.Add('NM_ESPANHOL')
              else
                 vQryEventos.SQL.Add('NM_EVENTO');
              vQryEventos.SQL.Add(' from TEVENTO (NOLOCK) where CD_EVENTO="'+str_CD_EVENTO+'"');
              vQryEventos.Prepare;
              vQryEventos.Open;

              inc(nColuna);
              oSheet.Cells[ nLinha, nColuna ].EntireColumn.Insert;
              oSheet.Cells[ nLinha, nColuna ].Font.Bold           := True;
              oSheet.Cells[ nLinha, nColuna ].value               := vQryEventos.Fields[0].AsString;;

           end;
        end;


        { Busca os Processos Năo Faturados }
        with qry_mail_proc_nao_fat do begin
           SQL.Clear;
           SQL.Add ( ' SELECT          PR.NR_PROCESSO, EE.NM_EMPRESA DOCS_ENVIADO_PARA, ');
           SQL.Add ( ' (select descricao from TPAIS (NOLOCK) where CODIGO=PR.CD_PAIS_DESTINO ) NM_PAIS_DESTINO  , ');
           SQL.Add ( ' (select descricao from TLOCAL_EMBARQUE (NOLOCK) where CODIGO=PR.CD_LOCAL_DESEMBARQUE ) NM_PORTO_DESTINO  , ');
           SQL.Add ( ' ( SELECT MASTER.DBO.RowConcat( DISTINCT RTRIM(R.CD_REFERENCIA)  + " / " ) FROM TREF_CLIENTE R (NOLOCK) ');
           SQL.Add ( '                                                                 WHERE R.NR_PROCESSO=PR.NR_PROCESSO AND R.TP_REFERENCIA = CASE WHEN SUBSTRING(R.NR_PROCESSO,3,2)<>"02" THEN "01" ELSE ');
           SQL.Add ( '                                                                ( SELECT ISNULL(g.TP_PEDIDO_BUSCA,"01")                                                                              ');
           SQL.Add ( '                                                                  FROM TGRUPO g (NOLOCK)                                                                                             ');
           SQL.Add ( '                                                                  WHERE g.CD_GRUPO = ( SELECT e.CD_GRUPO                                                                             ');
           SQL.Add ( '                                                                  FROM TEMPRESA_NAC e (NOLOCK)                                                                 ');
           SQL.Add ( '                                                                  WHERE e.CD_EMPRESA = R.CD_EMPRESA ) ) END  ) CD_REFERENCIA,                                  ');
           SQL.Add ( ' ( SELECT MASTER.DBO.RowConcat( DISTINCT RTRIM(R.CD_REFERENCIA) + " / " ) FROM TREF_CLIENTE R (NOLOCK)   ');
           SQL.Add ( '                                                                  WHERE R.NR_PROCESSO=PR.NR_PROCESSO AND R.TP_REFERENCIA ="01" ) CUSTOMER_PO,  ');

           SQL.Add ( ' ( SELECT MASTER.DBO.RowConcat( DISTINCT RTRIM(R.CD_REFERENCIA) + " / " ) FROM TREF_CLIENTE R (NOLOCK)   ');
           SQL.Add ( '                                                                  WHERE R.NR_PROCESSO=PR.NR_PROCESSO AND R.TP_REFERENCIA ="09" ) DHL,  ');


           SQL.Add ( ' ISNULL(F2.TX_OBS,"-") TX_OBS, ');
           SQL.Add ( ' isnull(E.NM_EMBARCACAO,"") NM_EMBARCACAO , case substring(PR.NR_PROCESSO,5,2) when "ER" then ISNULL(TR.NM_TRANSP_ROD,"")   else    ISNULL(A.NM_AGENTE_REDUZIDO,A.NM_AGENTE) end NM_AGENTE  ,  ');

           {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 07 (BACH MARK) }
           SQL.Add ( ' (SELECT top 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="+MASTER.DBO.FN_CRIPROGRAFA("docs_novo/"+d.nr_processo+"/"+d.NM_ARQUIVO) ');
           SQL.Add ( ' FROM TPROCESSO_DOCTOS d (NOLOCK) WHERE d.CD_TIPO_DOCTO IN (89, 20) and d.ID_TABELA=1652005462  and  d.NR_PROCESSO = pr.NR_PROCESSO AND  d.in_ativo = "1"  and upper(right(rtrim(d.NM_ARQUIVO),3))="PDF"');
           SQL.Add ( ' ORDER BY CASE D.CD_TIPO_DOCTO WHEN 89 THEN 0 ELSE 1 END, D.DT_CRIACAO DESC ) doc_digital_BML, ');

           {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 08 (INVOICE) }
           SQL.Add ( ' (SELECT top 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="+MASTER.DBO.FN_CRIPROGRAFA("docs_novo/"+d.nr_processo+"/"+d.NM_ARQUIVO) ');
           SQL.Add ( ' FROM TPROCESSO_DOCTOS d (NOLOCK) WHERE d.CD_TIPO_DOCTO=19 and d.ID_TABELA=1652005462  and  d.NR_PROCESSO = pr.NR_PROCESSO AND  d.in_ativo = "1"  and upper(right(rtrim(d.NM_ARQUIVO),3))="PDF"  ) doc_digital_invoice, ');

           {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 09 (B/L) }
           SQL.Add ( ' (SELECT top 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="+MASTER.DBO.FN_CRIPROGRAFA("docs_novo/"+d.nr_processo+"/"+d.NM_ARQUIVO) ');
           SQL.Add ( ' FROM TPROCESSO_DOCTOS d (NOLOCK) WHERE d.CD_TIPO_DOCTO=70 and d.ID_TABELA=1652005462  and  d.NR_PROCESSO = pr.NR_PROCESSO AND  d.in_ativo = "1"  and upper(right(rtrim(d.NM_ARQUIVO),3))="PDF"  ) doc_digital_BL, ');

           {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 10 (DOCs) }
           SQL.Add ( ' (SELECT top 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="+MASTER.DBO.FN_CRIPROGRAFA("docs_novo/"+d.nr_processo+"/"+d.NM_ARQUIVO) ');
           SQL.Add ( ' FROM TPROCESSO_DOCTOS d (NOLOCK) WHERE d.CD_TIPO_DOCTO=22 and d.ID_TABELA=1652005462  and  d.NR_PROCESSO = pr.NR_PROCESSO AND  d.in_ativo = "1"  and upper(right(rtrim(d.NM_ARQUIVO),3))="PDF"  ) doc_digital_docs ');

           SQL.Add ( ' FROM   TPROCESSO PR (NOLOCK) ');
           SQL.Add ( ' INNER JOIN TFOLLOWUP F  (NOLOCK) ON ( PR.NR_PROCESSO = F.NR_PROCESSO ) ');
           SQL.Add ( ' INNER JOIN TFOLLOWUP F1 (NOLOCK) ON ( PR.NR_PROCESSO = F1.NR_PROCESSO AND F1.CD_EVENTO="314" AND F1.DT_REALIZACAO IS not NULL ) ');
           SQL.Add ( ' LEFT  JOIN TFOLLOWUP F2 (NOLOCK) ON ( PR.NR_PROCESSO = F2.NR_PROCESSO AND F2.CD_EVENTO="653" ) '); //OBS que passou para NOTE
           SQL.Add ( ' INNER JOIN TFOLLOWUP F3 (NOLOCK) ON ( PR.NR_PROCESSO = F3.NR_PROCESSO AND F3.CD_EVENTO="261" ) ');
           SQL.Add ( ' INNER JOIN TFOLLOWUP F4 (NOLOCK) ON ( PR.NR_PROCESSO = F4.NR_PROCESSO AND F4.CD_EVENTO= case  substring(pr.NR_PROCESSO,5,2) when "ER" then "333" else "668" end  ) ');
           SQL.Add ( ' LEFT  JOIN TEMBARCACAO E (NOLOCK) ON PR.CD_EMBARCACAO = E.CD_EMBARCACAO ');
           SQL.Add ( ' LEFT  JOIN TAGENTE A (NOLOCK) ON A.CD_AGENTE = PR.CD_AGENTE ');
           SQL.Add ( ' LEFT  JOIN TEMPRESA_EST EE (NOLOCK) ON EE.CD_EMPRESA = PR.DOCS_ENVIADO_PARA ');
           SQL.Add ( ' LEFT  JOIN TTRANSP_ROD TR (NOLOCK) ON  PR.CD_TRANSP_NAC=TR.CD_TRANSP_ROD  ');

           SQL.Add ( ' WHERE ( F.CD_EVENTO = "092" AND F.IN_APLICAVEL=1  AND  ( F.DT_REALIZACAO IS NULL  OR  CONVERT(DATE,F.DT_REALIZACAO,103) >= CONVERT(DATE,GETDATE()-45,103 ))) ');
           SQL.Add ( ' AND  ( F3.DT_REALIZACAO IS NULL  OR  CONVERT(DATE,F3.DT_REALIZACAO,103) >= CONVERT(DATE,GETDATE()-5,103 )) ');
           SQL.Add ( ' AND  PR.IN_CANCELADO  = "0"   ');
           SQL.Add ( ' AND  PR.IN_LIBERADO   = "1"   ');
           SQL.Add ( '  AND F3.IN_APLICAVEL = "1"'); // INDELP-359
           SQL.Add ( ' AND isnull(E.NM_EMBARCACAO,"")  not in ("* PROCESSO CANCELADO","TBN","AGUARDANDO NAVIO" )    ');
           if pProduto<>'' then
              SQL.Add ( ' AND  PR.CD_PRODUTO    = "' + pProduto + '" ');
           if pUnidade<>'' then
              SQL.Add ( ' AND  PR.CD_UNID_NEG   = "' + pUnidade + '" ');
           if pGrupo<>'' then
              SQL.Add ( ' AND  PR.CD_GRUPO      = "' + pGrupo   + '" ');
           if pImportador<>'' then
              SQL.Add ( ' AND  PR.CD_IMPORTADOR = "' + pImportador  + '" ');
           if pCliente <> '' then
            SQL.Add('  AND PR.CD_CLIENTE = "' + pCliente  + '"');
           if pTransportador <> '' then
            SQL.Add('  AND PR.CD_TRANSP_NAC = "' + pTransportador  + '"');
           SQL.Add ( ' order by f4.dt_realizacao,2 ');

           if not DirectoryExists(GetPath+'SQL') then
             ForceDirectories(GetPath+'SQL');
           try
             SQL.SaveToFile(GetPath+'SQL\' + pRelatorio + '.sql');
           except
           end;

           Open;
        end;


        //--------------------------------------------------------------------------//

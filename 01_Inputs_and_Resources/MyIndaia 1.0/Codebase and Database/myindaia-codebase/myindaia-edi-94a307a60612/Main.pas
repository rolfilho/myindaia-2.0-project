procedure TfrmMain.InitSendMail;
var
  vNmRelatorio, vTipoRelatorio, str_cd_grupo, str_cd_importador, str_cd_produto,  vPara , vcd_relatorio, str_CorpoEmail: string;
begin
  try
    COUNTER := 0;
    stbMain.Panels[0].Text := 'Gerenciador de Envio de Mail ativado...';
    {**Inicializaçăo concluída**}
    VMSG('Enviando arquivo por email para os usuários das : ' + ExtractWord(2,EDI.Filtro.Text,'"') + ' horas.', msSystem, True);
    // processamento do programa deve ser colocado aqui
    with TQuery.Create(Self) do
    begin
      try
        DatabaseName := 'BROKER';
        SessionName  := 'SES_EDI';
        SQL.Clear;
        SQL.TEXT := 'SELECT NM_RELATORIO, CD_TIPO_RELATORIO, TX_CONFIGURACAO, CD_RELATORIO , TX_CORPO_EMAIL' + sLineBreak +
                    '  FROM TRELATORIOS_MAIL_AUT (NOLOCK)                                  ' + sLineBreak +
                    ' WHERE CD_RELATORIO = ''' + ExtractWord(4,EDI.Filtro.Text,'"') + '''' + sLineBreak ;
        Open;

        vNmRelatorio       := Fields[0].AsString;
        vTipoRelatorio     := Fields[1].AsString;
        str_cd_produto     := ExtractWord(2,Fields[2].AsString,'/');
        str_cd_grupo       := ExtractWord(3,Fields[2].AsString,'/');
        vcd_relatorio      := Fields[3].AsString;
        str_CorpoEmail     := Fields[4].AsString;

        if (vTipoRelatorio='E06') or
           (vTipoRelatorio='E07') or
           (vTipoRelatorio='E14') or
           (vTipoRelatorio='E15') or
           (vTipoRelatorio='E16') or
           (vTipoRelatorio='E17') then
          str_cd_importador  := ExtractWord(4,Fields[2].AsString,'/')
        else
          str_cd_importador  := '';

        Close;
        SQL.Clear;
        SQL.TEXT := '  SELECT CONVERT(VARCHAR(MAX),NM_EMAIL) NM_EMAIL                                                     '  + sLineBreak +
                    '    FROM TUSUARIO WITH (NOLOCK)                                                                      '  + sLineBreak +
                    '   WHERE CD_USUARIO IN ( SELECT CD_USUARIO                                                           '  + sLineBreak +
                    '                           FROM TRELATORIOS_MAIL_AUT_USUARIOS WITH (NOLOCK)                          '  + sLineBreak +
                    '                          WHERE TX_HORARIOS_ENVIO LIKE ''%'+ExtractWord(2,EDI.Filtro.Text,'"')+'%''  '  + sLineBreak +
                    '                            AND CD_RELATORIO = ''' + ExtractWord(4,EDI.Filtro.Text,'"') + ''' )      '  + sLineBreak ;
        Open;

        while not EOF do
        begin
          vPara := Fields[0].AsString + '; ' + vPara;
          Next;
        end;

        if (vTipoRelatorio = 'E05') or
           (vTipoRelatorio = 'E06') or
           (vTipoRelatorio = 'E07') or
           (vTipoRelatorio = 'E08') or
           (vTipoRelatorio = 'E09') or
           (vTipoRelatorio = 'E10') or
           (vTipoRelatorio = 'E12') or
           (vTipoRelatorio = 'E14') or
           (vTipoRelatorio = 'E18') or
           (vTipoRelatorio = 'DFF') or
           (vTipoRelatorio = 'FPE') or
           (vTipoRelatorio = 'DFT') or
           (vTipoRelatorio = 'FDT') or
           (vTipoRelatorio = 'DFA') or
           (vTipoRelatorio = 'CIS') or
           (vTipoRelatorio = 'DUE') or
           (vTipoRelatorio = 'AVE') or
           (vTipoRelatorio = 'DF0') then
           EnviaEmailHtmlAnexo(vPara,vNmRelatorio,EDI.Path, str_cd_grupo, str_cd_importador,
                                str_cd_produto, vTipoRelatorio , vcd_relatorio, str_CorpoEmail)
        else
           EnviaEmail(vPara,vNmRelatorio,EDI.Path);

        Close;
      Finally
        Free;
      end;
    end;
    //até aqui
  finally
    VMSG('Email enviado!!!' + ExtractWord(2,EDI.Filtro.Text,'"'), msSuccess, True);
//    TotalErros := 0;
    Reload             := False;
    EDI.Inicio         := FormatDateTime('DD/MM/YYYY HH:NN:SS',Now);
    ProcIni            := 0;
    CriarBufferDespesa := True;
    SetLength(DespInserts,0);
    EnvioAbortado      := False;
  end;
end;


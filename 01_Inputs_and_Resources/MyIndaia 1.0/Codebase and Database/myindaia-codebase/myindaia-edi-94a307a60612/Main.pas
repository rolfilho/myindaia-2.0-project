    ' , TP.CD_DUE ' + sLineBreak +
    ' , CAST(F124.DT_REALIZACAO AS DATE) AS F124_EMISSAO_DDE ' + sLineBreak +
    ' , (SELECT COUNT(NR_CNTR) FROM TPROCESSO_CNTR WHERE NR_PROCESSO = TP.NR_PROCESSO) AS QTDE_CNTR ' + sLineBreak +

                     case DayOfTheWeek(dtNow) of
                       DaySunday: DiasSub := 2;
                       DaySaturday: DiasSub := 1;
                     else
                       DiasSub := 0;
                     end;
                     if dtEfetiva > dtNow - DiasSub then
                       oSheet.Cells[ nLinha, nColuna ].interior.ColorIndex := 40;
                   end

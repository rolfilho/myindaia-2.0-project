function FORMATACAO_DATA : String;
Var
  Aux_Data : String;
  A, M, D  : String;
begin
  Aux_Data := COPY(TAB.Fieldbyname(campo).AsString,1,10);
  if Aux_Data <> '' then
  begin
    A := frmMain.ExtractWord(1,Aux_Data,'/');
    M := frmMain.ExtractWord(2,Aux_Data,'/');
    D := frmMain.ExtractWord(3,Aux_Data,'/');
    if length(A) > length(D) then
      Result := A + M + D
    else
      Result := D + M + A;
  end
  else
    Result := '';
end;


{**Loop de processamento das ordens (retorno e envio)**}
procedure TfrmMain.ProcessLoop(Sender: TObject; var Done: Boolean);
var Prev: Cardinal;
    h,m,s: String;
begin
  Done := True;
  {**Sair se estiver no timer Watch**}
  if Lock then
    Exit;

  try
    {**Nada a fazer**}
    if Ocupado = 0 then
      Exit;

    {**Inicio de uma nova ordem**}
    if Reload then begin
       if EDI.OP = 'M' then
        InitSendMail
       else
       if EDI.OP = 'R' then
        InitImport
       else
        InitExport;
    end;

    {**Processar uma linha da ordem**}
    if (Edi.Tipo <> 'R') and (Edi.Tipo <> 'M') then
    begin
       if EDI.OP = 'R' then ReadLine
       else  WriteLine;
    end;

    if EnvioAbortado then
      EDI.NrLn := EDI.LIMITE+1;

    {**Verificar se a ordem esta completa**}
    {if (TAB = qryBNC) then
    begin
      if (EDI.OP = 'R') and (EDI.NrLn >= (EDI.LIMITE-1)) then
        FinishImport;
    end
    else}

    if (EDI.OP = 'R') and (EDI.NrLn > EDI.LIMITE) then
      FinishImport;
    if (EDI.OP = 'M') then
      FinishSendMail
    else
    if ( (TAB_MAIN = qryMSG02)   or (TAB_MAIN = qryMSG05 ) or (TAB_MAIN = qryMSG06)    or (TAB_MAIN = qryMSG04)
       or (TAB_MAIN = qryMSG07)  or  (TAB_MAIN = qry001)   or (TAB_MAIN = qry002)
       or (TAB_MAIN = qry003)    or (TAB_MAIN = qry004)    or (TAB_MAIN = qryMSG08)    or (TAB_MAIN = qrymsg09a)
       or (TAB_MAIN = qrymsg09b) or (TAB_MAIN = qrymsg09c) or (TAB_MAIN = qryDeloitte) or (TAB_MAIN = qryZYCIT279))  then
    begin
      if (EDI.OP = 'E') and (EDI.NrLn > EDI.LIMITE) then
      begin
        FinishExport;
      end;
    end ;

    {**Calcular o tempo restante**}
    if (EDI.OP = 'R') then begin
       try
         Prev := Round(((GetTickCount-Start) / (EDI.NrLn/EDI.LIMITE)) - (GetTickCount-Start))
       except
         Prev := 0;
       end;
       h := FormatFloat('00',Prev div 3600000); Prev := Prev - ((Prev div 3600000) * 3600000);
       m := FormatFloat('00',Prev div 60000);   Prev := Prev - ((Prev div 60000) * 60000);
       s := FormatFloat('00',Prev div 1000);
       stbMain.Panels[0].Text := 'Tempo estimado: ' +  h + ':' + m + ':' + S;
    end;
  except
    on E: Exception do begin
//       Inc(TotalErros);
       stbMain.Panels[0].Text := 'Ativo';
       VMsg('Erro crítico no processamento do EDI. Impossível continuar. Processo interrompido.',msError,True);
       VMsg('Erro foi: "' + E.Message + '".',msError,True);
       grfBar.Progress := 0;
       grfBar.ShowText := False;
       EDI.NrLn := 0;
       Ocupado := 0;
       EDI.Texto.Clear;
       with TQuery.Create(Self) do begin
        try
         SessionName := 'SES_EDI';
         DataBaseName := 'BROKER';
         SQL.Add('UPDATE TFILA_LOG SET RESOLVIDA = ''E'' WHERE CD_FILA = ' + IntToStr(EDI.Fila_Reg));
         ExecSQL;
        finally
         Free;
        end;
       end;
       WatchTimer.Enabled := True;
    end;
  end;
end;


             str_obs:=TMemo.Create(nil);
             str_obs.Name       := 'memObs';
             str_obs.Parent     := frmMain;
             str_obs.WordWrap   := False;
             str_obs.Lines.Text := str_linha;
             str_linha          := '';
             ctLinha            := 0;
             for i := str_obs.lines.Count downto str_obs.lines.count-15 do
             begin
               try
                 if trim(str_obs.Lines[i])<>'' then
                 begin
                    str_linha:=str_obs.Lines[i]+#13+str_linha;
                    Inc(ctLinha);
                    if ctLinha>=5 then
                      Break;
                 end;
               except
                 continue;
               end;
             end;
             str_obs.Free;

             // pega a OBS inteira
             if pProduto='02' then
               oSheet.Cells[ nLinha, vTotalEventos +13].value := str_linha
             else
               oSheet.Cells[ nLinha, vTotalEventos +16].value   := str_linha;

             if pProduto = '00' then // Modelo Novo Importaçăo
             begin
               str_linha := qry_mail_proc_nao_fat.FieldByName('Status').AsString;
               str_obs := TMemo.Create(nil);
               str_obs.Name       := 'memObs';
               str_obs.Parent     := frmMain;
               str_obs.WordWrap   := False;
               str_obs.Lines.Text := str_linha;
               str_linha          := '';
               ctLinha            := 0;
               for i := 0 to str_obs.lines.Count -1 do
               begin
                 try
                   if trim(str_obs.Lines[i]) <> '' then
                   begin
                     str_linha := str_linha + #13 + str_obs.Lines[i];
                     Inc(ctLinha);
                   end;
                 except
                   continue;
                 end;
               end;
               str_obs.Free;

               oSheet.Cells[ nLinha, vTotalEventos +20].value   := str_linha;

               Range := oSheet.Range['A' + IntToStr(nLinha) + ':' + string(oSheet.Cells[ nLinha, vTotalEventos +21].Address)];
             end
             else
               Range := oSheet.Range['A' + IntToStr(nLinha) + ':' + string(oSheet.Cells[ nLinha, vTotalEventos +20].Address)];

             Range.Borders[xlDiagonalDown].LineStyle := 0;
             Range.Borders[xlDiagonalUp].LineStyle := 0;
             Range.Borders[xlEdgeLeft].LineStyle := xlContinuous;
             Range.Borders[xlEdgeLeft].ColorIndex := 15;
             Range.Borders[xlEdgeLeft].Weight := xlThin;
             Range.Borders[xlEdgeTop].LineStyle := xlContinuous;
             Range.Borders[xlEdgeTop].ColorIndex := 15;
             Range.Borders[xlEdgeTop].Weight := xlThin;
             Range.Borders[xlEdgeBottom].LineStyle := xlContinuous;
             Range.Borders[xlEdgeBottom].ColorIndex := 15;
             Range.Borders[xlEdgeBottom].Weight := xlThin;
             Range.Borders[xlEdgeRight].LineStyle := xlContinuous;
             Range.Borders[xlEdgeRight].ColorIndex := 15;
             Range.Borders[xlEdgeRight].Weight := xlThin;
             Range.Borders[xlInsideVertical].LineStyle := xlContinuous;
             Range.Borders[xlInsideVertical].ColorIndex := 15;
             Range.Borders[xlInsideVertical].Weight := xlThin;
             Range.Borders[xlInsideHorizontal].LineStyle := xlContinuous;
             Range.Borders[xlInsideHorizontal].ColorIndex := 15;
             Range.Borders[xlInsideHorizontal].Weight := xlThin;

             oSheet.Rows[IntToStr(nLinha) + ':' + IntToStr(nLinha)].RowHeight := 15;

             qry_mail_proc_nao_fat.Next;
          end;

          if pProduto = '01' then
          begin
            oSheet.Sort.SortFields.Clear;
            for I := vTotalEventos downto 1 do
              oSheet.Sort.SortFields.Add(Key:=oSheet.Range[GetCellName(oSheet, I + 13, 9) + ':' + GetCellName(oSheet, I + 13, nLinha)], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);
            oSheet.Sort.SetRange(oSheet.Range[GetCellName(oSheet, 1, 9) + ':' + GetCellName(oSheet, vTotalEventos + 20, nLinha)]);
            oSheet.Sort.Header := xlGuess;
            oSheet.Sort.MatchCase := False;
            oSheet.Sort.Orientation := xlTopToBottom;
            oSheet.Sort.SortMethod := xlPinYin;
            oSheet.Sort.Apply;
          end;

        finally
          //--------------------------------------------------------------------------//
          // finalizando...
          //--------------------------------------------------------------------------//
          //--------------------------------------------------------------------------//
          // deixar a planilha visivel no windows
          //--------------------------------------------------------------------------//

          Excel.Visible := chkVisualizarExcel.checked;
          if FileExists(GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.XLS') then
            SysUtils.DeleteFile(GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.XLS');
          Excel.ActiveWorkBook.SaveAs(GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.XLS');
        end;

        if tem_dados then
           Result := GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.XLS'
        else
           Result := 'Sem Dados';

      finally
        Excel.ActiveWorkBook.Close(False);
        KillExcel(Excel);
      end;
    finally
      FreeAndNil(vQryEventos);
      FreeAndNil(qry_mail_proc_nao_fat);
      FreeAndNil(db_broker);
    end;
  except
    on e:Exception do
    begin
      VMsg('Erro - RelEventosFupClientes: ' + e.Message, msError, True);
    end;
  end;
end;


Function TFrmMain.RelEventosFupClientesE12(pUnidade, pProduto, pGrupo, pCliente, pArea, pEvento, pRelatorio, pHorario: string): String;
var
  Excel, WorkBook, Sheet, Range: OleVariant;
  Arquivo: String;
  Linha: Integer;
  TemDados: Boolean;
  DescCab: TDescCab;
  vTimeStamp: string;
  Hour, min, sec, MSec: Word;
  Coluna: Integer;

  procedure PreencheData(ALinha, AColuna: Integer; Data: string);
  begin
    Sheet.Cells[ ALinha, AColuna ].NumberFormat        := 'DD/MM/AAAA';
    Sheet.Cells[ ALinha, AColuna ].HorizontalAlignment := 3;

    if (Data <> 'N/A') and (Data <> '') then
    begin
      Sheet.Cells[ ALinha, AColuna ].Value := StrToDate(FormatDateTime('dd/mm/yyyy', StrToDate(Data)));
    end
    else
      Sheet.Cells[ ALinha, AColuna ].Value := Data;
  end;

  procedure PreencheHiperlink(ALinha, AColuna: Integer; AValue: String);
  begin
    if AValue <> '' then
    begin
      Excel.ActiveSheet.Hyperlinks.Add(Anchor:=Sheet.Cells[ALinha, AColuna], Address:=AValue);
      Sheet.Cells[Linha, Coluna].value := 'a';
    end
    else
      Sheet.Cells[Linha, AColuna].value := ' ';

    Sheet.Cells[ ALinha, AColuna].Font.Bold       := False;
    Sheet.Cells[ ALinha, AColuna].Font.Name       := 'Webdings';
    Sheet.Cells[ ALinha, AColuna].Font.Size       := 18;
    Sheet.Cells[ ALinha, AColuna].Font.ColorIndex := 50;
    Sheet.Cells[ ALinha, AColuna].Font.Underline  := false;
  end;

  procedure PreencheCanal(ALinha, AColuna: Integer; AValue: integer);
  begin
    case AValue of
     0:Sheet.Cells[ ALinha, AColuna ].Font.ColorIndex := 3; //canal vermelho
     1:Sheet.Cells[ ALinha, AColuna ].Font.ColorIndex := 6; //canal amarelo

function TfrmMain.Integra_EDI( vCdrelatorio: String ) : Boolean; //by carlos
var
  Word : Variant;
  FileName,wdFormatText : OleVariant;
  vQryTexto : TQuery;
  vTextoTodo, vTextoParte, vNmModelo, vNmModelo_Tmp, vNmModelo_Original, vTexto, vVar_cartas_config : String;
  vProduto, vGrupo, vEvento, vProcesso, vModal,vTipo_Extensao, vExtensao,
  vEnvio, vPath, vMailUsuario, vNmRelatorio, vRefCliente, Subject,  vTpArquivoGravarDigitalizacao : string;
  i,x,qt_img : Integer;
  vQryAlerta, vQryAux  : TQuery;
  InTeste, vGravarDigitalizacao: Boolean;
  {$region 'BuscaNomeArq'}
  function BuscaNomeArq(vTcartas_Config : String) :String;
  var
  strSQL:String;
  begin
    with TQuery.Create(Self) do begin
      try
        SessionName := 'SES_EDI';
        DataBaseName := 'BROKER';
        Sql.Clear;
        SQL.Add('select NM_SQL_MANUAL from TCARTAS_CONFIG (NOLOCK) where TX_CARTAS_CONFIG= "'+vTCartas_Config+'"' );
        Open;
        strSQL:=Fields[0].AsString;
        Close;
        //

        Sql.Clear;
        SQL.Add(strSQL);
        // Se há o parâmetro NR_PROCESSO na consulta, atribui o numero do processo
        if Pos(':NR_PROCESSO', strSQL) > 0 then
           ParamByName('NR_PROCESSO').AsString := vProcesso;

        Open;
        Result:=Fields[0].AsString;
        if result='' then
           result:='arq';

        close;
      finally
        Free;
      end;
    end;

  end;
 {$endregion}

  {$region 'InsereTexto'}
  function InsereTexto(vTipoVariavel : String) :String;
  var
    vSQL, vCampo, vStrTexto : String;
    vQryCampo : TQuery;
  begin
    Result := '';
    if vQryAlerta.FieldByName('NM_SQL_MANUAL').Value <> '' then
      vSQL := vQryAlerta.FieldByName('NM_SQL_MANUAL').AsString
    else
    begin
      if vQryAlerta.FieldByName('NM_TABELA').AsString <> '' then
        vSQL := ' SELECT '+ vQryAlerta.FieldByName('NM_CAMPO').AsString +
                ' FROM '  + vQryAlerta.FieldByName('NM_TABELA').AsString + ' (NOLOCK) ' +
                ' WHERE ' + Trim(Copy(vQryAlerta.FieldByName('NM_JOIN').AsString, Pos('>', vQryAlerta.FieldByName('NM_JOIN').AsString) +1, Length(vQryAlerta.FieldByName('NM_JOIN').AsString))) +
                '    = ( SELECT ' + Trim(Copy(vQryAlerta.FieldByName('NM_JOIN').AsString, 1, Pos('>', vQryAlerta.FieldByName('NM_JOIN').AsString) -1)) +
                         ' FROM TPROCESSO (NOLOCK) WHERE NR_PROCESSO = :NR_PROCESSO)'
      else
        vSQL := '  SELECT ' + vQryAlerta.FieldByName('NM_CAMPO').AsString +
                ' FROM TPROCESSO (NOLOCK) WHERE NR_PROCESSO = :NR_PROCESSO';
    end;

    vQryCampo := TQuery.Create(Self);
    with vQryCampo do
    begin
      try
        SessionName := 'SES_EDI';
        DataBaseName := 'BROKER';
        Sql.Clear;
        SQL.Add(vSql);
        // Se há o parâmetro NR_PROCESSO na consulta, atribui o numero do processo
        if Pos(':NR_PROCESSO', vSQL) > 0 then
          ParamByName('NR_PROCESSO').AsString := vProcesso; //'0101im-0001-08';

        Open;
        if vTipoVariavel = '0' then
        begin
          if Fields[0].DataType in [ftFloat, ftCurrency] then
            vCampo := FormatFloat('#0.,00', Fields[0].AsFloat)
          else if (Fields[0].DataType in [ftDate, ftDateTime, ftTime]) and (Fields[0].AsString <> '') and (not Fields[0].IsNull) then
            vCampo := FormatDateTime('dd/mm/yyyy', Fields[0].AsDateTime)
          else
            vCampo := Fields[0].AsString;
          Result := vCampo;
        end
        else
        begin
          while not Eof do
          begin
            // Formata o valor de acordo com o tipo do campo
            if Fields[0].DataType in [ftFloat, ftCurrency] then
              vCampo := FormatFloat('#0.,00', Fields[0].AsFloat)
            else if (Fields[0].DataType in [ftDate, ftDateTime, ftTime]) and (Fields[0].AsString <> '') and (not Fields[0].IsNull) then
              vCampo := FormatDateTime('dd/mm/yyyy', Fields[0].AsDateTime)
            else
              vCampo := Fields[0].AsString;

            // Verifica a direçăo para definir a ordem da lista - Michel - 11/12/2008
            if vQryAlerta.FieldByName('CD_DIRECAO').AsString = 'H' then
              vStrTexto := vStrTexto + ', ' + Trim(vCampo) // H - Lista os itens um do lado do outro separados por virgula
            else
              vStrTexto := vStrTexto + '^l' + Trim(vCampo); // V - Lista os itens um em cada linha
            Next;
          end;
          Result := Copy(vStrTexto, 3, Length(vStrTexto) - 2);
        end;
        // Adicionado porque quando vazio năo substitui a variavel - Michel - 16/12/2008 - Ocorręncia 06950/08
        if Result = '' then
          Result := ' ';
        Close;
      finally
        Free;
      end;
    end;
  end;
  {$endregion}
begin
  //EDI

//exit; //temp carlos

  Result := False;

  InTeste := Copy(vCdrelatorio, 1, 1) = 'X';

  if InTeste then
    Delete(vCdrelatorio, 1, 1);

  vQryAux := TQuery.Create(Self);
  with vQryAux do
  begin
    try
      try
        SessionName := 'SES_EDI';
        DataBaseName := 'BROKER';
        SQL.Clear;
        SQL.text := 'SELECT TX_CONFIGURACAO,                                                 '+
                    '       TP_IDIOMA,                                                       '+
                    '       TX_MODELO,                                                       '+
                    '       CD_VIA_TRANSPORTE,                                               '+
                    '       LTRIM(RTRIM(VARIAVEL_CARTAS_CONFIG)) AS VARIAVEL_CARTAS_CONFIG,  '+
                    '       ISNULL(IN_GRAVAR_DIGITALIZACAO,0)    AS IN_GRAVAR_DIGITALIZACAO, '+
                    '       CD_TP_DOCTO_GRAVAR                                               '+
                    '  FROM TRELATORIOS_MAIL_AUT (NOLOCK)                                    '+
                    ' WHERE CD_RELATORIO = ''' + vCdrelatorio + '''                          ';
        Open;

        vGrupo                        := ExtractWord(1, Fields[0].AsString,'/');
        vProduto                      := ExtractWord(2, Fields[0].AsString,'/');
        vEvento                       := ExtractWord(3, Fields[0].AsString,'/');
        vTipo_Extensao                := ExtractWord(4, Fields[0].AsString,'/');
        vExtensao                     := ExtractWord(5, Fields[0].AsString,'/');
        vEnvio                        := ExtractWord(6, Fields[0].AsString,'/');
        vPath                         := ExtractWord(7, Fields[0].AsString,'/');

        vNmModelo                     := Fields[2].AsString;
        vNmModelo_Original            := vNmModelo;
        vVar_cartas_config            := Fields[4].AsString;
        vGravarDigitalizacao          := Fields[5].asBoolean;
        vTpArquivoGravarDigitalizacao := Fields[6].AsString;
        Close;
      Finally
        Free;
      end;
    except
      on E: Exception do
        VMsg(E.message, msError, True);
    end;
  end;

  vQryTexto := TQuery.Create(Self);
  with vQryTexto do
  begin
    try
      SessionName := 'SES_EDI';
      DataBaseName := 'BROKER';
      Close;
      SQL.Clear;
      SQL.Add(' SELECT FUP.NR_PROCESSO, g.NM_GRUPO                                           ');
      SQL.Add(' FROM TFOLLOWUP              FUP (NOLOCK)                                     ');
      SQL.Add(' INNER JOIN TPROCESSO        PR  (NOLOCK) ON PR.NR_PROCESSO = FUP.NR_PROCESSO ');
      SQL.Add(' INNER JOIN TSERVICO_NOVO    S   (NOLOCK) ON S.CD_SERVICO   = PR.CD_SERVICO   ');
      SQL.Add(' INNER JOIN TGRUPO           g   (NOLOCK) ON g.CD_GRUPO     = PR.CD_GRUPO     ');

      if SameText(vGrupo, 'B35') and (vEvento = '141') then
        SQL.Add(' WHERE FUP.DT_REALIZACAO IS NOT NULL ')
      else
        SQL.Add(' WHERE FUP.DT_REALIZACAO IS NOT NULL  AND  ISNULL(FUP.DT_REALIZACAO_EFETIVA,FUP.DT_REALIZACAO) > GETDATE()- 18');

      if vProduto<>'' then
         SQL.Add('   AND PR.CD_PRODUTO = "' + vProduto + '"' );

      SQL.Add('   AND FUP.CD_EVENTO    = ''' + vEvento + ''' ');
      SQL.Add('   AND PR.CD_GRUPO      =  "' + vGrupo  + '"' );

      if not InTeste then
        SQL.Add('   AND ISNULL(FUP.IN_EDI_ENVIADO,"0") = "0" ');

      Open;

      vGrupoLogo := '';
      vGrupoLogo := vGrupo;

      while not EOF do
      begin
        vNmModelo_tmp  := vNmModelo_Original;
        //copiar para a pasta temporaria
        System.Insert('TMP_EMAIL\' , vNmModelo_tmp , 28);

        if not DirectoryExists(ExtractFileDir(vNmModelo_tmp)) then
          ForceDirectories(ExtractFileDir(vNmModelo_tmp));

        CopyFile(PChar(vNmModelo_Original),PChar(vNmModelo_Tmp),true);

        vProcesso := Trim(Fields[0].AsString);

        //Abre O word
        try Word := GetActiveOleObject('Word.Application');
        except
            Word := CreateOleObject('Word.Application');
        end;
        Word.Visible := True;

        // utilizar o arquivo temporario
        FileName:=vNmModelo_Tmp;

        //Abre o Arquivo do Alerta
        Word.Documents.Open(FileName);

        vQryAlerta := TQuery.Create(Self);
        with vQryAlerta do begin
          SessionName := 'SES_EDI';
          DataBaseName := 'BROKER';
          Sql.Clear;
          Sql.Add(' SELECT * FROM TCARTAS_CONFIG (NOLOCK)');
          Open;
          While not Eof do
          begin
            Word.Selection.Find.ClearFormatting;
            Word.Selection.Find.Text := LowerCase(StringReplace(StringReplace(FieldByName('TX_CARTAS_CONFIG').AsString,'\','123', [rfReplaceAll]), '/', '321', [rfReplaceAll]));
            Word.Selection.Find.Forward           := True;
            Word.Selection.Find.Wrap              := 1;
            Word.Selection.Find.Format            := False;
            Word.Selection.Find.MatchCase         := False;
            Word.Selection.Find.MatchWholeWord    := False;
            Word.Selection.Find.MatchWildcards    := True;
            Word.Selection.Find.MatchSoundsLike   := False;
            Word.Selection.Find.MatchAllWordForms := False;
            lblMensagem.Caption := vProcesso + ': Variável: ' + Trim(FieldByName('CD_CARTAS_CONFIG').AsString) + ' - ' + StringReplace(StringReplace(Trim(FieldByName('TX_CARTAS_CONFIG').AsString),'\','', [rfReplaceAll]), '/', '', [rfReplaceAll]);

            Application.ProcessMessages;

            if Word.Selection.Find.Execute then
            begin
               vTextoTodo := InsereTexto(FieldByName('IN_VARIOS_REGISTROS').AsString);
               vTexto := vTextoTodo;
               begin
                  while vTextoTodo <> '' do
                  begin
                    // Verifica se é parâmetro de quebra do word para năo mandar errado
                    if Copy(vTextoTodo, 200, 1) = '^' then
                    begin
                       vTextoParte := Copy(vTextoTodo, 1, 199);
                       System.Delete(vTextoTodo, 1, 199);
                    end
                    else
                    begin
                       vTextoParte := Copy(vTextoTodo, 1, 200);
                       System.Delete(vTextoTodo, 1, 200);
                    end;
                    // Coloca a variável no final novamente se ainda houver texto para substiruir - Michel - 04/12/2008
                    if vTextoTodo <> '' then
                      vTextoParte := vTextoParte +  Word.Selection.Find.Text;

                    Word.Selection.Find.Replacement.Text  := StringReplace(vTextoParte,'\','/',[rfReplaceAll]);

                    Word.Selection.Find.Execute(Replace   := 2);
                  end;
               end;
            end;
            vQryAlerta.Next;
          end;

          lblMensagem.Caption := '';

          // SALVA ARQUIVO .doc em .html
  //        vNmModelo := 'H:\DDBROKER\DOCUMENTOSEDI\SGMC'+FormatDateTime('yyyyMMddhhmm', Now)+'.'+vExtensao;

          vNmModelo := 'H:\DDBROKER\DOCUMENTOSEDI\'+BuscaNomeArq(vVar_cartas_config)+'.'+vExtensao;
          vNmModelo := StringReplace(vNmModelo, '/', '', [rfReplaceAll, rfIgnoreCase]);

          wdFormatText:=$00000004; //somente texto
          try
            Word.ActiveDocument.SaveAs(FileName:= vNmModelo, FileFormat:= wdFormatText, AddToRecentFiles := False);
          except on e:exception do
          begin
            VMsg('Erro ao salvar WORD ' + e.message, msSystem, False);
            vEnvio:='erro';
          end;
          end;
          Word.ActiveDocument.Close;
          Word.Quit;
          Word := Unassigned;
          freeandnil(word);

          sleep(2000);

          if vEnvio='0' then //Por Email
          begin
             vMailUsuario := '';
             with TQuery.Create(Self) do
             begin
               try
                 SessionName := 'SES_EDI';
                 DataBaseName := 'BROKER';
                 SQL.Clear;
                 SQL.Add(' SELECT CONVERT(VARCHAR(MAX),U.NM_EMAIL) NM_EMAIL, MAIL.NM_RELATORIO');
                 SQL.Add(' FROM TRELATORIOS_MAIL_AUT                  MAIL  (NOLOCK) ');
                 SQL.Add('   INNER JOIN TRELATORIOS_MAIL_AUT_USUARIOS UMAIL (NOLOCK) ON MAIL.CD_RELATORIO = UMAIL.CD_RELATORIO');
                 SQL.Add('   INNER JOIN TUSUARIO                      U     (NOLOCK) ON U.CD_USUARIO = UMAIL.CD_USUARIO');
                 SQL.Add(' WHERE UMAIL.CD_RELATORIO = ''' + vCdrelatorio + ''' ');
                 SQL.Add(' AND IsNull(U.NM_EMAIL,"")<>"" ');   //apesar de năo ser necessario, inclui essa validaçăo - by carlos 25/08/2011
                 Open;

                 if not InTeste then
                   while not EOF do
                   begin
                     vMailUsuario := vMailUsuario + FieldByName('NM_EMAIL').AsString + ';';
                     Next;
                   end;

                 vNmRelatorio := FieldByName('NM_RELATORIO').AsString;
                 Close;

                 { busca a referencia do cliente - respeitando o produto - 05/05/2011 }
                 SQL.Clear;
                 SQL.Add(' SELECT TOP 1 RTRIM(LTRIM(rc.CD_REFERENCIA)) NR_PEDIDO FROM TREF_CLIENTE rc (NOLOCK) ');
                 SQL.Add(' JOIN TPROCESSO pr (NOLOCK) ON rc.NR_PROCESSO = pr.NR_PROCESSO ');
                 SQL.Add(' WHERE rc.NR_PROCESSO= "'+vPROCESSO+'" ');
                 SQL.Add('   AND rc.TP_REFERENCIA = ');
                 SQL.Add(' ( SELECT ISNULL( CASE WHEN SUBSTRING(rc.NR_PROCESSO,3,2)="01" THEN g.TP_PEDIDO_BUSCA_IMP ELSE g.TP_PEDIDO_BUSCA END  ,"01" ) ');
                 SQL.Add('     FROM TGRUPO g (NOLOCK) ');
                 SQL.Add('    WHERE g.CD_GRUPO = ( SELECT e.CD_GRUPO ');
                 SQL.Add(' FROM TEMPRESA_NAC e (NOLOCK) ');
                 SQL.Add(' WHERE e.CD_EMPRESA = rc.CD_EMPRESA ) ) ');
                 Open;
                 vRefCliente:=Fields[0].AsString;
                 Close;
               Finally
                 Free;
               end;
             end;

             Subject := vNmRelatorio + ' ( ' +vProcesso+'/'+vRefCliente +' )';

             if InTeste then
              vMailUsuario := 'agatha.nigro@myindaia.com.br';

             if EnviaEmail(vMailUsuario, Subject, vNmModelo) then
             begin
               with TQuery.Create(Self) do
               begin
                 try
                   SessionName  := 'SES_EDI';
                   DataBaseName := 'BROKER';
                   SQL.Clear;
                   SQL.Add('UPDATE TFOLLOWUP SET IN_EDI_ENVIADO = "1" ');
                   SQL.Add(' WHERE CD_EVENTO   = "' + vEvento + '" ');
                   SQL.Add('   AND NR_PROCESSO = "' + vProcesso + '" ');
                   ExecSQL;
                 Finally
                   Free;
                 end;

                 try
                   if vGravarDigitalizacao and (trim(vTpArquivoGravarDigitalizacao) <> '') then
                   begin
                     GravaArquivo(FDConnection, vNmModelo, vProcesso, vNmRelatorio, strtoint(vTpArquivoGravarDigitalizacao));
                   end;
                 except on e:exception do
                    VMsg('Erro ao digitalizar : ' + e.message, msSystem, False);
                 end;
               end;
               Result:=True;
             end;
          end;


  //         if vEnvio='1' then //Por FTP
  //              Result:=True;

  //         if vEnvio='2' then //Pasta Local
  //           Result:=True;


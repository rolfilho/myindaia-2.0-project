              '        AND ID_TABELA     = 1652005462                                                                                                                                         ' +sLineBreak +
              '        AND IN_ATIVO      = 1                                                                                                                                                  ' +sLineBreak +
              '      ORDER BY DT_CRIACAO DESC)                                                       AS [DOCUMENTOS_IMPORTACAO],                                                              ' +sLineBreak +
              '     (SELECT TOP 1 ''HTTP://WWW.MYINDAIAWEB.COM.BR/REDIRECIONA_DOC.ASP?COD='' +                                                                                                ' +sLineBreak +
              '                    MASTER.DBO.FN_CRIPROGRAFA(''DOCS_NOVO/'' + NR_PROCESSO + ''/'' + RTRIM(NM_ARQUIVO))                                                                        ' +sLineBreak +
              '      FROM TPROCESSO_DOCTOS WITH (NOLOCK)                                                                                                                                      ' +sLineBreak +
              '      WHERE NR_PROCESSO   = PR.NR_PROCESSO                                                                                                                                     ' +sLineBreak +
              '        AND CD_TIPO_DOCTO = 9                                                                                                                                                  ' +sLineBreak +
              '        AND ID_TABELA     = 1652005462                                                                                                                                         ' +sLineBreak +
              '        AND IN_ATIVO      = 1                                                                                                                                                  ' +sLineBreak +
              '      ORDER BY DT_CRIACAO DESC)                                                       AS [EXTRATO_DI],                                                                         ' +sLineBreak +
              '     (SELECT TOP 1 ''HTTP://WWW.MYINDAIAWEB.COM.BR/REDIRECIONA_DOC.ASP?COD=''                                                                                                  ' +sLineBreak +
              '                  + MASTER.DBO.FN_CRIPROGRAFA(''DOCS_NOVO/'' + NR_PROCESSO + ''/'' + RTRIM(NM_ARQUIVO))                                                                        ' +sLineBreak +
              '      FROM TPROCESSO_DOCTOS WITH (NOLOCK)                                                                                                                                      ' +sLineBreak +
              '      WHERE NR_PROCESSO   = PR.NR_PROCESSO                                                                                                                                     ' +sLineBreak +
              '        AND CD_TIPO_DOCTO = 10                                                                                                                                                 ' +sLineBreak +
              '        AND ID_TABELA     = 1652005462                                                                                                                                         ' +sLineBreak +
              '        AND IN_ATIVO      = 1                                                                                                                                                  ' +sLineBreak +
              '      ORDER BY DT_CRIACAO DESC)                                                       AS [EXTRATO_CI],                                                                         ' +sLineBreak +
              '     (SELECT TOP 1 ''HTTP://WWW.MYINDAIAWEB.COM.BR/REDIRECIONA_DOC.ASP?COD=''                                                                                                  ' +sLineBreak +
              '                  + MASTER.DBO.FN_CRIPROGRAFA(''DOCS_NOVO/'' + NR_PROCESSO + ''/'' + RTRIM(NM_ARQUIVO))                                                                        ' +sLineBreak +
              '      FROM TPROCESSO_DOCTOS WITH (NOLOCK)                                                                                                                                      ' +sLineBreak +
              '      WHERE NR_PROCESSO   = PR.NR_PROCESSO                                                                                                                                     ' +sLineBreak +
              '        AND CD_TIPO_DOCTO = 80                                                                                                                                                 ' +sLineBreak +
              '        AND ID_TABELA     = 1652005462                                                                                                                                         ' +sLineBreak +
              '        AND IN_ATIVO      = 1                                                                                                                                                  ' +sLineBreak +
              '      ORDER BY DT_CRIACAO DESC)                                                       AS [DANFE],                                                                              ' +sLineBreak +
              '     PR.NR_CONHECIMENTO                                                               AS [NR_CONHECIMENTO],                                                                    ' +sLineBreak +
              '     DI.NR_DECLARACAO_IMP                                                             AS [NR_DECLARACAO_IMP],                                                                   ' +sLineBreak +
              '     Cast(ISNULL(STUFF((SELECT DISTINCT '', ''                                                                                                                                 ' +sLineBreak +
              '                          + LTRIM(RTRIM(PC.NR_CNTR))                                                                                                                           ' +sLineBreak +
              '                          + '' ('' + LTRIM(RTRIM(TCC.NM_TP_CNTR)) + '') ''                                                                                                     ' +sLineBreak +
              '                          + ''/ FreeTime: '' + convert(varchar(max),(isnull(PC.NR_FREE_TIME,''-'')))                                                                           ' +sLineBreak +
              '                          + '' / Dt dev.: '' + CASE WHEN PC.DT_DEVOLUCAO_CNTR IS NULL THEN ''-'' ELSE CONVERT(VARCHAR(10),PC.DT_DEVOLUCAO_CNTR,103) END                        ' +sLineBreak +
              '                        FROM TPROCESSO_CNTR PC WITH (NOLOCK)                                                                                                                   ' +sLineBreak +
              '                        LEFT JOIN TTP_CNTR TCC (NOLOCK) ON TCC.TP_CNTR = PC.TP_CNTR                                                                                            ' +sLineBreak +
              '                        WHERE PC.NR_PROCESSO = PR.NR_PROCESSO                                                                                                                  ' +sLineBreak +
              '                 FOR XML PATH('''')), 1, 1, ''''), '''') as Varchar(max)) AS [DADOS_CNT]                                                                                      ' +sLineBreak +
              '     FROM TPROCESSO                         	  PR   WITH (NOLOCK)                                                                                                              ' +sLineBreak +
              '       INNER JOIN TEMPRESA_NAC              	  EN   WITH (NOLOCK) ON EN.CD_EMPRESA    = PR.CD_CLIENTE                                                                          ' +sLineBreak +
              '       INNER JOIN TGRUPO                    	  GR   WITH (NOLOCK) ON GR.CD_GRUPO      = EN.CD_GRUPO                                                                            ' +sLineBreak +
              '       INNER JOIN TSERVICO_NOVO             	  SV                 ON SV.CD_SERVICO    = PR.CD_SERVICO                                                                          ' +sLineBreak +
              '       INNER JOIN TVIA_TRANSP_BROKER        	  VT   WITH (NOLOCK) ON VT.CD_VIA_TRANSP = SV.CD_VIA_TRANSPORTE                                                                   ' +sLineBreak +
              '       LEFT  JOIN TAREA                     	  AR   WITH (NOLOCK) ON AR.CD_AREA       = PR.CD_AREA                                                                             ' +sLineBreak +
              '       LEFT  JOIN TPAIS_BROKER              	  PB   WITH (NOLOCK) ON PB.CD_PAIS       = PR.CD_PAIS_ORIGEM                                                                      ' +sLineBreak +
              '       LEFT  JOIN TDECLARACAO_IMPORTACAO    	  DI   WITH (NOLOCK) ON DI.NR_PROCESSO   = PR.NR_PROCESSO                                                                         ' +sLineBreak +
              '       OUTER APPLY (SELECT DM.NR_PROCESSO,                                                                                                                                     ' +sLineBreak +
              '                           LEFT(MASTER.DBO.ROWCONCAT(DISTINCT ISNULL(DM.CD_UN_MED_COMERC, '''')), 3) AS CD_UNID_MEDIDA,                                                        ' +sLineBreak +
              '                           SUM(DM.QT_MERC_UN_COMERC) AS QT_COMERCIALIZADA                                                                                                      ' +sLineBreak +
              '                      FROM TDETALHE_MERCADORIA DM WITH (NOLOCK)                                                                                                                ' +sLineBreak +
              '                     WHERE DM.NR_PROCESSO = DI.NR_PROCESSO                                                                                                                     ' +sLineBreak +
              '                  GROUP BY DM.NR_PROCESSO) DM                                                                                                                                  ' +sLineBreak +
              '    LEFT  JOIN TEMPRESA_EST            			  EF   WITH (NOLOCK) ON EF.CD_EMPRESA    = DI.CD_FORNECEDOR                                                                       ' +sLineBreak +
              '    LEFT  JOIN TTP_CANAL               			  TC   WITH (NOLOCK) ON TC.CD_CANAL      = PR.CD_CANAL                                                                            ' +sLineBreak +
              '    LEFT  JOIN TEMBARCACAO             			  EB   WITH (NOLOCK) ON EB.CD_EMBARCACAO = PR.CD_EMBARCACAO                                                                       ' +sLineBreak +
              '    LEFT  JOIN TAGENTE                 			  AG   WITH (NOLOCK) ON AG.CD_AGENTE     = PR.CD_AGENTE                                                                           ' +sLineBreak +
              '    LEFT  JOIN TTRANSP_ROD             			  TR   WITH (NOLOCK) ON TR.CD_TRANSP_ROD = PR.CD_TRANSP_NAC                                                                       ' +sLineBreak +
              '    LEFT  JOIN TFOLLOWUP               			  F    WITH (NOLOCK) ON F.NR_PROCESSO    = PR.NR_PROCESSO                                                                         ' +sLineBreak +
              '                                       			                    AND F.CD_EVENTO      = CASE WHEN (SELECT COUNT(*)                                                             ' +sLineBreak +
              '                                       			              		                    	             FROM TFOLLOWUP FL WITH (NOLOCK)                                              ' +sLineBreak +
              '                                       			              		                    	            WHERE FL.NR_PROCESSO = PR.NR_PROCESSO                                         ' +sLineBreak +
              '                                       			              		                    	              AND FL.CD_EVENTO   = ''082''                                                ' +sLineBreak +
              '                                       			              		                    	              AND FL.CD_SERVICO  = PR.CD_SERVICO) > 0                                     ' +sLineBreak +
              '                                       			              		                    	     THEN ''082''                                                                         ' +sLineBreak +
              '                                       			              		      			    	     ELSE ''215''                                                                             ' +sLineBreak +
              '                                       			              		      					 END                                                                                            ' +sLineBreak +
              '    INNER JOIN TFOLLOWUP               			  F092 WITH (NOLOCK) ON PR.NR_PROCESSO    = F092.NR_PROCESSO                                                                      ' +sLineBreak +
              '                                       			               	   	AND F092.CD_EVENTO    = ''092''                                                                               ' +sLineBreak +
              '                                       			               	   	AND PR.CD_SERVICO     = F092.CD_SERVICO                                                                       ' +sLineBreak +
              '                                       			               	  	AND F092.IN_APLICAVEL = 1                                                                                     ' +sLineBreak +
              '    INNER JOIN TFOLLOWUP               			  F022 WITH (NOLOCK) ON PR.NR_PROCESSO    = F022.NR_PROCESSO AND F022.CD_EVENTO = ''022'' AND PR.CD_SERVICO = F022.CD_SERVICO     ' +sLineBreak +
              '    LEFT  JOIN TFOLLOWUP               			  F653 WITH (NOLOCK) ON F653.NR_PROCESSO  = PR.NR_PROCESSO   AND F653.CD_EVENTO = ''653'' AND PR.CD_SERVICO = F653.CD_SERVICO     ' +sLineBreak +
              '    WHERE ((F092.DT_REALIZACAO IS NULL)                                                                                                                                        ' +sLineBreak +
              '     OR CONVERT(DATETIME, F092.DT_REALIZACAO, 103) >= CONVERT(DATETIME, GETDATE() -2, 103))                                                                                    ' +sLineBreak +
              '     AND SV.CD_VIA_TRANSPORTE <> ''10''                                                                                                                                        ' +sLineBreak +
              '     AND PR.IN_CANCELADO  = ''0''                                                                                                                                              ' +sLineBreak +
              '     AND PR.IN_LIBERADO   = ''1''                                                                                                                                              ' +sLineBreak ;

              if pProduto <> '' then
                SQL.Add('  AND PR.CD_PRODUTO    = "' + pProduto + '"                                                                          ');
              if pUnidade <> '' then
                SQL.Add('  AND PR.CD_UNID_NEG   = "' + pUnidade + '"                                                                          ');
              if pGrupo <> '' then
                SQL.Add('  AND PR.CD_GRUPO      = "' + pGrupo   + '"                                                                          ');
              if pCliente <> '' then
                SQL.Add('  AND PR.CD_CLIENTE    = "' + pCliente + '"                                                                          ');
              if pArea <> '' then
                SQL.Add('  AND PR.CD_AREA       = "' + pArea    + '"                                                                          ');

              SQL.Add('ORDER BY F.DT_REALIZACAO                                                                                               ');

            end
            else
            begin
              SQL.Add ( ' SELECT PR.NR_PROCESSO, case                                                                                                                                                                        ');
              SQL.Add ( '                       when substring(PR.NR_PROCESSO,6,1)="M" then ISNULL(E.NM_EMBARCACAO,"-")                                                                                                      ');
              SQL.Add ( '                       when substring(PR.NR_PROCESSO,6,1)="A" then ISNULL(PR.NR_VOO,"-")                                                                                                            ');
              SQL.Add ( '                       when substring(PR.NR_PROCESSO,6,1)="R" then ISNULL(PR.NR_PLACA_VEICULO,"-")                                                                                                  ');
              SQL.Add ( '                       else "-"                                                                                                                                                                     ');
              SQL.Add ( '                     end NM_VEICULO, isnull(PR.CD_CANAL,4) CD_CANAL,                                                                                                                                ');
              SQL.Add ( '  case when PR.CD_PRODUTO="01" then (select descricao from tpais (NOLOCK) where CODIGO=PR.CD_PAIS_ORIGEM)                                                                                           ');
              sql.Add ( '                               else (select descricao from tpais (NOLOCK) where CODIGO=PR.CD_PAIS_DESTINO ) end NM_PAIS_PROCEDENCIA,                                                                ');
              SQL.Add ( ' (select ISNULL(DESCRICAO,"-") from TLOCAL_EMBARQUE (NOLOCK) WHERE CODIGO=PR.CD_LOCAL_DESEMBARQUE  ) NM_DESEMBARQUE  ,                                                                              ');
              //Modificado por Andressa (retirar ultima barra do rowconcat) 22/06/2011
              SQL.Add ( ' ( SELECT substring(MASTER.DBO.RowConcat( DISTINCT LTRIM(RTRIM(R.CD_REFERENCIA))+''-''),0,len(MASTER.DBO.RowConcat( DISTINCT LTRIM(RTRIM(R.CD_REFERENCIA))+''-''))-0)  FROM TREF_CLIENTE R (NOLOCK) ');
              SQL.Add ( '                                                                 WHERE R.NR_PROCESSO=PR.NR_PROCESSO AND R.TP_REFERENCIA =                                                                           ');
              SQL.Add ( '                                                                ( SELECT ISNULL( CASE WHEN SUBSTRING(R.NR_PROCESSO,3,2)="01" THEN g.TP_PEDIDO_BUSCA_IMP ELSE g.TP_PEDIDO_BUSCA END  ,"01" )         ');
              SQL.Add ( '                                                                  FROM TGRUPO g (NOLOCK)                                                                                                            ');
              SQL.Add ( '                                                                  WHERE g.CD_GRUPO = ( SELECT e.CD_GRUPO                                                                                            ');
              SQL.Add ( '                                                                  FROM TEMPRESA_NAC e  (NOLOCK)                                                                                                     ');
              SQL.Add ( '                                                                  WHERE e.CD_EMPRESA = R.CD_EMPRESA ) ) ) CD_REFERENCIA,                                                                            ');


              SQL.Add ( ' ISNULL(F2.TX_OBS,"-") TX_OBS,                                                                                                                                                                      ');
              SQL.Add ( ' PR.NR_CONHECIMENTO, CONVERT(VARCHAR,PR.DT_CONHECIMENTO,103) DT_CONHECIMENTO , ISNULL(T.NM_TRANSP_ROD,"") NM_TRANSPORTADOR, ISNULL(DI.NR_DECLARACAO_IMP,"-") NR_DI                                  ');

              if pProduto='02' then
              begin
                SQL.Add ( ' , (                                                                                                                                                                                              ' );
                SQL.Add ( '  select master.dbo.fn_retira_caracter(master.dbo.rowconcat(ltrim(rtrim(CD_REFERENCIA))+", "), "," )                                                                                              ' );
                SQL.Add ( '  from TREF_CLIENTE (NOLOCK)                                                                                                                                                                      ' );
                SQL.Add ( '  where TP_REFERENCIA="09" and NR_PROCESSO=PR.NR_PROCESSO ) NR_COURRIER                                                                                                                           ' );
                SQL.Add ( ' , (                                                                                                                                                                                              ' );

                SQL.Add ( '  select master.dbo.fn_retira_caracter(master.dbo.rowconcat( substring(NR_RE,1,2)+"/"+substring(NR_RE,3,7)+"-"+substring(NR_RE,10,3) +", "), "," )                                                ');
                SQL.Add ( '  from TPROCESSO_EXP_RE (NOLOCK) where NR_PROCESSO=PR.NR_PROCESSO ) NR_RE                                                                                                                         ');

                SQL.Add ( ' , PR.CD_DUE NR_DDE                                                                                                                                                                               ');
              end;

              SQL.Add ( ' FROM   TPROCESSO PR (NOLOCK)                                                                                                                                                                       ');
              SQL.Add ( ' INNER JOIN TFOLLOWUP F   (NOLOCK) ON ( PR.NR_PROCESSO = F.NR_PROCESSO)                                                                                                                             ');

              if pProduto='02' then
              begin
                 // se năo tiver o evento 131 , utilizar o '113' by Carlos 07/11/2011
                 SQL.Add ( ' INNER JOIN TFOLLOWUP F1 (NOLOCK) ON (PR.NR_PROCESSO = F1.NR_PROCESSO                                                                                                                            ');
                 SQL.Add ( ' AND F1.CD_EVENTO = ( case when ( select COUNT(*) from TFOLLOWUP FL (NOLOCK) where FL.NR_PROCESSO=F1.NR_PROCESSO and FL.CD_EVENTO="131") > 0 then "131" else "113" end  ) )                      ');
              end
              else
              begin
                 SQL.Add ( ' LEFT JOIN TFOLLOWUP F1 (NOLOCK) ON ( PR.NR_PROCESSO = F1.NR_PROCESSO                                                                                                                            '); // Alterado de INNER para LEFT porque nos casos da Visteon Aéreo e Rodoviário năo tem nenhum dos dois eventos - Michel - 21/02/2013
                 SQL.Add ( ' AND F1.CD_EVENTO = ( case when ( select COUNT(*) from TFOLLOWUP FL (NOLOCK) where FL.NR_PROCESSO=F1.NR_PROCESSO and FL.CD_EVENTO="082") > 0 then "082" else "215" end  ) )                      ');
              end;

              SQL.Add ( ' INNER JOIN TFOLLOWUP               F2 (NOLOCK) ON ( PR.NR_PROCESSO = F2.NR_PROCESSO AND F2.CD_EVENTO="022")                                                                                        ');
              SQL.Add ( ' INNER JOIN TFOLLOWUP               F3 (NOLOCK) ON ( PR.NR_PROCESSO = F3.NR_PROCESSO AND F3.CD_EVENTO="114")                                                                                        ');  // COLOCADO EM 26/07/2011 - BY CARLOS - retificado em 10/08/2011 deixou de ser LEFT JOIN
              SQL.Add ( ' LEFT  JOIN TEMBARCACAO             E  (NOLOCK) ON PR.CD_EMBARCACAO = E.CD_EMBARCACAO                                                                                                               ');
              SQL.Add ( ' LEFT  JOIN TTRANSP_ROD             T  (NOLOCK) ON T.CD_TRANSP_ROD = PR.CD_TRANSP_NAC                                                                                                               ');
              SQL.Add ( ' LEFT  JOIN TDECLARACAO_IMPORTACAO  DI (NOLOCK) ON DI.NR_PROCESSO=PR.NR_PROCESSO                                                                                                                    ');

              SQL.Add ( '  WHERE ( F.CD_EVENTO = "092"  AND F.IN_APLICAVEL=1  AND                                                                                                                                            ');
              SQL.Add ( ' ( ( F.DT_REALIZACAO IS NULL  OR F3.DT_REALIZACAO IS NULL )  OR                                                                                                                                     ');

        AGENDA.SQL.ADD('   INNER JOIN TUSUARIO             U (NOLOCK) ON F.NM_PATH_EDI LIKE ''%CD_USUARIO="'' +  U.CD_USUARIO + ''"%'' --AND U.CD_CARGO = ''001'' AND CD_USUARIO = ''1781''');

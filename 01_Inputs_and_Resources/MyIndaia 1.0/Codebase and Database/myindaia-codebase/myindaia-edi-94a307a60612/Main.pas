'     LEFT JOIN TFOLLOWUP              F162   (NOLOCK) ON F162.NR_PROCESSO     = P.NR_PROCESSO AND F162.CD_SERVICO = P.CD_SERVICO AND F162.CD_EVENTO = ''162'' --CHEGADA DO NAVIO / AVIĂO / CAMINHĂO             ' + sLineBreak +

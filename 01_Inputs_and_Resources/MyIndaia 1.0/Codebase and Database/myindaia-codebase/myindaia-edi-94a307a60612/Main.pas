function TEXTO_INFORMACAO_COMPLEMENTAR : String;
Var
  Aux_Info                       : String;
  Aux_Linha                      : string;
  x,Posicao,i, Y                 :Integer;
  NovoTexto, Texto, I_Formatado,
  C_Formatado                    : String;
  Trocou                         : Boolean;
  Tamanho_Total, Tamanho_Parcial,
  Tamanho_Compl                  : Integer;
begin
  i:=1;
  Tamanho_Total    := cnt;
  Tamanho_Parcial  := 0;
  Trocou := True;
  Texto  := TAB.Fieldbyname(campo).AsString;
  NovoTexto := '';
  if (Texto <> '') then
  begin
    for x:=0 to (Length(Texto)-1) do
    begin
      if Texto[x] = Char(13) then
      begin
        inc(i);
        NovoTexto := NovoTexto+Texto[x];
        Trocou := True;
        Tamanho_Parcial:=0;
      end
      else
      begin
        if (Tamanho_Parcial <= Tamanho_Total) then
          NovoTexto := NovoTexto+Texto[x];
        inc(Tamanho_Parcial);
        if Trocou then
        begin
          Y := X;
          Tamanho_Compl := 0;
          while Texto[Y] <> Char(13) do
          begin
            inc(Tamanho_Compl);
            inc(Y);
          end;
          I_Formatado := IntToStr(i);
          {Alinhar a direita}
          Tamanho_Compl := Tamanho_Total - Tamanho_Compl;
          while Length(I_Formatado) < 4 do I_Formatado := '0' + I_Formatado;
          if i = 1 then {1ş VEZ - JÁ ESTA NA LINHA CORRETADO DO EDI}
            NovoTexto := I_Formatado + ' '
          else
            NovoTexto := NovoTexto+EDI.Linha+I_Formatado;
          C_Formatado := ' ';
          while Length(C_Formatado) <= (Tamanho_Compl-1) do C_Formatado := ' ' + C_Formatado;
          NovoTexto := NovoTexto + C_Formatado;
          Trocou := False;
        end;
      end;
    end;
  end;
  Result := NovoTexto;
end;


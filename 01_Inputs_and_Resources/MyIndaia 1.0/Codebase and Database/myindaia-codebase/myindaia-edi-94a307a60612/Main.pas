            Range.Borders[xlEdgeRight].Weight             := xlThin;
            Range.Borders[xlInsideVertical].LineStyle     := xlContinuous;
            Range.Borders[xlInsideVertical].ColorIndex    := 15;
            Range.Borders[xlInsideVertical].Weight        := xlThin;
            Range.Borders[xlInsideHorizontal].LineStyle   := xlContinuous;
            Range.Borders[xlInsideHorizontal].ColorIndex  := 15;
            Range.Borders[xlInsideHorizontal].Weight      := xlThin;

            Range.RowHeight := 15;

            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['AE:AE'], SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['AD:AD'], SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['AC:AC'], SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['AA:AA'], SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['Z:Z']  , SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['Y:Y']  , SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['X:X']  , SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['W:W']  , SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['T:T']  , SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['S:S']  , SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['R:R']  , SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['Q:Q']  , SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['P:P']  , SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);
            oSheet.Sort.SortFields.Add(Key  :=  oSheet.Range['O:O']  , SortOn  :=  xlSortOnValues, Order  :=  xlAscending, DataOption  :=  xlSortNormal);


            //ANTENCAO A ESSA LINHA. SE ADICIONAR UMA COLUNA, PRECISA ALTERAR O "RANGE"
            oSheet.Sort.SetRange(oSheet.Range['A9:BZ' + IntToStr(nLinha)]);


            oSheet.Sort.Header       := xlGuess;
            oSheet.Sort.MatchCase    := False;
            oSheet.Sort.Orientation  := xlTopToBottom;
            oSheet.Sort.SortMethod   := xlPinYin;
            oSheet.Sort.Apply;

          except
            on e:Exception do
            begin
              VMsg('Erro - 2 RelEventosFupClientesNestle: ' + e.Message, msError, True);
            end
          end;
        finally
          Excel.Visible := chkVisualizarExcel.checked;
          if FileExists(GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xlsx') then
            SysUtils.DeleteFile(GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xlsx');

          Excel.ActiveWorkBook.SaveAs(GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xlsx');
        end;

        if tem_dados then
           Result := GetPath+'Gerados\FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.xlsx'
        else
           Result := 'Sem Dados';

      finally
        try
          Excel.ActiveWorkBook.Close(False);
          KillExcel(Excel);
        except
        end;
      end;

    finally
    //  FreeAndNil(qryFollowupFixo);
      FreeAndNil(vQryEventos);
      mdados.Free;
      FreeAndNil(qry_mail_proc_nao_fat);
      FreeAndNil(db_broker);
    end;
end;


function TfrmMain.GetCellName(ASheet: OleVariant; ACol, ARow: Integer): String;
begin
  Result := string(ASheet.Cells[ARow, ACol].Address);
  Result := StringReplace(Result, '$', '', [rfReplaceAll]);
end;

Function TFrmMain.RelEventosDailyFupMod2(pUnidade, pProduto, pGrupo, pImportador, pEvento, pCliente, pTransportador, pRelatorio, pHorario: string): String;
var
  db_broker                                              : TDatabase;
  vQryEventos, qry_mail_proc_nao_fat, qryAuxiliar        : TQuery;
  Excel, xlWorkB, oSheet                                 : OleVariant;
  nLinha, ctLinha, nColuna, vPrimeiraLinha, vCont,i,x,vTotalEventos,vUlt_Col_Fixa, vNegrita : Integer;
  vValorTotalServico                                     : Real;
  vAno, vMes, vDia                                       : Word;
  vTimeStamp, vNomeProduto, vIdioma, str_CD_EVENTO,strTmp,QTDE,CD_MERCADORIA,QT_MERCADORIA: string;
  str_linha                                              : widestring;
  Hour, min, sec, MSec                                   : Word;
  str_OBS                                                : TMemo;
  tem_dados                                              : boolean;
begin
  try
    db_broker:= TDatabase.Create(Self);
    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;
    vQryEventos := TQuery.Create(Self);
    vQryEventos.DatabaseName := 'DBBROKER';
    //
    qry_mail_proc_nao_fat              := TQuery.Create(Self);
    qry_mail_proc_nao_fat.DatabaseName := 'DBBROKER';


    qryAuxiliar              := TQuery.Create(Self);
    qryAuxiliar.DatabaseName := 'DBBROKER';

    try
      Excel      := CreateOLEObject('Excel.Application');
      try
        db_broker.Connected := True;
        xlWorkB    := Excel.Workbooks.Open( GetPath+'DAILY_FOLLOWUP.xls' );
        Excel.Visible := chkVisualizarExcel.checked;
        DecodeTime(now, Hour, min, sec, MSec);
        vTimeStamp := FormatDateTime('ddmmyyyy',now) + Copy('00',1,2-Length(IntToStr(Hour)))+IntToStr(Hour) + Copy('00',1,2-Length(IntToStr(min)))+IntToStr(min) + Copy('00',1,2-Length(IntToStr(sec)))+IntToStr(sec) + Copy('00',1,2-Length(IntToStr(MSec)))+IntToStr(MSec);

        oSheet := Excel.WorkBooks[1].Worksheets[1];

        with TQuery.Create(Self) do
        begin
          try
            DatabaseName := 'DBBROKER';
            // Produto
            SQL.Clear;
            SQL.Add('SELECT NM_PRODUTO FROM TPRODUTO ( NOLOCK ) WHERE CD_PRODUTO = ''' + pProduto + '''');
            Open;
            vNomeProduto := Copy(Fields[0].AsString,1,3);
            Close;

            // Importador
            SQL.Clear;
            SQL.Add('SELECT NM_EMPRESA FROM TEMPRESA_EST ( NOLOCK ) WHERE CD_EMPRESA = ''' + pImportador + '''');
            Open;
            oSheet.Cells[ 03, 04 ].value :=  ' ' + pImportador + ' - ' + Fields[0].AsString;
            Close;

            //busca o idioma do Importador
            SQL.Clear;
            SQL.Add(' select Isnull(P.CD_IDIOMA_PADRAO,"9") ');
            SQL.Add(' from TEMPRESA_EST E (NOLOCK) ');
            SQL.Add(' JOIN TPAIS P (NOLOCK) ON E.CD_PAIS=P.CODIGO ');
            SQL.Add(' where e.CD_EMPRESA="'+pImportador+'"');
            Open;
            vIdioma:=Fields[0].AsString;
            Close;

          finally
            Free;
          end;
        end;

        oSheet.Cells[ 04, 04 ].value :=  ' ' + FormatDateTime('mm/dd/yyyy',now);

        //--------------------------------------------------------------------------//
        // Busca o nome dos Eventos e Monta Cabeçalho
        // colunas fixas
        //--------------------------------------------------------------------------//
        vUlt_Col_Fixa  := 5;
        nLinha         := 9;
        nColuna        := vUlt_Col_Fixa;

        //coloca todas as colunas fixas em negrito
        for vNegrita:=2 to vUlt_Col_Fixa do begin
           oSheet.Cells[ nLinha, vNegrita ].Font.Bold := True;
        end;
        //
        if vIdioma='2' then begin
           oSheet.Cells[ nLinha, 02 ].value := 'Nr. Pedido';
//           oSheet.Cells[ nLinha, 03 ].value := 'Nr. Ordem';
           oSheet.Cells[ nLinha, 03 ].value := 'Contâineres';
//           oSheet.Cells[ nLinha, 05 ].value := 'Qtde. Volumes';
//           oSheet.Cells[ nLinha, 06 ].value := 'Mercadoria';
//           oSheet.Cells[ nLinha, 07 ].value := 'Qtde. Produtos';
           oSheet.Cells[ nLinha, 04 ].value := 'Navio';
           oSheet.Cells[ nLinha, 05 ].value := 'Booking';
        end else begin
           oSheet.Cells[ nLinha, 02 ].value := 'Customer Contract';
//           oSheet.Cells[ nLinha, 03 ].value := 'Customer Order';
           oSheet.Cells[ nLinha, 03 ].value := 'CNTR';
//           oSheet.Cells[ nLinha, 05 ].value := 'Packing';
//           oSheet.Cells[ nLinha, 06 ].value := 'Goods';
//           oSheet.Cells[ nLinha, 07 ].value := 'Quantities';
           oSheet.Cells[ nLinha, 04 ].value := 'Vessel';
           oSheet.Cells[ nLinha, 05 ].value := 'Booking';

        end;
        vTotalEventos := ContaOcorrencias(pEvento,';')+1;
        for i:=1 to vTotalEventos do begin
           str_CD_EVENTO:=Trim(ExtractWord(i,pEvento,';'));
           if str_CD_EVENTO<>'' then begin
              vQryEventos.SQL.Clear;
              vQryEventos.SQL.Add('Select ');
              if vIdioma='1' then
                 vQryEventos.SQL.Add('NM_INGLES')
              else if vIdioma='2' then
                 vQryEventos.SQL.Add('NM_ESPANHOL')
              else
                 vQryEventos.SQL.Add('NM_EVENTO');
              vQryEventos.SQL.Add(' from TEVENTO (NOLOCK) where CD_EVENTO="'+str_CD_EVENTO+'"');
              vQryEventos.Prepare;
              vQryEventos.Open;
              inc(nColuna);
              oSheet.Cells[ nLinha, nColuna ].EntireColumn.Insert;
              oSheet.Cells[ nLinha, nColuna ].Font.Bold           := True;
              oSheet.Cells[ nLinha, nColuna ].value               := vQryEventos.Fields[0].AsString;

           end;
        end;
//        inc(nColuna);
//        oSheet.Cells[ nLinha, nColuna ].value               := 'Obs';
        inc(nColuna);
        oSheet.Cells[ nLinha, nColuna ].value               := '(FILE) COMMERCIAL INVOICE';
        inc(nColuna);
        oSheet.Cells[ nLinha, nColuna ].value               := '(FILE) PACKING LIST';
        inc(nColuna);
        oSheet.Cells[ nLinha, nColuna ].value               := '(FILE) BILL OF LADING';
        inc(nColuna);
        oSheet.Cells[ nLinha, nColuna ].value               := '(FILE) PACOTE DE DOCUMENTOS';

        tem_dados:=True;

        { Busca os Processos Năo Faturados }
        with qry_mail_proc_nao_fat do
        begin
           SQL.Clear;
            SQL.Add ( ' SELECT   PR.NR_PROCESSO NR_PROCESSO,     ');
            SQL.Add ( '          ( SELECT MASTER.DBO.RowConcat( DISTINCT RTRIM(R.CD_REFERENCIA) + " / " ) FROM TREF_CLIENTE R (NOLOCK)  ');
            SQL.Add ( '            WHERE R.NR_PROCESSO=PR.NR_PROCESSO AND R.TP_REFERENCIA ="01" ) Nr_Pedido,   ');
            SQL.Add ( '          ( SELECT MASTER.DBO.RowConcat( DISTINCT RTRIM(R.CD_REFERENCIA) + " / " ) FROM TREF_CLIENTE R (NOLOCK)   ');
            SQL.Add ( '            WHERE R.NR_PROCESSO=PR.NR_PROCESSO AND R.TP_REFERENCIA ="02" ) Nr_Ordem,  ');
            SQL.Add ( '            (SELECT COUNT(VL_QTDE) FROM TPROCESSO_CARGA_SOLTA WHERE NR_PROCESSO =PR.NR_PROCESSO) Qtde_Volumes, ');
            SQL.Add ( '             ISNULL(F2.TX_OBS,"-") TX_OBS, ');
            SQL.Add ( '         isnull(E.NM_EMBARCACAO,"") NAVIO ,');
            SQL.Add ( '         isnull(RC.CD_REFERENCIA,"") REFERENCIA ,');
                   {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 07 (BACH MARK) }
            SQL.Add ( '         (SELECT top 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="+MASTER.DBO.FN_CRIPROGRAFA("docs_novo/"+d.nr_processo+"/"+d.NM_ARQUIVO) ');
            SQL.Add ( '         FROM TPROCESSO_DOCTOS d (NOLOCK) WHERE d.CD_TIPO_DOCTO IN (19) and d.ID_TABELA=1652005462  and  d.NR_PROCESSO = pr.NR_PROCESSO AND  d.in_ativo = "1"  and upper(right(rtrim(d.NM_ARQUIVO),3))="PDF"  ');
            SQL.Add ( '         ORDER BY CASE D.CD_TIPO_DOCTO WHEN 89 THEN 0 ELSE 1 END, D.DT_CRIACAO DESC ) Fatura_Comercial,  ');
                   {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 08 (INVOICE) }
            SQL.Add ( '         (SELECT top 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="+MASTER.DBO.FN_CRIPROGRAFA("docs_novo/"+d.nr_processo+"/"+d.NM_ARQUIVO) ');
            SQL.Add ( '         FROM TPROCESSO_DOCTOS d (NOLOCK) WHERE d.CD_TIPO_DOCTO=20 and d.ID_TABELA=1652005462  and  d.NR_PROCESSO = pr.NR_PROCESSO AND  d.in_ativo = "1"  and upper(right(rtrim(d.NM_ARQUIVO),3))="PDF"  ) Packing_List, ');
                   {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 09 (B/L) }
            SQL.Add ( '         (SELECT top 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="+MASTER.DBO.FN_CRIPROGRAFA("docs_novo/"+d.nr_processo+"/"+d.NM_ARQUIVO) ');
            SQL.Add ( '         FROM TPROCESSO_DOCTOS d (NOLOCK) WHERE d.CD_TIPO_DOCTO=70 and d.ID_TABELA=1652005462  and  d.NR_PROCESSO = pr.NR_PROCESSO AND  d.in_ativo = "1"  and upper(right(rtrim(d.NM_ARQUIVO),3))="PDF"  ) Conhecimento_Embarque,');
                               {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 21 (Certificado de Origem) }
            SQL.Add ( '         (SELECT top 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="+MASTER.DBO.FN_CRIPROGRAFA("docs_novo/"+d.nr_processo+"/"+d.NM_ARQUIVO) ');
            SQL.Add ( '         FROM TPROCESSO_DOCTOS d (NOLOCK) WHERE d.CD_TIPO_DOCTO=21 and d.ID_TABELA=1652005462  and  d.NR_PROCESSO = pr.NR_PROCESSO AND  d.in_ativo = "1"  and upper(right(rtrim(d.NM_ARQUIVO),3))="PDF"  ) Certificado_origem, ');
                   {  Lista de Documentos Digitalizados - Coluna Relacionada da Planilha = 22 (Pacote com diversos Documentos) }
            SQL.Add ( '         (SELECT top 1 "http://www.myindaiaweb.com.br/redireciona_doc.asp?cod="+MASTER.DBO.FN_CRIPROGRAFA("docs_novo/"+d.nr_processo+"/"+d.NM_ARQUIVO) ');
            SQL.Add ( '         FROM TPROCESSO_DOCTOS d (NOLOCK) WHERE d.CD_TIPO_DOCTO=22 and d.ID_TABELA=1652005462  and  d.NR_PROCESSO = pr.NR_PROCESSO AND  d.in_ativo = "1"  and upper(right(rtrim(d.NM_ARQUIVO),3))="PDF"  ) Pacote_doctos ');


            SQL.Add ( '         FROM   TPROCESSO PR (NOLOCK)     ');
            SQL.Add ( '         INNER JOIN TFOLLOWUP F  (NOLOCK) ON ( PR.NR_PROCESSO = F.NR_PROCESSO AND F.CD_EVENTO="092" ) ');
            SQL.Add ( '         INNER JOIN TFOLLOWUP F1 (NOLOCK) ON ( PR.NR_PROCESSO = F1.NR_PROCESSO AND F1.CD_EVENTO="314" AND F1.DT_REALIZACAO IS not NULL ) ');
            SQL.Add ( '         LEFT  JOIN TFOLLOWUP F2 (NOLOCK) ON ( PR.NR_PROCESSO = F2.NR_PROCESSO AND F2.CD_EVENTO="653" )  -- //OBS que passou para NOTE    ');
            SQL.Add ( '         LEFT JOIN TFOLLOWUP F3 (NOLOCK) ON ( PR.NR_PROCESSO = F3.NR_PROCESSO AND F3.CD_EVENTO="261" ) ');
            SQL.Add ( '         LEFT JOIN TFOLLOWUP F4 (NOLOCK) ON ( PR.NR_PROCESSO = F4.NR_PROCESSO AND F4.CD_EVENTO= "333" ) ');
            SQL.Add ( '         LEFT JOIN TFOLLOWUP F5 (NOLOCK) ON ( PR.NR_PROCESSO = F5.NR_PROCESSO AND F5.CD_EVENTO="132" ) ');
            SQL.Add ( '         LEFT JOIN TFOLLOWUP F6 (NOLOCK) ON ( PR.NR_PROCESSO = F6.NR_PROCESSO AND F6.CD_EVENTO="149" ) ');

            SQL.Add ( '         LEFT  JOIN TEMBARCACAO E (NOLOCK) ON PR.CD_EMBARCACAO = E.CD_EMBARCACAO  ');
            SQL.Add ( '         LEFT JOIN TREF_CLIENTE RC (NOLOCK) ON RC.NR_PROCESSO = PR.NR_PROCESSO AND TP_REFERENCIA = 05  ');

           SQL.Add ( ' WHERE PR.IN_CANCELADO  = "0" AND  PR.IN_LIBERADO   = "1" ');

           SQL.Add ( ' AND (( PR.CD_GRUPO IN ("C67","C54") AND ( ( PR.CD_SERVICO IN ("6","41") AND F6.DT_REALIZACAO IS NULL )            ');
           SQL.Add ( '      OR ( PR.CD_SERVICO NOT IN ("6","41") AND ( F4.DT_REALIZACAO IS NULL OR CONVERT(DATE,F4.DT_REALIZACAO) >= CONVERT(DATE,GETDATE()) ) ))) OR  ');

           SQL.Add ( '      ( PR.CD_GRUPO NOT IN ("C67","C54") AND  ');
           SQL.Add ( '      ( F.IN_APLICAVEL=1  AND  ( F.DT_REALIZACAO IS NULL  OR  CONVERT(DATE,F.DT_REALIZACAO,103) >= CONVERT(DATE,GETDATE()-45,103 ))) ');
           SQL.Add ( ' AND ( ( F6.IN_APLICAVEL="1" AND F6.DT_REALIZACAO IS NULL ) OR ( F4.IN_APLICAVEL="1" AND F4.DT_REALIZACAO IS NULL ) )) ) ');

           SQL.Add ( ' AND isnull(E.NM_EMBARCACAO,"")  not in ("* PROCESSO CANCELADO","TBN","AGUARDANDO NAVIO" )    ');
           if pProduto<>'' then
              SQL.Add ( ' AND  PR.CD_PRODUTO    = "' + pProduto + '" ');
           if pUnidade<>'' then
              SQL.Add ( ' AND  PR.CD_UNID_NEG   = "' + pUnidade + '" ');
           if pGrupo<>'' then
              SQL.Add ( ' AND  PR.CD_GRUPO      = "' + pGrupo   + '" ');
           if pImportador<>'' then
              SQL.Add ( ' AND  PR.CD_IMPORTADOR = "' + pImportador  + '" ');
           if pCliente <> '' then
            SQL.Add('  AND PR.CD_CLIENTE = "' + pCliente  + '"');
           if pTransportador <> '' then
            SQL.Add('  AND PR.CD_TRANSP_NAC = "' + pTransportador  + '"');
           SQL.Add ( ' order by f4.dt_realizacao,2 ');

          if not DirectoryExists(GetPath+'SQL') then
             ForceDirectories(GetPath+'SQL');
           try
             SQL.SaveToFile(GetPath+'SQL\' + pRelatorio + '.sql');
           except
           end;
           Open;
        end;
        tem_dados := False;
        qry_mail_proc_nao_fat.First;
        while not qry_mail_proc_nao_fat.Eof do
        begin
          tem_dados := True;
          nColuna   := vUlt_Col_Fixa;
          nLinha    := nLinha+1;

          strTmp:=qry_mail_proc_nao_fat.FieldByName('Nr_Pedido').AsString;
          strTmp:=copy(strTmp,1,length(strTmp)-2);
          oSheet.Cells[ nLinha, 02 ].value := strTmp;

         // oSheet.Cells[ nLinha, 03 ].value := qry_mail_proc_nao_fat.FieldByName('Nr_Ordem').AsString;
          IF qryAuxiliar.active then
            qryAuxiliar.Close;
          qryAuxiliar.SQL.Clear;
          qryAuxiliar.SQL.Add('SELECT NR_CNTR,(SELECT COUNT(VL_QTDE) FROM TPROCESSO_CARGA_SOLTA WHERE NR_PROCESSO =PC.NR_PROCESSO) QTDE');
          qryAuxiliar.SQL.Add('FROM TPROCESSO_CNTR PC (NOLOCK)');
          qryAuxiliar.SQL.Add('WHERE PC.NR_PROCESSO = :NR_PROCESSO');
          qryAuxiliar.ParamByName('NR_PROCESSO').AsString := qry_mail_proc_nao_fat.FieldByName('NR_PROCESSO').AsString;
          qryAuxiliar.Open;
          strTmp := '';
          QTDE :='';
          qryAuxiliar.First;
          while not qryAuxiliar.Eof do
          begin
            strTmp := strTmp + #10 + Trim(qryAuxiliar.FieldByName('NR_CNTR').AsString);
            QTDE := QTDE + #10 + Trim(qryAuxiliar.FieldByName('QTDE').AsString);
            qryAuxiliar.Next;
          end;
          Delete(strTmp, 1, 1);
          Delete(QTDE, 1, 1);
          oSheet.Cells[ nLinha, 03 ].value := strTmp;
         // oSheet.Cells[ nLinha, 05 ].value := QTDE;
         // if (strTmp <> '') and  (not TemContainer) then
         //   TemContainer := True;

         //IF qryAuxiliar.active then
         //   qryAuxiliar.Close;
         // qryAuxiliar.SQL.Clear;
         // qryAuxiliar.SQL.Add('SELECT  E.CD_MERCADORIA,CONVERT(VARCHAR,QT_MERCADORIA) +'' ''+ NM_UNID_MEDIDA  QT_MERCADORIA' );
         // qryAuxiliar.SQL.Add('FROM TPROCESSO_EXP_ITEM E');
         // qryAuxiliar.SQL.Add('   INNER JOIN TMERCADORIA_EXP M ON M.CD_MERCADORIA = E.CD_MERCADORIA ');
         // qryAuxiliar.SQL.Add('   INNER JOIN TUNID_MEDIDA_BROKER UN ON UN.CD_UNID_MEDIDA=E.CD_UNID_MEDIDA  ');
         // qryAuxiliar.SQL.Add('WHERE NR_PROCESSO = :NR_PROCESSO');
         // qryAuxiliar.ParamByName('NR_PROCESSO').AsString := qry_mail_proc_nao_fat.FieldByName('NR_PROCESSO').AsString;
         // qryAuxiliar.Open;
         // CD_MERCADORIA :='';
         // QT_MERCADORIA :='';
         // qryAuxiliar.First;
         // while not qryAuxiliar.Eof do
         // begin
         //   CD_MERCADORIA := CD_MERCADORIA + #10 + Trim(qryAuxiliar.FieldByName('CD_MERCADORIA').AsString);
         //   QT_MERCADORIA := QT_MERCADORIA + #10 + Trim(qryAuxiliar.FieldByName('QT_MERCADORIA').AsString);
         //   qryAuxiliar.Next;
         // end;
         // Delete(CD_MERCADORIA, 1, 1);
         // Delete(QT_MERCADORIA, 1, 1);
         // oSheet.Cells[ nLinha, 06 ].value := CD_MERCADORIA;
         // oSheet.Cells[ nLinha, 07 ].value := QT_MERCADORIA;
          oSheet.Cells[ nLinha, 04 ].value := qry_mail_proc_nao_fat.FieldByName('NAVIO').AsString;
          oSheet.Cells[ nLinha, 05 ].value := qry_mail_proc_nao_fat.FieldByName('REFERENCIA').AsString;

          nColuna :=5;
          for i:=1 to vTotalEventos do
          begin
              str_CD_EVENTO:=ExtractWord(i,pEvento,';');
              if str_CD_EVENTO<>'' then
              begin
                 with vQryEventos do begin
                    SQL.Clear;
                    SQL.Add ( ' SELECT CASE WHEN F.IN_APLICAVEL<>1 THEN "N/A" WHEN F.DT_REALIZACAO IS NULL THEN "TO BE CONFIRMED" ELSE CONVERT(VARCHAR,F.DT_REALIZACAO,103) END DT_REALIZACAO, convert(DateTime,Convert(varchar,isnull(F.DT_REALIZACAO_EFETIVA,0),103),103) '  );
                    SQL.Add ( ' FROM   TPROCESSO P (NOLOCK) ' );

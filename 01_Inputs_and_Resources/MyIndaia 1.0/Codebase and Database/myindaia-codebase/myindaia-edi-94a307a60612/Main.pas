function DETERMINA_EMPRESA_NAC : String;
Var
  Codigo,
  CNPJ : String;
begin
  Mensagem := False;
  CNPJ := copy(EDI.Linha, Count_Cardinal+3,14);
  with TQuery.Create(frmMain) do begin
    try
      SessionName := 'SES_EDI';
      DataBaseName := 'BROKER';
      SQL.Add('SELECT CD_EMPRESA, CD_GRUPO FROM TEMPRESA_NAC (NOLOCK) WHERE CGC_EMPRESA =' + QuotedSTR(CNPJ));
      Open;
      Codigo_De_Para := Fields[0].AsString;
      Grupo_De_Para  := Fields[1].AsString;
    finally
      Free;
    end;
  end;
  if Codigo_De_Para <> '' then
  begin
    if not(frmMain.Compara_De_Para) then
      frmMain.Cadastra_De_Para;
    Codigo := frmMain.Determina_Codigo_De_Para;
    Result := Codigo
  end
  else
    Result := '';
  if Codigo <> '' then
    Result := Codigo
  else
  begin
    VMSG('Exportador năo cadastrado.',msSystem,True);
    VMSG('O Processo será finalizado.',msSystem,True);
    EDI.NrLn := 0;
    Ocupado := 0;
    EDI.Texto.Clear;
    mensagem := True;
  end;
end;


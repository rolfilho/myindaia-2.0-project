function TFrmMain.RelEventosInspecionaveis(pUnidade, pProduto, pNivel, pGrupo, pUsuario, pRelatorio, pTipoPedido, pCelula, pHorario, pModal, pAnalista : string) : string;
var
  vPrimeiroEvento: string;
  vPrimeiroCliente: string;
  vMails: string;
  vLinhaZebrada: string;
  vClienteAnterior: string;
  pwAssunto: string;
  pwDestinatarios: string;
  pwRemetente: string;
  Body: TStrings;
begin
  Body := TStringList.Create;
  try
    Result := '';
    Body.Add('<html>');
    Body.Add('<body>');
    Body.Add('<table width=100% border=0 cellpadding="0" cellspacing="0">');
    with TQuery.Create(Self) do
    begin
      try
        SessionName := 'SES_EDI';
        DataBaseName := 'BROKER';
        vMails := '';
        SQL.Clear;
        SQL.Add('SELECT CONVERT(VARCHAR(MAX),USU.NM_EMAIL) NM_EMAIL');
        SQL.Add('  FROM TFILA_AGENDA AG (NOLOCK),');
        SQL.Add('       TUSUARIO USU    (NOLOCK)');
        SQL.Add(' WHERE AG.NM_PATH_EDI  LIKE ''%CD_RELATORIO="' + pRelatorio + '"%''');
        SQL.Add('   AND AG.PROXIMA_EXEC =    ''' + pHorario + '''');
        SQL.Add('   AND USU.CD_USUARIO  =    SUBSTRING(AG.NM_PATH_EDI,34,4)');
        Open;
        while not EOF do
        begin
          vMails := vMails + FieldByName('NM_EMAIL').AsString + ';';
          Next;
        end;
        Close;

        vPrimeiroCliente := '';
        vPrimeiroEvento  := '';
        if ( pTipoPedido <> '' ) or ( pCelula <> '' ) then
        begin
          Body.Add('    <tr height=5>');
          Body.Add('      <td colspan=6>');
          Body.Add('      </td>');
          Body.Add('    </tr>');
          if Trim(pTipoPedido) <> '' then
          begin
            Body.Add('    <tr height=7 border=0 bgcolor=white>');
            Body.Add('      <td colspan=6>');
            Body.Add('        <font size=2 color=black> <b>&nbsp; Tipo de Pedido : ' + ConsultaLookupSQL('SELECT NM_PEDIDO FROM TTP_PEDIDO (nolock) WHERE CD_PEDIDO = ''' + pTipoPedido + '''','NM_PEDIDO') + '</b> </font>');
            Body.Add('      </td>');
            Body.Add('    </tr>');
          end;
          if Trim(pCelula) <> '' then
          begin
            Body.Add('    <tr height=7 border=0 bgcolor=white>');
            Body.Add('      <td colspan=6>');
            Body.Add('        <font size=2 color=black> <b>&nbsp; Célula : ' + ConsultaLookupSQL('SELECT NM_CELULA FROM TCELULA (nolock) WHERE CD_CELULA = ''' + pCelula + '''','NM_CELULA') + '</b> </font>');
            Body.Add('      </td>');
            Body.Add('    </tr>');
          end;
          Body.Add('    <tr height=5>');
          Body.Add('      <td colspan=6>');
          Body.Add('      </td>');
          Body.Add('    </tr>');
        end;

        SQL.Clear;
        if StrToInt(pProduto) in [1, 2, 3, 10] then
          SQL.Add('SELECT  EV.NM_EVENTO, RTRIM(SUBSTRING(FU.NR_PROCESSO, 5, 14)) NR_PROCESSO, FU.DT_PREVISTA, DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) ''ATRASO'',');
        if pProduto = '06' then
          SQL.Add('SELECT  EV.NM_EVENTO, ( RTRIM(FU.NR_PROCESSO) + '' / '' + FU.NR_ITEM_CLIENTE + '' / '' + CONVERT(CHAR, FU.NR_PARCIAL,103)) NR_PROCESSO, (PI.QT_INICIAL) SALDO_DISPONIVEL,' +
                    '( FU2.DT_REALIZACAO + SE.PZ_DO_EV_BASICO ) ''DT_PREVISTA'', DATEDIFF(DAY,( FU2.DT_REALIZACAO + SE.PZ_DO_EV_BASICO ),GETDATE()) ''ATRASO'',');
        if pProduto = '01' then
        begin
          SQL.Add('	       CASE WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) <  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO2_IMP),1000)  THEN ''1''');
          SQL.Add('	            WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) <=  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO3_IMP),1000) THEN ''2''');
          SQL.Add('	            WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) >  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO3_IMP),1000)  THEN ''3''');
        end;
        if pProduto = '02' then
        begin
          SQL.Add('	       CASE WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) <  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO2),1000)  THEN ''1''');
          SQL.Add('	            WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) <=  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO3),1000) THEN ''2''');
          SQL.Add('	            WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) >  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO3),1000)  THEN ''3''');
        end;
        if pProduto = '03' then
        begin
          SQL.Add('	       CASE WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) <  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO1_FI_IMP),1000)  THEN ''1''');
          SQL.Add('	            WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) <=  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO2_FI_IMP),1000) THEN ''2''');
          SQL.Add('	            WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) >  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO3_FI_IMP),1000)  THEN ''3''');
        end;
        if pProduto = '06' then
        begin
          SQL.Add('	       CASE WHEN DATEDIFF(DAY,( FU2.DT_REALIZACAO + SE.PZ_DO_EV_BASICO ),GETDATE()) <  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO2_GP),1000)  THEN ''1''');
          SQL.Add('	            WHEN DATEDIFF(DAY,( FU2.DT_REALIZACAO + SE.PZ_DO_EV_BASICO ),GETDATE()) <=  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO3_GP),1000) THEN ''2''');
          SQL.Add('	            WHEN DATEDIFF(DAY,( FU2.DT_REALIZACAO + SE.PZ_DO_EV_BASICO ),GETDATE()) >  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO3_GP),1000)  THEN ''3''');
        end;
        if pProduto = '10' then
        begin
          SQL.Add('	       CASE WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) <  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO1_FI_EXP),1000)  THEN ''1''');
          SQL.Add('	            WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) <=  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO2_FI_EXP),1000) THEN ''2''');
          SQL.Add('	            WHEN DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) >  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO3_FI_EXP),1000)  THEN ''3''');
        end;
        SQL.Add('      	 END ''NIVEL'',');
        SQL.Add('	       GR.CD_GRUPO, GR.NM_GRUPO, ');
        if StrToInt(pProduto) in [1,2,3,10] then
          SQL.Add('	       SUBSTRING(PR.TX_MERCADORIA,1,30) TX_MERCADORIA,');
        if pProduto = '06' then
        begin
          SQL.Add('	       SUBSTRING(PI.TX_MERCADORIA,1,30) TX_MERCADORIA,');
          SQL.Add('	       ( SELECT NM_PAIS FROM TPAIS_BROKER (NOLOCK) WHERE CD_PAIS = PI.CD_PAIS_ORIGEM ) CD_PAIS_ORIGEM,')
        end
        else SQL.Add('	       ( SELECT NM_PAIS FROM TPAIS_BROKER (NOLOCK) WHERE CD_PAIS = PR.CD_PAIS_ORIGEM ) CD_PAIS_ORIGEM,');
        SQL.Add('	       ( SELECT NM_PAIS FROM TPAIS_BROKER (NOLOCK) WHERE CD_PAIS = PR.CD_PAIS_DESTINO ) CD_PAIS_DESTINO,');
        SQL.Add('	       AR.NM_AREA');

        if StrToInt(pProduto) in [3,10] then
        begin
          SQL.Add(' ,(SELECT TOP 1 CD_REFERENCIA FROM TREF_CLIENTE REF (NOLOCK) WHERE REF.NR_PROCESSO = PR.NR_PROCESSO AND TP_REFERENCIA = ''05'') AS BOOKING');
          SQL.Add(' ,(SELECT TOP 1 CD_REFERENCIA FROM TREF_CLIENTE REF (NOLOCK) WHERE REF.NR_PROCESSO = PR.NR_PROCESSO AND TP_REFERENCIA = ''12'') AS COTACAO');
        end;

        if StrToInt(pProduto) in [1] then
        begin
          SQL.Add('  , CONVERT (DATETIME, FU4.DT_REALIZACAO, 103) DT_PREV_EMBARQUE, CONVERT (DATETIME, FU5.DT_REALIZACAO, 103) DT_REAL_EMBARQUE, EMB.NM_EMBARCACAO ');
          SQL.Add('  FROM  TEVENTO EV (NOLOCK), /*TSERVICO_EVENTO SE (NOLOCK), */TFOLLOWUP FU (NOLOCK), TFOLLOWUP FU2 (NOLOCK), TPROCESSO PR (NOLOCK), ' );
          SQL.Add('        TGRUPO GR (NOLOCK), TAREA AR (NOLOCK), TFOLLOWUP FU3 (NOLOCK), TFOLLOWUP FU4 (NOLOCK), TFOLLOWUP FU5 (NOLOCK), TEMBARCACAO EMB (NOLOCK) ' );
        end;
        if StrToInt(pProduto) in [2,3,10] then
          SQL.Add('  FROM  TEVENTO EV (NOLOCK), /*TSERVICO_EVENTO SE (NOLOCK), */TFOLLOWUP FU (NOLOCK), TFOLLOWUP FU2 (NOLOCK), TPROCESSO PR (NOLOCK), TGRUPO GR (NOLOCK), TAREA AR (NOLOCK), TFOLLOWUP FU3 (NOLOCK)');
        if pProduto = '06' then
          SQL.Add('  FROM  TPO_ITEM PI ( NOLOCK), TEVENTO EV (NOLOCK), TSERVICO_EVENTO SE (NOLOCK), TFLP_PO_ITEM FU (NOLOCK), TFLP_PO_ITEM FU2 (NOLOCK), TPROCESSO PR (NOLOCK), TGRUPO GR (NOLOCK), TAREA AR (NOLOCK)');
        if pProduto = '01' then
          SQL.Add(' WHERE  EV.IN_INSPECIONAVEL_IMP = ''1'' AND FU.DT_PREVISTA < GETDATE()-EV.PRZ_INSPECAO1_IMP');
        if pProduto = '02' then
          SQL.Add(' WHERE  EV.IN_INSPECIONAVEL = ''1'' AND FU.DT_PREVISTA < GETDATE()-EV.PRZ_INSPECAO');
        if pProduto = '03' then
          SQL.Add(' WHERE  EV.IN_INSPECIONAVEL_FI_IMP = ''1'' AND FU.DT_PREVISTA < GETDATE()-EV.PRZ_INSPECAO1_FI_IMP');
        if pProduto = '06' then
          SQL.Add(' WHERE  EV.IN_INSPECIONAVEL_GP = ''1'' AND ( FU2.DT_REALIZACAO + SE.PZ_DO_EV_BASICO ) < GETDATE()-EV.PRZ_INSPECAO1_GP');
        if pProduto = '10' then
          SQL.Add(' WHERE  EV.IN_INSPECIONAVEL_FI_EXP = ''1'' AND  FU.DT_PREVISTA < GETDATE()-EV.PRZ_INSPECAO1_FI_EXP');
        SQL.Add('   AND  FU.CD_EVENTO = EV.CD_EVENTO');
        SQL.Add('   AND  FU.DT_REALIZACAO IS NULL');
        SQL.Add('   AND  FU.IN_APLICAVEL = ''1''');

        if pProduto = '01' then
        begin
          SQL.Add('   AND  (  ( DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE())     <  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO2_IMP ),1000)');
          SQL.Add('             AND PATINDEX(''%1%'',:INSPECAO) > 0 )');
          SQL.Add('        OR ( DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE())     < ISNULL(CONVERT(INT,EV.PRZ_INSPECAO3_IMP ),1000)');
          SQL.Add('             AND DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE()) >=  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO2_IMP ),1000)');
          SQL.Add('             AND PATINDEX(''%2%'',:INSPECAO) > 0 )');
          SQL.Add('        OR ( DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE())     >=  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO3_IMP ),1000)');
          SQL.Add('             AND PATINDEX(''%3%'',:INSPECAO) > 0 ) )');
          SQL.Add('   AND FU4.NR_PROCESSO = PR.NR_PROCESSO AND FU4.CD_EVENTO = ''161'' ');
          SQL.Add('   AND FU5.NR_PROCESSO = PR.NR_PROCESSO AND FU5.CD_EVENTO = ''162'' ');
          SQL.Add('   AND EMB.CD_EMBARCACAO = PR.CD_EMBARCACAO ');
        end;
        if pProduto = '02' then
        begin
          SQL.Add('   AND  (  ( DATEDIFF(DAY,FU.DT_PREVISTA,GETDATE())     <  ISNULL(CONVERT(INT,EV.PRZ_INSPECAO2 ),1000)');

end;

function TfrmMain.RelPlanilhaGenerica(pRelatorio, pTipo, pUnidade,
  pProduto, pTabelaOuSQL, pCampo, pPrazo, pSQLExtra,
  pCamposNomes: String): string;
var
  db_broker                     : TDatabase;
  qry_mail_proc_nao_fat         : TQuery;
  Excel, xlWorkB, oSheet        : OleVariant;
  nLinha, vPrimeiraLinha, vCont, i : Integer;
  vValorTotalServico            : Real;
  Valor : Double;
  Data  : TDateTime;
  vMes, vDia              : Word;
  vTimeStamp, vNomeProduto, vDataAux,a : string;
  Hour, min, sec, MSec          : Word;
  vCampoChave, vCamposHidden : Integer;
begin
  try
    vImprimindoPrevistosHoje := False;
    db_broker:= TDatabase.Create(Self);
    with db_broker do
    begin
      AliasName := 'BROKER';
      DatabaseName := 'DBBROKER';
      LoginPrompt := False;
      Params.Add('USER NAME=MYROBO');
      Params.Add('PASSWORD=123');
    end;

    try
      db_broker.Connected := True;

      with TQuery.Create(Self) do
      begin
        try
          DatabaseName := 'DBBROKER';
          SQL.Clear;
          if pTipo = '0' then
          begin
            SQL.Add('SELECT ');
            for i := 1 to ContaOcorrencias(pCamposNomes,';') do
            begin
              if Copy(ExtractWord(i,pCamposNomes,';'),1,6) = '*cons*' then
                SQL.Add('       "CONSULTA" "CONSULTA' + ExtractWord(2, Copy(ExtractWord(i,pCamposNomes,';'),Pos(')',ExtractWord(i,pCamposNomes,';'))+1,Length(ExtractWord(i,pCamposNomes,';')) ) ,'"') + '",')
              else
              if Copy(ExtractWord(i,pCamposNomes,';'),1,1) = '#' then
              begin
                SQL.Add('       ' + Trim(Copy(ExtractWord(i,pCamposNomes,';'),2,30)) + ',');
                vCampoChave := i;
              end
              else SQL.Add('       ' + ExtractWord(i,pCamposNomes,';') + ',');
            end;
            SQL.Add('       CONVERT(DATETIME, ' + pCampo + ' + ' + pPrazo + ' ,103) "Data Prevista",');
            SQL.Add('       DATEDIFF( d , ' + pCampo + ' + ' + pPrazo + ' , GETDATE() ) "Variaçăo"');
            SQL.Add('  FROM ' + pTabelaOuSQL + '  ( NOLOCK) ');
            SQL.Add(' WHERE DATEDIFF( d , ' + pCampo + ' , GETDATE() ) > ' + pPrazo + ' - 4 ');
            SQL.Add(ExtractWord(1,pSQLExtra,'/'));
            if pUnidade <> '' then
              SQL.Add('  AND SUBSTRING(NR_PROCESSO,1,2) = ''' + pUnidade + '''');
            if pProduto <> '' then
              SQL.Add('  AND SUBSTRING(NR_PROCESSO,3,2) = ''' + pProduto + '''');
            SQL.Add(' ORDER BY DATEDIFF( d , ' + pCampo + ' + ' + pPrazo + ' , GETDATE() ) DESC ');
          end
          else
          begin
            SQL.Text := pTabelaOuSQL;
          end;
          sql.savetofile('c:\txt.txt');
          Open;

          try
            Excel      := CreateOLEObject('Excel.Application');
            Excel.Visible := chkVisualizarExcel.checked;
            xlWorkB    := Excel.Workbooks.Add;
            DecodeTime(now, Hour, min, sec, MSec);
            vTimeStamp := FormatDateTime('ddmmyyyyhhnnss', Now);

            oSheet := Excel.WorkBooks[1].Worksheets[1];

            nLinha := 1;

            vCamposHidden := 0;
            for i := 0 to Fields.Count - 1 do
            begin
              if i = vCampoChave-1 then
              begin
                vCamposHidden := vCamposHidden + 1;
                continue;
              end;
              if Copy(Fields[i].FieldName,1,8) = 'CONSULTA' then
                oSheet.Cells[ nLinha, i+1-vCamposHidden ].value := Copy(Fields[i].FieldName,9,Length(Fields[i].FieldName))
              else
              if UpperCase(Copy(Fields[i].FieldName,1,2)) = 'F!' then
                oSheet.Cells[ nLinha, i+1-vCamposHidden ].value := Trim(Copy(Fields[i].FieldName,Pos('>',Fields[i].FieldName)+1,Length(Fields[i].FieldName)))
              else oSheet.Cells[ nLinha, i+1-vCamposHidden ].value := Fields[i].FieldName;

              oSheet.Cells[ nLinha, i+1 ].Font.Bold := True;
              oSheet.Cells[ nLinha, i+1 ].Interior.ColorIndex := 33;
            end;
            nLinha := nLinha + 1;

            while not EOF do
            begin
              vCamposHidden := 0;
              for i := 0 to Fields.Count - 1 do
              begin
                if i = vCampoChave-1 then
                begin
                  vCamposHidden := vCamposHidden + 1;
                  continue;
                end;

                oSheet.Cells[ nLinha, i+1-vCamposHidden ].NumberFormat := '@';

                if (Fields[i].DataType in [ftSmallint, ftInteger, ftWord, ftLargeint, ftBytes, ftFloat, ftCurrency]) and TryStrToFloat(Fields[i].AsString, Valor) then
                begin
                  if Fields[i].DataType in [ftSmallint, ftInteger, ftWord, ftLargeint, ftBytes] then
                    oSheet.Cells[ nLinha, i+1-vCamposHidden ].NumberFormat := '0'
                  else
                    oSheet.Cells[ nLinha, i+1-vCamposHidden ].NumberFormat := '0' + FormatSettings.DecimalSeparator + '00';
                  oSheet.Cells[ nLinha, i+1-vCamposHidden ].value := Valor;
                end
                else
                begin
                  //Acrecentado para formatar o fild se for data (Andressa)
                  if Fields[i].DataType in [ftDate,ftTime,ftDateTime] then
                  begin
                    a:= frmMain.FORMATAR_DATA(Fields[i].AsString, 'P') +  '  ';
                    oSheet.Cells[ nLinha, i+1-vCamposHidden ].value := '''' + a;
                  end
                  else
                   oSheet.Cells[ nLinha, i+1-vCamposHidden ].value := Fields[i].AsString;
                end;
                a:= Fields[i].AsString;
                continue;
              end;
              Next;
              nLinha := nLinha + 1;
            end;

            nLinha := nLinha + 1;
            for i := 0 to Fields.Count - 1 do
              oSheet.Columns[i+1].EntireColumn.AutoFit;
            Close;

            if FileExists(GetPath+'Gerados\Planilha_' + vTimeStamp + '.XLS') then
              SysUtils.DeleteFile(GetPath+'Gerados\Planilha_' + vTimeStamp + '.XLS');
            Excel.ActiveWorkBook.SaveAs(GetPath+'Gerados\Planilha_' + vTimeStamp + '.XLS');
          //  Excel.ActiveWorkBook.Save;
            Result := GetPath+'Gerados\Planilha_' + vTimeStamp + '.XLS';

          finally
            Excel.ActiveWorkBook.Close(False);
            KillExcel(Excel);
          end;
        finally
          Free;
        end;
      end;
    finally
      db_broker.Free;
    end;
  except
    on e:Exception do
      VMsg('Erro - RelPlanilhaGenerica: ' +e.message, msError, True);
  end;
end;


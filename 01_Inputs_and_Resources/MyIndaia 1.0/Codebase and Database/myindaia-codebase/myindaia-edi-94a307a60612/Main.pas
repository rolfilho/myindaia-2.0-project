function TfrmMain.RelCargil(pUnidade, pProduto, pGrupo, pCliente, pArea,
  pEvento, pRelatorio, pHorario: String): String;
var
  db_broker                                              : TDatabase;
  qryCargil : TFDQuery;
  Excel, xlWorkB, oSheet                                 : OleVariant;
  nLinha, Coluna, ctLinha, nColuna,
  vPrimeiraLinha, vCont,i,x,vTotalEventos                : Integer;
  vTimeStamp                                             : string;
  tem_dados                                              : boolean;
  mDados : TFDMemTable;

  procedure PreencheData(ALinha, AColuna: Integer; Data: string);
  begin
    oSheet.Cells[ ALinha, AColuna ].NumberFormat        := 'dd/mm/aaaa';
    oSheet.Cells[ ALinha, AColuna ].HorizontalAlignment := 3;

    if (Data <> 'N/A') and (trim(Data) <> '') then
    begin
      oSheet.Cells[ ALinha, AColuna ].Value := StrToDate(Data)//FormatDateTime('dd/mm/yyyy', Data)
    end
    else
      oSheet.Cells[ ALinha, AColuna ].Value := Data;
  end;

begin

  if Screen.ActiveForm is TfrmGeraRelatorio then
    ShowMessage('Este relatório está configurado para ser emitido apenas segundas-feiras. Este e-mail de teste será enviado normalmente.')
  else
  if not (dayofweek(now)  in [2]) then {apenas nas segundas}
    exit;

  db_broker:= TDatabase.Create(Self);
  db_broker.AliasName    := 'BROKER';
  db_broker.DatabaseName := 'DBBROKER';
  db_broker.LoginPrompt  := False;
  db_broker.Params.Add('USER NAME=MYROBO');
  db_broker.Params.Add('PASSWORD=123');

  qryCargil            := TFDQuery.Create(Self);
  qryCargil.Connection := FDConnection;

  try

    Excel   := CreateOLEObject('Excel.Application');
    try
      db_broker.Connected := True;

      xlWorkB       := Excel.Workbooks.Open(GetPath+'CargilIntegracaoSap.xlsx');
      Excel.Visible := chkVisualizarExcel.checked;
      vTimeStamp    := FormatDateTime('ddmmyyyyhhnnsszz', Now);

      try
        oSheet := Excel.WorkBooks[1].Worksheets[1];

        try
          qryCargil.Close;
          qryCargil.SQL.Clear;

          {$region 'Sql'}
          qryCargil.SQL.Text :=
            'SELECT * FROM ( ' + sLineBreak +
            '  SELECT ' + sLineBreak +
            '  TP.NR_PROCESSO, ''0'' AS NR_ITEM_PO, ' + sLineBreak +
            '  ''H'' AS [A] ' + sLineBreak +
            '  ,NULL AS [B] ' + sLineBreak +
            '  ,Cast(ISNULL(STUFF((SELECT DISTINCT '','' + LTRIM(RTRIM(R.CD_REFERENCIA)) ' + sLineBreak +
            '                      FROM BROKER.DBO.TREF_CLIENTE R WITH (NOLOCK) ' + sLineBreak +
            '                      WHERE R.NR_PROCESSO = TP.NR_PROCESSO AND R.TP_REFERENCIA = ''02'' ' + sLineBreak +
            '                      FOR XML PATH('''')), 1, 1, ''''), '''') as Varchar(300)) AS [C] ' + sLineBreak +
            '  ,YEAR(TP.DT_ABERTURA) AS [D] ' + sLineBreak +
            '  ,CASE ' + sLineBreak +
            '  WHEN TP.CD_CANAL = 0 THEN ''RED'' ' + sLineBreak +
            '  WHEN TP.CD_CANAL = 1 THEN ''YEL'' ' + sLineBreak +
            '  WHEN TP.CD_CANAL = 2 THEN ''GRE'' ' + sLineBreak +
            '  WHEN TP.CD_CANAL = 3 THEN ''CIN'' ' + sLineBreak +
            '  END AS [E] ' + sLineBreak +
            '  ,NULL AS [F] ' + sLineBreak +
            '  ,TP.NR_DI AS [G] ' + sLineBreak +
            '  ,PP.NM_SIGLA_2L AS [H] ' + sLineBreak +
            '  ,DI.CD_TIPO_DECLARACAO AS [I] ' + sLineBreak +
            '  ,SUBSTRING(EN.CGC_EMPRESA,1,2)+''.''+SUBSTRING(EN.CGC_EMPRESA,3,3)+''.''+SUBSTRING(EN.CGC_EMPRESA,6,3)+''/''+SUBSTRING(EN.CGC_EMPRESA,9,4)+''-''+SUBSTRING(EN.CGC_EMPRESA,13,2) AS [J] ' + sLineBreak +
            '  ,NULL AS [K] ' + sLineBreak +
            '  ,CAST(DI.VL_TOT_MLE_MNEG AS NUMERIC(15,2)) AS [L] ' + sLineBreak +
            '  ,MB.AP_MOEDA AS [M] ' + sLineBreak +
            '  ,CAST(DI.TX_MLE AS NUMERIC(15,4)) AS [N] ' + sLineBreak +
            '  ,CASE ' + sLineBreak +
            '  WHEN DI.VL_TOT_FRT_COLLECT = 0 THEN CAST(DI.VL_TOT_FRT_PREPAID AS NUMERIC(15,2)) ' + sLineBreak +
            '  ELSE CAST(DI.VL_TOT_FRT_COLLECT AS NUMERIC(15,2)) END AS [O] ' + sLineBreak +
            '  ,MF.AP_MOEDA AS [P] ' + sLineBreak +
            '  ,CAST(DI.VL_TOT_SEGURO_MNEG AS NUMERIC(15,2)) AS [Q] ' + sLineBreak +
            '  ,MS.AP_MOEDA AS [R] ' + sLineBreak +
            '  ,CAST((SELECT SUM(VL_MOEDA) ' + sLineBreak +
            '                 FROM BROKER.DBO.TACRESCIMO_DEDUCAO AD (NOLOCK) ' + sLineBreak +
            '                 WHERE AD.NR_PROCESSO = TP.NR_PROCESSO AND TP_DESPESA=''A'') AS NUMERIC(15,2)) AS [S] ' + sLineBreak +
            '  ,MA.AP_MOEDA AS [T] ' + sLineBreak +
            '  ,CAST((SELECT CASE WHEN SUM(VL_AFRMM_ITEM)=0 THEN NULL ELSE SUM(VL_AFRMM_ITEM) END FROM BROKER.DBO.TDETALHE_MERCADORIA DM (NOLOCK) WHERE DM.NR_PROCESSO = TP.NR_PROCESSO) AS NUMERIC(15,2)) AS [U] ' + sLineBreak +
            '  ,(SELECT CASE WHEN SUM(VL_AFRMM_ITEM)=0 THEN NULL ELSE ''BRL'' END FROM BROKER.DBO.TDETALHE_MERCADORIA DM (NOLOCK) WHERE DM.NR_PROCESSO = TP.NR_PROCESSO) AS [V] ' + sLineBreak +
            '  ,NULL AS [W] ' + sLineBreak +
            '  ,NULL AS [X] ' + sLineBreak +
            '  ,CONVERT(VARCHAR(10),DI.DT_DI,104) AS [Y] ' + sLineBreak +
            '  ,CONVERT(VARCHAR(10),EV088.DT_REALIZACAO,104) AS [Z] ' + sLineBreak +
            '  ,NULL AS [AA] ' + sLineBreak +
            '  ,NULL AS [AB] ' + sLineBreak +
            '  ,NULL AS [AC] ' + sLineBreak +
            '  ,NULL AS [AD] ' + sLineBreak +
            '  ,NULL AS [AE] ' + sLineBreak +
            '  ,NULL AS [AF] ' + sLineBreak +
            '  ,NULL AS [AG] ' + sLineBreak +
            '  ,NULL AS [AH] ' + sLineBreak +
            '  ,NULL AS [AI] ' + sLineBreak +
            '  ,NULL AS [AJ] ' + sLineBreak +
            '  ,NULL AS [AK] ' + sLineBreak +
            '  ,NULL AS [AL] ' + sLineBreak +
            '  ,NULL AS [AM] ' + sLineBreak +
            '  ,NULL AS [AN] ' + sLineBreak +
            '  ,NULL AS [AO] ' + sLineBreak +
            '  ,NULL AS [AP] ' + sLineBreak +
            '  ,NULL AS [AQ] ' + sLineBreak +
            '  ,NULL AS [AR] ' + sLineBreak +
            '  ,NULL AS [AS] ' + sLineBreak +
            '  ,NULL AS [AT] ' + sLineBreak +
            '  ,NULL AS [AU] ' + sLineBreak +
            '  ,NULL AS [AV] ' + sLineBreak +
            '  ,NULL AS [AW] ' + sLineBreak +
            '  ,NULL AS [AX] ' + sLineBreak +
            '  ,NULL AS [AY] ' + sLineBreak +
            '  ,NULL AS [AZ] ' + sLineBreak +
            '  ,NULL AS [BA] ' + sLineBreak +
            '  ,NULL AS [BB] ' + sLineBreak +
            '  ,NULL AS [BC] ' + sLineBreak +
            '  ,NULL AS [BD] ' + sLineBreak +
            '  ,NULL AS [BE] ' + sLineBreak +
            '  FROM BROKER.DBO.TPROCESSO TP (NOLOCK) ' + sLineBreak +
            '  INNER JOIN BROKER.DBO.TEMPRESA_NAC EN (NOLOCK) ON EN.CD_EMPRESA = TP.CD_CLIENTE ' + sLineBreak +
            '  LEFT JOIN BROKER.DBO.TFOLLOWUP EV021 (NOLOCK) ON EV021.NR_PROCESSO = TP.NR_PROCESSO AND EV021.CD_EVENTO=''021'' ' + sLineBreak +
            '  LEFT JOIN BROKER.DBO.TDECLARACAO_IMPORTACAO DI (NOLOCK) ON DI.NR_PROCESSO = TP.NR_PROCESSO ' + sLineBreak +
            '  LEFT JOIN BROKER.DBO.TPAIS_BROKER PP (NOLOCK) ON PP.CD_PAIS = DI.CD_PAIS_PROC_CARGA ' + sLineBreak +
            '  LEFT JOIN BROKER.DBO.TMOEDA_BROKER MB (NOLOCK) ON MB.CD_MOEDA = DI.CD_MOEDA_MLE ' + sLineBreak +
            '  LEFT JOIN BROKER.DBO.TMOEDA_BROKER MF (NOLOCK) ON MF.CD_MOEDA = DI.CD_MOEDA_FRETE ' + sLineBreak +
            '  LEFT JOIN BROKER.DBO.TMOEDA_BROKER MS (NOLOCK) ON MS.CD_MOEDA = DI.CD_MOEDA_SEGURO ' + sLineBreak +
            '  LEFT JOIN BROKER.DBO.TMOEDA_BROKER MA (NOLOCK) ON MA.CD_MOEDA = (SELECT CD_MOEDA FROM BROKER.DBO.TACRESCIMO_DEDUCAO AD (NOLOCK) WHERE AD.NR_PROCESSO = TP.NR_PROCESSO AND TP_DESPESA=''A'') ' + sLineBreak +
            '  LEFT JOIN BROKER.DBO.TFOLLOWUP EV088 (NOLOCK) ON EV088.NR_PROCESSO = TP.NR_PROCESSO AND EV088.CD_EVENTO=''088'' ' + sLineBreak +
            '  WHERE EV021.DT_REALIZACAO > GETDATE()-10 AND ' + sLineBreak +
            '  EV021.DT_REALIZACAO IS NOT NULL AND (EV021.IN_EDI_ENVIADO IS NULL OR EV021.IN_EDI_ENVIADO=''0'') ' + sLineBreak +
            '  AND TP.CD_GRUPO=''B58'' ' + sLineBreak +
            '  AND TP.CD_PRODUTO=''01'' ' + sLineBreak +
            '  AND TP.CD_AREA=''HN'' ' + sLineBreak +

            '  UNION ALL ' + sLineBreak +

            '  SELECT ' + sLineBreak +
            '  TP.NR_PROCESSO, DM.NR_ITEM_PO, ' + sLineBreak +
            '  ''D'' AS [A] ' + sLineBreak +
            '  ,NULL AS [B] ' + sLineBreak +
            '  ,NULL AS [C] ' + sLineBreak +
            '  ,NULL AS [D] ' + sLineBreak +
            '  ,NULL AS [E] ' + sLineBreak +
            '  ,NULL AS [F] ' + sLineBreak +
            '  ,NULL AS [G] ' + sLineBreak +
            '  ,NULL AS [H] ' + sLineBreak +
            '  ,NULL AS [I] ' + sLineBreak +
            '  ,NULL AS [J] ' + sLineBreak +
            '  ,NULL AS [K] ' + sLineBreak +
            '  ,NULL AS [L] ' + sLineBreak +
            '  ,NULL AS [M] ' + sLineBreak +
            '  ,NULL AS [N] ' + sLineBreak +
            '  ,NULL AS [O] ' + sLineBreak +
            '  ,NULL AS [P] ' + sLineBreak +
            '  ,NULL AS [Q] ' + sLineBreak +
            '  ,NULL AS [R] ' + sLineBreak +
            '  ,NULL AS [S] ' + sLineBreak +
            '  ,NULL AS [T] ' + sLineBreak +
            '  ,NULL AS [U] ' + sLineBreak +
            '  ,NULL AS [V] ' + sLineBreak +
            '  ,NULL AS [W] ' + sLineBreak +
            '  ,NULL AS [X] ' + sLineBreak +
            '  ,NULL AS [Y] ' + sLineBreak +
            '  ,NULL AS [Z] ' + sLineBreak +
            '  ,DM.NR_ITEM_PO AS [AA] ' + sLineBreak +
            '  ,NULL AS [AB] ' + sLineBreak +
            '  ,CAST(DM.PL_MERCADORIA AS NUMERIC(15,3)) AS [AC] ' + sLineBreak +
            '  ,''KG'' AS [AD] ' + sLineBreak +

var
  db_broker                                              : TDatabase;
  qryDUEsAverbadas : TFDQuery;
  Excel, xlWorkB, oSheet                                 : OleVariant;
  nLinha, Coluna, ctLinha, nColuna,
  vPrimeiraLinha, vCont,i,x,vTotalEventos                : Integer;
  vTimeStamp                                             : string;
  tem_dados                                              : boolean;
  mDados : TFDMemTable;

  procedure PreencheData(ALinha, AColuna: Integer; Data: string);
  begin
    oSheet.Cells[ ALinha, AColuna ].NumberFormat        := 'dd/mm/aaaa';
    oSheet.Cells[ ALinha, AColuna ].HorizontalAlignment := 3;

    if (Data <> 'N/A') and (trim(Data) <> '') then
    begin
      oSheet.Cells[ ALinha, AColuna ].Value := StrToDate(Data)//FormatDateTime('dd/mm/yyyy', Data)
    end
    else
      oSheet.Cells[ ALinha, AColuna ].Value := Data;
  end;

begin

  if Screen.ActiveForm is TfrmGeraRelatorio then
    ShowMessage('Este relatório está configurado para ser emitido apenas segunda-feira. Este e-mail de teste será enviado normalmente.')
  else
  if not (dayofweek(now)  in [2]) then {apenas nas segundas}
    exit;

  db_broker:= TDatabase.Create(Self);
  db_broker.AliasName    := 'BROKER';
  db_broker.DatabaseName := 'DBBROKER';
  db_broker.LoginPrompt  := False;
  db_broker.Params.Add('USER NAME=MYROBO');
  db_broker.Params.Add('PASSWORD=123');

  qryDUEsAverbadas            := TFDQuery.Create(Self);
  qryDUEsAverbadas.Connection := FDConnection;

  try

    Excel   := CreateOLEObject('Excel.Application');
    try
      db_broker.Connected := True;

      xlWorkB       := Excel.Workbooks.Open(GetPath+'DUEsAverbadas.xlsx');
      Excel.Visible := chkVisualizarExcel.checked;
      vTimeStamp    := FormatDateTime('ddmmyyyyhhnnsszz', Now);

      try
        oSheet := Excel.WorkBooks[1].Worksheets[1];

        try
          qryDUEsAverbadas.Close;
          qryDUEsAverbadas.SQL.Clear;

          {$region 'Sql'}
          qryDUEsAverbadas.SQL.Text :=
            ' SELECT ' + sLineBreak +
            ' RC.CD_REFERENCIA AS A,--[Nr. Fatura], ' + sLineBreak +
            ' CONVERT(VARCHAR(10),EV132.DT_REALIZACAO,103) AS B, --[Saída Navio/Aviăo/Caminhăo], ' + sLineBreak +
            ' CONVERT(VARCHAR(10),EV141.DT_REALIZACAO,103) AS C  --[Averbaçăo]  ' + sLineBreak +
            ' FROM BROKER.DBO.TPROCESSO TP (NOLOCK) ' + sLineBreak +
            ' LEFT JOIN BROKER.DBO.TREF_CLIENTE RC (NOLOCK) ON RC.NR_PROCESSO = TP.NR_PROCESSO AND RC.TP_REFERENCIA=''21''     ' + sLineBreak +
            ' LEFT JOIN BROKER.DBO.TFOLLOWUP EV132 (NOLOCK) ON EV132.NR_PROCESSO = TP.NR_PROCESSO AND EV132.CD_EVENTO=''132''   ' + sLineBreak +
            ' LEFT JOIN BROKER.DBO.TFOLLOWUP EV141 (NOLOCK) ON EV141.NR_PROCESSO = TP.NR_PROCESSO AND EV141.CD_EVENTO=''141''   ' + sLineBreak +
            ' WHERE TP.CD_GRUPO = ''C22''  ' + sLineBreak +
            ' AND TP.CD_PRODUTO=''02''    ' + sLineBreak +
            ' AND EV141.DT_REALIZACAO >= GETDATE()-7 ';
          {$endregion}

          if not DirectoryExists(GetPath+'SQL') then
            ForceDirectories(GetPath+'SQL');

          try
            qryDUEsAverbadas.SQL.SaveToFile(GetPath+'SQL\' + pRelatorio + '.sql');
          except
          end;

          qryDUEsAverbadas.Open;

        except
          on e:Exception do
          begin
            VMsg('Erro - 1 Relatório Cargil: ' + e.Message, msError, True);
          end
        end;

       mdados := TFDMemTable.Create(nil);
       qryDUEsAverbadas.FetchAll;
       mdados.Data := qryDUEsAverbadas.Data;

       qryDUEsAverbadas.Close;

       try
          tem_dados := False;
          nLinha := 1;
          mdados.First;
          while not mdados.Eof do
          begin
            tem_dados := True;
            nLinha    := nLinha +1;
            Coluna := 0;

            oSheet.Cells[ nLinha, MyInc(Coluna)].Value := mdados.FieldByName('A').AsString;
            oSheet.Cells[ nLinha, MyInc(Coluna)].Value := mdados.FieldByName('B').AsString;
            oSheet.Cells[ nLinha, MyInc(Coluna)].Value := mdados.FieldByName('C').AsString;
            mdados.Next;
          end;

        except
          on e:Exception do
          begin
            VMsg('Erro - 2 Relatório DUEs Averbadas: ' + e.Message, msError, True);
          end
        end;
      finally
        Excel.Visible := chkVisualizarExcel.checked;
        if FileExists(GetPath+'Gerados\RelatorioDUEsAverbadas_' + vTimeStamp + '.XLS') then
          SysUtils.DeleteFile(GetPath+'Gerados\RelatorioDUEsAverbadas_' + vTimeStamp + '.XLS');

        Excel.ActiveWorkBook.SaveAs(GetPath+'Gerados\RelatorioDUEsAverbadas_' + vTimeStamp + '.XLS');
      end;

      if tem_dados then
         Result := GetPath+'Gerados\RelatorioDUEsAverbadas_' + vTimeStamp + '.XLS'
      else
         Result := 'Sem Dados';
    finally
      try
        Excel.ActiveWorkBook.Close(False);
        KillExcel(Excel);
      except
      end;
    end;

  finally
    mdados.Free;
    FreeAndNil(qryDUEsAverbadas);
    FreeAndNil(db_broker);
  end;
end;



function TfrmMain.RelConfirmacaoRealizacao( vCdrelatorio: String ) : Boolean; //andre;
var
  Word : Variant;
  vWord : THandle;
  FileName : OleVariant;

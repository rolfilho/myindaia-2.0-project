Function TFrmMain.RelPrevisaoGeral(pUnidade, pProduto, pEvento, pArea, pSubArea, pCliente, pGrupo, pAtendente, pCelula, pModal : string) : String;
const
  _SQL: array[1..3] of String = (' SELECT DISTINCT MP.*, ' +
                                 '                 G.NM_GRUPO, ' +
                                 '                 P.CD_CELULA, ' +
                                 '                 ISNULL((SELECT U.NM_USUARIO ' +
                                 '                  FROM TCLIENTE_HABILITACAO CH ' +
                                 '                     LEFT JOIN TUSUARIO U ON U.CD_USUARIO = CH.CD_ATENDENTE ' +
                                 '                  WHERE CH.CD_CLIENTE = P.CD_CLIENTE ' +
                                 '                    AND CH.CD_UNID_NEG = P.CD_UNID_NEG ' +
                                 '                    AND CH.CD_PRODUTO = P.CD_PRODUTO ' +
                                 '                    AND CH.IN_ATIVO = ''1''), '' '') AS NM_ATENDENTE ' +
                                 ' FROM TMAIL_PENDENTES    MP (NOLOCK) ' +
                                 '    INNER JOIN TPROCESSO P  (NOLOCK) ON P.NR_PROCESSO = MP.NR_PROCESSO ' +
                                 '    INNER JOIN TGRUPO    G  (NOLOCK) ON G.CD_GRUPO = P.CD_GRUPO ' +
                                 ' WHERE STATUS = ''-'' ' +
                                 '   AND ATRASO > 0 ' +
                                 ' ORDER BY ATRASO DESC',


                                 ' SELECT DISTINCT MP.*, ' +
                                 '                 G.NM_GRUPO, ' +
                                 '                 P.CD_CELULA, ' +
                                 '                 ISNULL((SELECT U.NM_USUARIO ' +
                                 '                  FROM TCLIENTE_HABILITACAO CH ' +
                                 '                     LEFT JOIN TUSUARIO U ON U.CD_USUARIO = CH.CD_ATENDENTE ' +
                                 '                  WHERE CH.CD_CLIENTE = P.CD_CLIENTE ' +
                                 '                    AND CH.CD_UNID_NEG = P.CD_UNID_NEG ' +
                                 '                    AND CH.CD_PRODUTO = P.CD_PRODUTO ' +
                                 '                    AND CH.IN_ATIVO = ''1''), '' '') AS NM_ATENDENTE ' +
                                 ' FROM TMAIL_PENDENTES    MP (NOLOCK) ' +
                                 '    INNER JOIN TPROCESSO P  (NOLOCK) ON P.NR_PROCESSO = MP.NR_PROCESSO ' +
                                 '    INNER JOIN TGRUPO    G  (NOLOCK) ON G.CD_GRUPO = P.CD_GRUPO ' +
                                 ' WHERE STATUS = ''-'' ' +
                                 '   AND ATRASO = 0 ' +
                                 ' ORDER BY ATRASO DESC',

                                 ' SELECT DISTINCT MP.*, ' +
                                 '                 G.NM_GRUPO, ' +
                                 '                 P.CD_CELULA, ' +
                                 '                 ISNULL((SELECT U.NM_USUARIO ' +
                                 '                  FROM TCLIENTE_HABILITACAO CH ' +
                                 '                     LEFT JOIN TUSUARIO U ON U.CD_USUARIO = CH.CD_ATENDENTE ' +
                                 '                  WHERE CH.CD_CLIENTE = P.CD_CLIENTE ' +
                                 '                    AND CH.CD_UNID_NEG = P.CD_UNID_NEG ' +
                                 '                    AND CH.CD_PRODUTO = P.CD_PRODUTO ' +
                                 '                    AND CH.IN_ATIVO = ''1''), '' '') AS NM_ATENDENTE ' +
                                 ' FROM TMAIL_PENDENTES    MP (NOLOCK) ' +
                                 '    INNER JOIN TPROCESSO P  (NOLOCK) ON P.NR_PROCESSO = MP.NR_PROCESSO ' +
                                 '    INNER JOIN TGRUPO    G  (NOLOCK) ON G.CD_GRUPO = P.CD_GRUPO ' +
                                 ' WHERE STATUS = ''+'' ' +
                                 ' ORDER BY ATRASO DESC');


end;

function TfrmMain.GetDescCab(const CD_Unidade, CD_Produto, CD_Grupo, CD_Cliente,  CD_Area: string): TDescCab;
begin
  FDQuery.Close;
  FDQuery.SQL.Text := 'SELECT ISNULL((SELECT RTRIM(AP_UNID_NEG) '+
    '               FROM TUNID_NEG (NOLOCK) '+
    '               WHERE CD_UNID_NEG = :CD_UNID_NEG), ''Todas'') AS NM_UNID_NEG, '+
    '       ISNULL((SELECT RTRIM(NM_PRODUTO) '+
    '               FROM TPRODUTO (NOLOCK) '+
    '               WHERE CD_PRODUTO = :CD_PRODUTO), ''Todos'') AS NM_PRODUTO, '+
    '       ISNULL((SELECT RTRIM(NM_GRUPO) '+
    '               FROM TGRUPO (NOLOCK) '+
    '               WHERE CD_GRUPO = :CD_GRUPO), ''Todos'') AS NM_GRUPO, '+
    '       ISNULL((SELECT RTRIM(NM_EMPRESA) '+
    '               FROM TEMPRESA_NAC (NOLOCK) '+
    '               WHERE CD_EMPRESA = :CD_CLIENTE), ''Todos'') AS NM_CLIENTE, '+
    '       ISNULL((SELECT RTRIM(NM_AREA) '+
    '               FROM TAREA (NOLOCK) '+
    '               WHERE CD_AREA = :CD_AREA), ''Todas'') AS NM_AREA ';
  FDQuery.ParamByName('CD_UNID_NEG').AsString := CD_Unidade;
  FDQuery.ParamByName('CD_PRODUTO').AsString := CD_Produto;
  FDQuery.ParamByName('CD_GRUPO').AsString := CD_Grupo;
  FDQuery.ParamByName('CD_CLIENTE').AsString := CD_Cliente;
  FDQuery.ParamByName('CD_AREA').AsString := CD_Area;
  FDQuery.Open;
  Result.Unidade := TrimRight(FDQuery.FieldByName('NM_UNID_NEG').AsString);
  Result.Produto := TrimRight(FDQuery.FieldByName('NM_PRODUTO').AsString);
  Result.Grupo := TrimRight(FDQuery.FieldByName('NM_GRUPO').AsString);
  Result.Cliente := TrimRight(FDQuery.FieldByName('NM_CLIENTE').AsString);
  Result.Area := TrimRight(FDQuery.FieldByName('NM_AREA').AsString);
end;


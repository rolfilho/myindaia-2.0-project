                //Solicitaçăo da Deborah Gonçalves em 24/01/2014 - HD 00000751/14 Migrar o Evento 132 quando o 165 estiver preenchido - ANDRESSA TI 25/07/2014
               { ConfirmaEmbarque:=
                ConsultaLookUpSQL('SELECT ISNULL(DT_REALIZACAO,'''') DT_REALIZACAO '+
                                  '  FROM TFOLLOWUP (nolock) '+
                                  ' WHERE NR_PROCESSO =''' + qry_mail_proc_nao_fat.FieldByName('NR_PROCESSO').AsString +''' '+
                                  '   AND CD_EVENTO   = 165 '
                                 ,'DT_REALIZACAO') ;}

                if (str_CD_EVENTO = '132') then
                begin
                  with TQuery.Create(frmMain) do
                  begin
                    try
                       SessionName  := 'SES_EDI';
                       DataBaseName := 'BROKER';
                       SQL.Text     := ' SELECT ISNULL(DT_REALIZACAO,'''') DT_REALIZACAO  ' + sLineBreak +
                                       '   FROM TFOLLOWUP (NOLOCK)                        ' + sLineBreak +
                                       '  WHERE NR_PROCESSO = :NR_PROCESSO                ' + sLineBreak +
                                       '   AND CD_EVENTO    = 165                         ' + sLineBreak +
                                       '   AND IN_APLICAVEL = 1                           ' + sLineBreak ;
                       ParamByName('NR_PROCESSO').AsString := qry_mail_proc_nao_fat.FieldByName('NR_PROCESSO').AsString;
                       Open;

                       if IsEmpty then
                       begin
                         ConfirmaEmbarque := 'N/A'
                       end
                       else
                       begin
                         ConfirmaEmbarque  := Fields[0].AsString;
                       end;
                    Finally
                     Free;
                    end;
                  end;
                  if (ConfirmaEmbarque <> '')then
                    oSheet.Cells[ nLinha, nColuna + QtdCourier -1 ].Value :=strTodate(vQryEventos.Fields[0].AsString)
                  else
                    oSheet.Cells[ nLinha, nColuna + QtdCourier -1 ].Value :='';
                end
                else
                begin
                  oSheet.Cells[ nLinha, nColuna + QtdCourier -1 ].Value :=strTodate(vQryEventos.Fields[0].AsString)
                end;
              end
              else
                oSheet.Cells[ nLinha, nColuna + QtdCourier -1 ].Value :=vQryEventos.Fields[0].AsString;

              { se năo existir o evento }
              if vQryEventos.Eof then
                oSheet.Cells[ nLinha, nColuna + QtdCourier -1 ].Value :='N/A';

              //pintar a celula caso a data de realizacao_efetiva tenha sido realizado no dia anterior, se for segunda-feira, pinta sexta, sabado e domingo
              if DayOfWeek(Date) = 2 then
              begin
                if vQryEventos.Fields[1].AsDateTime >= Date -3 then
                  oSheet.Cells[ nLinha, nColuna + QtdCourier -1 ].interior.ColorIndex := 40;
              end
              else
              begin
                if vQryEventos.Fields[1].AsDateTime = Date -1 then
                  oSheet.Cells[ nLinha, nColuna + QtdCourier -1 ].interior.ColorIndex := 40;
              end;
            end;
          end;

          Inc(nColuna);

          //oSheet.Cells[ 9, nColuna + QtdCourier -1 ].Font.Bold := True;
          //oSheet.Cells[ 9, nColuna + QtdCourier -1 ].value     := 'Notes';

          str_linha := qry_mail_proc_nao_fat.FieldByName('TX_OBS').AsString;

          { Pega 5 linhas uteis das ultimas 15 linhas da TX_OBS - by Carlos }
          str_obs := TMemo.Create(nil);
          try
            str_obs.Name := 'memObs';
            str_obs.Parent := frmMain;
            str_obs.WordWrap := False;
            str_obs.Lines.Text := str_linha;
            str_linha := '';
            ctLinha := 0;
            for I := str_obs.lines.Count downto 0 do
            begin
              try
                if trim(str_obs.Lines[I]) <> '' then
                begin
                  str_linha := str_obs.Lines[I] + str_linha;
                  Inc(ctLinha);
                  //if ctLinha >= 5 then
                  //  Break;
                end;
              except
                Continue;
              end;
            end;
            oSheet.Cells[ nLinha, nColuna + QtdCourier -1 ].Font.Name := 'Calibri';
            oSheet.Cells[ nLinha, nColuna + QtdCourier -1 ].value     := str_linha; // pega a OBS inteira
            //if length(trim(str_linha)) > 100 then //somente alongar quando o texto ultrapassar o limite de pelo menos 1 linha ( by carlos - 06/07/2011)
              oSheet.Cells[ nLinha, nColuna + QtdCourier -1 ].Rows.Autofit;
          finally
            FreeAndNil(str_obs);
          end;

          Range := oSheet.Range['B' + IntToStr(nLinha) + ':' + string(oSheet.Cells[ nLinha, vTotalEventos +17 + QtdCourier].Address)];

          Range.Borders[xlDiagonalDown].LineStyle := 0;
          Range.Borders[xlDiagonalUp].LineStyle := 0;
          Range.Borders[xlEdgeLeft].LineStyle := xlContinuous;
          Range.Borders[xlEdgeLeft].ColorIndex := 15;
          Range.Borders[xlEdgeLeft].Weight := xlThin;
          Range.Borders[xlEdgeTop].LineStyle := xlContinuous;
          Range.Borders[xlEdgeTop].ColorIndex := 15;
          Range.Borders[xlEdgeTop].Weight := xlThin;
          Range.Borders[xlEdgeBottom].LineStyle := xlContinuous;
          Range.Borders[xlEdgeBottom].ColorIndex := 15;
          Range.Borders[xlEdgeBottom].Weight := xlThin;
          Range.Borders[xlEdgeRight].LineStyle := xlContinuous;
          Range.Borders[xlEdgeRight].ColorIndex := 15;
          Range.Borders[xlEdgeRight].Weight := xlThin;
          Range.Borders[xlInsideVertical].LineStyle := xlContinuous;
          Range.Borders[xlInsideVertical].ColorIndex := 15;
          Range.Borders[xlInsideVertical].Weight := xlThin;
          Range.Borders[xlInsideHorizontal].LineStyle := xlContinuous;
          Range.Borders[xlInsideHorizontal].ColorIndex := 15;
          Range.Borders[xlInsideHorizontal].Weight := xlThin;

          qry_mail_proc_nao_fat.Next;
        end;

        oSheet.Sort.SortFields.Clear;
        for I := vTotalEventos -2 downto 0 do
          oSheet.Sort.SortFields.Add(Key:=oSheet.Range[GetCellName(oSheet, 19 + I, 13) + ':' + GetCellName(oSheet, 19 + I, nLinha)], SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal);

        oSheet.Sort.SetRange(oSheet.Range[GetCellName(oSheet, 2, 13) + ':' + GetCellName(oSheet, vTotalEventos + 19, nLinha)]);
        oSheet.Sort.Header := xlGuess;
        oSheet.Sort.MatchCase := False;
        oSheet.Sort.Orientation := xlTopToBottom;
        oSheet.Sort.SortMethod := xlPinYin;
        oSheet.Sort.Apply;

        //--------------------------------------------------------------------------//
        // finalizando...
        //--------------------------------------------------------------------------//
        //--------------------------------------------------------------------------//
        // deixar a planilha visivel no windows
        //--------------------------------------------------------------------------//
        //Excel.Visible := chkVisualizarExcel.checked;

        if not TemContainer then
          oSheet.Columns['K:K'].Delete(Shift:=xlToLeft);
        if not TemBooking then
          oSheet.Columns['J:J'].Delete(Shift:=xlToLeft);

        if FileExists(GetPath+'Gerados\DAILY_FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.XLS') then
          SysUtils.DeleteFile(GetPath+'Gerados\DAILY_FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.XLS');
        Excel.ActiveWorkBook.SaveAs(GetPath+'Gerados\DAILY_FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.XLS');

        if tem_dados then
          Result := GetPath+'Gerados\DAILY_FOLLOWUP_' + vNomeProduto + '_' + vTimeStamp + '.XLS'
        else
          Result := 'Sem Dados';

      finally
        Excel.ActiveWorkBook.Close(False);
        KillExcel(Excel);
      end;
    finally
      FreeAndNil(vQryEventos);
      FreeAndNil(qry_mail_proc_nao_fat);
      FreeAndNil(qryAuxiliar);
      FreeAndNil(db_broker);
    end;
  except
    on e:Exception do
    begin
      VMsg('Erro - RelEventosDailyFupNestle: ' + e.Message, msError, True);
    end;
  end;
end;


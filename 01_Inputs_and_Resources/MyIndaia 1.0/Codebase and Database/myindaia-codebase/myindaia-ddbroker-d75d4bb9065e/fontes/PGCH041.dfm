  end
  object qry_rel_imp_sap_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'SELECT SUBSTRING( I.NR_PROCESSO, 5, 14 ) AS NR_PROCESSO,'
      '       SUBSTRING( D.NR_DECLARACAO_IMP, 1, 2 ) + '#39'/'#39' +'
      '       SUBSTRING( D.NR_DECLARACAO_IMP, 3, 7 ) + '#39'-'#39' +'
      '       SUBSTRING( D.NR_DECLARACAO_IMP, 10, 1 ) AS NR_DI,'
      '       LTRIM( RTRIM( ISNULL( NR_PROC_PO, '#39#39' ) ) ) + '#39'/'#39' +'
      
        '       CONVERT( varchar, CONVERT( int, ISNULL( NR_ITEM_PO, 0 ) )' +
        ' ) AS NR_SAP,'
      
        '       VL_II_ITEM, VL_IPI_ITEM, VL_ICMS_ITEM, T.VL_TRIBUTO_PAGO ' +
        'AS VL_TX_SCX,'
      '       PL_MERCADORIA, P.CD_CLIENTE, E.NM_EMPRESA'
      
        'FROM   TDETALHE_MERCADORIA I, TDECLARACAO_IMPORTACAO D, TPAGAMEN' +
        'TO_TRIBUTOS T, TPROCESSO P, TEMPRESA_NAC E'
      'WHERE  I.NR_PROCESSO *= T.NR_PROCESSO AND'
      '       T.CD_RECEITA_PGTO = '#39'7811'#39' AND'
      '       I.NR_PROCESSO = D.NR_PROCESSO AND'
      '       I.NR_PROCESSO = P.NR_PROCESSO AND'
      '       P.CD_CLIENTE = E.CD_EMPRESA AND'
      
        '       E.CD_GRUPO IN ( SELECT CD_GRUPO_BASF FROM TPARAMETROS ) A' +
        'ND'
      '       P.IN_CANCELADO = '#39'0'#39' AND'
      '       P.CD_UNID_NEG = :CD_UNID_NEG AND'
      '       ISNULL( D.DT_REGISTRO_DI, '#39#39' ) <> '#39#39' AND'
      '       CONVERT( datetime,'
      '                SUBSTRING( D.DT_REGISTRO_DI, 1, 2 ) + '#39'/'#39' +'
      '                SUBSTRING( D.DT_REGISTRO_DI, 3, 2 ) + '#39'/'#39' +'
      '                SUBSTRING( D.DT_REGISTRO_DI, 5, 4 ), 103 ) ='
      '       CONVERT( datetime, :DT_REGISTRO_DI, 103 )'
      'ORDER BY E.NM_EMPRESA, I.NR_PROCESSO,'
      '         LTRIM( RTRIM( ISNULL( NR_PROC_PO, '#39#39' ) ) ) + '#39'/'#39' + '
      
        '         CONVERT( varchar, CONVERT( int, ISNULL( NR_ITEM_PO, 0 )' +
        ' ) )')
    Left = 200
    Top = 84
    ParamData = <
      item
        DataType = ftString
        Name = 'CD_UNID_NEG'
        ParamType = ptUnknown
      end
      item
        DataType = ftDate
        Name = 'DT_REGISTRO_DI'
        ParamType = ptUnknown
      end>
    object qry_rel_imp_sap_NR_PROCESSO: TStringField
      FieldName = 'NR_PROCESSO'
      Size = 14
    end
    object qry_rel_imp_sap_CD_CLIENTE: TStringField
      FieldName = 'CD_CLIENTE'
      Size = 5
    end
    object qry_rel_imp_sap_NR_DI: TStringField
      FieldName = 'NR_DI'
      Size = 12
    end

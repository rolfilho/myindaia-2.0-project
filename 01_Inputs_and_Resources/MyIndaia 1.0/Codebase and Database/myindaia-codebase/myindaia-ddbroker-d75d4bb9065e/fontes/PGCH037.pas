uses PGCH036, GSMLIB, PGGP001;

{$R *.DFM}

procedure Tdatm_sel_relat.qry_rel_retencao_CalcFields(DataSet: TDataSet);
begin
  qry_rel_retencao_CalcNrProcesso.AsString := Copy( qry_rel_retencao_NR_PROCESSO.AsString, 5, 14 );
end;

procedure Tdatm_sel_relat.ppTituloPrint(Sender: TObject);
begin
    case frm_sel_relat.tp_rel of
       1 :     if frm_sel_relat.msk_dt_inicio.Date = frm_sel_relat.msk_dt_fim.Date Then
                 ppTitulo.Caption := 'Retençăo de Impostos (Fatura) [ ' + FormatDateTime( 'dd/mm/yyyy', frm_sel_relat.msk_dt_inicio.Date ) + ' ]'
               else
                 ppTitulo.Caption := 'Retençăo de Impostos (Fatura) [ ' + FormatDateTime( 'dd/mm/yyyy', frm_sel_relat.msk_dt_inicio.Date ) + ' a ' + FormatDateTime( 'dd/mm/yyyy', frm_sel_relat.msk_dt_fim.Date ) + ' ]';
       8 :     if frm_sel_relat.msk_dt_inicio.Date = frm_sel_relat.msk_dt_fim.Date Then
                 ppTitulo.Caption := 'Valores de Retençăo [ ' + FormatDateTime( 'dd/mm/yyyy', frm_sel_relat.msk_dt_inicio.Date ) + ' ]'
               else
                 ppTitulo.Caption := 'Valores de Retençăo [ ' + FormatDateTime( 'dd/mm/yyyy', frm_sel_relat.msk_dt_inicio.Date ) + ' a ' + FormatDateTime( 'dd/mm/yyyy', frm_sel_relat.msk_dt_fim.Date ) + ' ]';
    end;
end;

procedure Tdatm_sel_relat.ppVarRodapeEsqCalc(Sender: TObject;
  var Value: Variant);
begin
  case frm_sel_relat.tp_rel of
     1 : ppVarRodapeEsq.AsString := 'RBFAT004' + Space(5) + 'Emitido em ' + FormatDateTime( 'dd/mm/yyyy', dt_server ) + '  ŕs  ' + FormatDateTime( 'hh:mm:ss', hr_server );
     8 : ppVarRodapeEsq.AsString := 'RBRET001' + Space(5) + 'Emitido em ' + FormatDateTime( 'dd/mm/yyyy', dt_server ) + '  ŕs  ' + FormatDateTime( 'hh:mm:ss', hr_server );
  end;
end;

procedure Tdatm_sel_relat.ppVarRodapeDirCalc(Sender: TObject;
  var Value: Variant);
begin
  ppVarRodapeDir.AsString := 'Folha ' + ppNumPag.Text + ' / ' + ppTotPag.Text;
end;

procedure Tdatm_sel_relat.qry_rel_valor_retencao_CalcFields(DataSet: TDataSet);
begin
  qry_rel_valor_retencao_CalcNrProcesso.AsString := Copy( qry_rel_valor_retencao_NR_PROCESSO.AsString, 5, 14 );
end;


procedure Tdatm_po_leitura.qry_po_AfterPost(DataSet: TDataSet);
begin
  //seleciona o processo e verifica se o serviço já existe
  //se năo existir, năo insere o follow up
  qry_po_.Close;
  qry_po_.ParamByName('NR_PROCESSO').AsString := Copy( frm_po_leitura.Stri, 5, 10 );
  qry_po_.Prepare;
  qry_po_.Open;

  if ( qry_po_CD_SERVICO.AsString <> '' ) or ( qry_po_CD_SERVICO.AsString <> NULL ) then
  begin
    //verifica se o item da po já existe no follow up, se năo existir adiciona
    qry_flp_po_.Close;
    qry_flp_po_.ParamByName('NR_PROCESSO').AsString := Copy( frm_po_leitura.Stri, 5, 10 );
    qry_flp_po_.Prepare;
    qry_flp_po_.Open;
    if qry_flp_po_.RecordCount >= 0 then
    begin
      CloseStoredProc(sp_flp_po);
      sp_flp_po.ParamByName('@NR_PROCESSO').AsString := qry_flp_po_NR_PROCESSO.AsString;
      sp_flp_po.ParamByName('@CD_SERVICO').AsString  := qry_po_CD_SERVICO.AsString;
      ExecStoredProc(sp_flp_po);
      CloseStoredProc(sp_flp_po);
    end;
    qry_flp_po_.Close;
  end;
end;


      'CD_PAIS_ORIGEM, '
      '   TP_BANCO_EXP, CD_BANCO_EXP, VL_FRETE_CUSTO, VL_M3, '
      'CD_AGENTE_SEGURO, '
      '   NR_AVERBACAO, DT_ESTOCAGEM, NR_CONHECIMENTO, '
      'DT_CONHECIMENTO, NR_CONHECIMENTO_MASTER, '
      '   NR_DDE, NR_PROCESSO_EXP_TEMP, DT_VENC_PROCESSO_EXP_TEMP, '
      'NR_DI_RETORNO, '
      '   CD_PAIS_DESTINO, VL_PESO_BRUTO, VL_PESO_LIQUIDO, '
      'CD_LINGUA_PEDIDO, CD_IMPORTADOR, '
      '   CD_TAB_FRETE, VL_FRETE_COLLECT_MNEG, NR_PLACA_VEICULO, '
      'NR_CAMINHAO, '
      '   NR_VOO, NR_MANIFESTO, DOCS_ENVIADO_PARA, VL_SEGURO_MNEG, '
      'VL_FRETE_TNAC_MNEG, '
      '   NM_CONEXAO, CD_FRONTEIRA, IN_COURRIER, IN_PRODUTO_IMPORTADO, '
      'VL_TRANSIT_TIME, '
      '   CD_CONSIGNEE, TP_CONSIGNEE, CD_LOCAL_ENTREGA, CD_ACORDO, '
      'QNTD_ACORDO, '
      '   TP_CERTIFICADO, TP_ENVIO_CERTIFICADO, CD_INCOTERM, '
      'CD_RESP_DRAFT, CD_RESP_DESEMB, '
      '   CD_TRANSPORTADOR, IN_PROCESSO_MAPA, '
      'IN_APENAS_EMISSAO_DOCTOS, VL_LEAD_TIME, '

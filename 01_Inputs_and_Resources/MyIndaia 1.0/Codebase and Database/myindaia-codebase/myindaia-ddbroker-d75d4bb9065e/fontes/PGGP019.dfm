  object upd_li_status: TUpdateSQL
    ModifySQL.Strings = (
      'update TPROCESSO_LI_STATUS'
      'set'
      '  NR_PROCESSO = :NR_PROCESSO,'
      '  NR_LI = :NR_LI,'
      '  DT_STATUS = :DT_STATUS,'
      '  TX_STATUS = :TX_STATUS,'
      '  TX_DIR_EXTRATO = :TX_DIR_EXTRATO,'
      '  CD_ORGAO_ANUENTE = :CD_ORGAO_ANUENTE,'
      '  TX_OBS = :TX_OBS'
      'where'
      '  NR_PROCESSO = :OLD_NR_PROCESSO and'
      '  NR_LI = :OLD_NR_LI and'
      '  CD_ORGAO_ANUENTE = :OLD_CD_ORGAO_ANUENTE')
    InsertSQL.Strings = (
      'insert into TPROCESSO_LI_STATUS'
      '  (NR_PROCESSO, NR_LI, DT_STATUS, TX_STATUS, TX_DIR_EXTRATO, '
      'CD_ORGAO_ANUENTE,TX_OBS)'
      'values'
      
        '  (:NR_PROCESSO, :NR_LI, :DT_STATUS, :TX_STATUS, :TX_DIR_EXTRATO' +
        ', '
      ':CD_ORGAO_ANUENTE,:TX_OBS)')
    DeleteSQL.Strings = (
      'delete from TPROCESSO_LI_STATUS'
      'where'
      '  NR_PROCESSO = :OLD_NR_PROCESSO and'
      '  NR_LI = :OLD_NR_LI and'

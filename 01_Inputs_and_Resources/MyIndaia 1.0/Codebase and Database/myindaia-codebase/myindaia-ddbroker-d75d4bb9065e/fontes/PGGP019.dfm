  object qry_proc_cntr_: TQuery
    CachedUpdates = True
    AfterInsert = qry_proc_cntr_AfterInsert
    AfterPost = qry_proc_cntr_AfterPost
    AfterCancel = qry_proc_cntr_AfterCancel
    AfterDelete = qry_proc_cntr_AfterDelete
    AfterScroll = qry_proc_cntr_AfterScroll
    OnCalcFields = qry_proc_cntr_CalcFields
    OnPostError = qry_proc_cntr_PostError
    DatabaseName = 'DBBROKER'
    DataSource = ds_processo
    SQL.Strings = (
      'SELECT'
      
        '  NR_PROCESSO, NR_CNTR, DT_ENT_ARM, IN_DESOVA, DT_DESOVA, IN_DEM' +
        'URRAGE, DT_DEMURRAGE,'
      
        '  NR_LACRE, TP_CNTR, NR_FREE_TIME, NR_CHEQUE_CAUCAO, VL_CHEQUE_C' +
        'AUCAO, DT_EMISSAO_CNTR,'
      
        '  IN_REPARO_CNTR, IN_PAGTO_EFETIVADO, TX_ESTUFAGEM, DT_DEVOLUCAO' +
        '_CNTR, TP_DIAS, TP_DIAS,'
      
        '  DT_ENT, DT_ENTREGA_FABRICA, TX_OBS_AVARIA, NM_MOTIVO_DEM, NM_R' +
        'ESP_DEM, NM_APROV_POR_DEM,'
      
        '  DT_SAIDA_ARM, CODIGO, NR_LACRE_SIF, TARA_CNTR, ISNULL(IN_PARTE' +
        '_LOTE, '#39'0'#39') AS IN_PARTE_LOTE, '
      
        '  DT_CHEGADA_FABR, DT_ENTR_TERMINAL, DT_PRE_STACKING, DT_CARREGA' +
        'MENTO, DT_SOLIC_RET_VAZIO, '
      
        '  DT_RET_VAZIO, DT_SAIDA_FABR, CD_CARRETA, DT_PREV_CHEGADA_FABR,' +
        ' CD_LOCAL_ENTREGA, '
      
        '  VL_CUBAGEM, VL_PESO_BRUTO, VL_PESO_LIQUIDO, VL_QUANTIDADE_EMBA' +
        'LAGEM, CD_EMBALAGEM, DS_TEMPERATURA, NR_CNTR_LEASING,'
      

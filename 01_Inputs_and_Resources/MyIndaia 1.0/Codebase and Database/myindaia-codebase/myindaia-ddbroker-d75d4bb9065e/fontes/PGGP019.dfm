  object qry_viagem_: TQuery
    DatabaseName = 'DBBROKER'
    ParamCheck = False
    SQL.Strings = (
      'SELECT NR_VIAGEM, NR_MANIFESTO, CD_ARMAZEM_ATRACACAO, CD_LOCAL'
      'FROM   TVIAGEM (NOLOCK)'
      
        'WHERE  CD_UNID_NEG   = (CASE WHEN :CD_UNID_NEG = '#39'07'#39' THEN '#39'01'#39' ' +
        'ELSE :CD_UNID_NEG END) AND'
      '       CD_PRODUTO    = :CD_PRODUTO AND'
      '       CD_EMBARCACAO = :CD_EMBARCACAO AND'
      '       NR_VIAGEM     = :NR_VIAGEM AND'
      '       CD_LOCAL        = :CD_LOCAL'
      '')
    Left = 539
    Top = 183
    ParamData = <
      item
        DataType = ftString
        Name = 'CD_UNID_NEG'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_UNID_NEG'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_PRODUTO'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_EMBARCACAO'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'NR_VIAGEM'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_LOCAL'
        ParamType = ptUnknown
      end>
  end

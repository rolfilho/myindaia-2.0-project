  object qry_li_status: TQuery
    OnCalcFields = qry_li_statusCalcFields
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      ' SELECT A.NR_PROCESSO, '
      '        NR_LI, '
      '        DT_STATUS, '
      '        TX_STATUS, '
      '        CD_ORGAO_ANUENTE, '
      '        DT_CONSULTA, '
      '        DT_STATUS_EFETIVA,'
      '        (SELECT PATH_DIGITALIZACAO FROM TPARAMETROS (NOLOCK)) + '
      
        '        '#39'TPROCESSO\'#39'+SUBSTRING(A.NR_PROCESSO,1,16)+'#39'\'#39'+ ISNULL(X' +
        '.NM_ARQUIVO, '#39#39') AS TX_DIR_EXTRATO,'
      '        REPLACE(TX_OBS , '#39'<BR>'#39', '#39#39')  AS TX_OBS'
      ' FROM TPROCESSO_LI_STATUS A (NOLOCK)'
      ' OUTER APPLY ( '
      ' SELECT TOP 1 NM_DESCRICAO, NM_ARQUIVO'
      '   FROM TPROCESSO_DOCTOS B(NOLOCK)  '
      ' WHERE B.NR_PROCESSO = A.NR_PROCESSO'
      '   AND B.NM_DESCRICAO LIKE '#39'%'#39'+LTRIM(RTRIM(A.TX_STATUS))+'#39'%'#39
      
        '   AND B.NM_DESCRICAO LIKE '#39'%'#39'+LTRIM(RTRIM(SUBSTRING(A.NR_LI, 1,' +
        ' 2) + '#39'/'#39' + '
      
        '                                           SUBSTRING(A.NR_LI, 3,' +
        ' 7) + '#39'-'#39' + '
      
        '                                           SUBSTRING(A.NR_LI, 10' +
        ', 1) +'#39'%'#39'))'
      ' )X'
      ' WHERE NR_PROCESSO      =:NR_PROCESSO '
      '   AND NR_LI            =:NR_LI '
      '   AND CD_ORGAO_ANUENTE =:CD_ORGAO_ANUENTE')
    UpdateObject = upd_li_status
    Left = 72
    Top = 624
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'NR_LI'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_ORGAO_ANUENTE'
        ParamType = ptUnknown
      end>
    object qry_li_statusNR_PROCESSO: TStringField
      FieldName = 'NR_PROCESSO'
      Origin = 'DBBROKER.TPROCESSO_LI_STATUS.NR_PROCESSO'
      FixedChar = True
      Size = 18
    end
    object qry_li_statusNR_LI: TStringField
      FieldName = 'NR_LI'
      Origin = 'DBBROKER.TPROCESSO_LI_STATUS.NR_LI'
      FixedChar = True
      Size = 10
    end
    object qry_li_statusCD_ORGAO_ANUENTE: TStringField
      FieldName = 'CD_ORGAO_ANUENTE'
      Origin = 'DBBROKER.TPROCESSO_LI_STATUS.CD_ORGAO_ANUENTE'
      FixedChar = True
      Size = 16
    end

  object qry_ult_ref_cliente_: TQuery
    DatabaseName = 'DBBROKER'
    DataSource = ds_processo
    SQL.Strings = (
      
        'SELECT SUBSTRING('#39'00000'#39',1,5-LEN(MAX(CONVERT(INT,NR_SEQUENCIA)))' +
        ') + CONVERT(CHAR,ISNULL(MAX(CONVERT(INT,NR_SEQUENCIA)),0))  ULTI' +
        'MO'
      'FROM TREF_CLIENTE (NOLOCK)'
      'WHERE NR_PROCESSO=:NR_PROCESSO')
    Left = 467

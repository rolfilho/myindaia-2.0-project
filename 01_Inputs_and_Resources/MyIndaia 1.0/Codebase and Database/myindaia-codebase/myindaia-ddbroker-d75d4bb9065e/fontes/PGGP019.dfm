  object qry_usuario_: TQuery
    DatabaseName = 'DBBROKER'
    ParamCheck = False
    SQL.Strings = (
      'SELECT U.CD_USUARIO, U.NM_USUARIO'
      'FROM   TUSUARIO U (NOLOCK)'
      'WHERE  U.CD_USUARIO = :CD_ANALISTA AND'
      '       ( (  U.CD_USUARIO = :CD_USUARIO OR'
      '            U.CD_CARGO = :CD_CARGO OR'
      '            U.CD_CARGO IN'
      '            ( SELECT CD_DESCENDENTE'
      '              FROM TCARGO_DESCENDENTE (NOLOCK)'
      '              WHERE CD_CARGO = U.CD_CARGO AND'
      '                    CD_DESCENDENTE <> :CD_CARGO ) ) OR'
      '      ( ( :CD_ANALISTA = '#39#39' ) AND ( :CD_CARGO = '#39#39' ) ) )')
    Left = 923
    Top = 81
    ParamData = <
      item
        DataType = ftString
        Name = 'CD_ANALISTA'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_USUARIO'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_CARGO'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_CARGO'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_ANALISTA'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_CARGO'
        ParamType = ptUnknown
      end>
  end

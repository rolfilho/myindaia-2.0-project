  object qry_ref_cliente_: TQuery
    CachedUpdates = True
    AfterPost = qry_ref_cliente_AfterPost
    AfterDelete = qry_ref_cliente_AfterPost
    AfterScroll = qry_ref_cliente_AfterScroll
    OnCalcFields = qry_ref_cliente_CalcFields
    OnNewRecord = qry_ref_cliente_NewRecord
    DatabaseName = 'DBBROKER'
    DataSource = ds_processo
    SQL.Strings = (
      'SELECT RC.*,'
      '      R.NM_REFERENCIA AS TIPO_PEDIDO'
      'FROM TREF_CLIENTE RC (NOLOCK)'
      
        '   LEFT JOIN TPROCESSO P (NOLOCK) ON P.NR_PROCESSO = RC.NR_PROCE' +
        'SSO'
      '   LEFT JOIN TGRUPO G (NOLOCK) ON G.CD_GRUPO = P.CD_GRUPO'
      
        '   LEFT JOIN TTP_REFERENCIA R (NOLOCK) ON R.CD_REFERENCIA = RC.T' +
        'P_REFERENCIA'
      'WHERE RC.NR_PROCESSO = :NR_PROCESSO'
      'ORDER BY CASE P.CD_PRODUTO'
      
        '             WHEN '#39'01'#39' THEN CASE WHEN RC.TP_REFERENCIA = G.TP_PE' +
        'DIDO_BUSCA_IMP THEN 0'
      '                            ELSE 1'
      '                            END'
      
        '             WHEN '#39'06'#39' THEN CASE WHEN RC.TP_REFERENCIA = G.TP_PE' +
        'DIDO_BUSCA_IMP THEN 0'
      '                            ELSE 1'
      '                            END'
      
        '             WHEN '#39'02'#39' THEN CASE WHEN RC.TP_REFERENCIA = G.TP_PE' +
        'DIDO_BUSCA THEN 0'
      '                            ELSE 1'
      '                            END'
      '         END')
    UpdateObject = updRefCliente
    Left = 272
    Top = 8
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
        Size = 19
      end>
    object qry_ref_cliente_NR_PROCESSO: TStringField
      DisplayLabel = 'Nr Processo'
      FieldName = 'NR_PROCESSO'

  object qry_proc_im_: TQuery
    CachedUpdates = True
    AfterPost = qry_proc_im_AfterPost
    AfterDelete = qry_proc_im_AfterDelete
    AfterScroll = qry_proc_im_AfterScroll
    OnCalcFields = qry_proc_im_CalcFields
    DatabaseName = 'DBBROKER'
    DataSource = ds_processo
    SQL.Strings = (
      'SELECT NR_PROCESSO, '
      '       IN_MERC_PERIGOSA, '
      '       IN_URGENTE, '
      '       CD_ANALISTA_COMISSARIA, '
      '       CD_CONTATO,'
      '       TP_FRETE, '
      '       CD_MOEDA_FRETE, '
      '       VL_FRETE_COLLECT_MNEG, '
      '       VL_FRETE_PREPAID_MNEG,'
      '       VL_TAXA_FRETE, '
      '       VL_MLE_MN, '
      '       VL_MLE_MNEG, '
      '       VL_CIF_MN, '
      '       VL_CIF_DOLAR, '
      '       VL_II_MN,'
      '       VL_IPI_MN, '
      '       VL_ICMS_MN, '
      '       CD_ARMAZEM_ATRACACAO, '
      '       CD_ARMAZEM_DESCARGA, '
      '       CD_EMBARCACAO,'
      '       NR_VIAGEM, '
      '       CD_LOCAL_EMBARQUE, '
      '       CD_LOCAL_DESEMBARQUE, '
      '       CD_PAIS_ORIGEM, '
      '       CD_AGENTE,'
      '       VL_FRETE_CUSTO, '
      '       VL_M3, '
      '       NR_MANIFESTO, '
      '       DT_CONHECIMENTO, '
      '       NR_CONHECIMENTO,'
      '       NR_CONHECIMENTO_MASTER, '
      '       NR_PRESENCA_CARGA, '
      '       DT_PRESENCA_CARGA, '
      '       CD_CANAL,'
      '       CD_TRANSPORTADOR, '
      '       CD_INCOTERM, '
      '       CD_TAB_FRETE, '
      '       VL_FRETE_TNAC_MNEG,'
      '       NR_PLACA_VEICULO, '
      '       NR_CAMINHAO, '
      '       NR_VOO,'
      '       CD_FRONTEIRA, '
      '       NUM_CE, '
      '       CD_PRIMEIRO_PORTO_ATRAC,'
      '       TP_CERTIFICADO, '
      '       IN_DRAWBACK_ALADI, '
      '       CD_LOCAL_ENTREGA, '
      '       QT_MERC_UN_COMERC, '
      '       VL_PESO_LIQUIDO,'
      '       VL_FOB, '
      '       CD_UNID_MEDIDA, '
      '       CD_MOEDA_MLE,'
      '       ISNULL(IN_COBRANCA_DTA,0) IN_COBRANCA_DTA,'
      '       TB_ARMAZENAGEM, '
      '       IN_TRANSMITE_SEM_PREVISAO,'
      '       ISNULL(IN_CROSSDOCKING,0) AS IN_CROSSDOCKING,'
      
        '       ISNULL(IN_DESEMBARACO_SOBRE_AGUAS,0) AS IN_DESEMBARACO_SO' +
        'BRE_AGUAS,'
      '       VL_PESO_BRUTO,'
      '       CD_EMBARCACAO_BALDEACAO,'
      '        NR_VIAGEM_BALDEACAO, '
      '        ISNULL( IN_BALDEACAO ,0) AS IN_BALDEACAO,       '
      '        ISNULL(IN_FRETE_ACORDADO, '#39'0'#39') AS IN_FRETE_ACORDADO,'
      '        CD_OPERADOR_TANQUE,'
      '        DS_ARMAZEM_MANTRA,'
      '       ISNULL(IN_ICMS_EXONERADO,'#39'0'#39') AS IN_ICMS_EXONERADO,'
      '       ISNULL(IN_MUDANCA_REGIME,0) IN_MUDANCA_REGIME,'
      '       CD_LOCAL_COLETA,'
      '       CD_RUC'
      ''
      'FROM   TPROCESSO WITH(NOLOCK)'
      'WHERE  NR_PROCESSO = :NR_PROCESSO')
    UpdateObject = upd_proc_im_
    Left = 19
    Top = 51
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
        Size = 19
      end>

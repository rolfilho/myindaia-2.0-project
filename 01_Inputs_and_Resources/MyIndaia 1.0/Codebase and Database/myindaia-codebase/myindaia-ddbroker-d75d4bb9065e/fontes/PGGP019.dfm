      '  , DT_LI_AUTORIZADA = :DT_LI_AUTORIZADA'
      '  , DT_PROTOCOLO_REMOTO_OK = :DT_PROTOCOLO_REMOTO_OK'
      '  , IN_INSPECAO = :IN_INSPECAO'
      '  , DT_INSPECAO = :DT_INSPECAO'
      '  , IN_COLETA_AMOSTRA = :IN_COLETA_AMOSTRA'
      '  , DT_COLETA_AMOSTRA = :DT_COLETA_AMOSTRA'
      '  , NR_INFA = :NR_INFA'
      '  , TX_OBS_LI_NOVA_SUB = :TX_OBS_LI_NOVA_SUB'
      '  , IN_EXIGENCIA = :IN_EXIGENCIA'
      '  , IN_LPCO = :IN_LPCO'
      '  , NR_LPCO = :NR_LPCO'
      'where'
      '  NR_PROCESSO = :OLD_NR_PROCESSO and'
      '  NR_LI = :OLD_NR_LI')
    InsertSQL.Strings = (
      'insert into TPROCESSO_LI'
      '  (NR_PROCESSO, NR_LI, DT_REGISTRO, DT_DEFERIMENTO, DT_VENCTO, '
      
        '  IN_SUBSTITUIDA,  NR_SUBSTITUIDA, IN_CANCELADO, TX_OBS_CANC, IN' +
        '_UTILIZADO, IN_SEM_REPRESENTACAO, '
      
        '  IN_LI_PRE_JA_EMBARCADO, NR_INMETRO,NUMERO_IP_BRI,DATA_SOLICI_P' +
        'RORROGACAO,IN_FILA_RECUPERAR, CD_POSTO_ANVISA        '
      
        '  , NR_PROCESSO_ANVISA, NR_EXPEDIENTE_ANVISA, IN_PRE_EMBARQUE, D' +
        'T_SOLICITACAO       '
      
        '  , CD_USUARIO_EMISSOR  , QT_ITENS, DT_APTO_FIN_DOSSIE, DT_FIN_D' +
        'OSSIE, NR_DOSSIE, NR_DOSSIE_POS            '
      
        '  , DT_DOCTOS_DOSSIE, DT_EMISSAO_GRU, NR_TRANSACAO_GRU, DT_PGMTO' +
        '_GRU         '
      
        '  , CD_CANAL, NR_PROCESSO_LECOM,  DT_SOLICITACAO_REQUISITO, DT_R' +
        'ECEPCAO_REQ_SANITARIO, DT_LECOM'
      
        '  , DT_LI_AUTORIZADA, DT_PROTOCOLO_REMOTO_OK, IN_INSPECAO, DT_IN' +
        'SPECAO, IN_COLETA_AMOSTRA, DT_COLETA_AMOSTRA'
      '  , NR_INFA, TX_OBS_LI_NOVA_SUB, IN_EXIGENCIA, IN_LPCO, NR_LPCO)'
      'values'
      
        '  (:NR_PROCESSO, :NR_LI, :DT_REGISTRO, :DT_DEFERIMENTO, :DT_VENC' +
        'TO,'
      
        '   :IN_SUBSTITUIDA,  :NR_SUBSTITUIDA, :IN_CANCELADO, :TX_OBS_CAN' +
        'C, :IN_UTILIZADO,'
      '   :IN_SEM_REPRESENTACAO, :IN_LI_PRE_JA_EMBARCADO, :NR_INMETRO,'
      '   :NUMERO_IP_BRI,:DATA_SOLICI_PRORROGACAO,1, :CD_POSTO_ANVISA'
      
        '  , :NR_PROCESSO_ANVISA, :NR_EXPEDIENTE_ANVISA, :IN_PRE_EMBARQUE' +
        ', :DT_SOLICITACAO       '
      
        '  , :CD_USUARIO_EMISSOR , :QT_ITENS, :DT_APTO_FIN_DOSSIE, :DT_FI' +
        'N_DOSSIE, :NR_DOSSIE, :NR_DOSSIE_POS            '
      
        '  , :DT_DOCTOS_DOSSIE, :DT_EMISSAO_GRU, :NR_TRANSACAO_GRU, :DT_P' +
        'GMTO_GRU         '
      
        '  , :CD_CANAL, :NR_PROCESSO_LECOM,  :DT_SOLICITACAO_REQUISITO, :' +
        'DT_RECEPCAO_REQ_SANITARIO, :DT_LECOM'
      
        '  , :DT_LI_AUTORIZADA, :DT_PROTOCOLO_REMOTO_OK, :IN_INSPECAO, :D' +
        'T_INSPECAO, :IN_COLETA_AMOSTRA, :DT_COLETA_AMOSTRA'
      
        '  , :NR_INFA, :TX_OBS_LI_NOVA_SUB, :IN_EXIGENCIA, :IN_LPCO, :NR_' +
        'LPCO) ')
    DeleteSQL.Strings = (
      'delete from TPROCESSO_LI'
      'where'
      '  NR_PROCESSO = :OLD_NR_PROCESSO and'
      '  NR_LI = :OLD_NR_LI')
    Left = 131
    Top = 473
  end

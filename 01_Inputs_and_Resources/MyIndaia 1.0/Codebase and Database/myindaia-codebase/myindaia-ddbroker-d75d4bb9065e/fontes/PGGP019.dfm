  object qry_usuario_habilitacao_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT UP.CD_UNID_NEG, U.AP_UNID_NEG, UP.CD_PRODUTO, P.AP_PRODUT' +
        'O'
      
        'FROM   TUNID_NEG_PRODUTO UP (NOLOCK), TUNID_NEG U (NOLOCK), TPRO' +
        'DUTO P (NOLOCK)'
      'WHERE  UP.CD_UNID_NEG = U.CD_UNID_NEG AND'
      '       UP.CD_PRODUTO = P.CD_PRODUTO AND'
      '       ( UP.CD_UNID_NEG + UP.CD_PRODUTO ) IN'
      '          ( SELECT ( CD_UNID_NEG + CD_PRODUTO )'
      '            FROM   TUSUARIO_HABILITACAO (NOLOCK)'
      '            WHERE  CD_USUARIO = :CD_USUARIO AND'
      '                   IN_ATIVO = '#39'1'#39' )'
      ''
      '')
    Left = 475
    Top = 42
    ParamData = <
      item
        DataType = ftString
        Name = 'CD_USUARIO'
        ParamType = ptUnknown
      end>
  end
  object qry_cliente_habilitacao_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      '    SELECT CH.CD_CLIENTE,'
      '       CH.CD_UNID_NEG,'
      '       CH.CD_PRODUTO,'
      '       CH.IN_OBS_UNICA,'
      '       CH.TP_TAB_SDA,'
      '       ISNULL(U.NM_USUARIO,'#39'--'#39') AS NM_ANALISTA,'
      '       ISNULL(U2.NM_USUARIO,'#39'--'#39') AS NM_ATENDENTE'
      'FROM TCLIENTE_HABILITACAO CH '
      
        '   LEFT JOIN TESTAGIO_PROCESSO EP ON EP.NR_PROCESSO_DES = :NR_PR' +
        'OCESSO'
      '   LEFT JOIN TPROCESSO P ON P.NR_PROCESSO = EP.NR_PROCESSO_ADM'
      
        '   LEFT JOIN TUSUARIO U ON U.CD_USUARIO = P.CD_ANALISTA_COMISSAR' +
        'IA'
      '   LEFT JOIN TUSUARIO U2 ON U2.CD_USUARIO =CH.CD_ATENDENTE '
      '   WHERE CH.CD_CLIENTE  =  :CD_CLIENTE'
      '  AND CH.CD_UNID_NEG = :CD_UNID_NEG'
      '  AND CH.CD_PRODUTO  = :CD_PRODUTO'
      '  AND CH.IN_ATIVO    = '#39'1'#39)
    Left = 400
    Top = 50
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptInput
        Value = ''
      end
      item
        DataType = ftString
        Name = 'CD_CLIENTE'
        ParamType = ptInput
        Value = ''
      end
      item
        DataType = ftString
        Name = 'CD_UNID_NEG'
        ParamType = ptInput
        Value = ''
      end
      item
        DataType = ftString
        Name = 'CD_PRODUTO'
        ParamType = ptInput
        Value = ''
      end>

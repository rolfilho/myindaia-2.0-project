  object qry_li_: TQuery
    CachedUpdates = True
    AfterOpen = qry_li_AfterOpen
    BeforePost = qry_li_BeforePost
    AfterPost = qry_li_AfterPost
    AfterCancel = qry_li_AfterOpen
    AfterDelete = qry_li_AfterDelete
    AfterScroll = qry_li_AfterScroll
    OnCalcFields = qry_li_CalcFields
    OnPostError = qry_li_PostError
    DatabaseName = 'DBBROKER'
    DataSource = ds_processo
    SQL.Strings = (
      'SELECT  L.NR_PROCESSO'
      #9'   ,L.NR_LI'
      #9'   ,L.DT_REGISTRO'
      #9'   ,L.DT_DEFERIMENTO'
      #9'   ,L.DT_VENCTO'
      #9'   ,L.IN_SUBSTITUIDA'
      #9'   ,L.NR_SUBSTITUIDA'
      #9'   ,L.IN_CANCELADO'
      #9'   ,L.TX_OBS_CANC'
      #9'   ,L.IN_UTILIZADO'
      #9'   ,L.IN_SEM_REPRESENTACAO'
      #9'   ,L.IN_LI_PRE_JA_EMBARCADO'
      #9'   ,L.DT_CONSULTA_SCX'
      #9'   ,L.IN_FILA_RECUPERAR'
      #9'   ,L.NR_INMETRO'
      #9'   ,L.NUMERO_IP_BRI'
      #9'   ,L.DATA_SOLICI_PRORROGACAO '#9'   '
      #9'   ,CASE WHEN CONT.JA_CONSULTADA >= 1'
      #9'         THEN 1'
      #9'         ELSE 0'
      #9'    END      AS LI_CONSULTADA   '
      '      , CD_POSTO_ANVISA'
      '      , NR_PROCESSO_ANVISA   '
      '      , NR_EXPEDIENTE_ANVISA '
      '      , IN_PRE_EMBARQUE      '
      '      , DT_SOLICITACAO       '
      '      , CD_USUARIO_EMISSOR       '
      '      , ITENS.QT_ITENS AS QT_ITENS             '
      '      , DT_APTO_FIN_DOSSIE   '
      '      , DT_FIN_DOSSIE        '
      '      , NR_DOSSIE            '
      '      , NR_DOSSIE_POS'
      '      , DT_DOCTOS_DOSSIE     '
      '      , DT_EMISSAO_GRU       '
      '      , NR_TRANSACAO_GRU     '
      '      , DT_PGMTO_GRU         '
      '      , ISNULL( CD_CANAL,'#39'4'#39') AS CD_CANAL'
      '      , NR_PROCESSO_LECOM'
      '      , DT_SOLICITACAO_REQUISITO'
      '      , DT_RECEPCAO_REQ_SANITARIO'
      '      , DT_LECOM'
      '      , DT_LI_AUTORIZADA'
      '      , DT_PROTOCOLO_REMOTO_OK'
      '      , IN_INSPECAO '
      '      , DT_INSPECAO'
      '      , IN_COLETA_AMOSTRA'
      '      , DT_COLETA_AMOSTRA'
      '      , NR_INFA'
      '      , TX_OBS_LI_NOVA_SUB'
      '      , IN_EXIGENCIA'
      '      , IN_LPCO'
      '      , NR_LPCO'
      '  FROM TPROCESSO_LI  L (NOLOCK)'
      '  OUTER APPLY ('
      
        '   SELECT COUNT(*) JA_CONSULTADA                                ' +
        '                              '
      '     FROM TPROCESSO_LI  A (NOLOCK)      '
      
        '     LEFT JOIN OPERA'#199#195'O_COM_TRATAMENTO O (NOLOCK) ON O.NR_OPER_T' +
        'RAT_PREV = A.NR_LI'
      
        '    WHERE  ((ISNULL(A.IN_FILA_RECUPERAR, '#39'0'#39') = '#39'1'#39') OR (O.NR_OP' +
        'ER_TRAT_PREV IS NOT NULL))'
      '    AND A.NR_LI       = L.NR_LI'
      '    AND A.NR_PROCESSO = L.NR_PROCESSO ) CONT'
      '  OUTER APPLY( SELECT COUNT(*) AS QT_ITENS'
      '                FROM DETALHE_MERC_COM_TRATAMENTO D(NOLOCK)'
      '                WHERE D.NR_OPER_TRAT_PREV   =L.NR_LI) ITENS'
      '    '
      ' WHERE NR_PROCESSO    = :NR_PROCESSO')
    UpdateObject = upd_li
    Left = 74
    Top = 470
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
        Size = 19
      end>

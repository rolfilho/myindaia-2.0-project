      'WHERE'
      '  NR_PROCESSO = :OLD_NR_PROCESSO')
    InsertSQL.Strings = (
      ''
      'INSERT INTO TPROCESSO'
      
        '  (NR_PROCESSO, CD_UNID_NEG, CD_PRODUTO, CD_USUARIO, DT_ABERTURA' +
        ', CD_CLIENTE, '
      
        '   CD_CELULA, CD_ANALISTA_COMISSARIA, CD_SERVICO, CD_REPRESENTAN' +
        'TE, CD_TRANSP_NAC_DOC, '
      
        '   CD_TRANSP_NAC, IN_IMP_ARM, NR_DTA, CD_TAB_SDA, CD_AREA, TX_ME' +
        'RCADORIA, '
      
        '   TX_OBSERVACOES, CD_RESTRICAO, CD_LIBERADOR, DT_LIBERACAO, CD_' +
        'DESPACHANTE, '
      
        '   IN_ETIQUETA, IN_LIBERADO, IN_CANCELADO, IN_PRODUCAO, TX_OBS_I' +
        'NT, IN_REL_LEAD_TIME, '
      
        '   NR_PRESENCA_CARGA, DT_PRESENCA_CARGA, NR_DI, NR_DA, NR_PERIOD' +
        'O_ARMAZENAGEM, '
      
        '   DT_VENCTO_ARMAZENAGEM, NR_DDE, DT_REG_DDE, IN_ENTREPOSTO, NR_' +
        'PROCESSO_OR_ENTREPOSTO, '
      
        '   NR_PROCESSO_VINC, ID_CODIGO_INSTR_DESEMB, CD_TP_DTA, CD_GRUPO' +
        ', TP_ESTUFAGEM, '
      
        '   IN_MERC_PERIGOSA, IN_URGENTE, IN_DSE, NR_PRAZO_VENCTO_ARM, IN' +
        '_PROCESSO_MAPA, '
      
        '   IN_APENAS_EMISSAO_DOCTOS, IN_TRANSMITE_SEM_PREVISAO, CD_USUAR' +
        'IO_LIB_TRANS_DI, '
      
        '   DT_LIB_TRANS_DI, NR_DEPOT, CD_RUC, CD_DUE, TX_EMAIL_PROCESSO,' +
        '   CD_DUIMP, IN_MADEIRA_CONDENADA,'
      '   CD_CHAVE_ACESSO_DUE, IN_CSI_MAPA, IN_COBRANCA_ECAC)'
      'VALUES'
      
        '  (:NR_PROCESSO, :CD_UNID_NEG, :CD_PRODUTO, :CD_USUARIO, :DT_ABE' +
        'RTURA, '
      
        '   :CD_CLIENTE, :CD_CELULA, :CD_ANALISTA_COMISSARIA, :CD_SERVICO' +
        ', :CD_REPRESENTANTE, '
      
        '   :CD_TRANSP_NAC_DOC, :CD_TRANSP_NAC, :IN_IMP_ARM, :NR_DTA, :CD' +
        '_TAB_SDA, '
      
        '   :CD_AREA, :TX_MERCADORIA, :TX_OBSERVACOES, :CD_RESTRICAO, :CD' +
        '_LIBERADOR, '
      
        '   :DT_LIBERACAO, :CD_DESPACHANTE, :IN_ETIQUETA, :IN_LIBERADO, :' +
        'IN_CANCELADO, '
      
        '   :IN_PRODUCAO, :TX_OBS_INT, :IN_REL_LEAD_TIME, :NR_PRESENCA_CA' +
        'RGA, :DT_PRESENCA_CARGA, '
      
        '   :NR_DI, :NR_DA, :NR_PERIODO_ARMAZENAGEM, :DT_VENCTO_ARMAZENAG' +
        'EM, :NR_DDE, '
      
        '   :DT_REG_DDE, :IN_ENTREPOSTO, :NR_PROCESSO_OR_ENTREPOSTO, :NR_' +
        'PROCESSO_VINC, '
      
        '   :ID_CODIGO_INSTR_DESEMB, :CD_TP_DTA, :CD_GRUPO, :TP_ESTUFAGEM' +
        ', :IN_MERC_PERIGOSA, '
      
        '   :IN_URGENTE, :IN_DSE, :NR_PRAZO_VENCTO_ARM, :IN_PROCESSO_MAPA' +
        ', :IN_APENAS_EMISSAO_DOCTOS, '
      
        '   :IN_TRANSMITE_SEM_PREVISAO, :CD_USUARIO_LIB_TRANS_DI, :DT_LIB' +
        '_TRANS_DI, :NR_DEPOT,'
      
        '   :CD_RUC, :CD_DUE, :TX_EMAIL_PROCESSO,  :CD_DUIMP, :IN_MADEIRA' +
        '_CONDENADA,'
      '   :CD_CHAVE_ACESSO_DUE, :IN_CSI_MAPA, :IN_COBRANCA_ECAC)')
    DeleteSQL.Strings = (
      'delete from TPROCESSO'
      'where'
      '  NR_PROCESSO = :OLD_NR_PROCESSO')
    Left = 91
    Top = 6
  end

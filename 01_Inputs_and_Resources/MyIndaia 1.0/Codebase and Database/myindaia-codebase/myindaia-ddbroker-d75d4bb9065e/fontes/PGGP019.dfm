  object qry_processo_: TQuery
    CachedUpdates = True
    BeforeOpen = qry_processo_BeforeOpen
    AfterOpen = qry_processo_AfterOpen
    AfterClose = qry_processo_AfterClose
    AfterInsert = qry_processo_AfterInsert
    BeforeEdit = qry_processo_BeforeEdit
    AfterPost = qry_processo_AfterPost
    AfterDelete = qry_processo_AfterPost
    AfterScroll = qry_processo_AfterScroll
    OnCalcFields = qry_processo_CalcFields
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT NR_PROCESSO, CD_UNID_NEG, CD_PRODUTO, CD_USUARIO, DT_ABER' +
        'TURA, CD_CLIENTE, CD_CELULA, CD_ANALISTA_COMISSARIA,'
      
        '       CD_SERVICO, CD_REPRESENTANTE, CD_TRANSP_NAC_DOC, CD_TRANS' +
        'P_NAC, IN_IMP_ARM, NR_DTA, CD_TAB_SDA, '
      
        '       CD_AREA, TX_MERCADORIA, TX_OBSERVACOES, CD_RESTRICAO, CD_' +
        'LIBERADOR, DT_LIBERACAO,'
      
        '       CD_DESPACHANTE, IN_ETIQUETA, IN_LIBERADO, IN_CANCELADO, I' +
        'N_PRODUCAO, TX_OBS_INT, IN_REL_LEAD_TIME,'
      
        '       NR_PRESENCA_CARGA, DT_PRESENCA_CARGA, NR_DI, NR_DA, NR_PE' +
        'RIODO_ARMAZENAGEM,'
      
        '       DT_VENCTO_ARMAZENAGEM, NR_DDE, DT_REG_DDE, IN_ENTREPOSTO,' +
        ' NR_PROCESSO_OR_ENTREPOSTO, NR_PROCESSO_VINC,'
      
        '       ID_CODIGO_INSTR_DESEMB, CD_TP_DTA, CD_GRUPO, TP_ESTUFAGEM' +
        ', IN_MERC_PERIGOSA, IN_URGENTE, IN_DSE, NR_PRAZO_VENCTO_ARM,'
      
        '       NR_DEPOT, IN_PROCESSO_MAPA, IN_APENAS_EMISSAO_DOCTOS, ISN' +
        'ULL(IN_TRANSMITE_SEM_PREVISAO, '#39'0'#39') AS IN_TRANSMITE_SEM_PREVISAO' +
        ', '
      
        '       CD_USUARIO_LIB_TRANS_DI, DT_LIB_TRANS_DI, CD_RUC, CD_DUE ' +
        ', TX_EMAIL_PROCESSO, CD_DUIMP, ISNULL(IN_MADEIRA_CONDENADA, '#39'0'#39')' +
        ' AS IN_MADEIRA_CONDENADA, '
      
        '       CD_CHAVE_ACESSO_DUE, ISNULL(IN_CSI_MAPA, '#39'0'#39') AS IN_CSI_M' +
        'APA, ISNULL(IN_COBRANCA_ECAC, '#39'0'#39') AS IN_COBRANCA_ECAC'
      'FROM   TPROCESSO (NOLOCK)'
      
        'WHERE  NR_PROCESSO = :NR_PROCESSO AND ( ( IN_PEDIDO = '#39'0'#39' ) OR (' +
        ' IN_PEDIDO IS NULL ) OR ( IN_PEDIDO = '#39'2'#39' ) OR ( IN_PEDIDO = '#39'1'#39 +
        ' ) )')
    UpdateObject = updProcesso
    Left = 23
    Top = 4

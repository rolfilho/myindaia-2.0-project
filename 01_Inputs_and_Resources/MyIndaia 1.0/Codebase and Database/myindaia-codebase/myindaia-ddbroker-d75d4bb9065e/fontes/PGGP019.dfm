  object qry_proc_em_: TQuery
    CachedUpdates = True
    AfterOpen = qry_proc_em_AfterOpen
    AfterInsert = qry_proc_em_AfterInsert
    AfterPost = qry_proc_em_AfterPost
    AfterDelete = qry_proc_em_AfterDelete
    AfterScroll = qry_proc_em_AfterScroll
    OnCalcFields = qry_proc_im_CalcFields
    DatabaseName = 'DBBROKER'
    DataSource = ds_processo
    RequestLive = True
    SQL.Strings = (
      'SELECT NR_PROCESSO, CD_ANALISTA_COMISSARIA, CD_CONTATO,'
      
        '       CD_MOEDA_MLE, VL_MLE_MNEG, VL_MLE_MN, CD_MOEDA_FRETE, TP_' +
        'FRETE, VL_FRETE_PREPAID_MNEG,'
      
        '       VL_FRETE_MN, CD_AGENTE, VL_CIF_MN, CD_ARMAZEM_ATRACACAO, ' +
        'CD_ARMAZEM_ESTOCAGEM,'
      
        '       CD_EMBARCACAO, NR_VIAGEM, CD_LOCAL_EMBARQUE, CD_LOCAL_DES' +
        'EMBARQUE, CD_PAIS_ORIGEM,'
      
        '       TP_BANCO_EXP, CD_BANCO_EXP, VL_FRETE_CUSTO, VL_M3, CD_AGE' +
        'NTE_SEGURO, NR_AVERBACAO,'
      
        '       DT_ESTOCAGEM, NR_CONHECIMENTO, DT_CONHECIMENTO, NR_CONHEC' +
        'IMENTO_MASTER, NR_DDE,'
      
        '       NR_PROCESSO_EXP_TEMP, DT_VENC_PROCESSO_EXP_TEMP, NR_DI_RE' +
        'TORNO, CD_PAIS_DESTINO,'
      
        '       VL_PESO_BRUTO, VL_PESO_LIQUIDO, CD_LINGUA_PEDIDO, CD_IMPO' +
        'RTADOR, CD_TAB_FRETE,'
      
        '       VL_FRETE_COLLECT_MNEG, NR_PLACA_VEICULO, NR_CAMINHAO, NR_' +
        'VOO,'
      
        '       NR_MANIFESTO,DOCS_ENVIADO_PARA, VL_SEGURO_MNEG, VL_FRETE_' +
        'TNAC_MNEG, '
      
        '       NM_CONEXAO, CD_FRONTEIRA, IN_COURRIER, IN_PRODUTO_IMPORTA' +
        'DO, '
      
        '       VL_TRANSIT_TIME, CD_CONSIGNEE, TP_CONSIGNEE, CD_LOCAL_ENT' +
        'REGA,'
      
        '       CD_ACORDO,QNTD_ACORDO, TP_CERTIFICADO,TP_ENVIO_CERTIFICAD' +
        'O,'
      
        '       CD_INCOTERM, CD_RESP_DRAFT, CD_RESP_DESEMB, CD_TRANSPORTA' +
        'DOR, '
      
        '       IN_PROCESSO_MAPA, IN_APENAS_EMISSAO_DOCTOS, VL_LEAD_TIME,' +
        ' NR_DEPOT,'
      
        '       CD_NOTIFY1_PROC, CD_NOTIFY2_PROC, TP_NOTIFY1_PROC, TP_NOT' +
        'IFY2_PROC, '
      
        '       TX_MARCACAO_VOL_PROC, VL_SEGURO_MN, VL_DESCONTO_MN, VL_AC' +
        'RESCIMO_MN, '
      
        '       CD_LOCAL_TRANSBORDO, CD_LOCAL_TRANSBORDO2, CD_LOCAL_TRANS' +
        'BORDO3, '
      
        '       BOOKING_CONTRACT_NUMBER, BOOKING_CONTRACT_PARTY, BOOKING_' +
        'MOVE_TYPE,'
      
        '       BOOKING_HS_CODE, BOOKING_CUSTOMER_COMMENTS, BOOKING_PARTN' +
        'ER_EMAIL, CD_OPERADOR_TANQUE'
      'FROM   TPROCESSO P (NOLOCK)'
      'WHERE  NR_PROCESSO = :NR_PROCESSO')
    UpdateObject = upd_proc_em_
    Left = 475
    Top = 571
    ParamData = <

  object qry_sistemas_dicas: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT TX_TITULO_DICA, TX_TEXTO_DICA, CD_USUARIO_CRIADOR, NM_USU' +
        'ARIO, NM_PATH_MANUAL, DENSE_RANK() OVER (ORDER BY TIPO, ORDEM) A' +
        'S ORDEM, TIPO'
      
        'FROM (SELECT SD.TX_TITULO_DICA, SD.TX_TEXTO_DICA, SD.CD_USUARIO_' +
        'CRIADOR, U.NM_USUARIO,NM_PATH_MANUAL, DENSE_RANK() OVER (ORDER B' +
        'Y CD_SISTEMAS_DICAS) AS ORDEM, 1 AS TIPO'
      #9'  FROM TSISTEMAS_DICAS SD (NOLOCK)'
      
        #9'     INNER JOIN TUSUARIO U (NOLOCK) ON U.CD_USUARIO = SD.CD_USU' +
        'ARIO_CRIADOR'
      '      WHERE CD_ROTINA IN (SELECT CD_ROTINA'
      '                          FROM TCONTROLE_ACESSO'#9
      '                          WHERE IN_ACESSO='#39'1'#39
      #9#9#9'                AND CD_CARGO IN (SELECT CD_CARGO'
      '                                             FROM TUSUARIO'
      
        '                                             WHERE CD_USUARIO = ' +
        ':CD_USUARIO  ))'
      '          OR (CD_MODULO IN (SELECT CD_MODULO'
      '                            FROM TCONTROLE_ACESSO'
      '                            WHERE IN_ACESSO = '#39'1'#39
      '                              AND CD_CARGO IN (SELECT CD_CARGO'
      '                                               FROM TUSUARIO'
      
        '                                               WHERE CD_USUARIO ' +
        '= :CD_USUARIO  ))'
      '         AND ISNULL(CD_ROTINA, '#39#39') = '#39#39')'
      
        '         OR (CD_SISTEMAS IS NULL AND CD_MODULO IS NULL AND CD_RO' +
        'TINA IS NULL) '
      
        '         OR (CD_SISTEMAS = '#39'1'#39' AND CD_MODULO IS NULL AND CD_ROTI' +
        'NA IS NULL)'
      'UNION'
      
        #9'SELECT SD.TX_TITULO_DICA, SD.TX_TEXTO_DICA, SD.CD_USUARIO_CRIAD' +
        'OR, U.NM_USUARIO,NM_PATH_MANUAL, DENSE_RANK() OVER (ORDER BY CD_' +
        'SISTEMAS_DICAS) AS ORDEM, 2 AS TIPO'
      #9'FROM TSISTEMAS_DICAS SD (NOLOCK)'
      
        #9'    INNER JOIN TUSUARIO U (NOLOCK) ON U.CD_USUARIO = SD.CD_USUA' +
        'RIO_CRIADOR'
      #9'WHERE '
      #9'    CD_ROTINA in '
      #9'        (SELECT CD_ROTINA'
      #9#9#9' FROM TCONTROLE_ACESSO '
      #9#9#9' WHERE IN_ACESSO='#39'1'#39'AND CD_CARGO IN '
      #9#9#9'    (SELECT CD_CARGO '
      #9#9#9'     FROM TUSUARIO '
      #9#9#9'     WHERE CD_USUARIO = :CD_USUARIO ))'
      #9#9#9#9'    OR CD_MODULO IN '
      #9#9#9#9'        (SELECT CD_MODULO '
      #9#9#9#9'         FROM TCONTROLE_ACESSO '
      #9#9#9#9'         WHERE IN_ACESSO = '#39'1'#39
      '                  AND CD_CARGO IN'
      '                   (SELECT CD_CARGO'
      '                    FROM TUSUARIO'
      '                    WHERE CD_USUARIO = :CD_USUARIO ))'
      
        '        OR (CD_SISTEMAS = '#39'1'#39' AND CD_MODULO IS NULL AND CD_ROTIN' +
        'A IS NULL)'
      'UNION'
      
        #9'SELECT SD.TX_TITULO_DICA, SD.TX_TEXTO_DICA, SD.CD_USUARIO_CRIAD' +
        'OR, U.NM_USUARIO,NM_PATH_MANUAL, DENSE_RANK() OVER (ORDER BY CD_' +
        'SISTEMAS_DICAS) AS ORDEM, 3 AS TIPO'
      '    FROM TSISTEMAS_DICAS SD (NOLOCK)'
      
        #9'    INNER JOIN TUSUARIO U (NOLOCK) ON U.CD_USUARIO = SD.CD_USUA' +
        'RIO_CRIADOR'
      #9'WHERE'
      #9'    CD_ROTINA in (SELECT CD_ROTINA'
      #9'                  FROM TCONTROLE_ACESSO'
      #9'                  WHERE IN_ACESSO='#39'1'#39'AND CD_CARGO IN'
      #9#9#9#9#9'    (SELECT CD_CARGO '
      #9#9#9#9#9'     FROM TUSUARIO '
      #9#9#9#9#9'     WHERE CD_USUARIO = :CD_USUARIO ))'
      #9#9#9#9#9'      OR CD_MODULO IN '
      #9#9#9#9#9'        (SELECT CD_MODULO '
      #9#9#9#9#9'           FROM TCONTROLE_ACESSO WHERE IN_ACESSO = '#39'1'#39
      #9#9#9#9#9#9#9'        AND CD_CARGO IN '
      #9#9#9#9#9#9#9'          (SELECT CD_CARGO'
      #9#9#9#9#9#9#9#9#9'   FROM TUSUARIO'
      #9#9#9#9#9#9#9#9#9'   WHERE CD_USUARIO = :CD_USUARIO ))'
      
        #9#9'OR (CD_SISTEMAS = '#39'1'#39' AND CD_MODULO IS NULL AND CD_ROTINA IS N' +
        'ULL)) AS TABLE1'
      'ORDER BY ORDEM')
    Left = 232
    Top = 120
    ParamData = <
      item
        DataType = ftString
        Name = 'CD_USUARIO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_USUARIO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_USUARIO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_USUARIO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_USUARIO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_USUARIO'
        ParamType = ptInput
      end>
    object qry_sistemas_dicasTX_TITULO_DICA: TStringField
      FieldName = 'TX_TITULO_DICA'
      FixedChar = True
      Size = 255
    end
    object qry_sistemas_dicasTX_TEXTO_DICA: TMemoField
      FieldName = 'TX_TEXTO_DICA'
      BlobType = ftMemo
    end
    object qry_sistemas_dicasCD_USUARIO_CRIADOR: TStringField
      FieldName = 'CD_USUARIO_CRIADOR'
      FixedChar = True
      Size = 4
    end
    object qry_sistemas_dicasNM_USUARIO: TStringField
      FieldName = 'NM_USUARIO'
      FixedChar = True
      Size = 50
    end
    object qry_sistemas_dicasORDEM: TFloatField
      FieldName = 'ORDEM'
    end
    object qry_sistemas_dicasNM_PATH_MANUAL: TStringField
      FieldName = 'NM_PATH_MANUAL'
      FixedChar = True
      Size = 80
    end
    object qry_sistemas_dicasTIPO: TIntegerField
      FieldName = 'TIPO'
    end
  end

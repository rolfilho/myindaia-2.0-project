  object qry_dicas: TQuery
    CachedUpdates = True
    BeforePost = qry_dicasBeforePost
    AfterPost = qry_dicasAfterPost
    AfterDelete = qry_dicasAfterDelete
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT CD_SISTEMAS_DICAS, CD_SISTEMAS, SD.CD_MODULO, SD.CD_ROTIN' +
        'A, TX_TITULO_DICA, TX_TEXTO_DICA, NM_PATH_MANUAL, CD_USUARIO_CRI' +
        'ADOR, NM_USUARIO,'
      '  DT_INCLUSAO, NM_SISTEMA, NM_MODULO, NM_ROTINA'
      'FROM TSISTEMAS_DICAS SD'
      '  LEFT JOIN TSISTEMAS S ON  S.CD_SISTEMA = SD.CD_SISTEMAS'
      '  LEFT JOIN TMODULO M ON SD.CD_MODULO = M.CD_MODULO'
      '  LEFT JOIN TMODULO_ROTINA MR ON SD.CD_ROTINA = MR.CD_ROTINA'
      '  LEFT JOIN TUSUARIO U ON SD.CD_USUARIO_CRIADOR=U.CD_USUARIO')
    UpdateObject = up_dicas
    Left = 176
    Top = 24
    object qry_dicasCD_SISTEMAS_DICAS: TIntegerField
      FieldName = 'CD_SISTEMAS_DICAS'
    end
    object qry_dicasCD_SISTEMAS: TIntegerField

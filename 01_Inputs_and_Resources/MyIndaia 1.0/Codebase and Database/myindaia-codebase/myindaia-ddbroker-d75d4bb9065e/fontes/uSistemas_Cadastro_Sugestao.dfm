  object up_dicas: TUpdateSQL
    ModifySQL.Strings = (
      'update TSISTEMAS_DICAS'
      'set'
      '  CD_SISTEMAS_DICAS = :CD_SISTEMAS_DICAS,'
      '  CD_SISTEMAS = :CD_SISTEMAS,'
      '  CD_MODULO = :CD_MODULO,'
      '  CD_ROTINA = :CD_ROTINA,'
      '  TX_TITULO_DICA = :TX_TITULO_DICA,'
      '  TX_TEXTO_DICA = :TX_TEXTO_DICA,'
      '  NM_PATH_MANUAL = :NM_PATH_MANUAL,'
      '  CD_USUARIO_CRIADOR = :CD_USUARIO_CRIADOR,'
      '  DT_INCLUSAO = :DT_INCLUSAO'
      'where'
      '  CD_SISTEMAS_DICAS = :OLD_CD_SISTEMAS_DICAS')
    InsertSQL.Strings = (
      'insert into TSISTEMAS_DICAS'
      
        '  (CD_SISTEMAS_DICAS, CD_SISTEMAS, CD_MODULO, CD_ROTINA, TX_TITU' +
        'LO_DICA, '
      
        '   TX_TEXTO_DICA, NM_PATH_MANUAL, CD_USUARIO_CRIADOR, DT_INCLUSA' +
        'O)'
      'values'
      
        '  (:CD_SISTEMAS_DICAS, :CD_SISTEMAS, :CD_MODULO, :CD_ROTINA, :TX' +
        '_TITULO_DICA, '
      
        '   :TX_TEXTO_DICA, :NM_PATH_MANUAL, :CD_USUARIO_CRIADOR, :DT_INC' +
        'LUSAO)')
    DeleteSQL.Strings = (
      'delete from TSISTEMAS_DICAS'
      'where'
      '  CD_SISTEMAS_DICAS = :OLD_CD_SISTEMAS_DICAS')
    Left = 296
    Top = 24
  end
end

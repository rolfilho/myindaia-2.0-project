  object updCadastroViagem: TUpdateSQL
    ModifySQL.Strings = (
      'update TVIAGEM'
      'set'
      '  CD_UNID_NEG = :CD_UNID_NEG,'
      '  CD_PRODUTO = :CD_PRODUTO,'
      '  CD_LOCAL = :CD_LOCAL,'
      '  CD_EMBARCACAO = :CD_EMBARCACAO,'
      '  NR_VIAGEM = :NR_VIAGEM,'
      '  DT_ESPERADA = :DT_ESPERADA,'
      '  DT_ENT = :DT_ENT,'
      '  NR_MANIFESTO = :NR_MANIFESTO,'
      '  CD_ARMAZEM_ATRACACAO = :CD_ARMAZEM_ATRACACAO'
      'where'
      '  CD_UNID_NEG = :OLD_CD_UNID_NEG and'
      '  CD_PRODUTO = :OLD_CD_PRODUTO and'
      '  CD_LOCAL = :OLD_CD_LOCAL and'
      '  CD_EMBARCACAO = :OLD_CD_EMBARCACAO and'
      '  NR_VIAGEM = :OLD_NR_VIAGEM')
    InsertSQL.Strings = (
      'insert into TVIAGEM'
      
        '  (CD_UNID_NEG, CD_PRODUTO, CD_LOCAL, CD_EMBARCACAO, NR_VIAGEM, ' +
        'DT_ESPERADA, '
      '   DT_ENT, NR_MANIFESTO, CD_ARMAZEM_ATRACACAO)'
      'values'
      
        '  (:CD_UNID_NEG, :CD_PRODUTO, :CD_LOCAL, :CD_EMBARCACAO, :NR_VIA' +
        'GEM, :DT_ESPERADA, '
      '   :DT_ENT, :NR_MANIFESTO, :CD_ARMAZEM_ATRACACAO)')
    DeleteSQL.Strings = (
      'delete from TVIAGEM'
      'where'
      '  CD_UNID_NEG = :OLD_CD_UNID_NEG and'
      '  CD_PRODUTO = :OLD_CD_PRODUTO and'
      '  CD_LOCAL = :OLD_CD_LOCAL and'
      '  CD_EMBARCACAO = :OLD_CD_EMBARCACAO and'
      '  NR_VIAGEM = :OLD_NR_VIAGEM')
    Left = 658
    Top = 526
  end

  object qry_unidade_negocio: TQuery
    CachedUpdates = True
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'select top 1 '
      
        '(SELECT '#39'- '#39'+isnull(ltrim(rtrim(END_UNID_NEG)),'#39#39')+'#39','#39'+ isnull(l' +
        'trim(rtrim(END_BAIRRO)),'#39#39') +'#39'- '#39'+'#39'Fone'#39'+ISNULL(NR_FONE,'#39#39') +'#39'/'#39 +
        '+'#39'Fax'#39'+ isnull(NR_FAX1,'#39#39')  FROM TUNID_NEG (NOLOCK) WHERE CD_UNI' +
        'D_NEG = '#39'01'#39') END_STS,'
      
        '(SELECT '#39'- '#39'+isnull(ltrim(rtrim(END_UNID_NEG)),'#39#39')+'#39','#39'+ isnull(l' +
        'trim(rtrim(END_BAIRRO)),'#39#39') +'#39'- '#39'+'#39'Fone'#39'+ISNULL(NR_FONE,'#39#39') +'#39'/'#39 +
        '+'#39' Fax'#39'+ isnull(NR_FAX1,'#39#39') FROM TUNID_NEG (NOLOCK) WHERE CD_UNI' +
        'D_NEG = '#39'02'#39') END_RIO,'
      
        '(SELECT '#39'- '#39'+isnull(ltrim(rtrim(END_UNID_NEG)),'#39#39')+'#39','#39'+ isnull(l' +
        'trim(rtrim(END_BAIRRO)),'#39#39') +'#39'- '#39'+'#39'Fone'#39'+ISNULL(NR_FONE,'#39#39') + is' +
        'null(NR_FAX1,'#39#39')            FROM TUNID_NEG (NOLOCK) WHERE CD_UNI' +
        'D_NEG = '#39'07'#39') END_SP')
    Left = 122
    Top = 466
    object qry_unidade_negocioEND_STS: TStringField
      FieldName = 'END_STS'
      FixedChar = True
      Size = 136
    end

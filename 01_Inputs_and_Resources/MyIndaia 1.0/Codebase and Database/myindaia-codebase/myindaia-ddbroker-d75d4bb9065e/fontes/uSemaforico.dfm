  object qryCadastroViagem: TQuery
    CachedUpdates = True
    AfterPost = qryCadastroViagemAfterPost
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'SELECT'
      '  V.CD_UNID_NEG'
      ', V.CD_PRODUTO'
      ', V.CD_LOCAL'
      ', L.DESCRICAO AS NM_PORTO'
      ', V.CD_EMBARCACAO'
      ', ISNULL(ES.ID_EMBARCACAO, 0) ID_EMBARCACAO'
      ', E.NM_EMBARCACAO'
      ', V.NR_VIAGEM'
      ', V.DT_ESPERADA'
      ', V.DT_ENT'
      ', V.NR_MANIFESTO'
      ', V.NR_VIAGEM_ARMADOR'
      ', ISNULL(V.CD_ARMAZEM_ATRACACAO, '#39#39') CD_ARMAZEM_ATRACACAO'
      ', ISNULL(A.NM_ARMAZEM,'#39#39') NM_ARMAZEM'
      ', CASE WHEN V.CD_PRODUTO IN ('#39'01'#39','#39'03'#39') '
      
        '       THEN ( CASE WHEN  CONVERT(VARCHAR,V.DT_ESPERADA,103)= CON' +
        'VERT(VARCHAR,GETDATE(),103) '
      '                     AND V.DT_ENT IS NULL'
      '                   THEN '#39'1.PREVISTO'#39
      '                   WHEN V.DT_ESPERADA IS NOT NULL '
      '                    AND V.DT_ENT IS NOT NULL'
      '                   THEN '#39'0.ATRACADO'#39' '
      '                   ELSE '#39'2'#39'   '
      '              END ) '
      '       WHEN V.CD_PRODUTO IN ('#39'02'#39','#39'10'#39')'
      
        '       THEN ( CASE WHEN  V.DT_ESPERADA IS NOT NULL AND V.DT_ENT ' +
        'IS NOT NULL'
      '                     AND ISNULL(V.CD_ARMAZEM_ATRACACAO,'#39#39')<>'#39#39
      '                   THEN '#39'0.SAIDO'#39
      
        '                   WHEN  CONVERT(VARCHAR,V.DT_ESPERADA,103)=CONV' +
        'ERT(VARCHAR,GETDATE(),103) '
      '                     AND V.DT_ENT IS NULL '
      '                     AND ISNULL(V.CD_ARMAZEM_ATRACACAO,'#39#39')='#39#39
      '                   THEN '#39'2.PREVISTO'#39
      '                   WHEN V.DT_ESPERADA IS NOT NULL '
      '                    AND V.DT_ENT IS NULL '
      '                    AND ISNULL(V.CD_ARMAZEM_ATRACACAO,'#39#39')<>'#39#39
      '                   THEN '#39'1.ATRACADO'#39' '
      '                   ELSE '#39'3'#39'  '
      '              END )'
      '  END STATUS_INDEXADO   '
      ', SUBSTRING('
      ' (CASE WHEN V.CD_PRODUTO IN ('#39'01'#39','#39'03'#39') '
      
        '       THEN ( CASE WHEN  CONVERT(VARCHAR,V.DT_ESPERADA,103)= CON' +
        'VERT(VARCHAR,GETDATE(),103) '
      '                     AND V.DT_ENT IS NULL'
      '                   THEN '#39'1.PREVISTO'#39
      '                   WHEN V.DT_ESPERADA IS NOT NULL '
      '                    AND V.DT_ENT IS NOT NULL'
      '                   THEN '#39'0.ATRACADO'#39' '
      '                   ELSE '#39'2'#39'   '
      '              END ) '
      '       WHEN V.CD_PRODUTO IN ('#39'02'#39','#39'10'#39')'
      
        '       THEN ( CASE WHEN  V.DT_ESPERADA IS NOT NULL AND V.DT_ENT ' +
        'IS NOT NULL'
      '                     AND ISNULL(V.CD_ARMAZEM_ATRACACAO,'#39#39')<>'#39#39
      '                   THEN '#39'0.SAIDO'#39
      
        '                   WHEN  CONVERT(VARCHAR,V.DT_ESPERADA,103)=CONV' +
        'ERT(VARCHAR,GETDATE(),103) '
      '                     AND V.DT_ENT IS NULL '
      '                     AND ISNULL(V.CD_ARMAZEM_ATRACACAO,'#39#39')='#39#39
      '                   THEN '#39'2.PREVISTO'#39
      '                   WHEN V.DT_ESPERADA IS NOT NULL '
      '                    AND V.DT_ENT IS NULL '
      '                    AND ISNULL(V.CD_ARMAZEM_ATRACACAO,'#39#39')<>'#39#39
      '                   THEN '#39'1.ATRACADO'#39' '
      '                   ELSE '#39'3'#39'  '
      '              END )'
      '  END),3,20) AS  STATUS    '
      ', CASE WHEN SUBSTRING('
      ' (CASE WHEN V.CD_PRODUTO IN ('#39'01'#39','#39'03'#39') '
      
        '       THEN ( CASE WHEN  CONVERT(VARCHAR,V.DT_ESPERADA,103)= CON' +
        'VERT(VARCHAR,GETDATE(),103) '
      '                     AND V.DT_ENT IS NULL'
      '                   THEN '#39'1.PREVISTO'#39
      '                   WHEN V.DT_ESPERADA IS NOT NULL '
      '                    AND V.DT_ENT IS NOT NULL'
      '                   THEN '#39'0.ATRACADO'#39' '
      '                   ELSE '#39'2'#39'   '
      '              END ) '
      '       WHEN V.CD_PRODUTO IN ('#39'02'#39','#39'10'#39')'
      
        '       THEN ( CASE WHEN  V.DT_ESPERADA IS NOT NULL AND V.DT_ENT ' +
        'IS NOT NULL'
      '                     AND ISNULL(V.CD_ARMAZEM_ATRACACAO,'#39#39')<>'#39#39
      '                   THEN '#39'0.SAIDO'#39
      
        '                   WHEN  CONVERT(VARCHAR,V.DT_ESPERADA,103)=CONV' +
        'ERT(VARCHAR,GETDATE(),103) '
      '                     AND V.DT_ENT IS NULL '
      '                     AND ISNULL(V.CD_ARMAZEM_ATRACACAO,'#39#39')='#39#39
      '                   THEN '#39'2.PREVISTO'#39
      '                   WHEN V.DT_ESPERADA IS NOT NULL '
      '                    AND V.DT_ENT IS NULL '
      '                    AND ISNULL(V.CD_ARMAZEM_ATRACACAO,'#39#39')<>'#39#39
      '                   THEN '#39'1.ATRACADO'#39' '
      '                   ELSE '#39'3'#39'  '
      '              END )'
      '  END),3,20) = '#39#39
      '   THEN '#39#39
      '   ELSE ISNULL(A.NM_ARMAZEM,'#39#39')'
      '   END  CALC_NM_ARMAZEM  '
      ''
      ' FROM TVIAGEM                     V  (NOLOCK)'
      
        'LEFT  JOIN TARMAZEM               A  (NOLOCK) ON A.CD_ARMAZEM   ' +
        ' = V.CD_ARMAZEM_ATRACACAO'
      
        'INNER JOIN TEMBARCACAO            E  (NOLOCK) ON E.CD_EMBARCACAO' +
        ' = V.CD_EMBARCACAO'
      
        '--INNER JOIN TPROCESSO              P  (NOLOCK) ON P.CD_EMBARCAC' +
        'AO = V.CD_EMBARCACAO AND P.NR_VIAGEM = V.NR_VIAGEM'
      
        'LEFT  JOIN TLOCAL_EMBARQUE        L  (NOLOCK) ON L.CODIGO       ' +
        ' = V.CD_LOCAL'
      
        'LEFT  JOIN TEMBARCACAO_SEMAFORICO ES (NOLOCK) ON RTRIM(UPPER(E.N' +
        'M_EMBARCACAO)) = RTRIM(UPPER(ES.NM_EMBARCACAO))'
      ''
      
        'WHERE V.DT_ESPERADA BETWEEN CONVERT(DATETIME, CONVERT(VARCHAR, G' +
        'ETDATE(), 103),103)-3 AND GETDATE()+11'
      ' AND V.CD_PRODUTO IN ('#39'01'#39','#39'03'#39')'
      ''
      ''
      ''
      
        'GROUP BY V.CD_UNID_NEG, V.CD_PRODUTO, V.CD_LOCAL, V.CD_EMBARCACA' +
        'O, ISNULL(ES.ID_EMBARCACAO, 0), E.NM_EMBARCACAO, V.NR_VIAGEM, V.' +
        'DT_ESPERADA, V.DT_ENT, V.NR_MANIFESTO, V.NR_VIAGEM_ARMADOR, ISNU' +
        'LL(V.CD_ARMAZEM_ATRACACAO, '#39#39'), ISNULL(A.NM_ARMAZEM,'#39#39'), L.DESCR' +
        'ICAO'
      'ORDER BY STATUS_INDEXADO, V.DT_ESPERADA'
      '')
    UpdateMode = upWhereKeyOnly
    UpdateObject = updCadastroViagem
    Left = 653
    Top = 474
    object qryCadastroViagemCD_UNID_NEG: TStringField
      FieldName = 'CD_UNID_NEG'
      FixedChar = True
      Size = 2
    end
    object qryCadastroViagemCD_PRODUTO: TStringField
      FieldName = 'CD_PRODUTO'
      FixedChar = True
      Size = 2
    end
    object qryCadastroViagemCD_LOCAL: TStringField
      FieldName = 'CD_LOCAL'
      FixedChar = True
      Size = 4
    end
    object qryCadastroViagemCD_EMBARCACAO: TStringField
      FieldName = 'CD_EMBARCACAO'
      FixedChar = True
      Size = 4
    end
    object qryCadastroViagemID_EMBARCACAO: TIntegerField
      FieldName = 'ID_EMBARCACAO'
    end
    object qryCadastroViagemNM_EMBARCACAO: TStringField
      DisplayLabel = 'Navio'
      FieldName = 'NM_EMBARCACAO'

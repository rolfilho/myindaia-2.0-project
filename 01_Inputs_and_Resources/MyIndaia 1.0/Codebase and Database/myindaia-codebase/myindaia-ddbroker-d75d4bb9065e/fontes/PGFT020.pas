procedure Tdatm_sel_unid_cli.ppHeaderBand1BeforePrint(Sender: TObject);
begin
  ppLabel2.Caption := 'Unidade: ' + frm_sel_unid_cli.edt_nm_unid_neg.Text;
  pplbl_titulo.Caption := 'Relatório de Canais Mod2 Período ' + DateToStr(frm_sel_unid_cli.msk_dt_inicio.Date) + ' a ' +  DateToStr(frm_sel_unid_cli.msk_dt_fim.Date) ;
  if Trim( frm_sel_unid_cli.msk_cd_cliente.Text ) <> '' then
    ppLabel3.Caption := 'Cliente: ' + frm_sel_unid_cli.edt_nm_cliente.Text else
    ppLabel3.Caption := 'Grupo: ' + frm_sel_unid_cli.edt_nm_grupo.Text;
  if Trim( frm_sel_unid_cli.msk_cd_area.Text ) <> '' then
    ppLabel4.Caption    := 'Área: ' + frm_sel_unid_cli.edt_nm_area.Text else
    if Trim( frm_sel_unid_cli.msk_cd_grupo_area.Text ) <> '' then
      ppLabel4.Caption    := 'Grupo Área: ' + frm_sel_unid_cli.msk_cd_grupo_area.Text else
      ppLabel4.Caption    := 'Grupo Área: Todos';
end;




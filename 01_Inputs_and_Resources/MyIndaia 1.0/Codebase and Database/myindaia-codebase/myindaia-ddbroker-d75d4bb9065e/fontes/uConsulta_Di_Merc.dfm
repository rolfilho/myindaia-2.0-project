  object qry_consulta_di_merc: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        '/*Um script para gerar um relat'#243'rio da BASF de v'#225'rios processos ' +
        'de importa'#231#227'o.'
      ''
      ' OK N'#250'mero do Processo'
      ' OK C'#243'digo da Mercadoria'
      ' OK Data de Registro da DI'
      ' OK N'#250'mero da Declara'#231#227'o de Importa'#231#227'o'
      ' OK Valor Unit'#225'rio'
      ' OK Data de Realiza'#231#227'o'
      ' OK Peso L'#237'quido'
      ' OK Pa'#237's Origem'
      ' OK Pa'#237's Aquisi'#231#227'o'
      ' OK Quantidade'
      ' OK NCM '
      ''
      ''
      
        'Os processos ser'#227'o inseridos em tempo de execu'#231#227'o no texto da Qu' +
        'ery, por isso n'#227'o h'#225' par'#226'metros'
      'nem cl'#225'usula WHERE no final da Query*/'
      ' '
      ' '
      'SELECT DI.NR_PROCESSO '#39'NR_PROCESSO'#39','
      '       DM.CD_MERCADORIA '#39'CD_MERCADORIA'#39','
      '       DI.DT_REGISTRO_DI '#39'DT_REGISTRO_DI'#39','
      '       DI.NR_DECLARACAO_IMP '#39'NR_DECLARACAO_IMP'#39','
      '       DM.VL_UNITARIO '#39'VL_UNITARIO'#39','
      '       FU.DT_REALIZACAO '#39'DT_REALIZACAO'#39','
      '       DM.PL_MERCADORIA '#39'PL_MERCADORIA'#39','
      '       PAIS.DESCRICAO '#39'PAIS_ORIGEM'#39','
      '       PAIS2.DESCRICAO '#39'PAIS_AQUISICAO'#39','
      '       DM.QT_MERC_UN_COMERC '#39'QT_MERC_UN_COMERC'#39','
      '       DM.CD_NCM_SH '#39'NCM'#39' '
      'FROM TDECLARACAO_IMPORTACAO DI'
      
        'INNER JOIN TDETALHE_MERCADORIA DM ON DI.NR_PROCESSO = DM.NR_PROC' +
        'ESSO'
      'LEFT JOIN   TPAIS PAIS ON PAIS.CODIGO = DM.CD_PAIS_ORIGEM'
      'LEFT JOIN   TPAIS PAIS2 ON PAIS2.CODIGO = DM.CD_PAIS_AQUISICAO'
      
        'INNER JOIN TFOLLOWUP FU ON FU.NR_PROCESSO = DI.NR_PROCESSO AND F' +
        'U.CD_EVENTO = '#39'419'#39)
    Left = 288
    Top = 80
  end
end

  object qry_cntr_nao_dev_: TQuery
    Active = True
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT U.CD_UNID_NEG, U.AP_UNID_NEG, P.CD_PRODUTO, P.NM_PRODUTO,' +
        ' E.CD_EMPRESA, E.NM_EMPRESA,'
      
        '       A.CD_AGENTE, A.NM_AGENTE, T.CD_TRANSP_ROD, T.AP_TRANSP_RO' +
        'D, R.NR_PROCESSO, R.NR_CNTR,'
      
        '       R.DT_ENT, R.DT_NF_TRANSP, SUBSTRING( R.NR_PROCESSO, 5, 14' +
        ' ) AS CalcProcesso'
      
        'FROM   TREL_CNTR_NAO_DEV R, TUNID_NEG U, TPRODUTO P, TEMPRESA_NA' +
        'C E, TAGENTE A, TTRANSP_ROD T'
      'WHERE  R.CD_UNID_NEG      = U.CD_UNID_NEG AND'
      '       R.CD_PRODUTO       = P.CD_PRODUTO AND'
      '       R.CD_CLIENTE       = E.CD_EMPRESA AND'
      '       R.CD_AGENTE        *= A.CD_AGENTE AND'
      '       R.CD_TRANSP_NAC    *= T.CD_TRANSP_ROD AND'
      '       R.NR_IDENTIFICADOR = :NR_IDENTIFICADOR'
      
        'ORDER BY U.CD_UNID_NEG, P.CD_PRODUTO, E.CD_EMPRESA, T.CD_TRANSP_' +
        'ROD')
    Params.Data = {01000100104E525F4944454E544946494341444F5200030400000000000000}
    Left = 165
    Top = 85

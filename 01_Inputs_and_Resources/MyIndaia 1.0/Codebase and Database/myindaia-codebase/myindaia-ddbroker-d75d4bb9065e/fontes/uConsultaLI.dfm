  object dsMain: TDataSource
    DataSet = qryMain
    Left = 468
    Top = 204
  end
  object qryMain: TSQLQuery
    MaxBlobSize = -1
    Params = <>
    SQL.Strings = (
      
        '     SELECT                                                     ' +
        '                                                                ' +
        '         '
      
        '     PLI.NR_LI,                                                 ' +
        '                                                                ' +
        '           '
      
        '     RTRIM(P.NR_CONHECIMENTO) AS NR_CONHECIMENTO,               ' +
        '                                                                ' +
        '           '
      
        '     PLI.DT_REGISTRO,                                           ' +
        '                                                                ' +
        '           '
      
        '     PLI.NR_INMETRO,                                            ' +
        '                                                                ' +
        '           '
      
        '     PLIOA.CD_ORGAO_ANUENTE,                                    ' +
        '                                                                ' +
        '           '
      
        '     PLIOA.DT_DEFERIMENTO,                                      ' +
        '                                                                ' +
        '           '
      
        '     PLIOA.DT_VENCTO,                                           ' +
        '                                                                ' +
        '           '
      
        '     PLIOA.DT_ENTR_PROC,                                        ' +
        '                                                                ' +
        '           '
      
        '     PLIOA.REFERENCIA,                                          ' +
        '                                                                ' +
        '           '
      
        '     PLIOA.DT_RESTRICAO_EMBARQUE,                               ' +
        '                                                                ' +
        '           '
      
        '     PLIS.TX_STATUS,                                            ' +
        '                                                                ' +
        '           '
      
        '     PLIS.DT_STATUS,                                            ' +
        '                                                                ' +
        '           '
      
        '     PLI.IN_UTILIZADO,                                          ' +
        '                                                                ' +
        '           '
      
        '     PLI.IN_SUBSTITUIDA,                                        ' +
        '                                                                ' +
        '           '
      
        '     PLI.NR_SUBSTITUIDA,                                        ' +
        '                                                                ' +
        '           '
      
        '     PLI.IN_CANCELADO,                                          ' +
        '                                                                ' +
        '           '
      
        '     C.NM_CONTATO,                                              ' +
        '                                                                ' +
        '           '
      
        '     PLI.NR_PROCESSO,                                           ' +
        '                                                                ' +
        '           '
      
        '     OT.CD_MERCADORIA_NCM,                                      ' +
        '                                                                ' +
        '           '
      
        '     OT.NR_IMPORTADOR,                                          ' +
        '                                                                ' +
        '           '
      
        '     OT.NM_FORN_ESTR,                                           ' +
        '                                                                ' +
        '           '
      
        '     OT.NM_FABRICANTE_MERC,                                     ' +
        '                                                                ' +
        '           '
      
        '     PAIS.NM_PAIS,                                              ' +
        '                                                                ' +
        '           '
      
        '     CONVERT(NUMERIC(15,2), REVERSE(STUFF(REVERSE(OT.VL_MERC_MNE' +
        'G_EMB),3,0,'#39'.'#39'))) AS VL_MERC_MNEG_EMB,                          ' +
        '         '
      
        '     CONVERT(NUMERIC(15,3), REVERSE(STUFF(REVERSE(OT.PL_MERCADOR' +
        'IA),4,0,'#39'.'#39'))) AS PL_MERCADORIA,                                ' +
        '         '
      
        '     E.NM_EMPRESA,                                              ' +
        '                                                                ' +
        '           '
      
        '     E.CGC_EMPRESA,                                             ' +
        '                                                                ' +
        '           '
      '     ARE.NM_AREA,'
      
        '     CAST((SELECT RTRIM(cast(RC.TX_DESC_DET_MERC as varchar(max)' +
        ')) + '#39'; '#39' AS '#39'data()'#39'                                           ' +
        '       '
      
        '             FROM BROKER.DBO.DETALHE_MERC_COM_TRATAMENTO RC   (n' +
        'olock)                                                          ' +
        '           '
      
        '            WHERE RC.NR_OPER_TRAT_PREV = Pli.NR_LI              ' +
        '                                                                ' +
        '           '
      
        '          FOR XML PATH('#39#39')) AS VARCHAR(MAX)) AS TX_DESC_DET_MERC' +
        ',                                                               ' +
        '         '
      
        ' --    CAST(DBO.FN_CONCATENA_DESC_DET_MERC(PLI.NR_LI) AS TEXT) A' +
        'S TX_DESC_DET_MERC,                                             ' +
        '           '
      
        '     F350.DT_REALIZACAO AS DT_REALIZACAO_350,                   ' +
        '                                                                ' +
        '           '
      
        '     F097.DT_REALIZACAO AS DT_REALIZACAO_097,                   ' +
        '                                                                ' +
        '           '
      
        '     F999.DT_REALIZACAO AS DT_REALIZACAO_999,                   ' +
        '                                                                ' +
        '           '
      
        '     F162.DT_REALIZACAO AS DT_REALIZACAO_162,                   ' +
        '                                                                ' +
        '           '
      
        '     F145.DT_REALIZACAO AS DT_REALIZACAO_145,                   ' +
        '                                                                ' +
        '           '
      
        '     F630.DT_REALIZACAO AS DT_REALIZACAO_630,                   ' +
        '                                                                ' +
        '           '
      
        '     F471.DT_REALIZACAO AS DT_REALIZACAO_471,                   ' +
        '                                                                ' +
        '           '
      
        '     F134.DT_REALIZACAO AS DT_REALIZACAO_134,                   ' +
        '                                                                ' +
        '           '
      
        '     TURF.DESCRICAO AS URF_DESPACHO,                            ' +
        '                                                                ' +
        '           '
      
        '     PLI.NUMERO_IP_BRI,                                         ' +
        '                                                                ' +
        '           '
      
        '     PLI.DATA_SOLICI_PRORROGACAO,                               ' +
        '                                                                ' +
        '           '
      
        '     DBO.FN_CONCATENA_DOCUMENTO_INSTRUCAO(P.NR_PROCESSO, '#39'01'#39') A' +
        'S FATURAS,                                                      ' +
        '         '
      
        '     CAST((SELECT RTRIM(RC.CD_REFERENCIA) + '#39', '#39' AS '#39'data()'#39'    ' +
        '                                                                ' +
        '       '
      
        '             FROM BROKER.DBO.TREF_CLIENTE RC                    ' +
        '                                                                ' +
        '           '
      
        '            WHERE RC.NR_PROCESSO   = P.NR_PROCESSO              ' +
        '                                                                ' +
        '           '
      
        '              AND RC.TP_REFERENCIA = '#39'01'#39'                       ' +
        '                                                                ' +
        '         '
      
        '           FOR XML PATH('#39#39')) AS VARCHAR(MAX))  AS [REF_CLIENTE_P' +
        'EDIDO],                                                         ' +
        '         '
      
        '     CAST((SELECT RTRIM(RC.CD_REFERENCIA) + '#39', '#39' AS '#39'data()'#39'    ' +
        '                                                                ' +
        '       '
      
        '             FROM BROKER.DBO.TREF_CLIENTE RC                    ' +
        '                                                                ' +
        '           '
      
        '            WHERE RC.NR_PROCESSO = P.NR_PROCESSO                ' +
        '                                                                ' +
        '           '
      
        '              AND RC.TP_REFERENCIA = '#39'04'#39'                       ' +
        '                                                                ' +
        '         '
      
        '           FOR XML PATH('#39#39')) AS VARCHAR(MAX)) AS [REF_CLIENTE_OU' +
        'TROS],                                                          ' +
        '         '
      
        '     CAST((SELECT RTRIM(RC.CD_REFERENCIA) + '#39', '#39' AS '#39'data()'#39'    ' +
        '                                                                ' +
        '       '
      
        '             FROM BROKER.DBO.TREF_CLIENTE RC                    ' +
        '                                                                ' +
        '           '
      
        '            WHERE RC.NR_PROCESSO = P.NR_PROCESSO                ' +
        '                                                                ' +
        '           '
      
        '              AND RC.TP_REFERENCIA = '#39'13'#39'                       ' +
        '                                                                ' +
        '         '
      
        '           FOR XML PATH('#39#39')) AS VARCHAR(MAX)) AS [REF_CLIENTE_LO' +
        'TE],                                                            ' +
        '         '
      
        '     PLI.DT_SOLICITACAO,                                        ' +
        '                                                                ' +
        '           '
      
        '     CASE ISNULL(PLI.IN_PRE_EMBARQUE, '#39#39')                       ' +
        '                                                                ' +
        '         '
      
        '          WHEN '#39'1'#39' THEN '#39'Pr'#233#39'                                   ' +
        '                                                                ' +
        '       '
      
        '          WHEN '#39'2'#39' THEN '#39'P'#243's'#39'                                   ' +
        '                                                                ' +
        '       '
      
        '          ELSE '#39#39'                                               ' +
        '                                                                ' +
        '         '
      
        '     END AS IN_PRE_EMBARQUE,                                    ' +
        '                                                                ' +
        '           '
      
        '     PLI.DT_APTO_FIN_DOSSIE,                                    ' +
        '                                                                ' +
        '           '
      
        '     PLI.DT_FIN_DOSSIE,                                         ' +
        '                                                                ' +
        '           '
      
        '     PLI.NR_DOSSIE,                                             ' +
        '                                                                ' +
        '           '
      
        '     PLI.DT_DOCTOS_DOSSIE,                                      ' +
        '                                                                ' +
        '           '
      
        '     PLI.DT_EMISSAO_GRU,                                        ' +
        '                                                                ' +
        '           '
      
        '     PLI.NR_TRANSACAO_GRU,                                      ' +
        '                                                                ' +
        '           '
      
        '     PLI.DT_PGMTO_GRU,                                          ' +
        '                                                                ' +
        '           '
      
        '     PLI.DT_PROTOCOLO_GRU,                                      ' +
        '                                                                ' +
        '           '
      
        '     PLI.NR_PROCESSO_ANVISA,                                    ' +
        '                                                                ' +
        '           '
      
        '     PLI.NR_EXPEDIENTE_ANVISA,                                  ' +
        '                                                                ' +
        '           '
      
        '     CASE ISNULL(PLI.CD_CANAL, 4)                               ' +
        '                                                                ' +
        '           '
      
        '          WHEN 4 THEN '#39#39'                                        ' +
        '                                                                ' +
        '         '
      
        '          WHEN 3 THEN '#39'Cinza'#39'                                   ' +
        '                                                                ' +
        '         '
      
        '          WHEN 2 THEN '#39'Verde'#39'                                   ' +
        '                                                                ' +
        '         '
      
        '          WHEN 1 THEN '#39'Amarelo'#39'                                 ' +
        '                                                                ' +
        '         '
      
        '          WHEN 0 THEN '#39'Vermelho'#39'                                ' +
        '                                                                ' +
        '         '
      
        '     END AS CANAL,                                              ' +
        '                                                                ' +
        '           '
      
        '     U.NM_USUARIO,                                              ' +
        '                                                                ' +
        '           '
      
        '     ARM.NM_ARMAZEM,                                            ' +
        '                                                                ' +
        '           '
      
        '     ITENS.QT_ITENS,                                            ' +
        '                                                                ' +
        '           '
      
        '     CONVERT(VARCHAR(3000),F022.TX_OBS)     AS TX_OBS           ' +
        '                                                                ' +
        '           '
      
        '     FROM TPROCESSO                         P     (NOLOCK)      ' +
        '                                                                ' +
        '           '
      
        '     INNER JOIN TPROCESSO_LI                PLI   (NOLOCK) ON PL' +
        'I.NR_PROCESSO        = P.NR_PROCESSO                            ' +
        '           '
      
        '     INNER JOIN TEMPRESA_NAC                E     (NOLOCK) ON E.' +
        'CD_EMPRESA           = P.CD_CLIENTE                             ' +
        '           '
      
        '     INNER JOIN TPROCESSO_LI_ORGAO_ANUENTE  PLIOA (NOLOCK) ON PL' +
        'IOA.NR_PROCESSO      = P.NR_PROCESSO                            ' +
        '           '
      
        '                                                          AND PL' +
        'IOA.NR_LI            = PLI.NR_LI                                ' +
        '           '
      
        '     LEFT  JOIN TFOLLOWUP                   F350  (NOLOCK) ON F3' +
        '50.NR_PROCESSO       = P.NR_PROCESSO                            ' +
        '           '
      
        '                                                          AND F3' +
        '50.CD_SERVICO        = P.CD_SERVICO                             ' +
        '           '
      
        '                                                          AND F3' +
        '50.CD_EVENTO         = '#39'350'#39'                                    ' +
        '         '
      
        '     LEFT  JOIN TFOLLOWUP                   F097  (NOLOCK) ON F0' +
        '97.NR_PROCESSO       = P.NR_PROCESSO                            ' +
        '           '
      
        '                                                          AND F0' +
        '97.CD_SERVICO        = P.CD_SERVICO                             ' +
        '           '
      
        '                                                          AND F0' +
        '97.CD_EVENTO         = '#39'097'#39'                                    ' +
        '         '
      
        '     LEFT  JOIN TFOLLOWUP                   F999  (NOLOCK) ON F9' +
        '99.NR_PROCESSO       = P.NR_PROCESSO                            ' +
        '           '
      
        '                                                          AND F9' +
        '99.CD_SERVICO        = P.CD_SERVICO                             ' +
        '           '
      
        '                                                          AND F9' +
        '99.CD_EVENTO         = '#39'999'#39'                                    ' +
        '         '
      
        '     LEFT  JOIN TFOLLOWUP                   F162  (NOLOCK) ON F1' +
        '62.NR_PROCESSO       = P.NR_PROCESSO                            ' +
        '           '
      
        '                                                          AND F1' +
        '62.CD_SERVICO        = P.CD_SERVICO                             ' +
        '           '
      
        '                                                          AND F1' +
        '62.CD_EVENTO         = '#39'162'#39'                                    ' +
        '         '
      
        '     LEFT  JOIN TFOLLOWUP                   F145  (NOLOCK) ON F1' +
        '45.NR_PROCESSO       = P.NR_PROCESSO                            ' +
        '           '
      
        '                                                          AND F1' +
        '45.CD_SERVICO        = P.CD_SERVICO                             ' +
        '           '
      
        '                                                          AND F1' +
        '45.CD_EVENTO         = '#39'145'#39'                                    ' +
        '         '
      
        '     LEFT  JOIN TFOLLOWUP                   F630  (NOLOCK) ON F6' +
        '30.NR_PROCESSO       = P.NR_PROCESSO                            ' +
        '           '
      
        '                                                          AND F6' +
        '30.CD_SERVICO        = P.CD_SERVICO                             ' +
        '           '
      
        '                                                          AND F6' +
        '30.CD_EVENTO         = '#39'630'#39'                                    ' +
        '         '
      
        '     LEFT  JOIN TFOLLOWUP                   F471  (NOLOCK) ON F4' +
        '71.NR_PROCESSO       = P.NR_PROCESSO                            ' +
        '           '
      
        '                                                          AND F4' +
        '71.CD_SERVICO        = P.CD_SERVICO                             ' +
        '           '
      
        '                                                          AND F4' +
        '71.CD_EVENTO         = '#39'471'#39'                                    ' +
        '         '
      
        '     LEFT  JOIN TFOLLOWUP                   F134  (NOLOCK) ON F1' +
        '34.NR_PROCESSO       = P.NR_PROCESSO                            ' +
        '           '
      
        '                                                          AND F1' +
        '34.CD_SERVICO        = P.CD_SERVICO                             ' +
        '           '
      
        '                                                          AND F1' +
        '34.CD_EVENTO         = '#39'134'#39'                                    ' +
        '         '
      
        '     LEFT  JOIN OPERACAO_COM_TRATAMENTO     OT    (NOLOCK) ON OT' +
        '.NR_OPER_TRAT_PREV   = PLI.NR_LI                                ' +
        '           '
      
        '     LEFT  JOIN TURF                              (NOLOCK) ON TU' +
        'RF.CODIGO            = OT.CD_URF_DESPACHO                       ' +
        '           '
      
        '     LEFT  JOIN TPAIS_BROKER                PAIS  (NOLOCK) ON PA' +
        'IS.CD_PAIS           = OT.CD_PAIS_ORIG_MERC                     ' +
        '           '
      
        '     LEFT  JOIN TPROCESSO_LI_STATUS         PLIS  (NOLOCK) ON PL' +
        'IS.NR_PROCESSO       = PLI.NR_PROCESSO                          ' +
        '           '
      
        '    '#9#9#9#9#9#9#9#9#9#9#9#9#9'                            AND PLIS.NR_LI     ' +
        '        = PLI.NR_LI                                           '
      
        '    '#9#9#9#9#9#9#9#9#9#9#9#9#9'                            AND PLIS.CD_ORGAO_A' +
        'NUENTE  = PLIOA.CD_ORGAO_ANUENTE                              '
      
        '     '#9#9#9#9#9#9#9#9#9#9'                                  AND PLIS.DT_STA' +
        'TUS_EFETIVA = (SELECT MAX(DT_STATUS_EFETIVA)                    ' +
        '  '
      
        '    '#9#9#9#9#9#9#9#9#9#9#9#9#9'                                               ' +
        '             FROM TPROCESSO_LI_STATUS A  (NOLOCK)             '
      
        '    '#9#9#9#9#9#9#9#9#9#9#9#9#9'                                               ' +
        '            WHERE A.NR_PROCESSO      = PLI.NR_PROCESSO        '
      
        '    '#9#9#9#9#9#9#9#9#9#9#9#9#9'                                               ' +
        '              AND A.CD_ORGAO_ANUENTE = PLIOA.CD_ORGAO_ANUENTE '
      
        '    '#9#9#9#9#9#9#9#9#9#9#9#9#9#9#9#9#9#9#9#9'                                        ' +
        '       AND A.NR_LI            = PLI.NR_LI )            '
      
        '     LEFT JOIN TCLIENTE_CONTATO             C    (NOLOCK) ON C.C' +
        'D_CLIENTE            = P.CD_CLIENTE                             ' +
        '           '
      
        '                                                         AND C.C' +
        'D_UNID_NEG           = P.CD_UNID_NEG                            ' +
        '           '
      
        '                                                         AND C.C' +
        'D_PRODUTO            = P.CD_PRODUTO                             ' +
        '           '
      
        '                                                         AND C.C' +
        'D_CONTATO            = P.CD_CONTATO                             ' +
        '           '
      
        '     LEFT JOIN TUSUARIO                     U    (NOLOCK) ON U.C' +
        'D_USUARIO            = PLI.CD_USUARIO_EMISSOR                   ' +
        '           '
      
        '     LEFT JOIN TARMAZEM                     ARM  (NOLOCK) ON ARM' +
        '.CD_ARMAZEM          = P.CD_ARMAZEM_DESCARGA                    ' +
        '           '
      
        '     OUTER APPLY( SELECT COUNT(*) AS QT_ITENS                   ' +
        '                                                                ' +
        '           '
      
        '                    FROM DETALHE_MERC_COM_TRATAMENTO D(NOLOCK)  ' +
        '                                                                ' +
        '           '
      
        '                   WHERE D.NR_OPER_TRAT_PREV = PLI.NR_LI) ITENS ' +
        '                                                                ' +
        '           '
      
        '     LEFT  JOIN TFOLLOWUP                   F022  (NOLOCK) ON F0' +
        '22.NR_PROCESSO       = P.NR_PROCESSO                            ' +
        '           '
      
        '                                                            AND ' +
        'F022.CD_SERVICO      = P.CD_SERVICO                             ' +
        '           '
      
        '                                                            AND ' +
        'F022.CD_EVENTO       = '#39'022'#39'      '
      
        '     LEFT JOIN TAREA                        ARE   (NOLOCK) ON AR' +
        'E.CD_AREA            = P.CD_AREA                                ' +
        '                                                                ' +
        '   '
      ''
      'WHERE P.CD_UNID_NEG = '#39'01'#39' AND  P.CD_PRODUTO ='#39'01'#39
      'AND PLI.DT_REGISTRO >= GETDATE()')
    SQLConnection = datm_main.SQLConnection
    Left = 428
    Top = 207

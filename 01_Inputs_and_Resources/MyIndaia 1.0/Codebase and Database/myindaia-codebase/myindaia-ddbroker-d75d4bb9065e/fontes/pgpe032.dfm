  object TProcI1: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT i.cd_naladi_sh as NALADI, na.descricao as DESC_NALADI, i.' +
        'cd_normas AS NORMAS, no.nm_descricao AS DESC_NORMAS, SUM( i.vl_t' +
        'ot_peso_liq ) as TOTAL_PESO_LIQ, SUM( i.qt_mercadoria ) as QT_ME' +
        'RCADORIA, SUM( i.vl_tot_item ) as TOTAL_ITEM, i.nr_seq_naladi as' +
        ' SEQ_NALADI'
      'FROM tprocesso_exp_item i'
      'LEFT JOIN tnaladish na ON i.cd_naladi_sh=na.codigo'
      'LEFT JOIN tnormas no ON i.cd_normas=no.codigo'
      
        'GROUP BY i.cd_naladi_sh, na.descricao, i.cd_normas, no.nm_descri' +
        'cao, i.nr_seq_naladi'
      'ORDER BY i.nr_seq_naladi')
    Left = 128
    Top = 156
  end

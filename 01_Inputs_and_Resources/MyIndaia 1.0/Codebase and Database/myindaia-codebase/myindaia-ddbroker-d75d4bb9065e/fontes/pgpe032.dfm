  object TProcesso: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT P.NR_PROCESSO, CASE LTRIM( RTRIM( ISNULL( P.NR_CONHECIMEN' +
        'TO, "" ) ) )'
      '                       WHEN "" THEN P.NR_CONHECIMENTO_MASTER'
      '                       ELSE P.NR_CONHECIMENTO'
      '                    END AS NR_CONHECIMENTO,'
      
        '       P.CD_EMBARCACAO, P.NR_VIAGEM, P.CD_PAIS_DESTINO, P.CD_PAI' +
        'S_ORIGEM,'
      '       P.TX_MERCADORIA, E.NM_EMBARCACAO,'
      
        '      (SELECT NM_AGENTE_REDUZIDO FROM TAGENTE WHERE CD_AGENTE =*' +
        ' PE.CD_AGENTE) AS NM_TRANSPORTADORA'
      'FROM   TPROCESSO P, TEMBARCACAO E, TPROCESSO_EXP PE '
      'WHERE  P.NR_PROCESSO = :NR_PROCESSO AND'
      '       P.NR_PROCESSO = PE.NR_PROCESSO  AND '
      '       P.CD_EMBARCACAO *= E.CD_EMBARCACAO')
    Left = 634
    Top = 9
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
      end>
  end

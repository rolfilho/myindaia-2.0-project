  object TProcI: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'select I.NR_PROCESSO, I.NR_ITEM, I.CD_MERCADORIA, I.CD_NCM, M.NM' +
        '_MERCADORIA, I.VL_TOT_PESO_LIQ, I.NR_PEDIDO, I.CD_ACORDO '
      'from tprocesso_exp_item i'
      'left join tmercadoria_exp m on i.cd_mercadoria=m.cd_mercadoria')
    Left = 352
    Top = 8
  end

  object TProcesso_Re: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'SELECT CASE NR_ANEXO_FIM'
      '         WHEN NR_ANEXO_INI THEN'
      
        '              SUBSTRING( LTRIM( RTRIM( E.NR_RE ) ), 1, 2 ) + '#39'/'#39 +
        ' +'
      
        '              SUBSTRING( LTRIM( RTRIM( E.NR_RE ) ), 3, 7 ) + '#39'-'#39 +
        ' + NR_ANEXO_INI'
      
        '         ELSE SUBSTRING( LTRIM( RTRIM( E.NR_RE ) ), 1, 2 ) + '#39'/'#39 +
        ' +'
      
        '              SUBSTRING( LTRIM( RTRIM( E.NR_RE ) ), 3, 7 ) + '#39'-'#39 +
        ' + '
      '              NR_ANEXO_INI + '#39'/'#39' + NR_ANEXO_FIM'
      
        '      END AS NR_RE, DT_RE, SUBSTRING( CD_NBM_SH, 1, 4 ) + '#39'.'#39' + ' +
        'SUBSTRING( CD_NBM_SH, 5, 2 ) + '#39'.'#39' + SUBSTRING( CD_NBM_SH, 7, 4 ' +
        ') AS CD_NBM_SH, VL_FOB, QT_PESO_LIQ, M.AP_MOEDA, '
      '      ( SELECT MAX( U.NM_SIGLA ) '
      '        FROM   TPROCESSO_EXP_ITEM I, TUNID_MEDIDA_BROKER U'
      '        WHERE  I.NR_PROCESSO = C.NR_PROCESSO AND'
      
        '               I.CD_UNID_MEDIDA *= U.CD_UNID_MEDIDA ) AS AP_UNID' +
        '_MED'
      
        'FROM   TPROCESSO_EXP_RE R, TPROCESSO_EXP_DDE_RE E, TPROCESSO_EXP' +
        ' C, TMOEDA_BROKER M'
      'WHERE  R.NR_PROCESSO = E.NR_PROCESSO AND'
      '       E.NR_PROCESSO = C.NR_PROCESSO AND'
      '       C.CD_MOEDA *= M.CD_MOEDA AND'
      '       R.NR_RE = LTRIM( RTRIM( E.NR_RE ) ) + NR_ANEXO_FIM AND'
      '       R.NR_PROCESSO = :NR_PROCESSO'
      '')
    Left = 580
    Top = 156
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
      end>
  end

  object TCarta_Cred: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT P.NR_PROCESSO, CASE LTRIM( RTRIM( ISNULL( P.NR_FATURA, ""' +
        ' ) ) )'
      '          WHEN "" THEN ""'
      '          ELSE LTRIM( RTRIM( ISNULL( P.NR_FATURA, "" ) ) )'
      '       END AS CalcNrProcesso, CA.TX_EXPORTADOR, CA.TX_NOTIFY1,'
      
        '       CA.NM_LOCAL_DESTINO, CA.NM_PAIS_DESTINO, P.NR_FATURA, P.D' +
        'T_FATURA, P.CD_ACORDO, P.DT_REGISTRO_PEDIDO, P.CD_AGENTE, P.CD_T' +
        'RANSPORTADORA, P.CD_VIA_TRANSPORTE, P.VL_PESO_BRUTO, CA.TX_IMPOR' +
        'TADOR,'
      
        '       P.VL_PESO_LIQUIDO, P.VL_TOT_COM_AGENTE, CD_LINGUA_PEDIDO,' +
        'P.TX_OBSERVACAO, P.TX_DECL_ADICIONAL, P.TX_MARCACAO_VOLUME, P.TX' +
        '_INF_EMBALAGEM, P.TX_MERCADORIA_BL,'
      
        '       P.TX_CRIT_ORIG_FORM_A, P.CD_EXPORTADOR, P.CD_FABRICANTE, ' +
        'P.CD_IMPORTADOR, P.TP_CONSIGNATARIO, P.CD_CONSIGNATARIO, P.CD_LO' +
        'CAL_ORIGEM, CA.TX_CONSIGNATARIO,'
      
        '       P.CD_LOCAL_DESTINO, P.CD_PAIS_DESTINO, A.NM_AGENTE AS NM_' +
        'TRANSPORTADORA, P.CD_PAIS_ORIG AS CD_PAIS_ORIGEM, P.CD_PAIS_DEST' +
        'INO AS CD_PAIS_DESTINO,'
      '       CASE ( SELECT CD_LOCAL_EMISSAO_SP FROM TPARAMETROS )'
      '          WHEN P.CD_LOCAL_EMISSAO THEN ""'
      '          ELSE LTRIM( RTRIM( ISNULL( LE.NOME, "" ) ) ) +'
      '               CASE LTRIM( RTRIM( ISNULL( LE.NOME, "" ) ) )'
      '                  WHEN "" THEN ""'
      '                  ELSE ", "'
      '               END'
      '       END +'
      
        '       RIGHT( '#39'0'#39' + CONVERT( varchar(2), DATEPART( dd, :DT_ATUAL' +
        ' ) ), 2 ) + '#39' de '#39' +'
      '       CASE DATEPART( m, :DT_ATUAL )'
      '          WHEN 1 THEN '#39'Janeiro'#39
      '          WHEN 2 THEN '#39'Fevereiro'#39
      '          WHEN 3 THEN '#39'Mar'#231'o'#39
      '          WHEN 4 THEN '#39'Abril'#39
      '          WHEN 5 THEN '#39'Maio'#39
      '          WHEN 6 THEN '#39'Junho'#39
      '          WHEN 7 THEN '#39'Julho'#39
      '          WHEN 8 THEN '#39'Agosto'#39
      '          WHEN 9 THEN '#39'Setembro'#39
      '          WHEN 10 THEN '#39'Outubro'#39
      '          WHEN 11 THEN '#39'Novembro'#39
      '          WHEN 12 THEN '#39'Dezembro'#39
      
        '       END + '#39' de '#39' + CONVERT(char(4), DATEPART( yyyy, :DT_ATUAL' +
        ' ) ) AS NM_LOCAL_ORIGEM_DATA,'
      
        '       '#39'p.p. '#39' + LTRIM( RTRIM( ISNULL( E.NM_EMPRESA, "" ) ) ) AS' +
        ' PP, P.CD_LOCAL_EMISSAO,'
      '       UPPER( V.NM_VIA_TRANSP_INGLES ) NM_VIA_TRANSP,'
      '       LO.DESCRICAO + '#39' - '#39' + PO.NM_PAIS_ING AS ORIGEM,'
      '       LD.DESCRICAO + '#39' - '#39' + PD.NM_PAIS_ING AS DESTINO,'
      '       CASE DATEPART( m, P.DT_FATURA )'
      '          WHEN 1 THEN '#39'January'#39
      '          WHEN 2 THEN '#39'February'#39
      '          WHEN 3 THEN '#39'March'#39
      '          WHEN 4 THEN '#39'April'#39
      '          WHEN 5 THEN '#39'May'#39
      '          WHEN 6 THEN '#39'June'#39
      '          WHEN 7 THEN '#39'July'#39
      '          WHEN 8 THEN '#39'August'#39
      '          WHEN 9 THEN '#39'September'#39
      '          WHEN 10 THEN '#39'October'#39
      '          WHEN 11 THEN '#39'November'#39
      '          WHEN 12 THEN '#39'December'#39
      
        '       END + '#39' '#39' + RIGHT( '#39'0'#39' + CONVERT( varchar(2), DATEPART( d' +
        'd, P.DT_FATURA ) ), 2 ) +'
      
        '       CASE RIGHT( CONVERT( varchar(2), DATEPART( d, P.DT_FATURA' +
        ' ) ), 1 )'
      '          WHEN '#39'1'#39' THEN '#39'st'#39
      '          WHEN '#39'2'#39' THEN '#39'nd'#39
      '          ELSE '#39'th'#39
      
        '       END + '#39', '#39' + CONVERT(char(4), DATEPART( yyyy, P.DT_FATURA' +
        ' ) ) AS DT_FATURA_ING,'
      '       EMB.DT_REALIZACAO AS DT_EMBARQUE'
      
        'FROM   TPROCESSO_EXP P, TAGENTE A, TEMPRESA_NAC E, TVIA_TRANSP_B' +
        'ROKER V, TUNID_NEG U,'
      
        '       TLOCAL_EMBARQUE LO, TLOCAL_EMBARQUE LD, TPAIS_BROKER PO, ' +
        'TEXP_CARTA_CRED CA,'
      
        '       TEMPRESA_EST IMP, TPAIS_BROKER PD, TLOCAL_EMISSAO LE, TFO' +
        'LLOWUP EMB'
      'WHERE  P.NR_PROCESSO = :NR_PROCESSO AND'
      '       P.CD_LOCAL_EMISSAO *= LE.CODIGO AND'
      '       P.CD_AGENTE *= A.CD_AGENTE AND'
      '       P.CD_EXPORTADOR *= E.CD_EMPRESA AND'
      '       P.CD_VIA_TRANSPORTE *= V.CD_VIA_TRANSP AND'
      '       P.CD_LOCAL_ORIGEM *= LO.CODIGO AND'
      '       P.CD_LOCAL_DESTINO *= LD.CODIGO AND'
      '       P.NR_PROCESSO = CA.NR_PROCESSO AND'
      '       P.CD_PAIS_ORIG *= PO.CD_PAIS AND'
      '       P.CD_IMPORTADOR = IMP.CD_EMPRESA AND'
      '       P.CD_PAIS_DESTINO *= PD.CD_PAIS AND'
      '       P.NR_PROCESSO *= EMB.NR_PROCESSO AND'
      
        '       EMB.CD_EVENTO IN ( SELECT CD_EV_EMBARQUE FROM TPARAMETROS' +
        ' )')
    Left = 914
    Top = 156
    ParamData = <
      item
        DataType = ftDateTime
        Name = 'DT_ATUAL'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'DT_ATUAL'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'DT_ATUAL'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
      end>
  end

  object TGrupoNCM: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT DISTINCT '#39'"W '#39' + SUBSTRING( CD_NCM_DOC, 1, 4 ) + '#39'"'#39' AS W' +

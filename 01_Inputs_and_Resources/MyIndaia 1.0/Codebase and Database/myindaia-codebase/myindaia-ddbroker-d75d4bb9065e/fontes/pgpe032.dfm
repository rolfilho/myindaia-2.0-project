  object TImp: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'SELECT E.CD_EMPRESA AS CODIGO, E.NM_EMPRESA AS NOME,'
      '       LTRIM( RTRIM( ISNULL( E.END_EMPRESA, "" ) ) ) +'
      
        '       CASE LTRIM( RTRIM( ISNULL( E.END_NUMERO, "" ) ) ) WHEN ""' +
        ' THEN "" ELSE ", " END +'
      
        '       LTRIM( RTRIM( ISNULL( E.END_NUMERO, "" ) ) ) AS ENDERECO_' +
        'NUM,'
      '       LTRIM( RTRIM( ISNULL( E.END_COMPL, "" ) ) ) +'
      
        '       CASE LTRIM( RTRIM( ISNULL( E.END_COMPL, "" ) ) ) WHEN "" ' +
        'THEN "" ELSE " - " END +'
      '       LTRIM( RTRIM( ISNULL( E.END_CIDADE, "" ) ) )  +'
      '       CASE P.CD_LINGUA_PEDIDO'
      '          WHEN '#39'1'#39' THEN'
      
        '             CASE LTRIM( RTRIM( ISNULL( PA.NM_PAIS_ING, "" ) ) )' +
        ' WHEN "" THEN "" ELSE " - " END + LTRIM( RTRIM( ISNULL( PA.NM_PA' +
        'IS_ING, "" ) ) )'
      '          WHEN '#39'2'#39' THEN'
      
        '             CASE LTRIM( RTRIM( ISNULL( PA.NM_PAIS_ESP, "" ) ) )' +
        ' WHEN "" THEN "" ELSE " - " END + LTRIM( RTRIM( ISNULL( PA.NM_PA' +
        'IS_ESP, "" ) ) )'
      '          ELSE'
      
        '             CASE LTRIM( RTRIM( ISNULL( PA.NM_PAIS_PORT, "" ) ) ' +
        ') WHEN "" THEN "" ELSE " - " END + LTRIM( RTRIM( ISNULL( PA.NM_P' +
        'AIS_PORT, "" ) ) )'
      '       END AS CIDADE_PAIS,'
      
        '       CASE LTRIM( RTRIM( ISNULL( E.NR_CLIENTE, "" ) ) ) WHEN ""' +
        ' THEN "" ELSE "( " END + LTRIM( RTRIM( ISNULL( E.NR_CLIENTE, "" ' +
        ') ) ) +'
      
        '       CASE LTRIM( RTRIM( ISNULL( E.NR_CLIENTE, "" ) ) ) WHEN ""' +
        ' THEN "" ELSE " )" END AS NR_CLIENTE,'
      '       E.CD_PAIS AS CD_PAIS'
      'FROM   TPROCESSO_EXP P, TEMPRESA_EST E, TPAIS_BROKER PA'
      'WHERE  P.NR_PROCESSO = :NR_PROCESSO AND'
      '       P.CD_IMPORTADOR = E.CD_EMPRESA AND'
      '       E.CD_PAIS *= PA.CD_PAIS')
    Left = 72
    Top = 8
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
      end>
  end
  object Dts_Imp: TDataSource
    DataSet = TImp
    Left = 72
    Top = 54
  end
  object TConsig: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT E.CD_EMPRESA AS CODIGO, LTRIM( RTRIM( E.NM_EMPRESA ) ) AS' +
        ' NOME, LTRIM( RTRIM( E.END_EMPRESA ) ) + CASE LTRIM( RTRIM( ISNU' +
        'LL( E.END_NUMERO, "" ) ) ) WHEN "" THEN "" ELSE ", " END + RTRIM' +
        '( LTRIM( E.END_NUMERO ) ) AS ENDERECO_NUM,'
      
        '       E.END_CIDADE + CASE LTRIM( RTRIM( ISNULL( P.NM_PAIS_PORT,' +
        ' "" ) ) ) WHEN "" THEN "" ELSE " - " END + RTRIM( LTRIM( P.NM_PA' +
        'IS_PORT ) ) AS CIDADE_PAIS, P.NM_PAIS_PORT AS NM_PAIS, ISNULL( E' +
        '.END_COMPL, "" ) AS NM_COMPLEMENTO'
      'FROM   TEMPRESA_EST E, TPAIS_BROKER P'
      'WHERE  E.CD_PAIS *= P.CD_PAIS')
    Left = 185
    Top = 8
  end
  object Dts_consig: TDataSource
    DataSet = TConsig
    Left = 185
    Top = 54
  end

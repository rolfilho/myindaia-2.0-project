  object TExp: TQuery
    OnCalcFields = TExpCalcFields
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'SELECT CD_EMPRESA AS CODIGO, NM_EMPRESA AS NOME,'
      '      '#39'p.p. '#39' + NM_EMPRESA AS PP_NOME,'
      '       AP_EMPRESA AS AP_EMPRESA, CGC_EMPRESA AS CGC_EMPRESA,'
      '       LTRIM( RTRIM( ISNULL( END_EMPRESA, "" ) ) ) +'
      
        '       CASE LTRIM( RTRIM( ISNULL( END_NUMERO, "" ) ) ) WHEN "" T' +
        'HEN "" ELSE ", " END +'
      
        '       LTRIM( RTRIM( ISNULL( END_NUMERO, "" ) ) ) AS ENDERECO_NU' +
        'M,'
      '       LTRIM( RTRIM( ISNULL( END_CIDADE, "" ) ) ) +'
      
        '       CASE LTRIM( RTRIM( ISNULL( END_UF, "" ) ) ) WHEN "" THEN ' +
        '"" ELSE "/" END +'
      '       RTRIM( LTRIM( END_UF ) ) +'
      '       CASE LTRIM( RTRIM( ISNULL( E.CD_PAIS_IMPORTADOR, "" ) ) )'
      '          WHEN "" THEN ""'
      '          ELSE " - " + LTRIM( RTRIM( P.NM_PAIS ) ) + " - "'
      '       END +'
      '       CASE LTRIM( RTRIM( ISNULL( END_CEP, "" ) ) )'
      
        '          WHEN "" THEN "" ELSE "CEP " + SUBSTRING( END_CEP, 1, 5' +
        ' ) + "-" + SUBSTRING( END_CEP, 6, 3 )'
      '       END AS END_CIDADE_UF_CEP,'
      
        '       END_CIDADE, END_CEP, END_BAIRRO, END_UF AS END_ESTADO, NR' +
        '_TELEFONE, NR_FAX'
      'FROM   TEMPRESA_NAC E, TPAIS_BROKER P'
      'WHERE  E.CD_PAIS_IMPORTADOR *= P.CD_PAIS AND'
      '       E.CD_EMPRESA = :CD_EXPORTADOR'
      '')
    Left = 16
    Top = 8
    ParamData = <
      item
        DataType = ftString
        Name = 'CD_EXPORTADOR'
        ParamType = ptUnknown
      end>
    object TExpCODIGO: TStringField
      FieldName = 'CODIGO'
      FixedChar = True
      Size = 5
    end
    object TExpNOME: TStringField
      FieldName = 'NOME'
      FixedChar = True
      Size = 50
    end
    object TExpPP_NOME: TStringField
      FieldName = 'PP_NOME'
      FixedChar = True
      Size = 55
    end
    object TExpAP_EMPRESA: TStringField
      FieldName = 'AP_EMPRESA'
      FixedChar = True
      Size = 10
    end
    object TExpCGC_EMPRESA: TStringField
      FieldName = 'CGC_EMPRESA'
      FixedChar = True
      Size = 14
    end
    object TExpENDERECO_NUM: TStringField
      FieldName = 'ENDERECO_NUM'
      FixedChar = True
      Size = 58
    end
    object TExpEND_CIDADE_UF_CEP: TStringField
      FieldName = 'END_CIDADE_UF_CEP'
      FixedChar = True
      Size = 172
    end
    object TExpEND_CIDADE: TStringField
      FieldName = 'END_CIDADE'
      FixedChar = True
      Size = 30
    end
    object TExpEND_CEP: TStringField
      FieldName = 'END_CEP'
      FixedChar = True
      Size = 8
    end
    object TExpEND_BAIRRO: TStringField
      FieldName = 'END_BAIRRO'
      FixedChar = True

  object dsPendenciasMenu: TDataSource
    DataSet = qryPendenciasMenu
    Left = 283
    Top = 365
  end
  object qryPendenciasMenu: TQuery
    OnCalcFields = qryPendenciasMenuCalcFields
    DatabaseName = 'Pendencias'
    SessionName = 'Session1'
    SQL.Strings = (
      
        'SELECT PP.NR_PROCESSO, CASE PP.NR_PROCESSO WHEN '#39'X'#39' THEN LTRIM(R' +
        'TRIM(PP.NR_REFERENCIA))+'#39'/'#39'+LTRIM(RTRIM(PP.NR_ITEM_CLIENTE))+'#39'/'#39 +
        '+LTRIM(RTRIM(PP.NR_PARCIAL)) ELSE SUBSTRING(PP.NR_PROCESSO,5,15)' +
        ' END AS NR_PROCESSO_REDUZIDO, PP.NR_REFERENCIA, PP.NR_ITEM_CLIEN' +
        'TE,  PP.NR_PARCIAL, PP.CD_EMPRESA, PP.CD_PENDENCIA, PP.NM_PENDEN' +
        'CIA, MAX(PL.DT_TEXTO) AS DT_MAXIMA, U.AP_USUARIO, SP.NM_STATUS,D' +
        'ATEDIFF(MINUTE,  ISNULL(PP.DT_SOLICITACAO, PP.DT_PRIMEIRA_SOLICI' +
        'TACAO), ISNULL(PP.DT_RESPOSTA_SOLICITA,GETDATE())) AS DIFERENCA,' +
        ' DATEDIFF(MINUTE,  PP.DT_PRIMEIRA_SOLICITACAO, ISNULL(PP.DT_FINA' +
        'LIZACAO, GETDATE())) AS DIFERENCA2, PP.CD_STATUS'
      '  FROM MYINDAIA.DBO.TPROCESSO_PENDENCIAS PP (NOLOCK)'
      
        '  LEFT JOIN MYINDAIA.DBO.TPROCESSO_PENDENCIAS_LOG PL (NOLOCK) ON' +
        ' PL.NR_PROCESSO = PP.NR_PROCESSO'
      
        '                                                     AND PL.CD_P' +
        'ENDENCIA = PP.CD_PENDENCIA'
      
        '  INNER JOIN TUSUARIO U (NOLOCK) ON U.CD_USUARIO = PP.CD_USUARIO' +
        '_CRIADOR'
      
        '  INNER JOIN MYINDAIA.DBO.TTP_STATUS_PENDENCIAS SP (NOLOCK) ON S' +
        'P.CD_STATUS = PP.CD_STATUS'
      
        '  WHERE ((PP.CD_USUARIO_CRIADOR = :CD_USUARIO_CRIADOR OR PP.CD_U' +
        'SUARIO_SOLICITACAO = :CD_USUARIO_CRIADOR)'
      '    AND PP.CD_STATUS NOT IN  ('#39'5'#39'))'
      
        '  GROUP BY PP.NR_PROCESSO, SUBSTRING(PP.NR_PROCESSO,5,15), PP.NR' +
        '_REFERENCIA, PP.NR_ITEM_CLIENTE,  PP.NR_PARCIAL, PP.CD_EMPRESA, ' +
        'PP.CD_PENDENCIA, PP.NM_PENDENCIA, U.AP_USUARIO, SP.NM_STATUS, PP' +
        '.DT_SOLICITACAO, PP.DT_RESPOSTA_SOLICITA, PP.DT_PRIMEIRA_SOLICIT' +
        'ACAO, PP.DT_FINALIZACAO,  PP.CD_STATUS'
      '  ORDER BY DIFERENCA'
      '  '
      '  ')
    Left = 315
    Top = 365
    ParamData = <
      item
        DataType = ftString
        Name = 'CD_USUARIO_CRIADOR'
        ParamType = ptInput
        Size = 4
      end
      item
        DataType = ftString
        Name = 'CD_USUARIO_CRIADOR'
        ParamType = ptInput
      end>
    object qryPendenciasMenuNR_PROCESSO: TStringField
      FieldName = 'NR_PROCESSO'
      FixedChar = True
      Size = 15
    end
    object qryPendenciasMenuNM_PENDENCIA: TStringField
      FieldName = 'NM_PENDENCIA'
      FixedChar = True
      Size = 50
    end
    object qryPendenciasMenuDT_MAXIMA: TDateTimeField
      FieldName = 'DT_MAXIMA'
    end
    object qryPendenciasMenuAP_USUARIO: TStringField
      FieldName = 'AP_USUARIO'
      FixedChar = True
      Size = 15
    end
    object qryPendenciasMenuNR_PROCESSO_REDUZIDO: TStringField
      FieldName = 'NR_PROCESSO_REDUZIDO'
      FixedChar = True
      Size = 15
    end
    object qryPendenciasMenuNM_STATUS: TStringField
      FieldName = 'NM_STATUS'
      FixedChar = True
      Size = 50
    end
    object qryPendenciasMenuCALC_DIF_TEMPO: TStringField
      FieldKind = fkCalculated
      FieldName = 'CALC_DIF_TEMPO'
      Size = 50
      Calculated = True
    end
    object qryPendenciasMenuCD_PENDENCIA: TIntegerField
      FieldName = 'CD_PENDENCIA'
    end
    object qryPendenciasMenuCALC_DIF_TEMPO2: TStringField
      FieldKind = fkCalculated
      FieldName = 'CALC_DIF_TEMPO2'
      Size = 50
      Calculated = True
    end
    object qryPendenciasMenuDIFERENCA: TIntegerField
      FieldName = 'DIFERENCA'
    end
    object qryPendenciasMenuDIFERENCA2: TIntegerField
      FieldName = 'DIFERENCA2'
    end
    object qryPendenciasMenuCD_STATUS: TStringField
      FieldName = 'CD_STATUS'
      FixedChar = True
      Size = 1
    end
    object qryPendenciasMenuNR_REFERENCIA: TStringField
      FieldName = 'NR_REFERENCIA'
      FixedChar = True
      Size = 18
    end
    object qryPendenciasMenuNR_ITEM_CLIENTE: TStringField
      FieldName = 'NR_ITEM_CLIENTE'
      FixedChar = True
      Size = 4
    end
    object qryPendenciasMenuNR_PARCIAL: TIntegerField

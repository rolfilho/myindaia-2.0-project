  object qry_trel_po_flp_item_: TQuery
    OnCalcFields = qry_trel_po_flp_item_CalcFields
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'SELECT *'
      'FROM   TREL_PO_FLP_ITEM'
      'WHERE  NR_IDENTIFICADOR =:NR_IDENTIFICADOR AND'

  object qry_trel_po_flp_ev_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'SELECT R.*, E.NM_EVENTO, S.NM_STATUS_FLP, V.NM_RESPONSAVEL'
      
        'FROM   TREL_PO_FLP_EV R, TEVENTO E, TSTATUS_FLP S, TRESPONSAVEL ' +
        'V'
      'WHERE  R.CD_EVENTO = E.CD_EVENTO AND'
      '       R.CD_RESPONSAVEL = V.CD_RESPONSAVEL AND'
      '       R.CD_STATUS = S.CD_STATUS_FLP AND'
      '       R.NR_IDENTIFICADOR = :NR_IDENTIFICADOR AND'
      '       NR_PROCESSO = :NR_PROCESSO'
      'ORDER BY R.NR_PROCESSO, R.NR_ORDEM')
    Params.Data = {
      01000200104E525F4944454E544946494341444F52000304000000000000000B
      4E525F50524F434553534F0001020030000000}
    Left = 40
    Top = 256
    object qry_trel_po_flp_ev_NR_IDENTIFICADOR: TIntegerField
      FieldName = 'NR_IDENTIFICADOR'

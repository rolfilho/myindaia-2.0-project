  object qry_conhecimento_: TQuery
    DatabaseName = 'DBBROKER'
    SessionName = 'Default'
    SQL.Strings = (
      
        'SELECT '#39'Vimos pela presente solicitar a V.Sa., a DESUNITIZA'#199#195'O, ' +
        'para admiss'#227'o em regime de entreposto aduaneiro, do(s) container' +
        '(s) abaixo relacionado(s), recebido(s) nesse EADI do Navio '#39' +'
      
        '       E.NM_EMBARCACAO +  ISNULL('#39' entrado dia'#39' +  CONVERT( varc' +
        'har(10), P.DT_ATRACACAO, 103), '#39#39') +'
      
        '       '#39', origin'#225'rio do Porto de '#39' + L.DESCRICAO +  '#39'. '#39' AS DADO' +
        'S_PROCESSO,'
      ''
      
        '       '#39'REF: '#39' +  E.NM_EMBARCACAO +  '#39', entrado dia _____/_____/' +
        '_____'#39
      '        AS NM_NAVIO,'
      ''
      '       '#39'BL: '#39' +  P.NR_CONHECIMENTO AS NR_CONHECIMENTO,'
      ''
      '       '#39'Processo: '#39' +'
      
        '       CASE LTRIM( RTRIM( ISNULL( P.NR_PROCESSO, "" ) ) ) WHEN "' +
        '" THEN "" ELSE "" END  +'
      
        '       SUBSTRING( P.NR_PROCESSO, 5, 10 ) + '#39' - '#39' + '#39'BL: '#39' +  P.N' +
        'R_CONHECIMENTO  AS PROCESSO,'
      '       A.NM_ARMAZEM AS NM_ARMAZEM,'
      
        '       '#39'2- O(s) cont'#234'iner(es) est'#225'('#227'o) depositado(s) no '#39' + LTRI' +
        'M( RTRIM( ISNULL( A.NM_ARMAZEM, '#39#39' ) ) ) +'
      
        '       '#39', sendo interesse da signat'#225'ria que o(s) mesmo(s) seja(m' +
        ') desunitizado(s), entretanto, '#39' +'
      
        '       '#39#233' a presente para formalizar o pedido de desist'#234'ncia de ' +
        'vistoria aduaneira assumindo, integralmente, '#39' +'
      
        '       '#39'a responsabilidade pelos '#244'nus decorrentes dessa desist'#234'n' +
        'cia, nos termos do disposto no artigo 473, '#39' +'
      
        '       '#39'do Decreto 91,030/85 (Regulamento Aduaneiro). '#39' AS NM_IT' +
        'EM2,'
      
        '       '#39'3- A presente solicita'#231#227'o de desunitiza'#231#227'o '#233' formulada c' +
        'om a responsabilidade da signat'#225'ria em efetuar o '#39' +'
      
        '       '#39'pagamento das despesas decorrentes ao '#39' + LTRIM( RTRIM( ' +
        'ISNULL( A.NM_ARMAZEM, '#39#39' ) ) ) +'
      
        '       '#39', isentando-o de qualquer responsabilidade pelas eventua' +
        'is avarias '#224' mercadorias desunitizadas, '#39' +'
      
        '       '#39'e autorizando-o a devolver ou entregar o cont'#234'iner ap'#243's ' +
        'a desunitiza'#231#227'o.'#39' AS NM_ITEM3,'
      
        '       '#39'A signat'#225'ria se coloca '#224' disposi'#231#227'o para complementar qu' +
        'aisquer dados necess'#225'rios, informando que, no caso '#39' +'
      
        '       '#39'de abandono das mercadorias desunitizadas, se responsabi' +
        'lizar'#225' pelo pagamento das taxas devidas ao '#39' +'
      '       LTRIM( RTRIM( ISNULL( A.NM_ARMAZEM, '#39#39' ) ) ) +'
      
        '       '#39', ressarcindo o mesmo dos preju'#237'zos decorrentes, at'#233' a d' +
        'estrui'#231#227'o das mercadorias ou a '#39' +'
      
        '       '#39'retirada das mesmas atrav'#233's de leil'#227'o ou outra destina'#231#227 +
        'o que essa reparti'#231#227'o aduaneira determinar.'#39' AS NM_ITEM4'
      
        'FROM   TPROCESSO P , TEMBARCACAO E, TLOCAL_EMBARQUE L, TARMAZEM ' +

  object qry_dados_clientes_: TQuery
    DatabaseName = 'DBBROKER'
    SessionName = 'Default'
    SQL.Strings = (
      'SELECT E.NM_EMPRESA + '#39', '#39' +'
      '       CASE ISNULL( E.CGC_EMPRESA, '#39#39' )'
      '         WHEN '#39#39' THEN '#39#39
      '         ELSE '#39'C.N.P.J.:'#39' +'
      
        '              SUBSTRING( E.CGC_EMPRESA, 1, 2 ) + '#39'.'#39' + SUBSTRING' +
        '( E.CGC_EMPRESA, 3, 3 ) + '#39'.'#39' + SUBSTRING( E.CGC_EMPRESA, 6, 3 )' +
        ' + '#39'/'#39' +'
      
        '              SUBSTRING( E.CGC_EMPRESA, 9, 4 ) + '#39'-'#39' + SUBSTRING' +
        '( E.CGC_EMPRESA, 13, 2 ) + '#39', '#39
      '       END +'
      '        '#39'com sede a '#39' +'
      '       E.END_EMPRESA + '#39', '#39' + E.END_NUMERO +'
      '       CASE ISNULL( E.END_BAIRRO, '#39#39' )'
      '         WHEN '#39#39' THEN '#39#39
      '         ELSE '#39' - '#39' + E.END_BAIRRO'
      '       END +'
      '       CASE ISNULL( E.END_CIDADE, '#39#39' )'
      '         WHEN '#39#39' THEN '#39#39
      '         ELSE '#39' - '#39' + E.END_CIDADE'
      '       END +'
      '       CASE ISNULL( E.END_UF, '#39#39' )'
      '         WHEN '#39#39' THEN '#39#39
      '         ELSE '#39' - '#39' + E.END_UF'
      '       END + '#39', '#39' +'
      
        '       '#39'por seu representante legal, assinado e qualificado, vem' +
        ' expor e requerer o seguinte:'#39
      '       AS DADOS_CLIENTE,'
      '       '#39'Importador: '#39' + E.NM_EMPRESA AS NM_IMPORTADOR'
      'FROM TPROCESSO P, TEMPRESA_NAC E'
      'WHERE P.CD_CLIENTE = E.CD_EMPRESA AND'
      '      NR_PROCESSO = :NR_PROCESSO'
      '')
    Left = 792
    Top = 296
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
        Value = '0101DD-0046-02'
      end>
  end

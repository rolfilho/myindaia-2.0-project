  object qry_fat_cc_: TQuery
    DatabaseName = 'DBBROKER'
    DataSource = ds_processo
    SQL.Strings = (
      'SELECT SUM( CASE C.IN_RESTITUI'
      
        '              WHEN '#39'0'#39' THEN (ISNULL(C.VL_ITEM, 0) + ISNULL(C.VL_' +
        'ASSIST, 0))'
      
        '              ELSE ((ISNULL(C.VL_ITEM, 0) + ISNULL(C.VL_ASSIST, ' +
        '0)) * (-1))'
      '            END ) VL_ITEM'
      'FROM TFATURAMENTO_CC C,'
      '     TITEM I,'
      '     TTIPO_ITEM T'
      'WHERE C.CD_ITEM = I.CD_ITEM AND'
      '      I.CD_TIPO_ITEM = T.CD_TIPO_ITEM AND'
      '      C.NR_PROCESSO = :NR_PROCESSO AND'
      '      C.CD_ITEM = :CD_ITEM AND'
      '      T.IN_FATURAR = '#39'1'#39' AND'
      '      ( ( T.TP_NATUREZA = '#39'D'#39' ) OR (T.CD_TIPO_ITEM = '#39'I'#39') ) AND'
      '      NOT T.CD_TIPO_ITEM  IN ('#39'T'#39','#39'V'#39') AND'
      '      C.IN_CANCELADO = '#39'0'#39)
    Left = 122
    Top = 388
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_ITEM'
        ParamType = ptUnknown
      end>
    object qry_fat_cc_VL_ITEM: TFloatField
      FieldName = 'VL_ITEM'
      Origin = 'TFATURAMENTO_CC.VL_ITEM'
    end
  end

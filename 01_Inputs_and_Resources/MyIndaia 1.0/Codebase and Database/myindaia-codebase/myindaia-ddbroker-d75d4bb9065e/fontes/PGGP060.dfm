  object qry_rel_est_vol_mod2_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT R.NR_IDENTIFICADOR, SUBSTRING( R.NR_PROCESSO, 5, 14) AS N' +
        'R_PROCESSO, R.CD_UNID_NEG, U.NM_UNID_NEG, R.CD_PRODUTO, '
      '       PR.NM_PRODUTO, R.NR_ADICAO, G.NM_GRUPO, '
      
        '       R.CD_CLIENTE, E.NM_EMPRESA AS NM_CLIENTE, R.CD_AGENTE, AG' +
        '.NM_AGENTE,'
      
        '       R.VL_QTDE, R.NM_VOLUME, AD.NM_ARMAZEM AS NM_ARMAZEM_DESCA' +
        'RGA, AA.NM_ARMAZEM AS NM_ARMAZEM_ATRACACAO,'
      
        '       R.VL_AFRMM, R.VL_LIB_BL, R.VL_TX_DESC, R.VL_HANDLING, R.V' +
        'L_CAPATAZIA,'
      
        '       R.VL_THC_TERMINAL, R.VL_MOV_CARREGAMENTO, R.VL_ARMAZENAGE' +
        'M, TC.NM_CANAL, R.CD_REFERENCIA,'
      
        '       R.VL_CIF_DOLAR, R.VL_CIF_MN, TF.DESCRICAO AS NM_TP_FRETE,' +
        ' R.DT_DESEMB, R.DT_PRES_CARGA,'
      
        '       R.DT_ENVIO_NF_TRANSP, R.VL_PESO_BRUTO, R.VL_FRETE_MNEG, R' +
        '.VL_FRETE_MN,'
      
        '       A.NM_AREA,  R.VL_IPI_MN, R.DT_REGISTRO, R.DT_LIB_NF_TRANS' +
        'P, S.CD_SERVICO, S.CD_SERVICO + '#39' - '#39' + S.NM_SERVICO as DS_SERVI' +
        'CO,'
      
        '       R.DT_CHEGADA_NAVIO, AP_MOEDA AS AP_MOEDA, ISNULL(R.VL_II_' +
        'MN, 0) AS VL_II_MN, ISNULL(R.VL_IPI_MN, 0) VL_IPI_MN, ISNULL(R.V' +
        'L_ALIQUOTA_IPI, '#39'0'#39') AS VL_ALIQUOTA_IPI, '
      
        '       ISNULL(R.VL_ALIQUOTA_II, '#39'0'#39')AS VL_ALIQUOTA_II, R.CD_REGI' +
        'ME_TRIBUTAR, '
      
        '       (SELECT REG.DESCRICAO FROM TREG_TRIBUTARIO REG, TRIBUTO T' +
        ' '
      
        '        WHERE T.NR_PROCESSO = R.NR_PROCESSO AND T.NR_ADICAO = R.' +
        'NR_ADICAO AND'
      
        '          REG.CODIGO = CD_REGIME_TRIBUTAR AND CD_RECEITA_IMPOSTO' +
        ' = '#39'0001'#39') AS REGIME_II, '
      '       (SELECT CASE WHEN AI.IN_IPI_NAO_TRIBUT = 1 THEN'
      '             '#39'N'#195'O TRIBUT'#193'VEL'#39' ELSE'
      '             REG.DESCRICAO'
      
        '        END FROM TREG_TRIBUTARIO REG, TRIBUTO T , TADICAO_DE_IMP' +
        'ORTACAO AI'
      
        '        WHERE T.NR_PROCESSO = R.NR_PROCESSO AND T.NR_ADICAO = R.' +
        'NR_ADICAO AND'
      
        #9'  AI.NR_PROCESSO = R.NR_PROCESSO AND AI.NR_ADICAO = R.NR_ADICAO' +
        ' AND'
      
        '          REG.CODIGO = CD_REGIME_TRIBUTAR AND CD_RECEITA_IMPOSTO' +
        ' = '#39'0002'#39') AS REGIME_IPI'
      
        'FROM TREL_EST_VOLUMES_MOD2 R, TEMPRESA_NAC E, TUNID_NEG U, TPROD' +
        'UTO PR, TAGENTE AG,'
      
        ' TARMAZEM AD, TARMAZEM AA , TTP_CANAL TC, TTP_FRETE TF, TAREA A,' +
        ' TSERVICO S, TMOEDA_BROKER M, TGRUPO G'
      'WHERE  R.NR_IDENTIFICADOR = :NR_IDENTIFICADOR  AND'
      '       R.CD_UNID_NEG = U.CD_UNID_NEG AND'
      '       R.CD_PRODUTO = PR.CD_PRODUTO AND'
      '       R.TP_FRETE *= TF.CODIGO AND'
      '       R.CD_CLIENTE = E.CD_EMPRESA AND'
      '       R.CD_AGENTE *= AG.CD_AGENTE AND'
      '       R.CD_ARMAZEM_DESCARGA *= AD.CD_ARMAZEM AND'
      '       R.CD_ARMAZEM_ATRACACAO *= AA.CD_ARMAZEM AND'
      '       R.CD_CANAL = TC.CD_CANAL AND'
      '       R.CD_AREA = A.CD_AREA AND'
      '       R.CD_SERVICO = S.CD_SERVICO AND'
      '       R.CD_MOEDA_FRETE = M.CD_MOEDA AND'
      '       E.CD_GRUPO = G.CD_GRUPO '
      
        'ORDER BY R.NR_IDENTIFICADOR, R.CD_UNID_NEG, R.CD_PRODUTO, R.CD_C' +
        'LIENTE, AG.NM_AGENTE, DS_SERVICO, R.NR_PROCESSO, R.CD_REFERENCIA' +
        ', R.NM_VOLUME')
    Left = 186
    Top = 208
    ParamData = <
      item
        DataType = ftInteger
        Name = 'NR_IDENTIFICADOR'
        ParamType = ptUnknown
      end>

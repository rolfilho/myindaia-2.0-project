  object ds_trel_est_vol_mod2_sub_: TDataSource
    DataSet = qry_rel_est_vol_mod2_sub_
    Left = 52
    Top = 259
  end
  object qry_rel_est_vol_mod2_sub_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT R.NR_IDENTIFICADOR, SUBSTRING( R.NR_PROCESSO, 5, 14) AS N' +
        'R_PROCESSO, R.CD_UNID_NEG, R.CD_PRODUTO, '
      
        '       R.NR_ADICAO, R.CD_CLIENTE, R.NM_VOLUME, R.NR_SEQUENCIA, R' +
        '.CD_REFERENCIA, '
      
        '       ISNULL(R.VL_II_MN, 0) AS VL_II_MN, ISNULL(R.VL_IPI_MN, 0)' +
        ' VL_IPI_MN, '
      '       ISNULL(R.VL_ALIQUOTA_IPI, '#39'0'#39') AS VL_ALIQUOTA_IPI, '
      '       ISNULL(R.VL_ALIQUOTA_II, '#39'0'#39')AS VL_ALIQUOTA_II, '
      
        '       (SELECT REG.DESCRICAO FROM TREG_TRIBUTARIO REG, TRIBUTO T' +
        ' '
      
        '        WHERE T.NR_PROCESSO = R.NR_PROCESSO AND T.NR_ADICAO = R.' +
        'NR_ADICAO AND'
      
        '          REG.CODIGO = CD_REGIME_TRIBUTAR AND CD_RECEITA_IMPOSTO' +
        ' = '#39'0001'#39') AS REGIME_II, '
      '       (SELECT CASE WHEN AI.IN_IPI_NAO_TRIBUT = 1 THEN'
      '             '#39'N'#195'O TRIBUT'#193'VEL'#39' ELSE'
      '             REG.DESCRICAO'
      
        '        END FROM TREG_TRIBUTARIO REG, TRIBUTO T , TADICAO_DE_IMP' +
        'ORTACAO AI'
      
        '        WHERE T.NR_PROCESSO = R.NR_PROCESSO AND T.NR_ADICAO = R.' +
        'NR_ADICAO AND'
      
        #9'  AI.NR_PROCESSO = R.NR_PROCESSO AND AI.NR_ADICAO = R.NR_ADICAO' +
        ' AND'
      
        '          REG.CODIGO = CD_REGIME_TRIBUTAR AND CD_RECEITA_IMPOSTO' +
        ' = '#39'0002'#39') AS REGIME_IPI'
      'FROM TREL_EST_VOLUMES_MOD2 R'
      'WHERE  R.NR_IDENTIFICADOR =:NR_IDENTIFICADOR'
      'ORDER BY R.NR_IDENTIFICADOR, R.NR_PROCESSO, R.CD_REFERENCIA')
    Left = 186
    Top = 259
    ParamData = <
      item
        DataType = ftInteger
        Name = 'NR_IDENTIFICADOR'
        ParamType = ptUnknown

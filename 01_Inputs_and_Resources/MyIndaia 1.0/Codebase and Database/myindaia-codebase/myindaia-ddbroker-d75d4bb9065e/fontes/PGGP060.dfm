      'FROM   TPROCESSO P (NOLOCK)'
      
        '       LEFT  JOIN TREF_CLIENTE R (NOLOCK) ON ( P.NR_PROCESSO = R' +
        '.NR_PROCESSO  )'
      
        '       INNER JOIN TEMBARCACAO E (NOLOCK) ON ( P.CD_EMBARCACAO = ' +
        'E.CD_EMBARCACAO )'
      
        '       LEFT  JOIN TTP_CANAL C (NOLOCK) ON ( P.CD_CANAL = C.CD_CA' +
        'NAL )'
      
        '       INNER JOIN TFOLLOWUP F (NOLOCK) ON ( P.NR_PROCESSO = F.NR' +
        '_PROCESSO AND F.CD_EVENTO = '#39'022'#39' )'
      
        '       INNER JOIN TFOLLOWUP F1 (NOLOCK) ON ( P.NR_PROCESSO = F1.' +

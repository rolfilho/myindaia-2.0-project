  object qry_rel_est_vol_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT R.NR_IDENTIFICADOR, R.CD_UNID_NEG, U.NM_UNID_NEG, R.CD_PR' +
        'ODUTO, PR.NM_PRODUTO,'
      
        '       R.CD_CLIENTE, E.NM_EMPRESA AS NM_CLIENTE, R.CD_AGENTE, AG' +
        '.NM_AGENTE, R.NR_PROCESSO,'
      
        '       R.VL_QTDE, R.NM_VOLUME, LO.DESCRICAO AS NM_LOCAL_ORIGEM, ' +
        'EX.NM_EMPRESA AS NM_EMP_EST,'
      
        '       TF.DESCRICAO AS NM_TP_FRETE, R.VL_PESO_BRUTO, R.VL_FRETE_' +
        'MNEG, R.VL_FRETE_MN,'
      
        '       MF.AP_MOEDA AS NM_MOEDA_FRETE, R.VL_AFRMM, R.VL_LIB_BL, R' +
        '.VL_TX_DESC, R.VL_HANDLING, R.VL_CAPATAZIA,'
      
        '       R.VL_THC_TERMINAL, R.VL_MOV_CARREGAMENTO, R.VL_ARMAZENAGE' +
        'M, R.TX_MERCADORIA,'
      
        '       R.VL_CIF_DOLAR, R.VL_CIF_MN, P.DESCRICAO AS NM_PAIS_DESTI' +
        'NO,'
      
        '       T.DESCRICAO AS NM_TRANSPORTADOR, AD.NM_ARMAZEM AS NM_ARMA' +
        'ZEM_DESCARGA,'
      
        '       AA.NM_ARMAZEM AS NM_ARMAZEM_ATRACACAO, R.DT_DESEMB, R.DT_' +
        'ENVIO_NF_TRANSP,'
      '       MM.AP_MOEDA AS NM_MOEDA_MLE, R.VL_MLE_MNEG, R.VL_MLE_MN'
      
        'FROM   TREL_EST_VOLUMES R, TEMPRESA_NAC E, TUNID_NEG U, TPRODUTO' +
        ' PR, TAGENTE AG,'
      
        '       TLOCAL_EMBARQUE LO, TEMPRESA_EST EX, TTP_FRETE TF, TMOEDA' +
        '_BROKER MF, TPAIS P,'
      
        '       TTRANSPORTADOR_ITL T, TARMAZEM AD, TARMAZEM AA, TMOEDA_BR' +
        'OKER MM'
      'WHERE  R.NR_IDENTIFICADOR = :NR_IDENTIFICADOR AND'
      '       R.CD_UNID_NEG = U.CD_UNID_NEG AND'
      '       R.CD_PRODUTO = PR.CD_PRODUTO AND'
      '       R.CD_CLIENTE = E.CD_EMPRESA AND'
      '       R.CD_AGENTE *= AG.CD_AGENTE AND'
      '       R.CD_LOCAL_ORIGEM *= LO.CODIGO AND'
      '       R.CD_EMP_EST *= EX.CD_EMPRESA AND'
      '       R.TP_FRETE *= TF.CODIGO AND'
      '       R.CD_PAIS_DESTINO *= P.CODIGO AND'
      '       R.CD_MOEDA_MLE *= MM.CD_MOEDA AND'
      '       R.CD_MOEDA_FRETE *= MF.CD_MOEDA AND'
      '       R.CD_TRANSPORTADOR *= T.CODIGO AND'
      '       R.CD_ARMAZEM_DESCARGA *= AD.CD_ARMAZEM AND'
      '       R.CD_ARMAZEM_ATRACACAO *= AA.CD_ARMAZEM'
      
        'ORDER BY R.NR_IDENTIFICADOR, R.CD_UNID_NEG, R.CD_PRODUTO, R.CD_C' +
        'LIENTE, R.CD_AGENTE'
      '')
    Left = 186
    Top = 108
    ParamData = <
      item
        DataType = ftInteger
        Name = 'NR_IDENTIFICADOR'
        ParamType = ptUnknown
      end>
  end

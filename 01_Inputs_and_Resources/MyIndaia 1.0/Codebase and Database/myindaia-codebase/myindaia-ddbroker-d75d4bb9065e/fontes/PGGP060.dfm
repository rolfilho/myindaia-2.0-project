  object qry_rel_armz_carga_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT A.NM_ARMAZEM, R.NR_MES, R.NR_ANO, SUM(R.VL_QTDE) AS QTDE,' +
        ' SUM(R.VL_ARMAZENAGEM) AS ARMA'
      'FROM TREL_EST_ARMZ_CARGA R, TARMAZEM A (NOLOCK)'
      'WHERE NR_IDENTIFICADOR = :NR_IDENTIFICADOR AND'
      '      R.CD_ARM_DESCARGA = A.CD_ARMAZEM'
      'GROUP BY A.NM_ARMAZEM, NR_MES, NR_ANO'
      'ORDER BY A.NM_ARMAZEM, NR_MES, NR_ANO')
    Left = 304
    Top = 157
    ParamData = <
      item
        DataType = ftInteger
        Name = 'NR_IDENTIFICADOR'
        ParamType = ptInput
      end>
    object qry_rel_armz_carga_NM_ARMAZEM: TStringField
      FieldName = 'NM_ARMAZEM'
      FixedChar = True
      Size = 50
    end
    object qry_rel_armz_carga_NR_MES: TStringField
      FieldName = 'NR_MES'
      FixedChar = True
      Size = 2
    end
    object qry_rel_armz_carga_NR_ANO: TStringField
      FieldName = 'NR_ANO'
      FixedChar = True
      Size = 4
    end
    object qry_rel_armz_carga_QTDE: TFloatField
      FieldName = 'QTDE'
    end
    object qry_rel_armz_carga_ARMA: TFloatField
      FieldName = 'ARMA'
    end
  end
  object qry_cabec_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'SELECT NR_MES AS MES, NR_ANO AS ANO'
      'FROM TREL_EST_ARMZ_CARGA'
      
        'WHERE CD_ARM_DESCARGA = ( SELECT MAX( CD_ARM_DESCARGA ) FROM TRE' +
        'L_EST_ARMZ_CARGA WHERE NR_IDENTIFICADOR = :NR_IDENTIFICADOR )'
      'AND NR_IDENTIFICADOR = :NR_IDENTIFICADOR1'
      'ORDER BY DT_FINAL ')
    Left = 304
    Top = 201
    ParamData = <
      item
        DataType = ftInteger
        Name = 'NR_IDENTIFICADOR'
        ParamType = ptInput
      end
      item
        DataType = ftInteger
        Name = 'NR_IDENTIFICADOR1'
        ParamType = ptInput
      end>

  object qry_fup_proc_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT SUBSTRING( P.NR_PROCESSO, 5, 10 ) AS NR_PROCESSO, R.CD_RE' +
        'FERENCIA,'
      '       ( SELECT F.DT_REALIZACAO'
      '         FROM   TFOLLOWUP F (NOLOCK)'
      '         WHERE  F.NR_PROCESSO = P.NR_PROCESSO AND'
      '                F.CD_EVENTO = '#39'257'#39' ) AS DT_REC_PO,'
      '       SUBSTRING( P.TX_MERCADORIA, 1, 250 ) AS PRODUTO,'
      '       P.NR_VOO, '
      '       ( SELECT F.DT_REALIZACAO'
      '         FROM   TFOLLOWUP F (NOLOCK)'

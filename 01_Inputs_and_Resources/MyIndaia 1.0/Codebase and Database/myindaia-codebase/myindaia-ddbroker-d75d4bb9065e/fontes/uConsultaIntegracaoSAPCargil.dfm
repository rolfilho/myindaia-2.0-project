  object dsMain: TDataSource
    DataSet = qryMain
    Left = 468
    Top = 204
  end
  object qryMain: TSQLQuery
    MaxBlobSize = -1
    Params = <>
    SQL.Strings = (
      'DECLARE @DATA_INICIAL DATE = CAST('#39'2020-05-01'#39' AS DATE)'
      'DECLARE @DATE_FINAL DATE = CAST('#39'2020-05-02'#39' AS DATE)'
      ''
      'WITH SELECTCARGIL('
      '[NR_PROCESSO],'
      '[ID COLUMN TESTE],'
      '[TEXT],'
      '[DOCUMENT NUMBER],'
      '[DOCUMENT YEAR],'
      '[CUSTOMS CONTROL RESULTS],'
      '[OGA CONTROL RESULTS],'
      '[REGISTRATION NUMBER],'
      '[EXPORTING COUNTRY],'
      '[ENTRY TYPE],'
      '[EXPORTER OF RECORD NUMBER],'
      '[CARGO CONTROL NO.],'
      '[TOTAL VALUE],'
      '[TOTAL VALUE CURRENCY],'
      '[EXCHANGE RATE],'
      '[FREIGHT],'
      '[FREIGHT CURRENCY],'
      '[INSURANCE],'
      '[INSURANCE CURRENCY],'
      '[CHARGES],'
      '[CHARGES CURRENCY],'
      '[FEES],'
      '[FEES CURRENCY],'
      '[OTHER TAXES],'
      '[OTHER TAXES CURRENCY],'
      '[DATE OF ACCEPTANCE],'
      '[ENTRY DATE],'
      '[Item Number],'
      '[Gross Weight],'
      '[Net Weight],'
      '[Net Weight UOM],'
      '[Net Quantity],'
      '[Net Quantity UOM],'
      '[Country of Origin],'
      '[Party Relationship/Affiliation],'
      '[Customs Status Placement],'
      '[HTS Number],'
      '[Entered Value],'
      '[Entered Value Currency],'
      '[Duty Amount],'
      '[Duty Amount Currency],'
      '[VAT Amount],'
      '[VAT Amount Currency],'
      '[Freight (Deductible)],'
      '[Freight (Deductible) Currency],'
      '[Total Amount Invoiced],'
      '[Currency of total amount invoiced],'
      '[Statistical Value],'
      '[Statistical Value Currency],'
      '[Charges2],'
      '[Charges Currency2],'
      '[Harbor Maintenance Fee (HMF)],'
      '[Harbor Maintenance Fee (HMF) Currency],'
      '[Merchandise Processing Fee (MPF)],'
      '[Merchandise Processing Fee (MPF) Currency],'
      '[Special Program Indicator],'
      '[Container Number]'
      ''
      ') AS'
      #9'('
      #9'SELECT '
      #9'TP.NR_PROCESSO,'
      #9#39'H'#39' AS [ID COLUMN] --A'
      #9','#39#39' AS [TEXT]--B'
      #9',FAT.CD_REFERENCIA AS [DOCUMENT NUMBER]--C'
      #9',YEAR(FAT.DT_REFERENCIA) AS [DOCUMENT YEAR]--D'
      #9','
      #9'CASE'
      #9'WHEN TP.CD_CANAL = 0 THEN '#39'RED'#39
      #9'WHEN TP.CD_CANAL = 1 THEN '#39'YEL'#39
      #9'WHEN TP.CD_CANAL = 2 THEN '#39'GRE'#39
      #9'WHEN TP.CD_CANAL = 3 THEN '#39'CIN'#39
      #9'END AS [CUSTOMS CONTROL RESULTS] --E'
      #9','#39#39' AS [OGA CONTROL RESULTS] --F'
      #9',TP.CD_DUE AS [REGISTRATION NUMBER] --G'
      #9',PD.NM_SIGLA_2L AS [EXPORTING COUNTRY] --H'
      #9','#39'EC01'#39' AS [ENTRY TYPE] --I'
      #9',EN.CGC_EMPRESA AS [EXPORTER OF RECORD NUMBER]--J'
      #9','#39#39' AS [CARGO CONTROL NO.] --K'
      #9',DUE.VL_LOCAL_EMBARQUE_TOTAL AS [TOTAL VALUE] --L'
      #9',ME.AP_MOEDA AS [TOTAL VALUE CURRENCY] --M'
      #9',DUE.VL_TAXA AS [EXCHANGE RATE] --N'
      #9',DUE.VL_FRETE AS [FREIGHT] --O'
      #9',MF.AP_MOEDA AS [FREIGHT CURRENCY] --P'
      #9',DUE.VL_SEGURO AS [INSURANCE] --Q'
      #9',ME.AP_MOEDA AS [INSURANCE CURRENCY] --R'
      #9','#39#39' AS [CHARGES] --S'
      #9','#39#39' AS [CHARGES CURRENCY] --T'
      #9','#39#39' AS [FEES] --U'
      #9','#39#39' AS [FEES CURRENCY] --V'
      #9','#39#39' AS [OTHER TAXES] --W'
      #9','#39#39' AS [OTHER TAXES CURRENCY] --X'
      
        #9',CONVERT(VARCHAR(10),EV124.DT_REALIZACAO,101) AS [DATE OF ACCEP' +
        'TANCE] --Y'
      
        #9',CONVERT(VARCHAR(10),EV088.DT_REALIZACAO,101) AS [ENTRY DATE] -' +
        '-Z'
      #9','#39#39' AS [Item Number] --AA'
      #9','#39#39' AS [Gross Weight] --AB'
      #9','#39#39' AS [Net Weight] --AC'
      #9','#39#39' AS [Net Weight UOM] --AD'
      #9','#39#39' AS [Net Quantity] --AE'
      #9','#39#39' AS [Net Quantity UOM] --AF'
      #9','#39#39' AS [Country of Origin] --AG'
      #9','#39#39' AS [Party Relationship/Affiliation] --AH'
      #9','#39#39' AS [Customs Status Placement] --AI'
      #9','#39#39' AS [HTS Number] --AJ'
      #9','#39#39' AS [Entered Value] --AK'
      #9','#39#39' AS [Entered Value Currency] --AL'
      #9','#39#39' AS [Duty Amount] --AM'
      #9','#39#39' AS [Duty Amount Currency] --NA'
      #9','#39#39' AS [VAT Amount] --AO'
      #9','#39#39' AS [VAT Amount Currency] --AP'
      #9','#39#39' AS [Freight (Deductible)] --AQ'
      #9','#39#39' AS [Freight (Deductible) Currency] --AR'
      #9','#39#39' AS [Total Amount Invoiced] --AS'
      #9','#39#39' AS [Currency of total amount invoiced] --AT'
      #9','#39#39' AS [Statistical Value] --AU'
      #9','#39#39' AS [Statistical Value Currency] --AV'
      #9','#39#39' AS [Charges2] --AW'
      #9','#39#39' AS [Charges Currency2] --AX'
      #9','#39#39' AS [Harbor Maintenance Fee (HMF)] --AY'
      #9','#39#39' AS [Harbor Maintenance Fee (HMF) Currency] --AZ'
      #9','#39#39' AS [Merchandise Processing Fee (MPF)] --BA'
      #9','#39#39' AS [Merchandise Processing Fee (MPF) Currency] --BB'
      #9','#39#39' AS [Special Program Indicator] --BC'
      #9','#39#39' AS [Container Number] --BD'
      ''
      #9'FROM BROKER.DBO.TPROCESSO TP'
      
        #9'LEFT JOIN BROKER.DBO.TREF_CLIENTE FAT (NOLOCK) ON FAT.NR_PROCES' +
        'SO = TP.NR_PROCESSO AND FAT.TP_REFERENCIA='#39'21'#39
      
        #9'LEFT JOIN BROKER.DBO.TPAIS_BROKER PD (NOLOCK) ON PD.CD_PAIS = T' +
        'P.CD_PAIS_DESTINO'
      
        #9'LEFT JOIN BROKER.DBO.TEMPRESA_NAC EN (NOLOCK) ON EN.CD_EMPRESA ' +
        '= TP.CD_CLIENTE'
      
        #9'LEFT JOIN BROKER.DBO.TPROCESSO_EXP PE (NOLOCK) ON PE.NR_PROCESS' +
        'O = TP.NR_PROCESSO'
      
        #9'LEFT JOIN BROKER.DBO.TPROCESSO_EXP_NF DUE (NOLOCK) ON DUE.NR_PR' +
        'OCESSO = TP.NR_PROCESSO'
      
        #9'LEFT JOIN BROKER.DBO.TMOEDA_BROKER ME (NOLOCK) ON ME.CD_MOEDA =' +
        ' PE.CD_MOEDA'
      
        #9'LEFT JOIN BROKER.DBO.TMOEDA_BROKER MF (NOLOCK) ON MF.CD_MOEDA =' +
        ' TP.CD_MOEDA_FRETE'
      
        #9'LEFT JOIN BROKER.DBO.TFOLLOWUP EV124 (NOLOCK) ON EV124.NR_PROCE' +
        'SSO = TP.NR_PROCESSO AND EV124.CD_EVENTO='#39'124'#39
      
        #9'LEFT JOIN BROKER.DBO.TFOLLOWUP EV088 (NOLOCK) ON EV088.NR_PROCE' +
        'SSO = TP.NR_PROCESSO AND EV088.CD_EVENTO='#39'088'#39#9
      #9'WHERE DT_ABERTURA BETWEEN @DATA_INICIAL AND @DATE_FINAL'
      #9'--WHERE TP.NR_PROCESSO = @NR_PROCESSO'
      ''
      #9'UNION ALL'
      ''
      #9'SELECT '
      #9'TP.NR_PROCESSO,'
      #9#39'D'#39' AS [ID COLUMN] --A'
      #9','#39#39' AS [TEXT]--B'
      #9','#39#39' AS [DOCUMENT NUMBER]--C'
      #9','#39#39' AS [DOCUMENT YEAR]--D'
      #9','#39#39' AS [CUSTOMS CONTROL RESULTS] --E'
      #9','#39#39' AS [OGA CONTROL RESULTS] --F'
      #9','#39#39' AS [REGISTRATION NUMBER] --G'
      #9','#39#39' AS [EXPORTING COUNTRY] --H'
      #9','#39#39' AS [ENTRY TYPE] --I'
      #9','#39#39' AS [EXPORTER OF RECORD NUMBER]--J'
      #9','#39#39' AS [CARGO CONTROL NO.] --K'
      #9','#39#39' AS [TOTAL VALUE] --L'
      #9','#39#39' AS [TOTAL VALUE CURRENCY] --M'
      #9','#39#39' AS [EXCHANGE RATE] --N'
      #9','#39#39' AS [FREIGHT] --O'
      #9','#39#39' AS [FREIGHT CURRENCY] --P'
      #9','#39#39' AS [INSURANCE] --Q'
      #9','#39#39' AS [INSURANCE CURRENCY] --R'
      #9','#39#39' AS [CHARGES] --S'
      #9','#39#39' AS [CHARGES CURRENCY] --T'
      #9','#39#39' AS [FEES] --U'
      #9','#39#39' AS [FEES CURRENCY] --V'
      #9','#39#39' AS [OTHER TAXES] --W'
      #9','#39#39' AS [OTHER TAXES CURRENCY] --X'
      #9','#39#39' AS [DATE OF ACCEPTANCE] --Y'
      #9','#39#39' AS [ENTRY DATE] --Z'
      #9','#39'DUVIDA'#39' AS [Item Number] --AA'
      #9','#39#39' AS [Gross Weight] --AB'
      #9',NF.QT_TRIBUTAVEL AS [Net Weight] --AC'
      #9',CASE'
      #9'WHEN NF.UN_TRIBUTAVEL='#39'CM'#39' THEN '#39'CG'#39
      #9'WHEN NF.UN_TRIBUTAVEL='#39'GR'#39' THEN '#39'G'#39
      #9'WHEN NF.UN_TRIBUTAVEL='#39'KG'#39' THEN '#39'KG'#39
      #9'WHEN NF.UN_TRIBUTAVEL='#39'LB'#39' THEN '#39'LB'#39
      #9'WHEN NF.UN_TRIBUTAVEL='#39'MG'#39' THEN '#39'MG'#39
      #9'WHEN NF.UN_TRIBUTAVEL='#39'MT'#39' THEN '#39'MT'#39
      #9'WHEN NF.UN_TRIBUTAVEL='#39'OZ'#39' THEN '#39'OZ'#39
      #9'WHEN NF.UN_TRIBUTAVEL='#39'TO'#39' THEN '#39'T'#39
      #9'END AS [Net Weight UOM] --AD'
      #9',NF.QT_COMERCIAL AS [Net Quantity] --AE'
      #9',CASE'
      #9'WHEN NF.UN_COMERCIAL='#39'CM'#39' THEN '#39'CG'#39
      #9'WHEN NF.UN_COMERCIAL='#39'GR'#39' THEN '#39'G'#39
      #9'WHEN NF.UN_COMERCIAL='#39'KG'#39' THEN '#39'KG'#39
      #9'WHEN NF.UN_COMERCIAL='#39'LB'#39' THEN '#39'LB'#39
      #9'WHEN NF.UN_COMERCIAL='#39'MG'#39' THEN '#39'MG'#39
      #9'WHEN NF.UN_COMERCIAL='#39'MT'#39' THEN '#39'MT'#39
      #9'WHEN NF.UN_COMERCIAL='#39'OZ'#39' THEN '#39'OZ'#39
      #9'WHEN NF.UN_COMERCIAL='#39'TO'#39' THEN '#39'T'#39
      #9'END AS [Net Quantity UOM] --AF'
      #9','#39'BR'#39' AS [Country of Origin] --AG'
      #9','#39#39' AS [Party Relationship/Affiliation] --AH'
      #9','#39#39' AS [Customs Status Placement] --AI'
      #9',NF.CD_NCM AS [HTS Number] --AJ'
      
        #9',(NF.VL_LOCAL_EMBARQUE / NF.QT_COMERCIAL) AS [Entered Value] --' +
        'AK'
      #9',ME.AP_MOEDA AS [Entered Value Currency] --AL'
      #9','#39#39' AS [Duty Amount] --AM'
      #9','#39#39' AS [Duty Amount Currency] --NA'
      #9','#39#39' AS [VAT Amount] --AO'
      #9','#39#39' AS [VAT Amount Currency] --AP'
      #9',NF.VL_TOTAL_FRETE_MNEG AS [Freight (Deductible)] --AQ'
      #9',MF.AP_MOEDA AS [Freight (Deductible) Currency] --AR'
      #9',NF.VL_CONDICAO_VENDA AS [Total Amount Invoiced] --AS'
      #9',ME.AP_MOEDA AS [Currency of total amount invoiced] --AT'
      #9','#39#39' AS [Statistical Value] --AU'
      #9','#39#39' AS [Statistical Value Currency] --AV'
      #9','#39#39' AS [Charges] --AW'
      #9','#39#39' AS [Charges Currency] --AX'
      #9','#39#39' AS [Harbor Maintenance Fee (HMF)] --AY'
      #9','#39#39' AS [Harbor Maintenance Fee (HMF) Currency] --AZ'
      #9','#39#39' AS [Merchandise Processing Fee (MPF)] --BA'
      #9','#39#39' AS [Merchandise Processing Fee (MPF) Currency] --BB'
      #9','#39#39' AS [Special Program Indicator] --BC'
      
        #9',(Cast(ISNULL(STUFF((SELECT DISTINCT '#39'/'#39' + LTRIM(RTRIM(CT.NR_CN' +
        'TR)) FROM BROKER.DBO.TPROCESSO_CNTR_NF CT WITH (NOLOCK) '
      
        #9'WHERE CT.NR_PROCESSO = TP.NR_PROCESSO AND CT.NR_NF = NF.NR_NF F' +
        'OR XML PATH('#39#39')), 1, 1, '#39#39'), (Cast(ISNULL(STUFF((SELECT DISTINCT' +
        ' '#39'/'#39' + LTRIM(RTRIM(CTR.NR_CNTR)) FROM BROKER.DBO.TPROCESSO_CNTR ' +
        'CTR WITH (NOLOCK) '
      
        #9'WHERE CTR.NR_PROCESSO = TP.NR_PROCESSO  FOR XML PATH('#39#39')), 1, 1' +
        ', '#39#39'), '#39#39') as Varchar(300)))) as Varchar(300))) AS [Container Nu' +
        'mber] --BD'
      #9'FROM BROKER.DBO.TPROCESSO TP'
      
        #9'LEFT JOIN BROKER.DBO.TPROCESSO_EXP_NF_ITEM NF (NOLOCK) ON NF.NR' +
        '_PROCESSO = TP.NR_PROCESSO'
      
        #9'LEFT JOIN BROKER.DBO.TPROCESSO_EXP PE (NOLOCK) ON PE.NR_PROCESS' +
        'O = TP.NR_PROCESSO'
      
        #9'LEFT JOIN BROKER.DBO.TMOEDA_BROKER ME (NOLOCK) ON ME.CD_MOEDA =' +
        ' PE.CD_MOEDA'
      
        #9'LEFT JOIN BROKER.DBO.TMOEDA_BROKER MF (NOLOCK) ON MF.CD_MOEDA =' +
        ' TP.CD_MOEDA_FRETE'
      #9'WHERE DT_ABERTURA BETWEEN @DATA_INICIAL AND @DATE_FINAL'
      #9'--TP.NR_PROCESSO = @NR_PROCESSO'
      ')'#9
      'SELECT * FROM SELECTCARGIL'
      'ORDER BY NR_PROCESSO, [ID COLUMN TESTE] DESC')

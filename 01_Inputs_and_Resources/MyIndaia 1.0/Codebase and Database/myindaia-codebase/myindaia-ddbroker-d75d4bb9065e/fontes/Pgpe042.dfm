  object TProcS: TQuery
    OnCalcFields = TProcSCalcFields
    DatabaseName = 'DbBroker'
    SQL.Strings = (
      'SELECT CASE ISNULL(S.NR_FATURA, '#39#39')'
      '       WHEN '#39#39' THEN (CASE E.NR_FATURA'
      
        '                      WHEN SUBSTRING( S.NR_PROCESSO, 5, 14 ) THE' +
        'N LTRIM( RTRIM( SUBSTRING( S.NR_PROCESSO, 5, 14 ) ) )'
      '                      ELSE --LTRIM( RTRIM( NM_SIGLA ) ) + '#39'-'#39' +'
      
        '                           --LTRIM( RTRIM( SUBSTRING( S.NR_PROCE' +
        'SSO, 5, 14 ) ) ) + '#39' / '#39' +'
      
        '                           LTRIM( RTRIM( ISNULL( E.NR_FATURA, ""' +
        ' ) ) )'
      '                    END)'
      '       ELSE (CASE S.NR_FATURA'
      
        '               WHEN SUBSTRING( S.NR_PROCESSO, 5, 14 ) THEN LTRIM' +
        '( RTRIM( SUBSTRING( S.NR_PROCESSO, 5, 14 ) ) )'
      '               ELSE --LTRIM( RTRIM( NM_SIGLA ) ) + '#39'-'#39' +'
      
        '                    --LTRIM( RTRIM( SUBSTRING( S.NR_PROCESSO, 5,' +
        ' 14 ) ) ) + '#39' / '#39' +'
      '                    LTRIM( RTRIM( ISNULL( S.NR_FATURA, "" ) ) )'
      '             END)'
      '       END AS NR_PROCESSO,'
      
        '       S.VL_TOT_SAQUE AS VL_TOT_SAQUE, S.CD_TERMO_PAGTO AS CD_TE' +
        'RMO_PAGTO, S.TX_VALUE AS TX_VALUE,'
      '       CONVERT( varchar(30),'
      '       CASE ISNULL( S.CD_TERMO_PAGTO, "" )'
      '          WHEN "" THEN "At Sight"'
      '          ELSE'
      '            CASE DATEPART( m, S.DT_VCTO_SAQUE )'
      '               WHEN 1 THEN '#39'January'#39
      '               WHEN 2 THEN '#39'February'#39
      '               WHEN 3 THEN '#39'March'#39
      '               WHEN 4 THEN '#39'April'#39
      '               WHEN 5 THEN '#39'May'#39
      '               WHEN 6 THEN '#39'June'#39
      '               WHEN 7 THEN '#39'July'#39
      '               WHEN 8 THEN '#39'August'#39
      '               WHEN 9 THEN '#39'September'#39
      '               WHEN 10 THEN '#39'October'#39
      '               WHEN 11 THEN '#39'November'#39
      '               WHEN 12 THEN '#39'December'#39
      
        '            END + '#39' '#39' + RIGHT( '#39'0'#39' + CONVERT( varchar(2), DATEPA' +
        'RT( dd, S.DT_VCTO_SAQUE ) ), 2 ) +'
      
        '            CASE RIGHT( CONVERT( varchar(2), DATEPART( d, S.DT_V' +
        'CTO_SAQUE ) ), 1 )'
      '               WHEN '#39'1'#39' THEN '#39'st'#39
      '               WHEN '#39'2'#39' THEN '#39'nd'#39
      '               ELSE '#39'th'#39
      
        '            END + '#39', '#39' + CONVERT(char(4), DATEPART( yyyy, S.DT_V' +
        'CTO_SAQUE ) )'
      '       END ) AS DT_VCTO_SAQUE,'
      '       S.TP_EMPRESA_PAGTO AS TP_EMPRESA_PAGTO,'
      '       M.NM_MOEDA_SING_ING AS NM_MOEDA_SING,'
      '       M.NM_MOEDA_PLURAL_ING AS NM_MOEDA_PLURAL,'
      '       M.NM_CENTAVOS_SING_ING AS NM_CENTAVOS_SING,'
      '       M.NM_CENTAVOS_PLURAL_ING AS NM_CENTAVOS_PLURAL,'
      '       CASE DATEPART( M, S.DT_INICIAL )'
      '          WHEN 1 THEN '#39'January'#39
      '          WHEN 2 THEN '#39'February'#39
      '          WHEN 3 THEN '#39'March'#39
      '          WHEN 4 THEN '#39'April'#39
      '          WHEN 5 THEN '#39'May'#39
      '          WHEN 6 THEN '#39'June'#39
      '          WHEN 7 THEN '#39'July'#39
      '          WHEN 8 THEN '#39'August'#39
      '          WHEN 9 THEN '#39'September'#39
      '          WHEN 10 THEN '#39'October'#39
      '          WHEN 11 THEN '#39'November'#39
      '          WHEN 12 THEN '#39'December'#39
      
        '       END + '#39' '#39' + RIGHT( '#39'0'#39' + CONVERT( varchar(2), DATEPART( d' +
        'd, S.DT_INICIAL ) ), 2 ) +'
      
        '       CASE RIGHT( CONVERT( varchar(2), DATEPART( d, S.DT_INICIA' +
        'L ) ), 1 )'
      '          WHEN '#39'1'#39' THEN '#39'st'#39
      '          WHEN '#39'2'#39' THEN '#39'nd'#39
      '          ELSE '#39'th'#39
      
        '       END + '#39', '#39' + CONVERT(char(4), DATEPART( yyyy, S.DT_INICIA' +
        'L ) ) AS DT_INICIAL'
      
        'FROM   TPROCESSO_EXP_SAQUE S, TPROCESSO_EXP E, TMOEDA_BROKER M, ' +
        'TUNID_NEG U, TPROCESSO P'
      'WHERE  E.NR_PROCESSO = P.NR_PROCESSO AND'
      '       P.NR_PROCESSO = S.NR_PROCESSO AND'
      '       P.CD_UNID_NEG = U.CD_UNID_NEG AND'
      '       E.CD_MOEDA *= M.CD_MOEDA AND'
      '       S.NR_PROCESSO = :NR_PROCESSO AND'
      '       S.NR_SAQUE = :NR_SAQUE')
    Left = 296
    Top = 8
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'NR_SAQUE'
        ParamType = ptInput
      end>

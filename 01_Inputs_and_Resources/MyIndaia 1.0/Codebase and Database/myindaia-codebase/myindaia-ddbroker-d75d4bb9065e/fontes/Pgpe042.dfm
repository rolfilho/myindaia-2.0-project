  object TProc: TQuery
    DatabaseName = 'DbBroker'
    SQL.Strings = (
      
        'select NR_PROCESSO, CD_EXPORTADOR, CD_IMPORTADOR, CD_LOCAL_ORIGE' +
        'M, CD_LOCAL_DESTINO, CD_MOEDA, TP_CONSIGNATARIO, CD_CONSIGNATARI' +
        'O,'
      
        '       TP_NOTIFY1, CD_NOTIFY1, TP_NOTIFY2, CD_NOTIFY2, CD_LINGUA' +
        '_PEDIDO, CD_BANCO_SAQUE_BORDERO'
      'from tprocesso_exp')
    Left = 184

  object TNotf1: TQuery
    DatabaseName = 'DbBroker'
    SQL.Strings = (
      
        'SELECT E.CD_EMPRESA AS CODIGO, E.NM_EMPRESA AS NOME, E.END_EMPRE' +
        'SA + CASE ltrim(rtrim(isnull(e.end_numero,""))) when "" then "" ' +
        'else ", " END + rtrim(ltrim(E.END_NUMERO)) AS ENDERECO_NUM, '
      
        '       E.END_CIDADE + CASE ltrim(rtrim(isnull(p.descricao,""))) ' +
        'when "" then "" else " - " END + rtrim(ltrim(P.DESCRICAO)) AS CI' +
        'DADE_PAIS'
      'FROM TEMPRESA_EST E'
      'LEFT JOIN TPAIS P ON E.CD_PAIS=P.CODIGO')
    Left = 352
    Top = 8
  end

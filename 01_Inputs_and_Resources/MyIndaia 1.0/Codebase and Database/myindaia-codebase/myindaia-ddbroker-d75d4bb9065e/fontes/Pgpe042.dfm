  object Texp: TQuery
    DatabaseName = 'DbBroker'
    SQL.Strings = (
      'SELECT CD_EMPRESA AS CODIGO, NM_EMPRESA AS NOME,'
      '       LTRIM( RTRIM( ISNULL( END_CIDADE, "" ) ) ) +'
      '       CASE LTRIM( RTRIM( ISNULL( END_UF, "" ) ) )'
      '          WHEN "" THEN ""'
      '          ELSE " - "'
      '       END +'
      '       LTRIM( RTRIM( ISNULL( END_UF, "" ) ) ) AS END_CIDADE'
      'FROM   TEMPRESA_NAC'
      'WHERE  CD_EMPRESA = :CD_EXPORTADOR')
    Left = 16
    Top = 8
    ParamData = <
      item
        DataType = ftString
        Name = 'CD_EXPORTADOR'
        ParamType = ptInput
      end>
  end
  object Dts_Exp: TDataSource
    DataSet = Texp
    Left = 16
    Top = 64
  end
  object TImp: TQuery
    DatabaseName = 'DbBroker'
    SQL.Strings = (
      
        'SELECT E.CD_EMPRESA AS CODIGO, LTRIM( RTRIM( ISNULL( E.NM_EMPRES' +
        'A, "" ) ) ) AS NOME,'
      
        '       LTRIM( RTRIM( ISNULL( E.END_EMPRESA, "" ) ) ) + CASE LTRI' +
        'M( RTRIM( ISNULL( E.END_NUMERO, "" ) ) ) WHEN "" THEN "" else ",' +
        ' " END + LTRIM( RTRIM( ISNULL( E.END_NUMERO, "" ) ) ) +'
      
        '       CASE LTRIM( RTRIM( ISNULL( E.END_COMPL, "" ) ) ) WHEN "" ' +
        'THEN "" ELSE " - " + LTRIM( RTRIM( ISNULL( E.END_COMPL, "" ) ) )' +
        '  END AS ENDERECO_NUM,'
      '       LTRIM( RTRIM( ISNULL( E.END_CIDADE, "" ) ) ) +'
      '       CASE :CD_LINGUA_PEDIDO'
      
        '          WHEN '#39'1'#39' THEN CASE LTRIM( RTRIM( ISNULL( P.NM_PAIS_ING' +
        ', "" ) ) ) WHEN "" THEN "" ELSE " - " END + LTRIM( RTRIM( ISNULL' +
        '( P.NM_PAIS_ING, "" ) ) )'
      
        '          WHEN '#39'2'#39' THEN CASE LTRIM( RTRIM( ISNULL( P.NM_PAIS_ESP' +
        ', "" ) ) ) WHEN "" THEN "" ELSE " - " END + LTRIM( RTRIM( ISNULL' +
        '( P.NM_PAIS_ESP, "" ) ) )'
      
        '          WHEN '#39'3'#39' THEN CASE LTRIM( RTRIM( ISNULL( P.NM_PAIS_POR' +
        'T, "" ) ) ) WHEN "" THEN "" ELSE " - " END + LTRIM( RTRIM( ISNUL' +
        'L( P.NM_PAIS_PORT, "" ) ) )'
      '       END AS CIDADE_PAIS,'
      
        '       CASE LTRIM( RTRIM( ISNULL( E.NR_CLIENTE, "" ) ) ) WHEN ""' +
        ' THEN "" ELSE "( " END + LTRIM( RTRIM( ISNULL( E.NR_CLIENTE, "" ' +
        ') ) ) +'
      
        '       CASE LTRIM( RTRIM( ISNULL( E.NR_CLIENTE, "" ) ) ) WHEN ""' +
        ' THEN "" ELSE " )" END AS NR_CLIENTE, E.CD_PAIS AS CD_PAIS'
      'FROM   TEMPRESA_EST E, TPAIS_BROKER P'
      'WHERE  E.CD_PAIS *= P.CD_PAIS AND'
      '       E.CD_EMPRESA = :CD_IMPORTADOR')
    Left = 72
    Top = 8
    ParamData = <
      item
        DataType = ftString
        Name = 'CD_LINGUA_PEDIDO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_IMPORTADOR'
        ParamType = ptInput
      end>
  end
  object Dts_Imp: TDataSource
    DataSet = TImp
    Left = 72
    Top = 64
  end
  object Tconsig: TQuery
    DatabaseName = 'DbBroker'
    SQL.Strings = (
      
        'SELECT E.CD_EMPRESA AS CODIGO, E.NM_EMPRESA AS NOME, E.END_EMPRE' +
        'SA + CASE ltrim(rtrim(isnull(e.end_numero,""))) when "" then "" ' +
        'else ", " END + rtrim(ltrim(E.END_NUMERO)) AS ENDERECO_NUM, '
      
        '       E.END_CIDADE + CASE ltrim(rtrim(isnull(p.descricao,""))) ' +
        'when "" then "" else " - " END + rtrim(ltrim(P.DESCRICAO)) AS CI' +
        'DADE_PAIS'
      'FROM TEMPRESA_EST E'
      'LEFT JOIN TPAIS P ON E.CD_PAIS=P.CODIGO'
      '')
    Left = 129
    Top = 8
  end
  object Dts_consig: TDataSource
    DataSet = Tconsig
    Left = 129
    Top = 64
  end

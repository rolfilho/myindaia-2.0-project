  object qryGeral: TQuery
    OnCalcFields = qryGeralCalcFields
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT SUBSTRING(P.NR_PROCESSO, 5, 14) AS NR_PROC, RP.NR_PROCESS' +
        'O, RA.NR_RECEBIMENTO, RA.CD_CLIENTE, RA.CD_UNID_NEG,'
      '       CASE P.CD_UNID_NEG'
      '         WHEN '#39'02'#39' THEN '#39'RIO DE JANEIRO'#39
      '         ELSE '#39'SANTOS'#39
      '       END AS CIDADE_UNID,'
      '       RA.VL_RECEBIMENTO,'
      '       CASE'
      
        '         WHEN (SELECT CD_EMPRESA FROM TEMPRESA_NAC (NOLOCK) WHER' +
        'E CD_EMPRESA = RP.CD_CLIENTE) IN (SELECT CD_EMPRESA FROM TEMPRES' +
        'A_NAC WHERE CD_GRUPO = '#39'018'#39')'
      '           THEN '#39'INDAI'#193' LOG'#205'STICA INTERNACIONAL LTDA.'#39
      
        '         ELSE (SELECT NM_EMPRESA FROM TEMPRESA_NAC (NOLOCK) WHER' +
        'E CD_EMPRESA = RP.CD_CLIENTE)'
      '       END AS NM_EMPRESA,'
      '       P.NR_CONHECIMENTO,'
      
        '       (SELECT NM_EMBARCACAO FROM TEMBARCACAO (NOLOCK) WHERE CD_' +
        'EMBARCACAO = P.CD_EMBARCACAO) AS NAVIO,'
      '       P.NR_VIAGEM_ARMADOR,'
      
        '       (SELECT DESCRICAO FROM TLOCAL_EMBARQUE (NOLOCK) WHERE COD' +
        'IGO = P.CD_LOCAL_EMBARQUE) AS ORIGEM,'
      
        '       (SELECT DESCRICAO FROM TLOCAL_EMBARQUE (NOLOCK) WHERE COD' +
        'IGO = P.CD_LOCAL_DESEMBARQUE) AS DESTINO,'
      
        '       CONVERT(DATETIME, CONVERT(VARCHAR, (SELECT F.DT_REALIZACA' +
        'O FROM TFOLLOWUP F (NOLOCK) WHERE F.NR_PROCESSO = RP.NR_PROCESSO' +
        ' AND F.CD_EVENTO = '#39'162'#39' ), 103), 103) AS DT_ATRACACAO'
      '  FROM TRECEBIMENTO_AG RA (NOLOCK)'
      
        ' INNER JOIN TRECEBIMENTO_PROCESSO RP (NOLOCK) ON RP.NR_PROCESSO ' +
        '= :NR_PROCESSO'
      
        '                                             AND RP.CD_CLIENTE =' +
        ' RA.CD_CLIENTE'
      
        '                                             AND RP.NR_RECEBIMEN' +
        'TO = RA.NR_RECEBIMENTO'
      
        '                                             AND RP.CD_UNID_NEG ' +
        '= RA.CD_UNID_NEG'
      
        ' INNER JOIN TPROCESSO P (NOLOCK) ON P.NR_PROCESSO = RP.NR_PROCES' +
        'SO'
      ' WHERE RA.CD_CLIENTE = :CD_CLIENTE'
      '   AND RA.NR_RECEBIMENTO = :NR_RECEBIMENTO'
      '   AND RA.CD_UNID_NEG = :CD_UNID_NEG')
    Left = 208
    Top = 376
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_CLIENTE'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'NR_RECEBIMENTO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_UNID_NEG'
        ParamType = ptInput
      end>
    object qryGeralNR_PROC: TStringField
      FieldName = 'NR_PROC'
      FixedChar = True
      Size = 14
    end
    object qryGeralNR_PROCESSO: TStringField
      FieldName = 'NR_PROCESSO'

  object qryDetalhe: TQuery
    DatabaseName = 'DBBROKER'
    DataSource = dsGeral
    SQL.Strings = (
      'SELECT (CASE RPI.CD_MOEDA_VENDA'
      
        '         WHEN '#39'220'#39' THEN (CASE ISNULL((SELECT NM_ITEM_INGLES FRO' +
        'M TITEM WHERE CD_ITEM = RPI.CD_ITEM), '#39#39')'
      
        '                           WHEN '#39#39' THEN (SELECT NM_ITEM FROM TIT' +
        'EM WHERE CD_ITEM = RPI.CD_ITEM)'
      
        '                           ELSE (SELECT NM_ITEM_INGLES FROM TITE' +
        'M WHERE CD_ITEM = RPI.CD_ITEM)'
      '                         END)'
      
        '         ELSE (SELECT NM_ITEM FROM TITEM WHERE CD_ITEM = RPI.CD_' +
        'ITEM)'
      '       END) AS NM_ITEM,'
      '       (CASE'
      '          WHEN RPI.CD_MOEDA_VENDA IN ('#39'150'#39','#39'155'#39','#39'160'#39','#39'165'#39','
      '                                     '#39'170'#39','#39'175'#39','#39'190'#39','#39'195'#39','
      '                                     '#39'200'#39','#39'205'#39','#39'210'#39','#39'215'#39','
      '                                     '#39'217'#39','#39'220'#39','#39'225'#39','#39'230'#39','
      '                                     '#39'235'#39','#39'245'#39','#39'640'#39','#39'980'#39','
      '                                     '#39'982'#39','#39'983'#39','#39'984'#39','#39'986'#39','
      
        '                                     '#39'988'#39','#39'990'#39','#39'992'#39','#39'998'#39') TH' +
        'EN '#39'USD'#39
      '          WHEN RPI.CD_MOEDA_VENDA IN ('#39'918'#39','#39'978'#39') THEN '#39'EUR'#39
      '          WHEN RPI.CD_MOEDA_VENDA  =  '#39'790'#39' THEN '#39'R$'#39
      
        '          ELSE (SELECT AP_MOEDA FROM TMOEDA_BROKER WHERE CD_MOED' +
        'A = RPI.CD_MOEDA_VENDA)'
      '       END) AS MOEDA,'
      ''
      '       (CASE RPI.CD_MOEDA_VENDA'
      '         WHEN '#39'790'#39' THEN 0'
      '         ELSE RPI.VL_VENDA'
      '       END) AS VL_ORIGINAL,'
      '       (CASE RPI.CD_MOEDA_VENDA'
      '         WHEN '#39'790'#39' THEN 0'
      '         ELSE RPI.VL_TARIFARIO'
      '       END) AS VL_TARIFA,'
      '       VL_RECEBIDO'
      '  FROM TRECEBIMENTO_PROCESSO_ITEM RPI (NOLOCK)'
      
        ' INNER JOIN TPROCESSO P (NOLOCK) ON P.NR_PROCESSO = RPI.NR_PROCE' +
        'SSO'
      ' WHERE RPI.NR_PROCESSO = :NR_PROCESSO'
      '   AND RPI.NR_RECEBIMENTO = :NR_RECEBIMENTO'
      '   AND ISNULL(RPI.IN_CANCELADO, '#39'0'#39') = '#39'0'#39
      ' ORDER BY RPI.CD_MOEDA_VENDA')
    Left = 205
    Top = 408
    ParamData = <
      item
        DataType = ftFixedChar
        Name = 'NR_PROCESSO'
        ParamType = ptInput
        Size = 19
      end
      item
        DataType = ftFixedChar
        Name = 'NR_RECEBIMENTO'
        ParamType = ptInput
        Size = 7
      end>
    object qryDetalheNM_ITEM: TStringField
      FieldName = 'NM_ITEM'
      FixedChar = True
      Size = 30
    end
    object qryDetalheMOEDA: TStringField
      FieldName = 'MOEDA'
      FixedChar = True
      Size = 6
    end
    object qryDetalheVL_ORIGINAL: TFloatField
      FieldName = 'VL_ORIGINAL'
    end
    object qryDetalheVL_TARIFA: TFloatField
      FieldName = 'VL_TARIFA'
    end
    object qryDetalheVL_RECEBIDO: TFloatField
      FieldName = 'VL_RECEBIDO'
    end
  end

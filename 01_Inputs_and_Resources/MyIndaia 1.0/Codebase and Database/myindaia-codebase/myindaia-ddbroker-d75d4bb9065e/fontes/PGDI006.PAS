  If (tsisco.tbl_taxa_cambio_.findkey([tbl_ad_deducoes_CD_MD_NEGOC_DEDUC.AsString])) Then
    tbl_ad_deducoes_VL_DEDUCAO_MN.AsFloat :=
    tbl_ad_deducoes_VL_DEDUCAO_MNEG.AsFloat *

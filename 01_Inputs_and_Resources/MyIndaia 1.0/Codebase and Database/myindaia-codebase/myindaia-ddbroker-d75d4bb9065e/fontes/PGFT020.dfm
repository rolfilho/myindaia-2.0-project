  object qry_rel_kpi_exportacao_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT ( K.NR_IDENTIFICADOR ) AS NR_IDENTIFICADOR, ( U.NM_UNID_N' +
        'EG ) AS NM_UNID_NEG,'
      
        '       ( E.NM_EMPRESA ) AS NM_CLIENTE, K.NR_REF_PEDIDO, K.DT_REF' +
        '_PEDIDO, I.DESCRICAO,'
      
        '       A.NM_AREA, ES.NM_EMPRESA, K.DT_ENV_COMEXT, K.NR_REF_ORDEM' +
        ', K.DT_REF_ORDEM,'
      
        '       K.DT_LIB_EST, K.NR_REF_REMESSA, K.DT_REF_REMESSA, K.DT_CO' +
        'NSOLIDACAO, K.DT_LIB_FAB,'
      
        '       K.DT_LIB_PROC, K.NR_NF, K.DT_NF, K.NR_PROCESSO, V.NM_VIA_' +
        'TRANSPORTE, K.NR_CAMINHAO,'
      
        '       TE.NM_EMBARCACAO, TR.NM_TRANSP_ROD, K.DT_PREV_EMB, K.DT_D' +
        'ESEMB, K.DT_EMB,'
      
        '       K.DT_ENV_DOC, K.DT_ENT_DOC, K.DT_AVERBACAO, K.DT_CHEGADA_' +
        'DOC,'
      
        '       K.DT_CH_MERC, M.AP_MOEDA, K.VL_TOTAL, K.CD_INCOTERM, C.NM' +
        '_CONTATO,'
      
        '       K.NR_DIAS_REC_PED, K.NR_DIAS_LIB_REC, K.NR_DIAS_SOLIC_LIB' +
        ', '
      
        '       K.NR_DIAS_OR_SOLIC, K.NR_DIAS_REM_SOLIC, K.NR_DIAS_SOLIC_' +
        'REM,'
      '       K.NR_DIAS_LIB_REM, K.NR_DIAS_NF_LIB, K.NR_DIAS_DES_NF,'
      '       K.NR_DIAS_EMB_DES, K.NR_DIAS_AV_EMB, K.NR_DIAS_EMB_DOCS,'
      '       K.NR_DIAS_EMB_REC, K.NR_DIAS_EMB_PED, K.NR_DIAS_LIB_LIB, '
      '       K.NR_DIAS_EMB_NF, K.NR_DIAS_CON_NF, K.NR_DIAS_EMB_CON, '
      '       K.NR_DIAS_DES_EMB, K.NR_DIAS_AV_DES, K.NR_DIAS_CH_DES,'
      '       K.DT_REC_PEDIDO, K.DT_SOLIC_OV, K.DT_SOLIC_REMESSA,'
      
        '       K.NR_DIAS_EMB_LIB, K.NR_DIAS_DES_LIB, K.DT_REC_NF, K.NR_D' +
        'IAS_DES_REC,'
      '       K.DT_DL_DRAFT, K.DT_RET_BL, K.DT_DL_CARGA, '
      
        '       K.NR_DIAS_LIB_DLD, K.NR_DIAS_LIB_DLC, K.NR_DIAS_LIB_DESEM' +
        'B, K.NR_DIAS_LIB_NF,'
      
        '       K.NR_DIAS_LIB_EMB, K.NR_DIAS_NF_DLD, K.NR_DIAS_EMB_BL, K.' +
        'NR_DIAS_EMB_DOC'
      
        'FROM TREL_KPI_EXPORTACAO K, TUNID_NEG U, TEMPRESA_NAC E, TPAIS I' +
        ', TAREA A, TEMPRESA_EST ES,'
      
        '     TVIA_TRANSPORTE V, TEMBARCACAO TE, TTRANSP_ROD TR, TMOEDA_B' +
        'ROKER M, TCLIENTE_CONTATO C'
      'WHERE NR_IDENTIFICADOR = :NR_IDENTIFICADOR AND'
      '      K.CD_UNID_NEG *= U.CD_UNID_NEG AND'
      '      K.CD_CLIENTE *= E.CD_EMPRESA AND'
      '      K.CD_PAIS_DESTINO *= I.CODIGO AND'
      '      K.CD_AREA *= A.CD_AREA AND'
      '      K.CD_IMPORTADOR *= ES.CD_EMPRESA AND'
      '      K.CD_VIA_TRANSPORTE *= V.CD_VIA_TRANSPORTE AND'
      '      K.CD_EMBARCACAO *= TE.CD_EMBARCACAO AND'
      '      K.CD_TRANSP_NAC *= TR.CD_TRANSP_ROD AND'
      '      K.CD_MOEDA *= M.CD_MOEDA AND'
      '      K.CD_CLIENTE *= C.CD_CLIENTE AND'
      '      K.CD_UNID_NEG *= C.CD_UNID_NEG AND'
      '      K.CD_CONTATO *= C.CD_CONTATO AND'
      '      C.CD_PRODUTO = '#39'02'#39
      'ORDER BY K.CD_CLIENTE'
      '')
    Left = 190
    Top = 190
    ParamData = <
      item
        DataType = ftInteger
        Name = 'NR_IDENTIFICADOR'
        ParamType = ptUnknown
      end>
    object qry_rel_kpi_exportacao_NR_IDENTIFICADOR: TIntegerField
      FieldName = 'NR_IDENTIFICADOR'
    end
    object qry_rel_kpi_exportacao_NM_UNID_NEG: TStringField
      FieldName = 'NM_UNID_NEG'
      Size = 50
    end
    object qry_rel_kpi_exportacao_NM_CLIENTE: TStringField
      FieldName = 'NM_CLIENTE'
      Size = 50
    end
    object qry_rel_kpi_exportacao_NR_REF_PEDIDO: TStringField
      FieldName = 'NR_REF_PEDIDO'
      Size = 15
    end
    object qry_rel_kpi_exportacao_DT_REF_PEDIDO: TDateTimeField
      FieldName = 'DT_REF_PEDIDO'
    end
    object qry_rel_kpi_exportacao_DESCRICAO: TStringField
      FieldName = 'DESCRICAO'
      Size = 120

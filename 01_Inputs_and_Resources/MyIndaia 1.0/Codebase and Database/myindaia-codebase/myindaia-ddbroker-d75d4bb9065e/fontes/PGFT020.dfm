  object qry_rel_exp_est_cambial_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT SUBSTRING( E.NR_PROCESSO, 5, 14 ) AS NR_PROCESSO, C.NM_CO' +
        'NTATO AS NM_CONTATO'
      
        'FROM   TPROCESSO_EXP E, TFOLLOWUP F, TPROCESSO P, TEMPRESA_NAC E' +
        'N, TCLIENTE_CONTATO C'
      'WHERE  E.NR_PROCESSO = F.NR_PROCESSO AND'
      '       E.NR_PROCESSO = P.NR_PROCESSO AND'
      
        '       F.CD_EVENTO IN ( SELECT CD_EV_ENVIO_SAQUE_BORDERO FROM TP' +
        'ARAMETROS ) AND'
      '       F.IN_APLICAVEL = '#39'1'#39' AND'
      '       P.CD_CLIENTE = EN.CD_EMPRESA AND'
      '       P.CD_UNID_NEG = C.CD_UNID_NEG AND'
      '       P.CD_PRODUTO = C.CD_PRODUTO AND'
      '       P.CD_CLIENTE = C.CD_CLIENTE AND'
      '       P.CD_CONTATO = C.CD_CONTATO AND'
      '       F.DT_REALIZACAO BETWEEN :DT_INICIO AND :DT_FIM AND'
      
        '       ( ( P.CD_UNID_NEG = :CD_UNID_NEG ) OR ( :CD_UNID_NEG = '#39#39 +
        ' ) ) AND'
      '       ( ( EN.CD_GRUPO = :CD_GRUPO ) OR ( :CD_GRUPO = '#39#39' ) ) AND'
      
        '       ( ( P.CD_CLIENTE = :CD_CLIENTE ) OR ( :CD_CLIENTE = '#39#39' ) ' +
        ') AND'
      '       P.CD_PRODUTO = '#39'02'#39
      'ORDER BY C.NM_CONTATO, E.NR_PROCESSO')
    Left = 190
    Top = 512
    ParamData = <
      item
        DataType = ftDate
        Name = 'DT_INICIO'
        ParamType = ptUnknown
      end
      item
        DataType = ftDate
        Name = 'DT_FIM'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_UNID_NEG'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_UNID_NEG'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_GRUPO'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_GRUPO'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_CLIENTE'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_CLIENTE'
        ParamType = ptUnknown
      end>
  end

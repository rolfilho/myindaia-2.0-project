  object qry_rel_di_reg_desemb_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT R.*, A.NM_AREA, SUBSTRING( R.NR_PROCESSO, 5, 14 ) AS Calc' +
        'NrProcesso'
      'FROM   TREL_DI_REG_DESEMB R, TAREA A'
      'WHERE  R.CD_AREA *= A.CD_AREA AND'
      '       R.NR_IDENTIFICADOR = :NR_IDENTIFICADOR'
      'ORDER BY R.NR_DI'
      '                           ')
    Left = 190
    Top = 352
    ParamData = <
      item
        DataType = ftInteger
        Name = 'NR_IDENTIFICADOR'
        ParamType = ptUnknown
        Value = 1
      end>
  end

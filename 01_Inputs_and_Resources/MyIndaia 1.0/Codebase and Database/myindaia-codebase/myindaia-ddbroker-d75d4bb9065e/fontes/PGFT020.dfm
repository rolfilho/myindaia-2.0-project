  object qry_rel_imp_demurrage_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'SELECT R.NR_IDENTIFICADOR, R.NR_PROCESSO, U.NM_UNID_NEG,'
      
        '       SUBSTRING( R.NR_CNTR, 1, 4 ) + '#39'-'#39' + SUBSTRING( R.NR_CNTR' +
        ', 5, 3 ) + '#39'-'#39' +'
      
        '       SUBSTRING( R.NR_CNTR, 8, 3 ) + '#39'-'#39' + SUBSTRING( R.NR_CNTR' +
        ', 11, 1 ) AS NR_CNTR,'
      
        '       T.NM_TP_CNTR, Y.TX_YESNO AS IN_DEMURRAGE, TI.DESCRICAO AS' +
        ' NM_TRANSPORTADOR,'
      
        '       AA.NM_ARMAZEM AS NM_ARMAZEM_ATRACACAO, AD.NM_ARMAZEM AS N' +
        'M_ARMAZEM_DESCARGA,'
      
        '       E.NM_EMPRESA AS NM_CLIENTE, C.NM_CANAL, TR.NM_TRANSP_ROD ' +
        'AS NM_TRANSP_NAC, A.NM_AREA,'
      '       TX_MERCADORIA, ES.NM_EMPRESA AS NM_EXPORTADOR,'
      
        '       DT_DOCTOS_OK, DT_ENT, DT_ENT_TERMINAL, DT_PRES_CARGA, DT_' +
        'LIB_BL, DT_REG_DI, DT_AVERBACAO,'
      
        '       DT_DESEMB, DT_CI, DT_INSP_MA, DT_NF_TRANSP, DT_ENTR_FABRI' +
        'CA, DT_DEVOLUCAO_CNTR'
      
        'FROM   TREL_IMP_DEMURRAGE R, TTP_CNTR T, TYES_NO Y, TTRANSPORTAD' +
        'OR_ITL TI, TARMAZEM AA, TARMAZEM AD,'
      
        '       TEMPRESA_NAC E, TTP_CANAL C, TTRANSP_ROD TR, TAREA A, TEM' +
        'PRESA_EST ES, TUNID_NEG U'
      'WHERE  R.TP_CNTR *= T.TP_CNTR AND'
      '       R.IN_DEMURRAGE = Y.CD_YESNO AND'
      '       R.CD_TRANSPORTADOR *= TI.CODIGO AND'
      '       R.CD_ARMAZEM_ATRACACAO *= AA.CD_ARMAZEM AND'
      '       R.CD_ARMAZEM_DESCARGA *= AD.CD_ARMAZEM AND'
      '       R.CD_CLIENTE *= E.CD_EMPRESA AND'
      '       R.CD_CANAL *= C.CD_CANAL AND'

  object qry_rel_fat_nf_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT F.NR_NF_SERV, F.DT_FATURA, E.NM_EMPRESA, N.VL_COMISSAO, N' +
        '.VL_SUB_TOT_TRIBUTAVEL, N.VL_TOT_TRIBUTAVEL'
      'FROM   TNF_SERV_OP N, TS_FATURA F, TEMPRESA_NAC E'
      'WHERE  N.CD_UNID_NEG = F.CD_UNID_NEG AND'
      '       N.CD_PRODUTO = F.CD_PRODUTO AND'
      '       N.NR_SOLICITACAO = F.NR_SOLICITACAO AND'
      '       N.CD_CLIENTE = E.CD_EMPRESA AND'
      '       F.IN_CANCELADO = '#39'0'#39' AND'
      
        '       ( ( N.CD_UNID_NEG = :CD_UNID_NEG ) OR ( :CD_UNID_NEG = '#39#39 +
        ' ) ) AND'
      '       F.DT_FATURA BETWEEN :DT_INICIO AND :DT_FIM AND'
      '       ISNULL( F.NR_NF_SERV, '#39#39' ) <> '#39#39
      'ORDER BY F.NR_NF_SERV'
      '')
    Left = 190
    Top = 406
    ParamData = <
      item
        DataType = ftString
        Name = 'CD_UNID_NEG'
        ParamType = ptUnknown
        Value = '01'
      end
      item
        DataType = ftString
        Name = 'CD_UNID_NEG'
        ParamType = ptUnknown
        Value = '01'
      end
      item
        DataType = ftDate
        Name = 'DT_INICIO'
        ParamType = ptUnknown
        Value = 37408d
      end
      item
        DataType = ftDate
        Name = 'DT_FIM'
        ParamType = ptUnknown
        Value = 37417d
      end>
  end

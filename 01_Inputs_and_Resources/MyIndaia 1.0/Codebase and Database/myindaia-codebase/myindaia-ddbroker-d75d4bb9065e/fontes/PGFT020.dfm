  object qry_rel_imp_demurrage_ref_merc: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT DISTINCT M.AP_MERCADORIA, REPLACE(REPLACE(CONVERT(VARCHAR' +
        '(8000), M.NM_MERCADORIA), NCHAR(13), '#39#39'), NCHAR(10), '#39' '#39') AS NM_' +
        'MERCADORIA'
      
        'FROM TDETALHE_MERCADORIA DM INNER JOIN TMERCADORIA M ON M.CD_MER' +
        'CADORIA = DM.CD_MERCADORIA'
      'WHERE NR_PROCESSO = :NR_PROCESSO'
      '  AND NR_PROC_PO  = :CD_REFERENCIA')
    Left = 595
    Top = 129
    ParamData = <
      item
        DataType = ftString
        Name = 'NR_PROCESSO'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'CD_REFERENCIA'
        ParamType = ptUnknown
      end>
    object qry_rel_imp_demurrage_ref_mercAP_MERCADORIA: TStringField
      FieldName = 'AP_MERCADORIA'
      FixedChar = True
      Size = 25
    end
    object qry_rel_imp_demurrage_ref_mercNM_MERCADORIA: TStringField
      FieldName = 'NM_MERCADORIA'
      FixedChar = True
      Size = 255
    end
  end

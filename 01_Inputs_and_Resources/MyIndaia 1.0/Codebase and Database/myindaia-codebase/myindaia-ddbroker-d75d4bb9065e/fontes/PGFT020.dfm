  object qry_rel_imp_sap_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      'DECLARE @DT_INICIO DATETIME'
      'DECLARE @DT_FIM DATETIME'
      'DECLARE @CD_UNID_NEG CHAR(2)'
      'DECLARE @CD_GRUPO CHAR(3)'
      'DECLARE @CD_CLIENTE CHAR(4)'
      'DECLARE @CD_AREA CHAR(2)'
      ''
      'SET @DT_INICIO   = :DT_INICIO'
      'SET @DT_FIM      = :DT_FIM'
      'SET @CD_UNID_NEG = :CD_UNID_NEG '
      'SET @CD_GRUPO    = :CD_GRUPO'
      'SET @CD_CLIENTE  = :CD_CLIENTE'
      'SET @CD_AREA     = :CD_AREA'
      ''
      ''
      'SELECT * '
      'FROM'
      '('
      '/*'
      
        'SELECT SUBSTRING(P.NR_PROCESSO, 5, 14)               '#9#9#9#9'AS NR_P' +
        'ROCESSO,'
      '       LEFT(D.NR_DECLARACAO_IMP, 2) + '#39'/'#39' + '
      '       SUBSTRING(D.NR_DECLARACAO_IMP, 3, 7) + '#39'-'#39' +  '#9#9#9#9
      
        '       RIGHT(D.NR_DECLARACAO_IMP, 1)                 '#9#9#9#9'AS NR_D' +
        'I,'
      
        '       LTRIM(RTRIM(ISNULL(NR_PROC_PO, '#39#39')))          '#9#9#9#9'AS NR_P' +
        'EDIDO,'
      
        '       CONVERT(VARCHAR, CONVERT(VARCHAR, ISNULL(NR_ITEM_PO, '#39#39'))' +
        ')   AS NR_ITEM,'
      '       '
      '       VL_II_ITEM,'
      '       VL_IPI_ITEM,'
      '       CASE ISNULL(A.VL_ICMS_A_RECOLHER, 0)'
      '            WHEN 0 '
      '            THEN 0'
      '            ELSE VL_ICMS_ITEM'
      
        '       END                                                      ' +
        '    AS VL_ICMS_ITEM,'
      '       '
      '       (SELECT SUM(ISNULL(A.VL_PIS_ITEM,0))'
      '          FROM TDETALHE_MERCADORIA   A (NOLOCK), '
      '               TADICAO_DE_IMPORTACAO B (NOLOCK)'
      '         WHERE A.NR_PROCESSO  = I.NR_PROCESSO'
      '          AND A.NR_ADICAO     = I.NR_ADICAO'
      '          AND A.NR_ITEM       = I.NR_ITEM'
      '          AND B.NR_PROCESSO   = A.NR_PROCESSO'
      '          AND B.NR_ADICAO     = A.NR_ADICAO'
      
        '          AND ISNULL(B.CD_TIPO_BENEF_PIS_COFINS,0) IN ('#39'1'#39', '#39'2'#39')' +
        ')   AS VL_PIS_ITEM,'
      '          '
      '       (SELECT SUM(ISNULL(A.VL_COFINS_ITEM,0))'
      '          FROM TDETALHE_MERCADORIA   A (NOLOCK) , '
      '               TADICAO_DE_IMPORTACAO B (NOLOCK)'
      '         WHERE A.NR_PROCESSO = I.NR_PROCESSO'
      '          AND A.NR_ADICAO    = I.NR_ADICAO'
      '          AND A.NR_ITEM      = I.NR_ITEM'
      '          AND B.NR_PROCESSO  = A.NR_PROCESSO'
      '          AND B.NR_ADICAO    = A.NR_ADICAO'
      
        '          AND ISNULL(B.CD_TIPO_BENEF_PIS_COFINS,0) IN ('#39'1'#39', '#39'2'#39')' +
        ')   AS VL_COFINS_ITEM,'
      '          '
      
        '       T.VL_TRIBUTO_PAGO                                        ' +
        '    AS VL_TX_SCX,'
      '       I.PL_MERCADORIA,'
      '       P.CD_CLIENTE,'
      '       E.NM_EMPRESA,'
      '       LEFT(D.DT_REGISTRO_DI, 2) + '#39'/'#39' + '
      '       SUBSTRING(D.DT_REGISTRO_DI, 3, 2) + '#39'/'#39' + '
      
        '       RIGHT(D.DT_REGISTRO_DI, 4)                               ' +
        '    AS DT_REG_DI,'
      '       D.NR_DECL_IMP_PROT,'
      '       E.END_CIDADE,'
      '       G.NM_GRUPO,'
      '       CASE LEFT(A.CD_CFOP, 4)'
      '           WHEN '#39'3102'#39' THEN 0'
      '           WHEN '#39'3101'#39' THEN 2'
      '                       ELSE '#39#39
      
        '       END                                                      ' +
        '    AS UTILIZ_MAT,'
      '       LEFT(E.CGC_EMPRESA, 2) + '#39'.'#39' + '
      '       SUBSTRING(E.CGC_EMPRESA, 3, 3) + '#39'.'#39' + '
      '       SUBSTRING(E.CGC_EMPRESA, 6, 3) + '#39'-'#39' + '
      '       SUBSTRING(E.CGC_EMPRESA, 9, 4) + '#39'/'#39' + '
      
        '       RIGHT(RTRIM(E.CGC_EMPRESA), 2)                           ' +
        '    AS CNPJ_EMPRESA,'
      '       ISNULL((TAD.VL_IPT_A_RECOLHER / A.VL_MERC_VENDA_MN) * '
      
        '       I.VL_MLE_ITEM_MN, 0)                                     ' +
        '    AS VL_ANTIDUMPING,'
      '       '
      '       CONVERT(VARCHAR(300),'
      '       STUFF((SELECT DISTINCT '#39', '#39' + LTRIM(RTRIM(NF.NR_NOTA))'
      '                FROM TPROCESSO_NF NF (NOLOCK)'
      '               WHERE NF.NR_PROCESSO = P.NR_PROCESSO'
      
        '        FOR XML PATH ('#39#39')), 1, 1, '#39#39'))                          ' +
        '    AS DS_NFS, /*AGATHA NIGRO 17/11/2017*/'
      '        '
      '       ISNULL((SELECT SUM(A.VL_TRIBUTO_PAGO)'
      '                 FROM TPAGAMENTO_TRIBUTOS A (NOLOCK)'
      '                WHERE A.CD_RECEITA_PGTO = '#39'5149'#39
      
        '                  AND A.NR_PROCESSO = P.NR_PROCESSO),0)         ' +
        '    AS VL_MULTA_LI /*AGATHA NIGRO 17/11/2017*/'
      '                  '
      'FROM TDETALHE_MERCADORIA         I   (NOLOCK) '
      
        'JOIN TDECLARACAO_IMPORTACAO      D   (NOLOCK) ON D.NR_PROCESSO  ' +
        '             = I.NR_PROCESSO                                    ' +
        '        '
      
        'JOIN TPAGAMENTO_TRIBUTOS         T   (NOLOCK) ON T.NR_PROCESSO  ' +
        '             = I.NR_PROCESSO'
      
        '                                             AND T.CD_RECEITA_PG' +
        'TO           = '#39'7811'#39
      
        'JOIN TPROCESSO                   P   (NOLOCK) ON P.NR_PROCESSO  ' +
        '             = I.NR_PROCESSO '
      
        'JOIN TEMPRESA_NAC                E   (NOLOCK) ON E.CD_EMPRESA   ' +
        '             = P.CD_CLIENTE  '
      
        'JOIN TGRUPO                      G   (NOLOCK) ON G.CD_GRUPO    '#9 +
        '             = E.CD_GRUPO'
      
        'LEFT JOIN TADICAO_DE_IMPORTACAO  A   (NOLOCK) ON A.NR_PROCESSO  ' +
        '             = I.NR_PROCESSO'
      
        '                                             AND A.NR_ADICAO    ' +
        '             = I.NR_ADICAO'
      
        'LEFT JOIN TRIBUTO                TAD (NOLOCK) ON TAD.NR_PROCESSO' +
        '             = A.NR_PROCESSO'
      
        '                                             AND TAD.NR_ADICAO  ' +
        '             = A.NR_ADICAO'
      
        '                                             AND TAD.CD_RECEITA_' +
        'IMPOSTO      = '#39'0003'#39
      'WHERE 1=1  '
      '  AND P.IN_CANCELADO              = '#39'0'#39
      '  AND ISNULL(D.DT_REGISTRO_DI, '#39#39') <> '#39#39'  '
      '  AND ((P.CD_UNID_NEG = @CD_UNID_NEG) OR (@CD_UNID_NEG = '#39#39'))'
      '  AND ((E.CD_GRUPO    = @CD_GRUPO)    OR (@CD_GRUPO = '#39#39'))'
      '  AND ((P.CD_CLIENTE  = @CD_CLIENTE)  OR (@CD_CLIENTE = '#39#39'))'
      '  AND ((P.CD_AREA     = @CD_AREA)     OR (@CD_AREA = '#39#39'))    '
      
        '  AND CONVERT(CHAR, RTRIM(CONVERT(CHAR, RIGHT(D.DT_REGISTRO_DI, ' +
        '4))) '
      
        '                  + RTRIM(CONVERT(CHAR, SUBSTRING(D.DT_REGISTRO_' +
        'DI, 3, 2))) '
      
        '                  + RTRIM(CONVERT(CHAR, LEFT(D.DT_REGISTRO_DI, 2' +
        ')))) BETWEEN @DT_INICIO AND @DT_FIM  '
      '  '
      ' ------AND (E.CD_GRUPO    = '#39'002'#39')                  '
      
        ' ------AND D.NR_PROCESSO  = '#39'0101IM-011150-18'#39'                  ' +
        ' '
      ''
      ''
      'UNION ALL'
      '*/'
      '         '
      
        'SELECT SUBSTRING(P.NR_PROCESSO, 5, 14)               '#9#9#9#9'AS NR_P' +
        'ROCESSO,'
      '       LEFT(P.NR_DI, 2) + '#39'/'#39' + '
      '       SUBSTRING(P.NR_DI, 3, 7) + '#39'-'#39' +  '#9#9#9#9
      
        '       RIGHT(P.NR_DI, 1)                             '#9#9#9#9'AS NR_D' +
        'I,'
      '   '
      '       CONVERT(VARCHAR(300),'
      
        '       STUFF((SELECT DISTINCT '#39','#39' + LTRIM(RTRIM(R.CD_REFERENCIA)' +
        ')'
      '                FROM TREF_CLIENTE R WITH (NOLOCK)'
      '               WHERE R.NR_PROCESSO  = P.NR_PROCESSO'
      '               and r.TP_REFERENCIA  = '#39'01'#39'   '
      
        '       FOR XML PATH('#39#39')), 1, 1, '#39#39'))                            ' +
        '    AS NR_PEDIDO,'
      ''
      #9'         '
      
        '       CONVERT(VARCHAR, CONVERT(VARCHAR, '#39#39'))                   ' +
        '    AS NR_ITEM,'
      '       '
      'ISNULL(      (SELECT SUM(PRICE)'
      
        '         FROM MYINDAIAV2.dbo.CustomClearance                 CC ' +
        '   (NOLOCK)'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED                   CR ' +
        '   (NOLOCK)ON CR.customClearance_id = CC.id'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED_ITEMCASHREQUESTED CRI' +
        'CR (NOLOCK)ON CRICR.CASHREQUESTED_ID = CR.ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEMCASHREQUESTED               IR ' +
        '   (NOLOCK)ON IR.ID = CRICR.ITEMS_ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEM                            I  ' +
        '   (NOLOCK)ON I.ID  = IR.ITEM_ID'
      '        WHERE CC.customID  = P.NR_PROCESSO '
      
        '          AND I.id in (128,129)),0)                             ' +
        '               AS VL_II_ITEM,'
      'ISNULL(      (SELECT SUM(PRICE)'
      
        '         FROM MYINDAIAV2.dbo.CustomClearance                 CC ' +
        '   (NOLOCK)'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED                   CR ' +
        '   (NOLOCK)ON CR.customClearance_id = CC.id'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED_ITEMCASHREQUESTED CRI' +
        'CR (NOLOCK)ON CRICR.CASHREQUESTED_ID = CR.ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEMCASHREQUESTED               IR ' +
        '   (NOLOCK)ON IR.ID = CRICR.ITEMS_ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEM                            I  ' +
        '   (NOLOCK)ON I.ID  = IR.ITEM_ID'
      '        WHERE CC.customID  = P.NR_PROCESSO '
      
        '          AND I.id in (124,125)) ,0)                            ' +
        '              AS VL_IPI_ITEM,'
      'ISNULL(      (SELECT SUM(PRICE)'
      
        '         FROM MYINDAIAV2.dbo.CustomClearance                 CC ' +
        '   (NOLOCK)'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED                   CR ' +
        '   (NOLOCK)ON CR.customClearance_id = CC.id'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED_ITEMCASHREQUESTED CRI' +
        'CR (NOLOCK)ON CRICR.CASHREQUESTED_ID = CR.ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEMCASHREQUESTED               IR ' +
        '   (NOLOCK)ON IR.ID = CRICR.ITEMS_ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEM                            I  ' +
        '   (NOLOCK)ON I.ID  = IR.ITEM_ID'
      '        WHERE CC.customID  = P.NR_PROCESSO '
      
        '          AND I.id in (122,123))  ,0)                           ' +
        '              AS VL_ICMS_ITEM,       '
      'ISNULL(      (SELECT SUM(PRICE)'
      
        '         FROM MYINDAIAV2.dbo.CustomClearance                 CC ' +
        '   (NOLOCK)'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED                   CR ' +
        '   (NOLOCK)ON CR.customClearance_id = CC.id'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED_ITEMCASHREQUESTED CRI' +
        'CR (NOLOCK)ON CRICR.CASHREQUESTED_ID = CR.ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEMCASHREQUESTED               IR ' +
        '   (NOLOCK)ON IR.ID = CRICR.ITEMS_ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEM                            I  ' +
        '   (NOLOCK)ON I.ID  = IR.ITEM_ID'
      '        WHERE CC.customID  = P.NR_PROCESSO '
      
        '          AND I.id in (166,167))   ,0)                          ' +
        '               AS VL_PIS_ITEM,'
      'ISNULL(      (SELECT SUM(PRICE)'
      
        '         FROM MYINDAIAV2.dbo.CustomClearance                 CC ' +
        '   (NOLOCK)'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED                   CR ' +
        '   (NOLOCK)ON CR.customClearance_id = CC.id'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED_ITEMCASHREQUESTED CRI' +
        'CR (NOLOCK)ON CRICR.CASHREQUESTED_ID = CR.ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEMCASHREQUESTED               IR ' +
        '   (NOLOCK)ON IR.ID = CRICR.ITEMS_ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEM                            I  ' +
        '   (NOLOCK)ON I.ID  = IR.ITEM_ID'
      '        WHERE CC.customID  = P.NR_PROCESSO '
      
        '          AND I.id in (40,41))  ,0)                             ' +
        '            AS VL_COFINS_ITEM,          '
      ' ISNULL(     (SELECT SUM(PRICE)'
      
        '         FROM MYINDAIAV2.dbo.CustomClearance                 CC ' +
        '   (NOLOCK)'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED                   CR ' +
        '   (NOLOCK)ON CR.customClearance_id = CC.id'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED_ITEMCASHREQUESTED CRI' +
        'CR (NOLOCK)ON CRICR.CASHREQUESTED_ID = CR.ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEMCASHREQUESTED               IR ' +
        '   (NOLOCK)ON IR.ID = CRICR.ITEMS_ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEM                            I  ' +
        '   (NOLOCK)ON I.ID  = IR.ITEM_ID'
      '        WHERE CC.customID  = P.NR_PROCESSO '
      
        '          AND I.id = 217) ,0)                                   ' +
        '       AS VL_TX_SCX,'
      
        '       0.00                                                     ' +
        '      AS PL_MERCADORIA,'
      
        '       P.CD_CLIENTE                                             ' +
        '    AS CD_CLIENTE,'
      
        '       E.NM_EMPRESA                                             ' +
        '    AS NM_EMPRESA,      '
      
        '       CONVERT(VARCHAR(10),F021.DT_REALIZACAO,103)              ' +
        '    AS DT_REG_DI,'
      '       CONVERT(VARCHAR(300),'
      
        '       STUFF((SELECT DISTINCT '#39','#39' + LTRIM(RTRIM(R.CD_REFERENCIA)' +
        ')'
      '                FROM TREF_CLIENTE R WITH (NOLOCK)'
      '               WHERE R.NR_PROCESSO  = P.NR_PROCESSO'
      '               and r.TP_REFERENCIA  = '#39'33'#39'   '
      
        '       FOR XML PATH('#39#39')), 1, 1, '#39#39'))                            ' +
        '                               AS NR_DECL_IMP_PROT,'
      '       E.END_CIDADE,'
      '       G.NM_GRUPO,'
      
        '       0                                                        ' +
        '   AS UTILIZ_MAT,'
      '       LEFT(E.CGC_EMPRESA, 2) + '#39'.'#39' + '
      '       SUBSTRING(E.CGC_EMPRESA, 3, 3) + '#39'.'#39' + '
      '       SUBSTRING(E.CGC_EMPRESA, 6, 3) + '#39'-'#39' + '
      '       SUBSTRING(E.CGC_EMPRESA, 9, 4) + '#39'/'#39' + '
      
        '       RIGHT(RTRIM(E.CGC_EMPRESA), 2)                           ' +
        '    AS CNPJ_EMPRESA,'
      '      (SELECT PRICE'
      
        '         FROM MYINDAIAV2.dbo.CustomClearance                 CC ' +
        '   (NOLOCK)'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED                   CR ' +
        '   (NOLOCK)ON CR.customClearance_id = CC.id'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED_ITEMCASHREQUESTED CRI' +
        'CR (NOLOCK)ON CRICR.CASHREQUESTED_ID = CR.ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEMCASHREQUESTED               IR ' +
        '   (NOLOCK)ON IR.ID = CRICR.ITEMS_ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEM                            I  ' +
        '   (NOLOCK)ON I.ID  = IR.ITEM_ID'
      '        WHERE CC.customID  = P.NR_PROCESSO '
      
        '          AND I.id = 12)                                        ' +
        '   AS VL_ANTIDUMPING,    '
      '   '
      '       CONVERT(VARCHAR(300),'
      '       STUFF((SELECT DISTINCT '#39', '#39' + LTRIM(RTRIM(NF.NR_NOTA))'
      '                FROM TPROCESSO_NF NF (NOLOCK)'
      '               WHERE NF.NR_PROCESSO = P.NR_PROCESSO'
      
        '        FOR XML PATH ('#39#39')), 1, 1, '#39#39'))                          ' +
        '   AS DS_NFS, /*AGATHA NIGRO 17/11/2017*/'
      '        '
      '      (SELECT PRICE'
      
        '         FROM MYINDAIAV2.dbo.CustomClearance                 CC ' +
        '   (NOLOCK)'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED                   CR ' +
        '   (NOLOCK)ON CR.customClearance_id = CC.id'
      
        '   INNER JOIN MYINDAIAV2.DBO.CASHREQUESTED_ITEMCASHREQUESTED CRI' +
        'CR (NOLOCK)ON CRICR.CASHREQUESTED_ID = CR.ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEMCASHREQUESTED               IR ' +
        '   (NOLOCK)ON IR.ID = CRICR.ITEMS_ID'
      
        '   INNER JOIN MYINDAIAV2.DBO.ITEM                            I  ' +
        '   (NOLOCK)ON I.ID  = IR.ITEM_ID'
      '        WHERE CC.customID  = P.NR_PROCESSO '
      
        '          AND I.id = 154)                                       ' +
        '    AS VL_MULTA_LI ,'
      ''
      
        ' (  SELECT TOP 1 CD_MERCADORIA FROM TDETALHE_MERCADORIA WHERE NR' +
        '_PROCESSO = P.NR_PROCESSO ) AS COD_MERCADORIA'
      ''
      '                  '
      'FROM TPROCESSO                   P    (NOLOCK)'
      
        'JOIN TEMPRESA_NAC                E    (NOLOCK) ON E.CD_EMPRESA  ' +
        '    = P.CD_CLIENTE  '
      
        'JOIN TGRUPO                      G    (NOLOCK) ON G.CD_GRUPO    ' +
        '    = E.CD_GRUPO'
      
        'LEFT JOIN TFOLLOWUP              F021 (NOLOCK) ON F021.NR_PROCES' +
        'SO  = P.NR_PROCESSO '
      
        '                                              AND F021.CD_SERVIC' +
        'O   = P.CD_SERVICO'
      
        '                                              AND F021.CD_EVENTO' +
        '    = '#39'021'#39
      
        '--LEFT JOIN TDECLARACAO_IMPORTACAO DI   (NOLOCK) ON DI.NR_PROCES' +
        'SO    = P.NR_PROCESSO                                           ' +
        '    '
      'WHERE  1=1  '
      '--  AND DI.NR_PROCESSO IS NULL    '
      '  AND P.IN_CANCELADO              = '#39'0'#39
      '  AND ((P.CD_UNID_NEG = @CD_UNID_NEG) OR (@CD_UNID_NEG = '#39#39'))'
      '  AND ((E.CD_GRUPO    = @CD_GRUPO)    OR (@CD_GRUPO = '#39#39'))'
      '  AND ((P.CD_CLIENTE  = @CD_CLIENTE)  OR (@CD_CLIENTE = '#39#39'))'
      '  AND ((P.CD_AREA     = @CD_AREA)     OR (@CD_AREA = '#39#39'))    '
      '  AND (F021.DT_REALIZACAO BETWEEN @DT_INICIO AND (@DT_FIM +1))'
      '    '
      '  ------AND (E.CD_GRUPO    = '#39'002'#39')           '
      '  --AND P.NR_PROCESSO  = '#39'0101IM-011150-18'#39'                   '
      ') TAB'
      'ORDER BY NM_EMPRESA,'
      '         NR_PROCESSO,'
      '         LTRIM(RTRIM(ISNULL(NR_PEDIDO, '#39#39'))) + '#39'/'#39' +'
      '         CONVERT(VARCHAR, CONVERT(VARCHAR, ISNULL(NR_ITEM, '#39#39')))'
      '         ')
    Left = 190
    Top = 460
    ParamData = <
      item
        DataType = ftString
        Name = 'DT_INICIO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'DT_FIM'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_UNID_NEG'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_GRUPO'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_CLIENTE'
        ParamType = ptInput
      end
      item
        DataType = ftString
        Name = 'CD_AREA'
        ParamType = ptInput
      end>

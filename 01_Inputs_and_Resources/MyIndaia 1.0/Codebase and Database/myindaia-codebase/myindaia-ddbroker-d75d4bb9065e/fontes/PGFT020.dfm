  object qry_rel_canal_graf_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT DISTINCT NR_IDENTIFICADOR, NM_CANAL, QT_PROC_CANAL, QT_PR' +
        'OC_TOTAL, QT_MEDIA_DIAS_TOTAL, '
      
        '(SELECT ROUND(ISNULL((QT_MEDIA_DIAS_CANAL / QT_MEDIA_DIAS_TOTAL)' +
        ' * 100, 0), 2, 0) FROM TREL_CANAL_GRAF R'
      
        ' WHERE R.NR_IDENTIFICADOR = RG.NR_IDENTIFICADOR AND R.NM_CANAL =' +
        ' '#39'VERMELHO'#39') AS QT_MEDIA_DIAS_VERMELHO,'
      
        '(SELECT ROUND(ISNULL((QT_MEDIA_DIAS_CANAL / QT_MEDIA_DIAS_TOTAL)' +
        ' * 100, 0), 2, 0) FROM TREL_CANAL_GRAF R'
      
        ' WHERE R.NR_IDENTIFICADOR = RG.NR_IDENTIFICADOR AND R.NM_CANAL =' +
        ' '#39'AMARELO'#39') AS QT_MEDIA_DIAS_AMARELO,'
      
        '(SELECT ROUND(ISNULL((QT_MEDIA_DIAS_CANAL / QT_MEDIA_DIAS_TOTAL)' +
        ' * 100, 0), 2, 0) FROM TREL_CANAL_GRAF R'
      
        ' WHERE R.NR_IDENTIFICADOR = RG.NR_IDENTIFICADOR AND R.NM_CANAL =' +
        ' '#39'VERDE'#39') AS QT_MEDIA_DIAS_VERDE,'
      
        '(SELECT ROUND(ISNULL((QT_MEDIA_DIAS_CANAL / QT_MEDIA_DIAS_TOTAL)' +
        ' * 100, 0), 2, 0) FROM TREL_CANAL_GRAF R'
      
        ' WHERE R.NR_IDENTIFICADOR = RG.NR_IDENTIFICADOR AND R.NM_CANAL =' +
        ' '#39'CINZA'#39') AS QT_MEDIA_DIAS_CINZA, RG.NR_ORDEM'
      'FROM TREL_CANAL_GRAF RG'
      'WHERE NR_IDENTIFICADOR =:NR_IDENTIFICADOR'
      'ORDER BY RG.NR_ORDEM')
    Left = 728
    Top = 73
    ParamData = <
      item
        DataType = ftInteger
        Name = 'NR_IDENTIFICADOR'
        ParamType = ptUnknown
      end>
    object qry_rel_canal_graf_NR_IDENTIFICADOR: TIntegerField
      FieldName = 'NR_IDENTIFICADOR'
    end
    object qry_rel_canal_graf_NM_CANAL: TStringField

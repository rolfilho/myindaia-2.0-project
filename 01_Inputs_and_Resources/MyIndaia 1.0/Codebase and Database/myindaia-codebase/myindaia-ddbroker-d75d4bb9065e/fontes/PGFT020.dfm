      FieldName = 'QT_MEDIA_DIAS_TOTAL'
    end
    object qry_rel_canal_graf_QT_MEDIA_DIAS_VERMELHO: TFloatField
      FieldName = 'QT_MEDIA_DIAS_VERMELHO'
    end
    object qry_rel_canal_graf_QT_MEDIA_DIAS_AMARELO: TFloatField
      FieldName = 'QT_MEDIA_DIAS_AMARELO'
    end
    object qry_rel_canal_graf_QT_MEDIA_DIAS_VERDE: TFloatField
      FieldName = 'QT_MEDIA_DIAS_VERDE'
    end
    object qry_rel_canal_graf_QT_MEDIA_DIAS_CINZA: TFloatField
      FieldName = 'QT_MEDIA_DIAS_CINZA'
    end

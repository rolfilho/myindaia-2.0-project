  object qry_rel_lead_time2_: TQuery
    DatabaseName = 'DBBROKER'
    SQL.Strings = (
      
        'SELECT DISTINCT NR_IDENTIFICADOR, CD_REFERENCIA, SUBSTRING( NR_P' +
        'ROCESSO, 5, LEN(NR_PROCESSO)) AS NR_PROCESSO, NM_CLIENTE, NM_EMB' +
        'ARCACAO, DT_CHEGADA_NAVIO, ARMZ_ATRACACAO, '
      
        '  NM_MARGEM, DT_REGISTRO_DI, DT_ENT_ARM, TEMPO_DESEMBARACO, DT_D' +
        'ESEMBARACO, NM_CANAL, VL_COMISSAO, VL_SDA, VL_CIF,'
      
        '  ARMZ_DESCARGA, PERIODO_ARMAZENAGEM, VL_ARMZ_TERMINAL, VL_ARMZ_' +
        'NORMAL, DT_ENVIO_NF, NM_ESPECIE, QT_VOLUMES,'
      
        '  DT_PRESENCA_CARGA, DT_DOCTOS_TRANSPORT, NM_AGENTE_CARGA, NM_AR' +
        'MAZEM_DESCARGA'
      'FROM TREL_LEAD_TIME2'
      'WHERE NR_IDENTIFICADOR=:NR_IDENTIFICADOR ')

            'ND NAME IN ('#39'+@COLUMNS+'#39')'#39'      '#13#10'      '#13#10'INSERT INTO @EXCLUDEDL' +
            'IST       '#13#10'       EXEC(@IDQUERY)         '#13#10'          '#13#10'SELECT @' +

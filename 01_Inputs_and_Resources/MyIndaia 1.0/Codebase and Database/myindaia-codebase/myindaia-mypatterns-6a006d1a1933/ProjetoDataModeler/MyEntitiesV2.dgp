            'SELECT @TEXT= '#39'SELECT '#39#39'INSERT INTO '#39'+@TABLE_NAME+'#39'('#39'+@CSV_COLUM' +
            'N+'#39')VALUES('#39#39#39'+'#39'+'#39'+SUBSTRING(@QUOTED_DATA,1,LEN(@QUOTED_DATA)-5)' +
            '+'#39'+'#39'+'#39#39#39')'#39#39#39'+'#39' FROM '#39'+@TABLE_NAME + '#39' '#39' + @FILTER       '#13#10'      ' +
            '   '#13#10'--SELECT @CSV_COLUMN AS CSV_COLUMN,@QUOTED_DATA AS QUOTED_D' +

  DataDictionary.Categories = <
    item
      CategoryType = ctProcedure
      Objects = <
        item
          ObjectName = 'SP_INSERE_PGMTO_MERCANTE_WALLET'
          CreateImplementation = 
            'CREATE PROCEDURE [DBO].[SP_INSERE_PGMTO_MERCANTE_WALLET]'#13#10'(@PROC' +
            'ESSO CHAR(18), @TIPO_CONTA CHAR(15), @USUARIO CHAR(4), @VALOR_DE' +
            'BITO NUMERIC(15,2), @RESULTADO VARCHAR(50) OUTPUT)            '#13#10 +
            'AS BEGIN            '#13#10'            '#13#10' DECLARE @FILIAL  CHAR(2)   ' +
            '         '#13#10' DECLARE @PRODUTO CHAR(2)            '#13#10' DECLARE @CHAV' +
            'E_PAYMENTREQUESTED BIGINT            '#13#10' DECLARE @CHAVE_ITEMPAYME' +
            'NTREQUESTED BIGINT            '#13#10' DECLARE @CHAVE_CASHREQUESTED BI' +
            'GINT            '#13#10' DECLARE @CHAVE_ITEMCASHREQUESTED BIGINT      ' +
            '      '#13#10' DECLARE @ID_BRANCH BIGINT            '#13#10' DECLARE @ID_PRO' +
            'DUCT BIGINT    '#13#10' DECLARE @CHAVE_BALANCE BIGINT        '#13#10'       ' +
            '     '#13#10' --SET @PROCESSO   = '#39'0101IM-007717-18'#39'            '#13#10' --S' +
            'ET @TIPO_CONTA = '#39'INDAIA'#39'              '#13#10'                       ' +
            ' '#13#10' SELECT @PRODUTO = CD_PRODUTO ,             '#13#10'        @FILIAL' +
            '  = CD_UNID_NEG            '#13#10'   FROM BROKER..TPROCESSO A (NOLOCK' +
            ')            '#13#10'  WHERE NR_PROCESSO = @PROCESSO            '#13#10'    ' +
            '        '#13#10'            '#13#10' SELECT @ID_BRANCH = ID             '#13#10'  ' +
            ' FROM MYINDAIAV2..BRANCH A (NOLOCK)             '#13#10'     WHERE A.A' +
            'KEY = @FILIAL            '#13#10'               '#13#10' SELECT @ID_PRODUCT ' +
            '= ID             '#13#10'   FROM MYINDAIAV2..PRODUCT A (NOLOCK)       ' +
            '      '#13#10'  WHERE A.AKEY = @PRODUTO              '#13#10'            '#13#10' ' +
            '         '#13#10' BEGIN TRAN        '#13#10' BEGIN TRY           '#13#10'   IF @TI' +
            'PO_CONTA = '#39'INDAIA'#39'            '#13#10'   BEGIN            '#13#10'         ' +
            'INSERT INTO MYINDAIAV2..PAYMENTREQUESTED(BARCODE,             '#13#10 +
            '                                    PAYMENTTOTAL,             '#13#10 +
            '                                    RECEIVEDDATE,             '#13#10 +
            '                                    SENIORKEY,             '#13#10'   ' +
            '                                 STATUS,             '#13#10'         ' +
            '                           TYPE,             '#13#10'                 ' +
            '                   APPROVEDUSER_ID,             '#13#10'              ' +
            '                      BENEFICIARY_ID,            '#13#10'             ' +
            '                       BILLING_ID,            '#13#10'                ' +
            '                    BRANCH_ID,             '#13#10'                   ' +
            '                 CUSTOMCLEARANCE_ID,             '#13#10'             ' +
            '                       CUSTOMER_ID,             '#13#10'              ' +
            '                      PRODUCT_ID,             '#13#10'                ' +
            '                    SERVICE_ID,             '#13#10'                  ' +
            '                  USER_ID,             '#13#10'                       ' +
            '             DUEDATE,             '#13#10'                            ' +
            '        SENIORSUBKEY,      '#13#10'                                   ' +
            ' CREATED )            '#13#10'    SELECT                              ' +
            '            '#13#10'     NULL           AS BARCODE,             '#13#10'    ' +
            ' @VALOR_DEBITO  AS PAYMENTTOTAL,             '#13#10'     NULL        ' +
            '   AS RECEIVEDDATE,             '#13#10'     NULL           AS SENIORK' +
            'EY,             '#13#10'     '#39'WAIT'#39'         AS STATUS,             '#13#10' ' +
            '    NULL           AS TYPE,             '#13#10'     NULL           AS' +
            ' APPROVEDUSER_ID,             '#13#10'     '#39'399'#39'          AS BENEFICIA' +
            'RY_ID,            '#13#10'     NULL           AS BILLING_ID,          ' +
            '  '#13#10'     @ID_BRANCH     AS BRANCH_ID,             '#13#10'     A.ID   ' +
            '        AS CUSTOMCLEARANCE_ID,             '#13#10'     A.CUSTOMER_ID ' +
            ' AS CUSTOMER_ID,             '#13#10'     @ID_PRODUCT    AS PRODUCT_ID' +
            ',             '#13#10'     A.SERVICE_ID   AS SERVICE_ID,             '#13 +
            #10'     @USUARIO       AS USER_ID,             '#13#10'     NULL        ' +
            '   AS DUE_DATE,             '#13#10'     NULL           AS SENIORSUBKE' +
            'Y,      '#13#10'     GETDATE()      AS CREATED                '#13#10'     F' +
            'ROM MYINDAIAV2..CUSTOMCLEARANCE A(NOLOCK)            '#13#10'    WHERE' +
            ' CUSTOMID  = @PROCESSO             '#13#10'                      '#13#10'   ' +
            '   SELECT @CHAVE_PAYMENTREQUESTED =  @@IDENTITY                 ' +
            #13#10'                                      '#13#10'              '#13#10'    IN' +
            'SERT INTO MYINDAIAV2..ITEMPAYMENTREQUESTED (DESTINO,            ' +
            #13#10'                                                  ITEM_ID,    ' +
            '         '#13#10'                                                  PRI' +
            'CE)            '#13#10'    SELECT 1,             '#13#10'           1,      ' +
            '      '#13#10'           @VALOR_DEBITO             '#13#10'              '#13#10' ' +
            '   SELECT @CHAVE_ITEMPAYMENTREQUESTED =  @@IDENTITY             ' +
            '    '#13#10'              '#13#10'              '#13#10'    INSERT INTO MYINDAIAV2' +
            '..PAYMENTREQUESTED_ITEMPAYMENTREQUESTED (PAYMENTREQUESTED_ID,   ' +
            '          '#13#10'                                                    ' +
            '               ITEMS_ID)            '#13#10'    SELECT @CHAVE_PAYMENTR' +
            'EQUESTED,             '#13#10'           @CHAVE_ITEMPAYMENTREQUESTED  ' +
            '    '#13#10'           '#13#10'    /*ATUALIZAR SALDO*/'#13#10'    IF ( SELECT CC.B' +
            'ALANCE_ID '#13#10'    '#9'   FROM MYINDAIAV2.DBO.CUSTOMCLEARANCE  CC (NOL' +
            'OCK) '#13#10#9'      WHERE CC.CUSTOMID = @PROCESSO ) IS NOT NULL'#13#10#9' BEG' +
            'IN'#9'   '#13#10#9#9#9'UPDATE MYINDAIAV2.DBO.BALANCE  '#13#10#9#9#9'   SET VALUE = (V' +
            'ALUE - @VALOR_DEBITO)'#13#10#9#9#9'  FROM MYINDAIAV2.DBO.BALANCE         ' +
            ' B  (NOLOCK)  '#13#10#9#9'INNER JOIN MYINDAIAV2.DBO.CUSTOMCLEARANCE  CC ' +
            '(NOLOCK)ON CC.BALANCE_ID = B.ID'#13#10#9#9#9' WHERE CC.CUSTOMID = @PROCES' +
            'SO'#13#10#9' END'#13#10#9' ELSE'#13#10#9' BEGIN'#13#10#9#9#9'INSERT INTO MYINDAIAV2.DBO.BALANC' +
            'E (VALUE)'#9#9#9#13#10#9#9#9'SELECT 0 - @VALOR_DEBITO AS VALUE'#13#10#9#9#9#13#10#9#9#9'SELE' +
            'CT @CHAVE_BALANCE = @@IDENTITY'#13#10#9#9#9#13#10#9#9#9'UPDATE MYINDAIAV2.DBO.CU' +
            'STOMCLEARANCE '#13#10#9#9#9'   SET BALANCE_ID  = @CHAVE_BALANCE'#13#10#9#9#9'  FRO' +
            'M MYINDAIAV2.DBO.CUSTOMCLEARANCE  CC (NOLOCK)'#13#10#9#9#9' WHERE CC.CUST' +
            'OMID = @PROCESSO'#13#10#9' END '#9'          '#13#10'     /*ATUALIZAR SALDO*/   ' +
            '      '#13#10'              '#13#10'   END            '#13#10'   ELSE             ' +
            #13#10'   IF @TIPO_CONTA = '#39'CLIENTE'#39'            '#13#10'   BEGIN           ' +
            '         '#13#10'    INSERT INTO MYINDAIAV2..CASHREQUESTED( CREATED,  ' +
            '          '#13#10'                                    RECEIVEDDATE,   ' +
            '          '#13#10'                                    SENIORKEY,      ' +
            '       '#13#10'                                    STATUS,            ' +
            ' '#13#10'                                    BRANCH_ID,             '#13#10 +
            '                                    CUSTOMCLEARANCE_ID,         ' +
            '    '#13#10'                                    CUSTOMER_ID,          ' +
            '   '#13#10'                                    PRODUCT_ID,            ' +
            #13#10'                                    SERVICE_ID,             '#13#10 +
            '                                    USER_ID,             '#13#10'     ' +
            '                               CASHREQUESTTOTAL      '#13#10'         ' +
            '                          )                                     ' +
            '  '#13#10'    SELECT         '#13#10'       GETDATE()     AS CREATED,       ' +
            '      '#13#10'       NULL          AS RECEIVEDDATE,             '#13#10'    ' +
            '   NULL          AS SENIORKEY,             '#13#10'       '#39'APPROVED'#39'  ' +
            '  AS STATUS,             '#13#10'       @ID_BRANCH    AS BRANCH_ID,   ' +
            '          '#13#10'       A.ID          AS CUSTOMCLEARANCE_ID,         ' +
            '    '#13#10'       A.CUSTOMER_ID AS CUSTOMER_ID,             '#13#10'       ' +
            '@ID_PRODUCT   AS PRODUCT_ID,            '#13#10'       A.SERVICE_ID  A' +
            'S SERVICE_ID,             '#13#10'       @USUARIO      AS USER_ID,    ' +
            '         '#13#10'       0             AS CASHREQUESTTOTAL             ' +
            ' '#13#10'     FROM MYINDAIAV2..CUSTOMCLEARANCE A(NOLOCK)            '#13#10 +
            '    WHERE CUSTOMID  = @PROCESSO            '#13#10'              '#13#10'   ' +
            ' SELECT @CHAVE_CASHREQUESTED = @@IDENTITY            '#13#10'         ' +
            '     '#13#10'              '#13#10'    INSERT INTO MYINDAIAV2..ITEMCASHREQUE' +
            'STED (DESTINO,              '#13#10'                                  ' +
            '             ITEM_ID,             '#13#10'                            ' +
            '                   PRICE)            '#13#10'    SELECT 2             ' +
            'AS DESTINO,             '#13#10'           1             AS ITEM_ID,  ' +
            '           '#13#10'           @VALOR_DEBITO AS PRICE            '#13#10'    ' +
            '                   '#13#10'    SELECT @CHAVE_ITEMCASHREQUESTED = @@IDE' +
            'NTITY            '#13#10'              '#13#10'              '#13#10'             ' +
            ' '#13#10'    INSERT INTO MYINDAIAV2..CASHREQUESTED_ITEMCASHREQUESTED (' +
            ' CASHREQUESTED_ID,             '#13#10'                               ' +
            '                               ITEMS_ID)            '#13#10'    SELECT' +
            ' @CHAVE_CASHREQUESTED,             '#13#10'           @CHAVE_ITEMCASHR' +
            'EQUESTED            '#13#10'      '#13#10'      '#13#10'    /*ATUALIZAR SALDO*/'#13#10' ' +
            '   IF ( SELECT CC.BALANCE_ID '#13#10'    '#9'   FROM MYINDAIAV2.DBO.CUSTO' +
            'MCLEARANCE  CC (NOLOCK) '#13#10#9'      WHERE CC.CUSTOMID = @PROCESSO )' +
            ' IS NOT NULL'#13#10#9' BEGIN'#9'   '#13#10#9#9#9'UPDATE MYINDAIAV2.DBO.BALANCE  '#13#10#9 +
            #9#9'   SET VALUE = (VALUE - @VALOR_DEBITO)'#13#10#9#9#9'  FROM MYINDAIAV2.D' +
            'BO.BALANCE          B  (NOLOCK)  '#13#10#9#9'INNER JOIN MYINDAIAV2.DBO.C' +
            'USTOMCLEARANCE  CC (NOLOCK)ON CC.BALANCE_ID = B.ID'#13#10#9#9#9' WHERE CC' +
            '.CUSTOMID = @PROCESSO'#13#10#9' END'#13#10#9' ELSE'#13#10#9' BEGIN'#13#10#9#9#9'INSERT INTO MY' +
            'INDAIAV2.DBO.BALANCE (VALUE)'#9#9#9#13#10#9#9#9'SELECT 0 - @VALOR_DEBITO AS ' +
            'VALUE'#13#10#9#9#9#13#10#9#9#9'SELECT @CHAVE_BALANCE = @@IDENTITY'#13#10#9#9#9#13#10#9#9#9'UPDAT' +
            'E MYINDAIAV2.DBO.CUSTOMCLEARANCE '#13#10#9#9#9'   SET BALANCE_ID  = @CHAV' +
            'E_BALANCE'#13#10#9#9#9'  FROM MYINDAIAV2.DBO.CUSTOMCLEARANCE  CC (NOLOCK)' +
            #13#10#9#9#9' WHERE CC.CUSTOMID = @PROCESSO'#13#10#9' END '#9'          '#13#10'     /*A' +
            'TUALIZAR SALDO*/     '#13#10#9' '#13#10'   END                      '#13#10'  COMMI' +
            'T                                          '#13#10'  SET @RESULTADO = ' +
            #39'OK'#39'         '#13#10' END TRY                                         ' +
            '   '#13#10' BEGIN CATCH                                          '#13#10'  R' +
            'OLLBACK         '#13#10'  SET @RESULTADO =  '#39'ERRO'#39'         '#13#10' END CATC' +
            'H        '#13#10'             '#13#10'END'
        end

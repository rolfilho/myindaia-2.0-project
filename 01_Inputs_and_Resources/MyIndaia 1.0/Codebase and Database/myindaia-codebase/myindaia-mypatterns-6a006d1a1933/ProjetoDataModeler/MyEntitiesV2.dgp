            ' SELECT '#39' ISNULL(QUOTENAME('#39'+CASE WHEN UPPER(B.NAME) = '#39'DATETIME' +
            #39' THEN '#39'CONVERT(VARCHAR,'#39' + A.NAME +'#39',21)'#39' ELSE A.NAME END+'#39','#39'+Q' +
            'UOTENAME('#39#39#39#39','#39#39#39#39#39#39')+'#39'),'#39'+'#39#39#39'NULL'#39#39#39'+'#39')+'#39#39','#39#39#39'+'#39'+'#39'       '#13#10'    ' +
            'FROM SYS.ALL_COLUMNS a      '#13#10'    LEFT JOIN SYS.TYPES B ON B.sys' +
            'tem_type_id = A.system_type_id      '#13#10'      WHERE OBJECT_ID=OBJE' +
            'CT_ID(@TABLE_NAME)       '#13#10'     AND ( ( (IS_IDENTITY != 1) AND (' +
            '@IDENTITY = 0) ) OR (@IDENTITY = 1) )       '#13#10'  AND A.NAME NOT I' +
            'N (SELECT NAME FROM @EXCLUDEDLIST)      '#13#10'    FOR XML PATH('#39#39')  ' +

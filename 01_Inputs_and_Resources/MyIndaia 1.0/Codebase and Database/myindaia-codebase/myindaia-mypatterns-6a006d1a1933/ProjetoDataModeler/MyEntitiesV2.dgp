            'CT '#39',['#39'+ NAME +'#39']'#39'       '#13#10'    FROM SYS.ALL_COLUMNS       '#13#10'    ' +
            '  WHERE OBJECT_ID = OBJECT_ID(@TABLE_NAME)       '#13#10'     AND ( ( ' +

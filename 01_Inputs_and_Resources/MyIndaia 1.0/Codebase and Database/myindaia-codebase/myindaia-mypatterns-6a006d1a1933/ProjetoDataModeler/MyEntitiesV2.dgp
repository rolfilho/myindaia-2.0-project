            'ON) > 0      '#13#10'INSERT INTO @RESULT      '#13#10' SELECT  @SQL_ON  + CH' +
            'AR(13)       '#13#10'      '#13#10'INSERT INTO @RESULT      '#13#10'EXEC (@TEXT)  ' +
            '    '#13#10'      '#13#10'IF LEN(@SQL_OFF) > 0      '#13#10'INSERT INTO @RESULT   ' +
            '   '#13#10'SELECT CHAR(13) + @SQL_OFF       '#13#10'      '#13#10'      '#13#10'SELECT I' +
            'NSERTS       '#13#10'  FROM @RESULT      '#13#10'      '#13#10'SET NOCOUNT OFF    ' +
            '  '#13#10'      '#13#10'END'
        end
        item
          ObjectName = 'sp_SaldoProcesso'
          CreateImplementation = 
            'CREATE PROCEDURE [dbo].[sp_SaldoProcesso](@customID varchar(18))' +
            ' as '#13#10'begin'#13#10#13#10'declare @CustomClearance integer'#13#10'declare @TotalN' +
            'umer'#225'rio float'#13#10'declare @TotalPagamento float'#13#10'declare @SaldoErr' +
            'adoHj float'#13#10'declare @SaldoProcesso float'#13#10#13#10'select @CustomClear' +
            'ance = id from CustomClearance where customID= @customID'#13#10#13#10'Sele' +
            'ct @TotalNumer'#225'rio = isnull(SUM(cr.cashRequestTotal),0) '#13#10'from  ' +
            'CashRequested cr '#13#10'where customClearance_id=@CustomClearance and' +
            ' '#13#10'      CR.status='#39'APPROVED'#39' and'#13#10'      cr.id not in (select ca' +
            'shRequests_id '#13#10'                    from Billing_CashRequested b' +
            'cr'#13#10'                    inner join Billing b on b.id=bcr.Billing' +
            '_id'#13#10'                    where status = '#39'INVOICED'#39')'#13#10#13#10'select @T' +
            'otalPagamento = isnull(sum(pr.paymentTotal),0) '#13#10'from PaymentReq' +
            'uested pr'#13#10'where pr.status= '#39'APPROVED'#39' and isnull(billing_id,'#39#39')' +
            ' = '#39#39#13#10'and pr.customClearance_id=@CustomClearance'#13#10#13#10'select @Sal' +
            'doErradoHj =  Value '#13#10'from Balance b'#13#10'inner join CustomClearance' +
            ' cc on cc.balance_id=b.id'#13#10'where cc.id=@CustomClearance'#13#10#13#10#13#10'sel' +
            'ect @SaldoProcesso = isnull(@TotalNumer'#225'rio,0) - isnull(@TotalPa' +
            'gamento,0)  '#13#10#13#10'update b set value = @SaldoProcesso'#13#10'from Balanc' +
            'e b'#13#10'inner join CustomClearance cc on cc.balance_id=b.id'#13#10'where ' +
            'cc.id=@CustomClearance'#13#10#13#10'select Value SaldoErrado,@SaldoProcess' +
            'o SaldoCorreto'#13#10'from Balance b'#13#10'inner join CustomClearance cc on' +
            ' cc.balance_id=b.id'#13#10'where cc.id=@CustomClearance'#13#10#13#10#13#10#13#10'end'
        end

procedure TfrmIntegracaoDueNovo.ImportarDUE;
var
  DUe: TDUe;
  Qtd, QtdLote: Integer;
  Atual: Integer;
  Hora: TDateTime;
  statusTexto : string;
  mDados : TFDMemTable;
  CodDespachante: Integer;
  i: integer;

FRespostaStr: TStringList;

begin
  i := 0;
  if not (dmdBroker.qryFilaExpo.recordCount > 0) then
  begin
    showmessage('A fila năo tem DUEs para consulta.');
    exit;
  end;

  mdados := TFDMemTable.Create(nil);
  mdados.Data := dmdBroker.qryFilaExpo.Data;

  lblstatus.Visible := true;
  ProgressBar1.Visible := true;
  ProgressBar1.Min := 0;
  ProgressBar1.Max := mdados.RecordCount;

  CodDespachante := mDados.FieldByName('CODIGO_CERTIFICADO_DESPACHANTE').AsInteger;

  //DUE.teste;
  try
    while not mdados.Eof do
    begin
      inc(i);
      DUe := TDUe.Create(True);
      try
        lblstatus.Caption := 'Importando DUE ' + ExtractFileName(mdados.fieldByName('NR_DUE').AsString) + ' |  ' + IntToStr(i) + ' de ' + IntToStr(mdados.RecordCount) + ' Dues.';
        ProgressBar1.Position := mdados.RecNo;
        try
          if CodDespachante <> mDados.FieldByName('CODIGO_CERTIFICADO_DESPACHANTE').AsInteger then
          begin
            CodDespachante := mDados.FieldByName('CODIGO_CERTIFICADO_DESPACHANTE').AsInteger;
            DUe.Consulta(Trim(mdados.fieldByName('NR_DUE').AsString), tcCompleta, CodDespachante, true);
          end
          else
            DUe.Consulta(Trim(mdados.fieldByName('NR_DUE').AsString), tcCompleta, CodDespachante, false);

          txtLog.Lines.Add('Due ' + mdados.fieldByName('NR_DUE').AsString + ' integrada com sucesso' );
          except
          on E: Exception do
          begin
            txtLog.Lines.Add('Erro ao integrar a Due ' + mdados.fieldByName('NR_DUE').AsString +
                             ' erro: ' + E.Message);
            if E.Message.Contains('Unauthorized') or
               E.Message.Contains('Internal') or
               E.Message.Contains('expired') or
               E.Message.Contains('Unprocessable') then
            begin
              dmdBroker.UpdateDueRecuperarCertificado(mdados.fieldByName('NR_DUE').AsString, CodDespachante);
              mdados.Next;
              Sleep(1000);
              Continue;
            end
            else
            begin
              mdados.Next;
              Sleep(1000);
              Continue;
            end;
          end;
        end;

        if not DUe.RespostaStr.IsEmpty then
        begin
          dmdBroker.GravaDueCompleta(mdados.fieldByName('NR_DUE').AsString, Due);
          dmdBroker.UpdateDueRecuperar(mdados.fieldByName('NR_DUE').AsString);
        end;

        mdados.Next;
      finally
        Due.Free;
      end;
      lblstatus.Caption := 'Importaçăo concluída.';
    end;
  finally
    Pesquisar;
  end;

//    if dmdBroker.cdsStatus.Eof then
//    begin
//      atualizaDespachante;
//    end;

end;

procedure TfrmIntegracaoDueNovo.FormActivate(Sender: TObject);
begin
  CarregaCertificados;
end;

procedure TfrmIntegracaoDueNovo.CarregaCertificados;
var
  iCertificado: integer;
begin
  if assigned(Certificados) then
    Certificados.free;

  dmdBroker.qrySelectCertificados.Open;
  Certificados := TObjectList<TCertificados>.create;
  dmdBroker.qrySelectCertificados.first;
  while not dmdBroker.qrySelectCertificados.eof do
  begin
    iCertificado := Certificados.add(TCertificados.Create);
    Certificados.Items[iCertificado].Codigo := dmdBroker.qrySelectCertificadosCODIGO.AsInteger;
    Certificados.Items[iCertificado].NomeArquivo := dmdBroker.qrySelectCertificadosNOME_ARQUIVO.AsString;
    Certificados.Items[iCertificado].Ordem := dmdBroker.qrySelectCertificadosORDEM_CONSULTA.AsInteger;
    dmdBroker.qrySelectCertificados.next;
  end;
end;

procedure TfrmIntegracaoDueNovo.FormShow(Sender: TObject);
begin
  Pesquisar;
end;

procedure TfrmIntegracaoDueNovo.IntegrarPlanilhaDue;
var
  Excel: OleVariant;
  oSheet: OleVariant;
  vNrDue: String;
  Linhas, LinhaItem: integer ;
begin
  if not OpenDialog1.Execute then
    exit;

  Excel := CreateOleObject('Excel.Application');
  try
    Excel.WorkBooks.Add(OpenDialog1.FileName);
    oSheet := Excel.Workbooks[1].WorkSheets[1];
    Linhas := oSheet.Cells.SpecialCells(11).Row;
    LinhaItem := 1;

    ProgressBar1.Visible := true;
    ProgressBar1.Min := 0;
    ProgressBar1.Max := Linhas;

    while oSheet.Cells[LinhaItem, 1].Value <> '' do
    begin
      ProgressBar1.Position := LinhaItem;
      vNrDue := Trim(oSheet.Cells[LinhaItem,1].value);
      dmdBroker.IncluirDueRecuperar(vNrDue, Certificados.Items[0].Codigo);
      Inc(LinhaItem);
    end;

    ShowMessage('Integraçăo realizada com SUCESSO. ');
  finally
    Excel.WorkBooks.Close;
    Excel.Quit;
    Pesquisar;
  end;
end;

end.

function TfrmRelatorioImpo.ValidarPreenchimento: boolean;
begin
  result:= true;
  if Trim(edtNrDi.Text) <> '' then
    exit;

  if (StrToDate(edtDataInicial.text) > StrToDate(edtDataFinal.text)) then
  begin
    ShowMessage('A data inicial deve ser menor ou igual a data final.');
    edtDataInicial.SetFocus;
    result:= False;
  end;

end;


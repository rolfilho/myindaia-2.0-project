function MyInc(var value: integer; valueInc: integer = 1): integer;
begin
  value := value + 1;
  result := value;
end;

procedure TfrmRelatorioImpo.Button1Click(Sender: TObject);
var
  i: integer;
  vFieldName: String;
  vFieldType: String;
  vFieldSize: String;
begin
  dmdBroker.GeraConsultaRelatorioImpo(StrToDateTime(edtDataInicial.text) , StrToDateTime(edtDataFinal.text), edtCNPJ.text, edtNrDi.text);
  for i:=0 to dmdBroker.qryRelatorioImpo.Fields.Count -1 do
  begin
    vFieldName := '';
    vFieldType := '';
    vFieldSize := '';

    vFieldName := dmdBroker.qryRelatorioImpo.Fields.Fields[i].FieldName;

    if pos('VALOR', UPPERCASE(vFieldName)) > 0 then
      vFieldType := 'FLOAT'
    else if pos('TOTAL', UPPERCASE(vFieldName)) > 0 then
      vFieldType := 'FLOAT'
    else if pos('ALIQUOTA', UPPERCASE(vFieldName)) > 0 then
      vFieldType := 'FLOAT'
    else if pos('BASECALCULO', UPPERCASE(vFieldName)) > 0 then
      vFieldType := 'FLOAT'
    else if pos('PESO', UPPERCASE(vFieldName)) > 0 then
      vFieldType := 'FLOAT'
    else if pos('QUANTIDADE', UPPERCASE(vFieldName)) > 0 then
      vFieldType := 'FLOAT'
    else if pos('DATA', UPPERCASE(vFieldName)) > 0 then
      vFieldType := 'DATETIME'
    else
    begin
      if length(TRIM(dmdBroker.qryRelatorioImpo.Fields.Fields[i].Value)) = 0 then
        vFieldSize := '2'
      else
        vFieldSize := IntToStr(length(TRIM(dmdBroker.qryRelatorioImpo.Fields.Fields[i].Value)));

      vFieldType := 'VARCHAR('+ vFieldSize +')';
    end;


//    memo1.lines.add(dmdBroker.qryRelatorioImpo.Fields.Fields[i].FieldName + ' ' + vFieldType + ',');
  end;

end;

procedure TfrmRelatorioImpo.FormShow(Sender: TObject);
begin
  edtDataInicial.SetFocus;
  edtDataInicial.Text := FormatDateTime('dd/mm/yyyy', now - 30);
  edtDataFinal.Text := FormatDateTime('dd/mm/yyyy', now);

  if Parametros.ModoTeste then
    edtDataInicial.Text := FormatDateTime('dd/mm/yyyy', now -  1095);
end;

procedure TfrmRelatorioImpo.Panel4Click(Sender: TObject);
begin
  if not ValidarPreenchimento then
    exit;

  dmdBroker.GeraConsultaRelatorioImpo(StrToDateTime(edtDataInicial.Text), StrToDateTime(edtDataFinal.text), edtCNPJ.text, edtNrDi.text);
  lblResultado.Visible := true;
  lblResultado.Caption := 'Resultado da pesquisa: ' + IntToStr(dmdBroker.qryRelatorioImpo.RecordCount);
end;

procedure TfrmRelatorioImpo.Panel5Click(Sender: TObject);
begin
  if dmdBroker.qryRelatorioImpo.RecordCount > 1 then
  begin
    if chkResumido.Checked then
      RelDrawbackDi(riAmbos)
    else
      RelDrawbackDi(riApenasCompleto)
  end
  else
    showmessage('Năo foi encontrado resultado de pesquisa para Importaçăo.');
end;


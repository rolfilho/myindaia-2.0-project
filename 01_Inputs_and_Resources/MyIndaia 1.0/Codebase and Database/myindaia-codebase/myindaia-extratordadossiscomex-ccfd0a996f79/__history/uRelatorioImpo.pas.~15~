  function TituloOuTipoErrado(Titulo: String; Linha, Coluna: Integer; aTipoRelatorioCampo: TTipoRelatorioImpo): Boolean;
  begin
    result := False;
    result := (aTipoRelatorio <> aTipoRelatorioCampo) and (aTipoRelatorioCampo <> riAmbos);

    if (not result) and (vLinha = nLinhaTitulo) then
    begin
      Excel.Cells[ vLinha, MyInc(vColuna) ].value := Titulo;
      Excel.Cells[ vLinha, vColuna ].Font.Bold := True;
      Excel.Cells[ vLinha, vColuna ].WrapText  := True;
      Excel.Cells[ vLinha, vColuna ].HorizontalAlignment  := 3;
      Excel.Cells[ vLinha, vColuna ].VerticalAlignment  := 2;
      Excel.Cells[ vLinha, vColuna ].RowHeight  := 30;


      //      Excel.WorkBooks[1].worksheets[1].rows[nLinhaTitulo].HorizontalAlignment  := xlHAlignCenter;
//      Excel.WorkBooks[1].worksheets[1].rows(nLinhaTitulo).VerticalAlignment  := xlVAlignCenter;
//      Excel.WorkBooks[1].worksheets[1].rows(nLinhaTitulo).RowHeight := 30;

      Result := True;
    end
  end;

  function TrataValor(value: String): String;
  var
    txtInicio: String;
  begin
    result := Copy(value, 0, 100);
    txtInicio := copy(result, 0, 1);
    if txtInicio = '=' then
      result := 'a' + result;
//      result := StringReplace(result, '=', '*', [rfReplaceAll]);
  end;

  procedure PreencheCelula(Titulo: String; aValue: String; aTipoRelatorioCampo: TTipoRelatorioImpo = riApenasCompleto; TipoNumero: Boolean = false); overload;
  begin
    if TituloOuTipoErrado(Titulo, vLinha, vColuna, aTipoRelatorioCampo) then
      exit;

    Excel.Cells[ vLinha, MyInc(vColuna) ].value := aValue;

    if not TipoNumero then
      Excel.Cells[ vLinha, vColuna ].WrapText  := false
    else
      Excel.Cells[ vLinha, vColuna ].NumberFormat  := '##0';

  end;

  procedure PreencheCelula(Titulo: String; aValue: Double; aTipoRelatorioCampo: TTipoRelatorioImpo = riApenasCompleto; NrFormatacao: String = '#.##0,00'); overload;

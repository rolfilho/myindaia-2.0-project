function TfrmRelatorioExpo.ValidarPreenchimento: boolean;
begin
  result:= true;
  if Trim(edtNrDue.Text) <> '' then
    exit;

//  if (Trim(edtCNPJ.Text) = '')  then
//  begin
//    ShowMessage('Obrigatio o preenchimento do CNPJ ou Nr Due.');
//    edtCNPJ.SetFocus;
//    result:= False;
//  end;

  if (StrToDateTime(edtDataInicial.text) > StrToDateTime(edtDataFinal.text)) then
  begin
    ShowMessage('A data inicial deve ser menor ou igual a data final.');
    edtDataInicial.SetFocus;
    result:= False;
  end;

end;

procedure TfrmRelatorioExpo.FormShow(Sender: TObject);
begin
  edtDataInicial.SetFocus;
  edtDataInicial.Text := FormatDateTime('dd/mm/yyyy', now - 30);
  edtDataFinal.Text := FormatDateTime('dd/mm/yyyy', now);

  if Parametros.ModoTeste then
    edtDataInicial.Text := FormatDateTime('dd/mm/yyyy', now -  1095);
end;

procedure TfrmRelatorioExpo.Panel4Click(Sender: TObject);
begin

  if not ValidarPreenchimento then
    exit;
  dmdBroker.GeraConsultaRelatorioExpo(StrToDateTime(edtDataInicial.text), StrToDateTime(edtDataFinal.text), edtCNPJ.text, edtNrDue.text);
  lblResultado.Visible := true;
  lblResultado.Caption := 'Resultado da pesquisa: ' + IntToStr(dmdBroker.qryRelatorioExpo.RecordCount);

end;

procedure TfrmRelatorioExpo.Panel5Click(Sender: TObject);
begin
  if dmdBroker.qryRelatorioExpo.RecordCount > 0 then
    RelDrawbackDUE
  else
    showmessage('N縊 foi encontrado resultado de pesquisa para exporta鈬o.');

end;


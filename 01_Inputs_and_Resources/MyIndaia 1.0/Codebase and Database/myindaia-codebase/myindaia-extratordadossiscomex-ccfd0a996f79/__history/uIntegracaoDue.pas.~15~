procedure TfrmIntegracaoDueNovo.Pesquisar;
begin
  dmdBroker.MostraFila;
  if dmdBroker.qryFilaExpo.RecordCount > 0 then
  begin
    lblStatus.Caption := IntToStr(dmdBroker.qryFilaExpo.RecordCount) + ' estŃo na fila aguardando Importar os dados do Siscomex.';
    btnImportar.Enabled := True;
  end
  else
  begin
    lblStatus.Caption := 'NŃo hß DUEs pendentes de importańŃo no momento.';
    btnImportar.Enabled := False;
  end;
end;

procedure TfrmIntegracaoDueNovo.ImportarDUE;
var
  DUe: TDUe;
  Qtd, QtdLote: Integer;
  Atual: Integer;
  Hora: TDateTime;
  statusTexto : string;
  mDados : TFDMemTable;
  CodDespachante: Integer;
  i: integer;

FRespostaStr: TStringList;

begin
  i := 0;
  if not btnImportar.Enabled then
  begin
    lblStatus.Caption := 'ImportańŃo de dados finalizada com sucesso.';
    exit;
  end;

  mdados := TFDMemTable.Create(nil);
  mdados.Data := dmdBroker.qryFilaExpo.Data;

  lblstatus.Visible := true;
  ProgressBar1.Visible := true;
  ProgressBar1.Min := 0;
  ProgressBar1.Max := mdados.RecordCount;

  CodDespachante := mDados.FieldByName('CodigoCertificadoDespachante').AsInteger;

  //DUE.teste;
  try
    while not mdados.Eof do
    begin
      inc(i);
      DUe := TDUe.Create(True);
      try
        lblstatus.Caption := 'Importando DUE ' + ExtractFileName(mdados.fieldByName('NrDue').AsString) + ' |  ' + IntToStr(i) + ' de ' + IntToStr(mdados.RecordCount) + ' Dues.';
        ProgressBar1.Position := mdados.RecNo;
        try
          if CodDespachante <> mDados.FieldByName('CodigoCertificadoDespachante').AsInteger then
          begin
            CodDespachante := mDados.FieldByName('CodigoCertificadoDespachante').AsInteger;
            DUe.Consulta(Trim(mdados.fieldByName('NrDue').AsString), tcCompleta, CodDespachante, true);
          end
          else
            DUe.Consulta(Trim(mdados.fieldByName('NrDue').AsString), tcCompleta, CodDespachante, false);

          txtLog.Lines.Add('Due ' + mdados.fieldByName('NrDue').AsString + ' integrada com sucesso' );
          except
          on E: Exception do
          begin
            txtLog.Lines.Add('Erro ao integrar a Due ' + mdados.fieldByName('NrDue').AsString +
                             ' erro: ' + E.Message);
            if E.Message.Contains('Unauthorized') or
               E.Message.Contains('Internal') or
               E.Message.Contains('expired') or
               E.Message.Contains('Unprocessable') then
            begin
              dmdBroker.UpdateDueRecuperarCertificado(mdados.fieldByName('NrDue').AsString, CodDespachante);
              mdados.Next;
              Sleep(1000);
              Continue;
            end
            else
            begin
              mdados.Next;
              Sleep(1000);
              Continue;
            end;
          end;
        end;

        if not DUe.RespostaStr.IsEmpty then
        begin
//          dmdBroker.TesteTamanhoCampos(mdados.fieldByName('NrDue').AsString, Due, PreencheMemo);
          dmdBroker.GravaDueCompleta(mdados.fieldByName('NrDue').AsString, Due);
          dmdBroker.UpdateDueRecuperar(mdados.fieldByName('NrDue').AsString);
        end;

        mdados.Next;
      finally
        Due.Free;
      end;
      lblstatus.Caption := 'ImportańŃo concluĒda.';
    end;
  finally
    Pesquisar;
    ImportarDUE;
  end;
end;

procedure TfrmIntegracaoDueNovo.CarregaCertificados;
var
  iCertificado: integer;
begin
  if assigned(Certificados) then
    Certificados.free;

  dmdBroker.qrySelectCertificados.Open;
  Certificados := TObjectList<TCertificados>.create;
  dmdBroker.qrySelectCertificados.first;
  while not dmdBroker.qrySelectCertificados.eof do
  begin
    iCertificado := Certificados.add(TCertificados.Create);
    Certificados.Items[iCertificado].Codigo := dmdBroker.qrySelectCertificadosCODIGO.AsInteger;
    Certificados.Items[iCertificado].NomeArquivo := dmdBroker.qrySelectCertificadosNomeArquivo.AsString;
    Certificados.Items[iCertificado].Ordem := dmdBroker.qrySelectCertificadosOrdemConsulta.AsInteger;
    dmdBroker.qrySelectCertificados.next;
  end;
end;

procedure TfrmIntegracaoDueNovo.FormShow(Sender: TObject);
begin
  Pesquisar;
  CarregaCertificados;
end;

procedure TfrmIntegracaoDueNovo.IntegrarPlanilhaDue;
var
  Excel: OleVariant;
  oSheet: OleVariant;
  vNrDue: String;
  Linhas, LinhaItem: integer ;
begin
  if not OpenDialog1.Execute then
    exit;

  Excel := CreateOleObject('Excel.Application');
  try
    Excel.WorkBooks.Add(OpenDialog1.FileName);
    oSheet := Excel.Workbooks[1].WorkSheets[1];
    Linhas := oSheet.Cells.SpecialCells(11).Row;
    LinhaItem := 1;

    ProgressBar1.Visible := true;
    ProgressBar1.Min := 0;
    ProgressBar1.Max := Linhas;

    while oSheet.Cells[LinhaItem, 1].Value <> '' do
    begin
      ProgressBar1.Position := LinhaItem;
      vNrDue := Trim(oSheet.Cells[LinhaItem,1].value);
      dmdBroker.IncluirDueRecuperar(vNrDue, Certificados.Items[0].Codigo);
      Inc(LinhaItem);
    end;

    ShowMessage('IntegrańŃo realizada com SUCESSO. ');
  finally
    Excel.WorkBooks.Close;
    Excel.Quit;
    Pesquisar;
  end;
end;

end.

procedure TdmdBroker.UpdateDueRecuperarCertificado(NrDue: String; CodCertificado: integer);
var
  vCodCert: Integer;
begin

  qrySelectCertificados.Close;
  qrySelectCertificados.open;

  qrySelectCertificados.Locate('Codigo', CodCertificado, []);

  if not qrySelectCertificados.Eof then
  begin
    qrySelectCertificados.Next;
    vCodCert := qrySelectCertificadosCodigo.AsInteger;
  end
  else
    vCodCert := 999;

  qryInsertDue.Close;
  qryInsertDue.SQL.Text := 'UPDATE ExpoDueImportadaControle SET CodigoCertificadoDespachante = :CodigoCertificadoDespachante WHERE NrDue = :NrDue';
  qryInsertDue.ParamByName('NrDue').AsString := NrDue;
  qryInsertDue.ParamByName('CodigoCertificadoDespachante').AsInteger := vCodCert;
  qryInsertDue.ExecSQL;
end;

procedure TdmdBroker.GeraConsultaRelatorioExpo(DataRegistroInicio, DataRegistroFim: TDateTime; DeclaranteNrDocumento, NrDue: String);
var
  vSelect : String;
begin
  qryRelatorioExpo.Close;
  vSelect := 'SELECT A.*, B.DataDueImportada FROM ExpoDueImportada A ' +
             ' CROSS APPLY (Select max(c.DataDueImportada) as DataDueImportada From ExpoDueImportadaControle c where c.NrDue = A.NrDue) as B ' +
             ' WHERE ';
  if NrDue <> '' then
    vSelect := vSelect + ' A.NrDue = :NrDue'
  else
  begin
    vSelect := vSelect + '(CAST(A.DataRegistro AS DATE) BETWEEN CAST(:DataRegistroInicio AS DATE) AND CAST(:DataRegistroFim AS DATE)) ';

    if DeclaranteNrDocumento <> '' then
      vSelect := vSelect + 'AND A.DeclaranteNrDocumento = :DeclaranteNrDocumento';
  end;
  qryRelatorioExpo.SQL.Text := vSelect;

  if NrDue <> '' then
    qryRelatorioExpo.ParamByName('NrDue').AsString := Trim(NrDue)
  else
  begin
    qryRelatorioExpo.ParamByName('DataRegistroInicio').AsString := formatDateTime('yyyy-mm-dd', DataRegistroInicio);
    qryRelatorioExpo.ParamByName('DataRegistroFim').AsString := formatDateTime('yyyy-mm-dd', DataRegistroFim);
    if DeclaranteNrDocumento <> '' then
      qryRelatorioExpo.ParamByName('DeclaranteNrDocumento').AsString := Trim(DeclaranteNrDocumento);
  end;
  qryRelatorioExpo.Open;
  qryRelatorioExpo.FetchAll;
end;



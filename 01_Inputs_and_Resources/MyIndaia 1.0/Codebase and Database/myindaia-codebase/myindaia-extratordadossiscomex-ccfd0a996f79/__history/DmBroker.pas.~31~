        qryInsertDi.paramByName('i_descricaoMercadoria').AsString := item.descricaoMercadoria;
        qryInsertDi.paramByName('i_numeroSequencialItem').AsString := item.numeroSequencialItem;
        qryInsertDi.paramByName('i_quantidade').AsFloat := item.quantidade;
        qryInsertDi.paramByName('i_unidadeMedida').AsString := item.unidadeMedida;
        qryInsertDi.paramByName('i_valorUnitario').AsFloat := item.valorUnitario;
        qryInsertDi.paramByName('i_vmle').AsFloat := item.vmle;
        qryInsertDi.paramByName('i_quantidadeEstatistica').AsFloat := item.quantidadeEstatistica;
        qryInsertDi.ExecSQL;
      end;
    end;

    qryHistoricoDi.Close;
    qryHistoricoDi.SQL.Text := 'INSERT INTO ImpoDiHistorico VALUES(:numeroDI, getdate(), ''Inclusăo'')';
    qryHistoricoDi.paramByName('numeroDI').AsString := Di.numeroDI;
    qryHistoricoDi.ExecSQL;
  end;
end;

procedure TdmdBroker.GeraConsultaRelatorioImpo(DataRegistroInicio, DataRegistroFim: TDateTime; NrDocumento, NrDi: String);
var
  vSelect : String;
begin
  qryRelatorioImpo.Close;

  if Parametros.ModoTeste then
    vSelect := 'SELECT TOP 10 * FROM ImpoDiImportada WHERE '
  else
    vSelect := 'SELECT * FROM ImpoDiImportada WHERE ';

  if NrDi <> '' then
    vSelect := vSelect + ' numeroDi = :NrDi'
  else
  begin
    vSelect := vSelect + '(CAST(DataRegistro AS DATE) BETWEEN CAST(:DataRegistroInicio AS DATE) AND CAST(:DataRegistroFim AS DATE)) ';

    if NrDocumento <> '' then
    begin
      if length(NrDocumento) = 8 then
        vSelect := vSelect + 'AND ImportadorNumero like :ImportadorNumero'
      else
        vSelect := vSelect + 'AND ImportadorNumero = :ImportadorNumero';
    end;

  end;

  vSelect := vSelect + ' ORDER BY numeroDi, a_numeroAdicao, i_numeroSequencialItem';
  qryRelatorioImpo.SQL.Text := vSelect;

  if NrDi <> '' then
    qryRelatorioImpo.ParamByName('NrDi').AsString := Trim(NrDi)
  else
  begin
    qryRelatorioImpo.ParamByName('DataRegistroInicio').AsDateTime := DataRegistroInicio;
    qryRelatorioImpo.ParamByName('DataRegistroFim').AsDateTime := DataRegistroFim;
    if NrDocumento <> '' then
      if length(NrDocumento) = 8 then
        qryRelatorioImpo.ParamByName('ImportadorNumero').AsString := Trim(NrDocumento)+'%'
      else
        qryRelatorioImpo.ParamByName('ImportadorNumero').AsString := Trim(NrDocumento);
  end;
  qryRelatorioImpo.Open;
  qryRelatorioImpo.FetchAll;
end;



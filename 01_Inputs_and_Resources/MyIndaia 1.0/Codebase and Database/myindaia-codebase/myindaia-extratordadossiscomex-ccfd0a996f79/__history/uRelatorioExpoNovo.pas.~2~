function TfrmRelatoriorExpo.ValidarPreenchimento: boolean;
begin
  result:= true;
  if Trim(edtNrDue.Text) <> '' then
    exit;

//  if (Trim(edtCNPJ.Text) = '')  then
//  begin
//    ShowMessage('Obrigatório o preenchimento do CNPJ ou Nr Due.');
//    edtCNPJ.SetFocus;
//    result:= False;
//  end;

  if (edtDataInicial.Date > edtDataFinal.Date) then
  begin
    ShowMessage('A data inicial deve ser menor ou igual a data final.');
    edtDataInicial.SetFocus;
    result:= False;
  end;

end;

procedure TfrmRelatorioExpoNovo.Panel4Click(Sender: TObject);
begin

  if not ValidarPreenchimento then
    exit;
  dmdBroker.GeraConsultaRelatorioRED(edtDataInicial.Date, edtDataFinal.Date, edtCNPJ.text, edtNrDue.text);
  lblResultado.Visible := true;
  lblResultado.Caption := 'Resultado da pesquisa: ' + IntToStr(dmdBroker.qryRelatorioRED.RecordCount);

end;

procedure TfrmRelatorioExpoNovo.Panel5Click(Sender: TObject);
begin
  if dmdBroker.qryRelatorioRED.RecordCount > 0 then
    RelDrawbackDUE
  else
    showmessage('Năo foi encontrado resultado de pesquisa para exportaçăo.');

end;

end.
